'' =================================================================================================
''
''   File....... DFS_SD_FAT32_fsck.spin2
''   Purpose.... FAT32 filesystem check and repair utility (thin wrapper around isp_fsck_utility)
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... FEB 2026
''   Updated.... 21 FEB 2026
''
'' =================================================================================================
''
''  Thin wrapper that launches the FSCK library in a temporary cog
''  and displays output via debug().
''
'' =================================================================================================

CON

    _CLKFREQ        = 320_000_000

    ' P2 Edge module SD slot pins
    SD_CS   = 60
    SD_MOSI = 59
    SD_MISO = 58
    SD_SCK  = 61

    ' External SD header (base pin 16)
    'SD_CS   = 20
    'SD_MOSI = 19
    'SD_MISO = 18
    'SD_SCK  = 21

OBJ

    fsck : "isp_fsck_utility"

PUB go() | pStr
'' Main entry point - runs FAT32 filesystem check and repair.

    debug("==============================================")
    debug("  FAT32 FSCK (via isp_fsck_utility)")
    debug("==============================================")
    debug(" ")

    if not fsck.startFsck(SD_CS, SD_MOSI, SD_MISO, SD_SCK)
        debug("FATAL: Could not start FSCK cog")
        debug("END_SESSION")
        return

    ' Pump FIFO output to debug
    repeat
        pStr := fsck.getOutput()
        if pStr
            debug(zstr_(pStr))
        elseif fsck.isDone()
            ' Drain any remaining output
            repeat while (pStr := fsck.getOutput())
                debug(zstr_(pStr))
            quit

    fsck.stop()

    debug(" ")
    debug("END_SESSION")

CON { license }

