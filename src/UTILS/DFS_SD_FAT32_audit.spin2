'' =================================================================================================
''
''   File....... DFS_SD_FAT32_audit.spin2
''   Purpose.... FAT32 filesystem audit tool (thin wrapper around isp_fsck_utility)
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... JAN 2026
''   Updated.... 21 FEB 2026
''
'' =================================================================================================
''
''  Thin wrapper that launches the Audit library in a temporary cog
''  and displays output via debug(). Read-only -- does not modify card.
''
'' =================================================================================================

CON

    _CLKFREQ        = 320_000_000

    ' Pin configuration for P2 Edge with SD card
    SD_CS   = 60
    SD_MOSI = 59
    SD_MISO = 58
    SD_SCK  = 61

    SUCCESS = 0                     ' Successful operation (matches dfs.SUCCESS)

OBJ

    fsck : "isp_fsck_utility"

PUB go() | pStr
'' Main entry point - runs FAT32 filesystem audit.

    debug("==============================================")
    debug("  FAT32 Audit (via isp_fsck_utility)")
    debug("==============================================")
    debug(" ")

    if fsck.startAudit() <> SUCCESS
        debug("FATAL: Could not start Audit cog")
    else
        ' Pump FIFO output to debug
        repeat
            pStr := fsck.getOutput()
            if pStr
                debug(zstr_(pStr))
            elseif fsck.isDone()
                ' Drain any remaining output
                repeat while (pStr := fsck.getOutput())
                    debug(zstr_(pStr))
                quit

        fsck.stop()

    debug(" ")
    debug("END_SESSION")

CON { license }

