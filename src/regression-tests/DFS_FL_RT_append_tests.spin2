    utils.evaluateFSStats(@"post file write", startingFileCount + 1, startingBlockCount + blocksUsed)


pri testAppendWords(pFilename, initialCount, count, startingFileCount, startingBlockCount) | startLength, bytesUsed, blocksAdded, blocksUsed, handle, testValue, status

    utils.startTest(@"Get starting length before append of WORDs")
    utils.setCheckCountPerTest(2)
    startLength := dfs.file_size(dfs.DEV_FLASH, pFilename)
    status := dfs.error()
    utils.evaluateSubValue(startLength, @"file_size()", initialCount * 2)
    utils.evaluateSubStatus(status, @"file_size()", dfs.SUCCESS)

