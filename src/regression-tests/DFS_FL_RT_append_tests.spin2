pri testAppendLongs(pFilename, initialCount, count, startingFileCount, startingBlockCount) | startLength, bytesUsed, blocksUsed, blocksAdded, handle, testValue, status

    utils.startTest(@"Get starting length before append of LONGs")
    utils.setCheckCountPerTest(2)
    startLength := dfs.file_size(dfs.DEV_FLASH, pFilename)
    status := dfs.error()
    utils.evaluateSubValue(startLength, @"file_size()", initialCount * 4)
    utils.evaluateSubStatus(status, @"file_size()", dfs.SUCCESS)

    '  open file for append
    utils.startTest(@"Open File for append")
    handle := dfs.open(dfs.DEV_FLASH, pFilename, dfs.FILEMODE_APPEND)
    utils.evaluateResultNegError(handle, dfs.SUCCESS)
    '    seek to various locations and read longs validating for correct value

    utils.startTest(@"Append count LONGs")
