'' =================================================================================================
''
''   File....... DFS_SD_RT_phase1_verify.spin2
''   Purpose.... Phase 1 verification: exercise dual_sd_fat32_flash_fs.spin2 SD-only API
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... FEB 2026
''   Updated.... 26 FEB 2026
''
'' =================================================================================================

CON

     _CLKFREQ        = 350_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61

     ' Unified error codes
     E_NOT_MOUNTED       = -20
     E_DEVICE_NOT_MOUNTED = -121
     E_BAD_DEVICE        = -120

#IFDEF __SPINTOOLS__
#DEFINE SD_INCLUDE_RAW
#DEFINE SD_INCLUDE_DEBUG
#ELSEIFDEF __FLEXSPIN__
#define SD_INCLUDE_RAW
#pragma exportdef SD_INCLUDE_RAW
#define SD_INCLUDE_DEBUG
#pragma exportdef SD_INCLUDE_DEBUG
#ELSE
'' Enable raw sector access for diagnostic tests
#PRAGMA EXPORTDEF SD_INCLUDE_RAW
'' Enable debug diagnostics
#PRAGMA EXPORTDEF SD_INCLUDE_DEBUG
#ENDIF

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "isp_rt_utilities"

DAT

testfile1       BYTE    "TEST1.TXT", 0
testdata        BYTE    "Hello from dual_sd_fat32_flash_fs Phase 1!", 0
readBuffer      BYTE    0[512]
readBuf_guard   BYTE    0[16]
sectorBuffer    BYTE    0[512]
secBuf_guard    BYTE    0[16]

PUB go() | result, status, freeSpace, handle, bytesRead, bytesWritten, pLabel
'' Main entry point for Phase 1 verification tests
''
'' Tests dual_sd_fat32_flash_fs.spin2 SD operations via new init()/mount(DEV_SD) API

    debug(" ")
    debug("==============================================")
    debug("  Dual FS Phase 1 Verification Tests")
    debug("  (SD-only via dual_sd_fat32_flash_fs.spin2)")
    debug("==============================================")

    ' ----------------------------------
    ' TEST GROUP: Pre-init operations should fail
    ' ----------------------------------
    utils.startTestGroup(@"Operations before init() should fail gracefully")

    utils.startTest(@"mount(DEV_SD) before init()")
    status := dfs.mount(dfs.DEV_SD)
    utils.evaluateBool(status < 0, @"mount(DEV_SD) returns error", true)

    ' ----------------------------------
    ' TEST GROUP: init() / mount(DEV_SD)
    ' ----------------------------------
    utils.startTestGroup(@"init() and mount(DEV_SD)")

    utils.startTest(@"init() with valid pins")
    result := dfs.init(SD_CS, SD_MOSI, SD_MISO, SD_SCK)
    utils.evaluateRange(result, @"init() returns cog ID", 0, 7)

    utils.startTest(@"mounted(DEV_SD) before mount")
    result := dfs.mounted(dfs.DEV_SD)
    utils.evaluateBool(result, @"mounted(DEV_SD)", false)

    utils.startTest(@"mount(DEV_SD)")
    status := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(status, @"mount(DEV_SD)", dfs.SUCCESS)

    utils.startTest(@"mounted(DEV_SD) after mount")
    result := dfs.mounted(dfs.DEV_SD)
    utils.evaluateBool(result, @"mounted(DEV_SD)", true)

    utils.startTest(@"mounted(DEV_FLASH) should be false")
    result := dfs.mounted(dfs.DEV_FLASH)
    utils.evaluateBool(result, @"mounted(DEV_FLASH)", false)

    ' DIAGNOSTIC: Show CMD13 and CRC state after mount
    debug(" ")
    debug("  DIAG: error()=", sdec_(dfs.error()))
    debug("  DIAG: lastCMD13=$", uhex_(dfs.getLastCMD13()), " lastCMD13Error=$", uhex_(dfs.getLastCMD13Error()))
    debug("  DIAG: CRC match=", udec_(dfs.getCRCMatchCount()), " mismatch=", udec_(dfs.getCRCMismatchCount()), " retry=", udec_(dfs.getCRCRetryCount()))

    ' ----------------------------------
    ' TEST GROUP: Volume info
    ' ----------------------------------
    utils.startTestGroup(@"Volume information via DEV_SD")

    utils.startTest(@"volumeLabel(DEV_SD)")
    pLabel := dfs.volumeLabel(dfs.DEV_SD)
    utils.evaluateNotZero(pLabel, @"volumeLabel() pointer")

    utils.startTest(@"freeSpace(DEV_SD)")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateRange(freeSpace, @"freeSpace(DEV_SD)", 1, $7FFF_FFFF)

    debug(" ")
    debug("  Card Info:")
    debug("    Volume Label: ", zstr_(pLabel))
    debug("    Free Space: ", udec_(freeSpace), " sectors (", udec_(freeSpace / 2048), " MB)")

    ' ----------------------------------
    ' TEST GROUP: Raw sector read (SD-only, pragma-gated)
    ' ----------------------------------
    utils.startTestGroup(@"Raw sector access")

    utils.startTest(@"readSectorRaw(0) reads MBR")
    utils.initGuard(@secBuf_guard)
    result := dfs.readSectorRaw(0, @sectorBuffer)
    utils.checkGuard(@secBuf_guard, @"secBuf guard")
    utils.evaluateBool(result, @"readSectorRaw(0)", true)

    ' Verify MBR signature bytes 0x55AA at offset $1FE
    if result
      utils.startTest(@"MBR signature is $55AA")
      utils.setCheckCountPerTest(2)
      utils.evaluateSubValueHex(sectorBuffer[$1FE], @"MBR[$1FE]", $55)
      utils.evaluateSubValueHex(sectorBuffer[$1FF], @"MBR[$1FF]", $AA)

    ' ----------------------------------
    ' TEST GROUP: V3 Handle API - file write/read round-trip
    ' ----------------------------------
    utils.startTestGroup(@"V3 Handle API - write/read round-trip")

    ' Delete test file if it exists from a prior run
    dfs.deleteFile(dfs.DEV_SD, @testfile1)

    utils.startTest(@"createFileNew(DEV_SD, TEST1.TXT)")
    handle := dfs.createFileNew(dfs.DEV_SD, @testfile1)
    utils.evaluateRange(handle, @"createFileNew() handle", 0, 5)

    if handle >= 0
      utils.startTest(@"writeHandle() test data")
      bytesWritten := dfs.writeHandle(handle, @testdata, strsize(@testdata))
      utils.evaluateSingleValue(bytesWritten, @"writeHandle() bytes", strsize(@testdata))

      utils.startTest(@"closeFileHandle() after write")
      result := dfs.closeFileHandle(handle)
      utils.evaluateSingleValue(result, @"closeFileHandle()", 0)

    utils.startTest(@"openFileRead(DEV_SD, TEST1.TXT)")
    handle := dfs.openFileRead(dfs.DEV_SD, @testfile1)
    utils.evaluateRange(handle, @"openFileRead() handle", 0, 5)

    if handle >= 0
      utils.startTest(@"readHandle() returns correct data")
      utils.initGuard(@readBuf_guard)
      bytefill(@readBuffer, 0, 512)
      bytesRead := dfs.readHandle(handle, @readBuffer, 512)
      utils.checkGuard(@readBuf_guard, @"readBuf guard")
      utils.evaluateSingleValue(bytesRead, @"readHandle() bytes", strsize(@testdata))

      utils.startTest(@"Data matches what was written")
      utils.evaluateBufferMatch(@readBuffer, @testdata, strsize(@testdata), @"read vs written")

      utils.startTest(@"closeFileHandle() after read")
      result := dfs.closeFileHandle(handle)
      utils.evaluateSingleValue(result, @"closeFileHandle()", 0)

    ' Clean up: delete the test file
    dfs.deleteFile(dfs.DEV_SD, @testfile1)

    ' ----------------------------------
    ' TEST GROUP: Flash stubs return proper errors
    ' ----------------------------------
    utils.startTestGroup(@"Flash stubs return proper errors")

    utils.startTest(@"openFileRead(DEV_FLASH, ...) returns error")
    handle := dfs.openFileRead(dfs.DEV_FLASH, @testfile1)
    utils.evaluateBool(handle < 0, @"openFileRead(DEV_FLASH) fails", true)

    utils.startTest(@"freeSpace(DEV_FLASH) returns 0 or error")
    result := dfs.freeSpace(dfs.DEV_FLASH)
    utils.evaluateSingleValue(result, @"freeSpace(DEV_FLASH)", 0)

    ' ----------------------------------
    ' TEST GROUP: Unmount/remount cycle
    ' ----------------------------------
    utils.startTestGroup(@"Unmount and remount")

    utils.startTest(@"unmount(DEV_SD)")
    status := dfs.unmount(dfs.DEV_SD)
    utils.evaluateSingleValue(status, @"unmount(DEV_SD)", dfs.SUCCESS)

    utils.startTest(@"mounted(DEV_SD) after unmount")
    result := dfs.mounted(dfs.DEV_SD)
    utils.evaluateBool(result, @"mounted(DEV_SD)", false)

    utils.startTest(@"freeSpace(DEV_SD) after unmount returns 0")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateSingleValue(freeSpace, @"freeSpace(DEV_SD)", 0)

    utils.startTest(@"mount(DEV_SD) again")
    status := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(status, @"mount(DEV_SD)", dfs.SUCCESS)

    utils.startTest(@"freeSpace(DEV_SD) after remount")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateRange(freeSpace, @"freeSpace(DEV_SD)", 1, $7FFF_FFFF)

    ' ----------------------------------
    ' TEST GROUP: Stack guard check
    ' ----------------------------------
    utils.startTestGroup(@"Worker cog health")

    utils.startTest(@"checkStackGuard() intact")
    result := dfs.checkStackGuard()
    utils.evaluateBool(result, @"stack guard intact", true)

    ' Final cleanup
    dfs.unmount(dfs.DEV_SD)
    dfs.stop()

    ' ----------------------------------
    ' Summary
    ' ----------------------------------
    utils.ShowTestEndCounts()

    debug(" ")
    debug("* Phase 1 Verification Tests Complete")
    debug("END_SESSION")


con { license }

