'' =================================================================================================
''
''   File....... DFS_SD_RT_register_tests.spin2
''   Purpose.... This object tests CSD register access and timeout value APIs
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... FEB 2026
''   Updated.... 18 FEB 2026
''
'' =================================================================================================
''
'' Tests the following APIs:
''   - readCSDRaw() - CSD register raw read
''   - getReadTimeout() / getWriteTimeout() - timeout values
''   - cardSizeSectors() - capacity cross-check
''   - getCardMaxSpeed() - TRAN_SPEED cross-check
''
'' =================================================================================================

CON

     _CLKFREQ        = 270_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61

     ' External SD header (base pin 16)
     'SD_CS   = 20
     'SD_MOSI = 19
     'SD_MISO = 18
     'SD_SCK  = 21

     GUARD_SIZE  = 16

#ifdef __SPINTOOLS__
#define SD_INCLUDE_REGISTERS
#define SD_INCLUDE_RAW
#define SD_INCLUDE_SPEED
#define SD_INCLUDE_STACK_CHECK
#elseifdef __FLEXSPIN__
#define SD_INCLUDE_REGISTERS
#pragma exportdef SD_INCLUDE_REGISTERS
#define SD_INCLUDE_RAW
#pragma exportdef SD_INCLUDE_RAW
#define SD_INCLUDE_SPEED
#pragma exportdef SD_INCLUDE_SPEED
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#else
'' Enable register and raw access
#pragma exportdef SD_INCLUDE_REGISTERS
#pragma exportdef SD_INCLUDE_RAW
#pragma exportdef SD_INCLUDE_SPEED
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#endif

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "DFS_RT_utilities"

DAT

' CSD register buffer (16 bytes)
csdBuf          BYTE    0[16]
csdBuf_guard    BYTE    0[GUARD_SIZE]

' CID register buffer (16 bytes)
cidBuf          BYTE    0[16]
cidBuf_guard    BYTE    0[GUARD_SIZE]

' SCR register buffer (8 bytes)
scrBuf          BYTE    0[8]
scrBuf_guard    BYTE    0[GUARD_SIZE]

' SD Status buffer (64 bytes)
sdsBuf          BYTE    0[64]
sdsBuf_guard    BYTE    0[GUARD_SIZE]

PUB go() | workerCog, opResult, regStatus, csdVer, tranSpeed, capacity, cardSectors, readTimeout, writeTimeout, maxSpeed, ocr, mid, sdSpec
'' Main entry point for register access regression tests

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (SD) - Register & Timeout Tests")
    debug("==============================================")

    ' Initialize worker cog
    workerCog := dfs.init()

    ' Mount the card first
    opResult := dfs.mount(dfs.DEV_SD)
    if opResult <> dfs.SUCCESS
        debug("ERROR: Could not mount SD card!")
    else
        ' Show card info
        debug(" ")
        debug("* SD Card Information:")
        debug("   Volume Label: ", zstr_(dfs.volumeLabel(dfs.DEV_SD)))
        debug("   Free Space: ", udec(dfs.freeSpace(dfs.DEV_SD)), " sectors")

        ' ======================================================================
        ' TEST GROUP: readCSDRaw
        ' ======================================================================
        utils.startTestGroup(@"readCSDRaw")

        ' Test: readCSDRaw returns data
        utils.startTest(@"readCSDRaw() returns data successfully")
        bytefill(@csdBuf, 0, 16)
        utils.initGuard(@csdBuf_guard)
        regStatus := dfs.readCSDRaw(@csdBuf)
        utils.checkGuard(@csdBuf_guard, @"csdBuf guard")
        utils.evaluateSingleValue(regStatus, @"readCSDRaw()", dfs.SUCCESS)

        ' Test: CSD version is valid (0 for SDSC, 1 for SDHC/SDXC)
        utils.startTest(@"CSD version is valid (0 or 1)")
        csdVer := (csdBuf[0] >> 6) & $03
        debug("   CSD version: ", udec_(csdVer))
        utils.evaluateRange(csdVer, @"CSD_STRUCTURE", 0, 1)

        ' Test: TRAN_SPEED is valid (byte 3 of CSD)
        utils.startTest(@"TRAN_SPEED is valid ($32-$5A)")
        tranSpeed := csdBuf[3]
        debug("   TRAN_SPEED: $", uhex_(tranSpeed))
        ' $32 = 25 MHz, $5A = 50 MHz - standard values for SD cards
        utils.evaluateRange(tranSpeed, @"TRAN_SPEED byte", $32, $5A)

        ' Test: Capacity > 0
        utils.startTest(@"Card capacity > 0 sectors")
        cardSectors := dfs.cardSizeSectors()
        debug("   Card sectors: ", udec(cardSectors))
        utils.evaluateSubBool(cardSectors > 0, @"capacity > 0", TRUE)

        ' Test: Capacity matches cardSizeSectors()
        utils.startTest(@"CSD capacity consistent with cardSizeSectors()")
        ' For CSD v1 (SDHC/SDXC), capacity = (C_SIZE + 1) * 1024 sectors
        if csdVer == 1
            ' C_SIZE is in CSD bytes 7-9 (bits 69:48)
            capacity := ((csdBuf[7] & $3F) << 16) | (csdBuf[8] << 8) | csdBuf[9]
            capacity := (capacity + 1) * 1024
            debug("   CSD computed sectors: ", udec(capacity))
            ' Should match within rounding
            utils.evaluateSingleValue(capacity, @"CSD vs cardSizeSectors", cardSectors)
        else
            ' SDSC: more complex calculation, just verify non-zero
            utils.evaluateSubBool(cardSectors > 0, @"SDSC capacity > 0", TRUE)

        ' Test: readCSDRaw works via initCardOnly path (unmounted)
        utils.startTest(@"readCSDRaw() works after initCardOnly")
        dfs.unmount(dfs.DEV_SD)
        regStatus := dfs.initCardOnly()
        utils.evaluateSubValue(regStatus, @"initCardOnly()", dfs.SUCCESS)
        bytefill(@csdBuf, 0, 16)
        utils.initGuard(@csdBuf_guard)
        regStatus := dfs.readCSDRaw(@csdBuf)
        utils.checkGuard(@csdBuf_guard, @"csdBuf guard")
        utils.evaluateSubValue(regStatus, @"readCSDRaw() unmounted", dfs.SUCCESS)
        ' Verify same version
        opResult := (csdBuf[0] >> 6) & $03
        utils.evaluateSubValue(opResult, @"CSD version matches", csdVer)

#ifdef SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#endif

        dfs.stop()

        ' Remount for timeout tests
        opResult := dfs.mount(dfs.DEV_SD)
        if opResult <> dfs.SUCCESS
            debug("ERROR: Could not remount!")
        else
            ' ==================================================================
            ' TEST GROUP: Timeout Values
            ' ==================================================================
            utils.startTestGroup(@"Timeout Values")

            ' Test: getReadTimeout() is reasonable (50-500ms)
            utils.startTest(@"getReadTimeout() in reasonable range")
            readTimeout := dfs.getReadTimeout()
            debug("   Read timeout: ", udec(readTimeout), " ms")
            utils.evaluateRange(readTimeout, @"read timeout ms", 50, 500)

            ' Test: getWriteTimeout() is reasonable (100-1000ms)
            utils.startTest(@"getWriteTimeout() in reasonable range")
            writeTimeout := dfs.getWriteTimeout()
            debug("   Write timeout: ", udec(writeTimeout), " ms")
            utils.evaluateRange(writeTimeout, @"write timeout ms", 100, 1000)

            ' Test: Write timeout >= read timeout
            utils.startTest(@"Write timeout >= read timeout")
            utils.evaluateSubBool(writeTimeout >= readTimeout, @"write >= read", TRUE)

            ' Test: TRAN_SPEED matches getCardMaxSpeed()
            utils.startTest(@"TRAN_SPEED consistent with getCardMaxSpeed()")
            maxSpeed := dfs.getCardMaxSpeed()
            debug("   Card max speed: ", udec(maxSpeed), " Hz")
            ' 25 MHz = $32 TRAN_SPEED, 50 MHz = $5A TRAN_SPEED
            if tranSpeed == $32
                utils.evaluateSingleValue(maxSpeed, @"25 MHz from $32", 25_000_000)
            elseif tranSpeed == $5A
                utils.evaluateSingleValue(maxSpeed, @"50 MHz from $5A", 50_000_000)
            else
                ' Other TRAN_SPEED values - just check range
                utils.evaluateRange(maxSpeed, @"max speed Hz", 25_000_000, 50_000_000)

            ' ==================================================================
            ' TEST GROUP: CID Register
            ' ==================================================================
            utils.startTestGroup(@"CID Register")

            utils.startTest(@"readCIDRaw() returns SUCCESS")
            bytefill(@cidBuf, 0, 16)
            utils.initGuard(@cidBuf_guard)
            regStatus := dfs.readCIDRaw(@cidBuf)
            utils.checkGuard(@cidBuf_guard, @"cidBuf guard")
            utils.evaluateSingleValue(regStatus, @"readCIDRaw()", dfs.SUCCESS)

            utils.startTest(@"CID manufacturer ID > 0")
            mid := cidBuf[0]
            debug("   CID Manufacturer ID: $", uhex_byte_(mid))
            utils.evaluateSubBool(mid > 0, @"MID > 0", TRUE)

            utils.startTest(@"CID MID matches getManufacturerID()")
            opResult := dfs.getManufacturerID()
            utils.evaluateSingleValue(opResult, @"getManufacturerID()", mid)

            ' ==================================================================
            ' TEST GROUP: SCR Register
            ' ==================================================================
            utils.startTestGroup(@"SCR Register")

            utils.startTest(@"readSCRRaw() returns SUCCESS")
            bytefill(@scrBuf, 0, 8)
            utils.initGuard(@scrBuf_guard)
            regStatus := dfs.readSCRRaw(@scrBuf)
            utils.checkGuard(@scrBuf_guard, @"scrBuf guard")
            utils.evaluateSingleValue(regStatus, @"readSCRRaw()", dfs.SUCCESS)

            utils.startTest(@"SCR SD_SPEC version in valid range")
            sdSpec := (scrBuf[0] >> 4) & $0F
            debug("   SCR SD_SPEC: ", udec_(sdSpec))
            ' SD_SPEC: 0=v1.0, 1=v1.10, 2=v2.00+, 3=v3.0x, 4=v4.xx
            utils.evaluateRange(sdSpec, @"SD_SPEC version", 0, 4)

            ' ==================================================================
            ' TEST GROUP: OCR Register
            ' ==================================================================
            utils.startTestGroup(@"OCR Register")

            utils.startTest(@"getOCR() returns non-zero")
            ocr := dfs.getOCR()
            debug("   OCR: $", uhex_long_(ocr))
            utils.evaluateSubBool(ocr <> 0, @"OCR non-zero", TRUE)

            utils.startTest(@"OCR voltage range bits set")
            ' Bits 20-23 should have voltage range bits set (3.2-3.6V typical)
            utils.evaluateSubBool((ocr >> 20) & $0F <> 0, @"voltage bits set", TRUE)

            ' ==================================================================
            ' TEST GROUP: SD Status Register
            ' ==================================================================
            utils.startTestGroup(@"SD Status Register")

            utils.startTest(@"readSDStatusRaw() returns SUCCESS")
            bytefill(@sdsBuf, 0, 64)
            utils.initGuard(@sdsBuf_guard)
            regStatus := dfs.readSDStatusRaw(@sdsBuf)
            utils.checkGuard(@sdsBuf_guard, @"sdsBuf guard")
            utils.evaluateSingleValue(regStatus, @"readSDStatusRaw()", dfs.SUCCESS)

            ' ==================================================================
            ' Cleanup
            ' ==================================================================
            dfs.unmount(dfs.DEV_SD)

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("END_SESSION")


con { license }

