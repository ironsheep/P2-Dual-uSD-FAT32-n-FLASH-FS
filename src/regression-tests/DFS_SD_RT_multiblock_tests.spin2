'' =================================================================================================
''
''   File....... DFS_SD_RT_multiblock_tests.spin2
''   Purpose.... Multi-block read/write data integrity tests for V2 driver
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... JAN 2026
''   Updated.... 1 MAR 2026
''
'' =================================================================================================
''
''   This test verifies the V2 driver's multi-block operations (readSectorsRaw/writeSectorsRaw)
''   work correctly by testing data integrity across multiple scenarios.
''
''   Test Scenarios:
''     1. Round-trip: writeSectorsRaw() 8 sectors -> readSectorsRaw() 8 sectors -> verify
''     2. Multi-write, single-read: writeSectorsRaw() -> 8x readSectorRaw() -> verify
''     3. Single-write, multi-read: 8x writeSectorRaw() -> readSectorsRaw() -> verify
''     4. Edge cases: count=1 (fallback), count=0 (immediate return)
''     5. Large transfer: 64 sectors (32KB) round-trip
''
''   Test Sectors: 200000+ (safe area for all card sizes)
''
'' =================================================================================================

CON

    _CLKFREQ        = 350_000_000

    ' P2 Edge module SD slot pins
    SD_CS   = 60
    SD_MOSI = 59
    SD_MISO = 58
    SD_SCK  = 61

    ' External SD header (base pin 16)
    'SD_CS   = 20
    'SD_MOSI = 19
    'SD_MISO = 18
    'SD_SCK  = 21

    ' Test sector numbers (in free space area, safe for 64GB+ cards)
    TEST_SECTOR_BASE = 200_000

    ' Test sizes
    SMALL_COUNT      = 8            ' Standard multi-block test size
    LARGE_COUNT      = 64           ' Large multi-block test
    GUARD_SIZE       = 16


#ifdef __SPINTOOLS__
#define SD_INCLUDE_ALL
#define SD_INCLUDE_STACK_CHECK
#elseifdef __FLEXSPIN__
#define SD_INCLUDE_ALL
#pragma exportdef SD_INCLUDE_ALL
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#else
'' Enable full driver features for multi-block testing
#pragma exportdef SD_INCLUDE_ALL
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#endif

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "DFS_RT_utilities"

VAR
    ' Buffers for multi-sector operations
    BYTE    write_buf[SMALL_COUNT * dfs.SECTOR_SIZE]     ' 4KB for 8 sectors
    BYTE    read_buf[SMALL_COUNT * dfs.SECTOR_SIZE]
    BYTE    read_buf_guard[GUARD_SIZE]
    BYTE    large_write_buf[LARGE_COUNT * dfs.SECTOR_SIZE]  ' 32KB for 64 sectors
    BYTE    large_read_buf[LARGE_COUNT * dfs.SECTOR_SIZE]
    BYTE    large_read_buf_guard[GUARD_SIZE]


PUB go() | workerCog, mountStatus
'' Main entry point for multi-block data integrity tests
''
'' Tests readSectorsRaw/writeSectorsRaw operations

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (SD) - Multi-Block Tests")
    debug("==============================================")

    ' Initialize worker cog
    workerCog := dfs.init()

    ' Mount the card
    mountStatus := dfs.mount(dfs.DEV_SD)
    if mountStatus <> dfs.SUCCESS
        debug("ERROR: Mount failed!")
    else

        ' ========================================
        ' TEST 1: Round-trip multi-block
        ' ========================================
        testRoundTripMultiBlock()

        ' ========================================
        ' TEST 2: Multi-write, single-read
        ' ========================================
        testMultiWriteSingleRead()

        ' ========================================
        ' TEST 3: Single-write, multi-read
        ' ========================================
        testSingleWriteMultiRead()

        ' ========================================
        ' TEST 4: Edge cases
        ' ========================================
        testEdgeCases()

        ' ========================================
        ' TEST 5: Large multi-block (64 sectors)
        ' ========================================
        testLargeMultiBlock()

        ' Unmount
        dfs.unmount(dfs.DEV_SD)

#ifdef SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#endif

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("* Multi-Block Tests Complete")
    debug("END_SESSION")


PRI testRoundTripMultiBlock() | sector, byteIdx, written, readCt, errors
' TEST 1: Write 8 sectors with writeSectorsRaw, read back with readSectorsRaw

    utils.startTestGroup(@"Round-trip Multi-Block (8 sectors)")
    utils.startTest(@"Write 8 sectors then read all back")
    sector := TEST_SECTOR_BASE

    ' Fill write buffer with known pattern: each byte = (sector_offset * 17 + byte_offset) & $FF
    repeat byteIdx from 0 to (SMALL_COUNT * dfs.SECTOR_SIZE) - 1
        write_buf[byteIdx] := ((byteIdx / dfs.SECTOR_SIZE) * 17 + (byteIdx // dfs.SECTOR_SIZE)) & $FF

    ' Write all 8 sectors at once
    debug("* Writing 8 sectors starting at ", udec_(sector))
    written := dfs.writeSectorsRaw(sector, SMALL_COUNT, @write_buf)
    if written <> SMALL_COUNT
        debug("  FAIL: writeSectorsRaw returned ", udec_(written), " (expected ", udec_(SMALL_COUNT), ")")
        utils.recordFail()
    else
        ' Clear read buffer
        bytefill(@read_buf, $00, SMALL_COUNT * dfs.SECTOR_SIZE)

        ' Read all 8 sectors at once
        debug("* Reading 8 sectors starting at ", udec_(sector))
        utils.initGuard(@read_buf_guard)
        readCt := dfs.readSectorsRaw(sector, SMALL_COUNT, @read_buf)
        utils.checkGuard(@read_buf_guard, @"read_buf guard")
        if readCt <> SMALL_COUNT
            debug("  FAIL: readSectorsRaw returned ", udec_(readCt), " (expected ", udec_(SMALL_COUNT), ")")
            utils.recordFail()
        else
            ' Verify every byte
            errors := 0
            repeat byteIdx from 0 to (SMALL_COUNT * dfs.SECTOR_SIZE) - 1
                if read_buf[byteIdx] <> write_buf[byteIdx]
                    if errors < 5  ' Only report first 5 errors
                        debug("  ERROR at byte ", udec_(byteIdx), ": expected $", uhex_byte_(write_buf[byteIdx]), " got $", uhex_byte_(read_buf[byteIdx]))
                    errors++

            if errors == 0
                debug("  -> PASS: All ", udec_(SMALL_COUNT * dfs.SECTOR_SIZE), " bytes verified")
                utils.recordPass()
            else
                debug("  -> FAIL: ", udec_(errors), " byte mismatches")
                utils.recordFail()


PRI testMultiWriteSingleRead() | sector, sctrIdx, byteIdx, written, errors, expectedByte, actualByte, bufOffset
' TEST 2: Write 8 sectors with writeSectorsRaw, read back with individual readSectorRaw calls

    utils.startTestGroup(@"Multi-Write, Single-Read (8 sectors)")
    utils.startTest(@"writeSectorsRaw then 8x readSectorRaw")
    sector := TEST_SECTOR_BASE + 10

    ' Fill write buffer with different pattern
    repeat byteIdx from 0 to (SMALL_COUNT * dfs.SECTOR_SIZE) - 1
        write_buf[byteIdx] := ((byteIdx / dfs.SECTOR_SIZE) * 23 + (byteIdx // dfs.SECTOR_SIZE) + $A0) & $FF

    ' Write all 8 sectors at once
    debug("* Writing 8 sectors with writeSectorsRaw at ", udec_(sector))
    written := dfs.writeSectorsRaw(sector, SMALL_COUNT, @write_buf)
    if written <> SMALL_COUNT
        debug("  FAIL: writeSectorsRaw returned ", udec_(written))
        utils.recordFail()
    else
        ' Read back with 8 individual reads and verify each
        errors := 0
        utils.initGuard(@read_buf_guard)
        repeat sctrIdx from 0 to SMALL_COUNT - 1
            ' Read single sector into read_buf (reuse first 512 bytes)
            dfs.readSectorRaw(sector + sctrIdx, @read_buf)
            utils.initAndCheckGuard(@read_buf_guard, @"read_buf guard")

            ' Verify this sector's data against write_buf
            bufOffset := sctrIdx * dfs.SECTOR_SIZE
            repeat byteIdx from 0 to dfs.SECTOR_SIZE - 1
                expectedByte := write_buf[bufOffset + byteIdx]
                actualByte := read_buf[byteIdx]
                if actualByte <> expectedByte
                    if errors < 5
                        debug("  ERROR sector ", udec_(sctrIdx), " byte ", udec_(byteIdx), ": expected $", uhex_byte_(expectedByte), " got $", uhex_byte_(actualByte))
                    errors++

        if errors == 0
            debug("  -> PASS: All 8 sectors verified with single reads")
            utils.recordPass()
        else
            debug("  -> FAIL: ", udec_(errors), " byte mismatches")
            utils.recordFail()


PRI testSingleWriteMultiRead() | sector, sctrIdx, byteIdx, readCt, errors, expectedByte, actualByte, bufOffset, bWriteOk
' TEST 3: Write 8 sectors with individual writeSectorRaw calls, read back with readSectorsRaw

    utils.startTestGroup(@"Single-Write, Multi-Read (8 sectors)")
    utils.startTest(@"8x writeSectorRaw then readSectorsRaw")
    sector := TEST_SECTOR_BASE + 20

    ' Write 8 sectors one at a time with unique pattern per sector
    debug("* Writing 8 sectors with individual writeSectorRaw at ", udec_(sector))
    bWriteOk := true
    repeat sctrIdx from 0 to SMALL_COUNT - 1
        ' Fill single sector buffer
        bufOffset := sctrIdx * dfs.SECTOR_SIZE
        repeat byteIdx from 0 to dfs.SECTOR_SIZE - 1
            write_buf[bufOffset + byteIdx] := ((sctrIdx * 31) + byteIdx + $B0) & $FF

        ' Write this sector
        if dfs.writeSectorRaw(sector + sctrIdx, @write_buf + bufOffset) <> dfs.SUCCESS
            debug("  FAIL: writeSectorRaw failed for sector ", udec_(sctrIdx))
            utils.recordFail()
            bWriteOk := false
            quit

    if bWriteOk
        ' Clear read buffer
        bytefill(@read_buf, $00, SMALL_COUNT * dfs.SECTOR_SIZE)

        ' Read all 8 sectors at once
        debug("* Reading 8 sectors with readSectorsRaw")
        utils.initGuard(@read_buf_guard)
        readCt := dfs.readSectorsRaw(sector, SMALL_COUNT, @read_buf)
        utils.checkGuard(@read_buf_guard, @"read_buf guard")
        if readCt <> SMALL_COUNT
            debug("  FAIL: readSectorsRaw returned ", udec_(readCt))
            utils.recordFail()
        else
            ' Verify all data
            errors := 0
            repeat sctrIdx from 0 to SMALL_COUNT - 1
                bufOffset := sctrIdx * dfs.SECTOR_SIZE
                repeat byteIdx from 0 to dfs.SECTOR_SIZE - 1
                    expectedByte := write_buf[bufOffset + byteIdx]
                    actualByte := read_buf[bufOffset + byteIdx]
                    if actualByte <> expectedByte
                        if errors < 5
                            debug("  ERROR sector ", udec_(sctrIdx), " byte ", udec_(byteIdx), ": expected $", uhex_byte_(expectedByte), " got $", uhex_byte_(actualByte))
                        errors++

            if errors == 0
                debug("  -> PASS: All 8 sectors verified")
                utils.recordPass()
            else
                debug("  -> FAIL: ", udec_(errors), " byte mismatches")
                utils.recordFail()


PRI testEdgeCases() | sector, byteIdx, written, readCt, errors
' TEST 4: Edge cases - count=1, count=0

    utils.startTestGroup(@"Edge Cases")

    ' Test 4a: count=1 (should work as single-sector operation)
    sector := TEST_SECTOR_BASE + 30
    utils.startTest(@"writeSectorsRaw/readSectorsRaw with count=1")

    ' Fill single sector
    repeat byteIdx from 0 to dfs.SECTOR_SIZE - 1
        write_buf[byteIdx] := (byteIdx + $C0) & $FF

    written := dfs.writeSectorsRaw(sector, 1, @write_buf)
    if written <> 1
        debug("  FAIL: count=1 write returned ", udec_(written))
        utils.recordFail()
    else
        bytefill(@read_buf, $00, dfs.SECTOR_SIZE)
        utils.initGuard(@read_buf_guard)
        readCt := dfs.readSectorsRaw(sector, 1, @read_buf)
        utils.checkGuard(@read_buf_guard, @"read_buf guard")
        if readCt <> 1
            debug("  FAIL: count=1 read returned ", udec_(readCt))
            utils.recordFail()
        else
            errors := 0
            repeat byteIdx from 0 to dfs.SECTOR_SIZE - 1
                if read_buf[byteIdx] <> write_buf[byteIdx]
                    errors++
            if errors == 0
                debug("  -> PASS: count=1 works correctly")
                utils.recordPass()
            else
                debug("  -> FAIL: count=1 data mismatch (", udec_(errors), " errors)")
                utils.recordFail()

    ' Test 4b: count=0 (should return 0 immediately)
    utils.startTest(@"writeSectorsRaw/readSectorsRaw with count=0")

    written := dfs.writeSectorsRaw(sector, 0, @write_buf)
    readCt := dfs.readSectorsRaw(sector, 0, @read_buf)

    if written == 0 and readCt == 0
        debug("  -> PASS: count=0 returns 0 for both operations")
        utils.recordPass()
    else
        debug("  -> FAIL: count=0 returned write=", udec_(written), " read=", udec_(readCt))
        utils.recordFail()


PRI testLargeMultiBlock() | sector, byteIdx, written, readCt, errors
' TEST 5: Large multi-block (64 sectors = 32KB)

    utils.startTestGroup(@"Large Multi-Block (64 sectors = 32KB)")
    utils.startTest(@"64 sector round-trip (32KB)")
    sector := TEST_SECTOR_BASE + 50

    ' Fill large write buffer with pattern
    debug("* Filling 32KB buffer with pattern...")
    repeat byteIdx from 0 to (LARGE_COUNT * dfs.SECTOR_SIZE) - 1
        large_write_buf[byteIdx] := ((byteIdx / dfs.SECTOR_SIZE) + (byteIdx // dfs.SECTOR_SIZE)) & $FF

    ' Write 64 sectors at once
    debug("* Writing 64 sectors starting at ", udec_(sector))
    written := dfs.writeSectorsRaw(sector, LARGE_COUNT, @large_write_buf)
    if written <> LARGE_COUNT
        debug("  FAIL: writeSectorsRaw returned ", udec_(written), " (expected ", udec_(LARGE_COUNT), ")")
        utils.recordFail()
    else
        debug("* Write complete, clearing read buffer...")
        bytefill(@large_read_buf, $00, LARGE_COUNT * dfs.SECTOR_SIZE)

        ' Read 64 sectors at once
        debug("* Reading 64 sectors starting at ", udec_(sector))
        utils.initGuard(@large_read_buf_guard)
        readCt := dfs.readSectorsRaw(sector, LARGE_COUNT, @large_read_buf)
        utils.checkGuard(@large_read_buf_guard, @"large_read_buf guard")
        if readCt <> LARGE_COUNT
            debug("  FAIL: readSectorsRaw returned ", udec_(readCt), " (expected ", udec_(LARGE_COUNT), ")")
            utils.recordFail()
        else
            ' Verify all 32KB
            debug("* Verifying 32KB of data...")
            errors := 0
            repeat byteIdx from 0 to (LARGE_COUNT * dfs.SECTOR_SIZE) - 1
                if large_read_buf[byteIdx] <> large_write_buf[byteIdx]
                    if errors < 5
                        debug("  ERROR at byte ", udec_(byteIdx), ": expected $", uhex_byte_(large_write_buf[byteIdx]), " got $", uhex_byte_(large_read_buf[byteIdx]))
                    errors++

            if errors == 0
                debug("  -> PASS: All 32KB (", udec_(LARGE_COUNT * dfs.SECTOR_SIZE), " bytes) verified")
                utils.recordPass()
            else
                debug("  -> FAIL: ", udec_(errors), " byte mismatches in 32KB")
                utils.recordFail()


CON { license }

