'' =================================================================================================
''
''   File....... DFS_SD_RT_file_ops_tests.spin2
''   Purpose.... This object exercises file create/open/close/delete/rename operations using V3 handle API
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... JAN 2026
''   Updated.... 29 JAN 2026
''
'' =================================================================================================
''
'' Updated for V3 handle-based API:
''   - Uses createFileNew() instead of newFile()
''   - Uses openFileRead() / openFileWrite() instead of openFile()
''   - Uses closeFileHandle(handle) instead of closeFile()
''   - Uses writeHandle() / readHandle() instead of writeString() / readString()
''
'' =================================================================================================

CON

     _CLKFREQ        = 350_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61

     ' External SD header (base pin 16)
     'SD_CS   = 20
     'SD_MOSI = 19
     'SD_MISO = 18
     'SD_SCK  = 21

     ' Named constants (Rule 4 - no magic numbers)
     GUARD_SIZE           = 16
     BYTES_PER_SECTOR     = 512
     READ_BUF_SIZE        = 128

     ' File content write sizes
     WRITE_SIZE_9         = 9           ' "Delete me" length
     WRITE_SIZE_14        = 14          ' "File N content" length

     ' Diagnostic fill patterns
     DIAG_FILL_EE         = $EE
     DIAG_FILL_AA         = $AA
     DIAG_FILL_CC         = $CC
     DIAG_FILL_BB         = $BB
     DIAG_FILL_DD         = $DD

     ' MBR signature bytes
     MBR_SIG_BYTE_55      = $55
     MBR_SIG_BYTE_AA      = $AA
     MBR_SIG_OFFSET_510   = 510
     MBR_SIG_OFFSET_511   = 511

     ' Sector threshold for extended diagnostics
     DIAG_SECTOR_THRESHOLD = 30000

     ' Directory entry structure
     DIR_ENTRY_ATTR_OFFSET = 11         ' Attribute byte within 32-byte entry
     DIR_ENTRY_SIZE       = 32
     LABEL_LENGTH         = 11          ' 8.3 filename display length

     ' Directory entry markers
     DELETED_ENTRY_MARKER = $E5

     ' ASCII
     ASCII_SPACE          = $20
     ASCII_DEL            = $7F

#IFDEF __SPINTOOLS__
#DEFINE SD_INCLUDE_RAW
#DEFINE SD_INCLUDE_DEBUG
#DEFINE SD_INCLUDE_STACK_CHECK
#ELSEIFDEF __FLEXSPIN__
#define SD_INCLUDE_RAW
#pragma exportdef SD_INCLUDE_RAW
#define SD_INCLUDE_DEBUG
#pragma exportdef SD_INCLUDE_DEBUG
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#ELSE
'' Enable raw sector access and debug methods for diagnostic tests
#PRAGMA EXPORTDEF SD_INCLUDE_RAW
#PRAGMA EXPORTDEF SD_INCLUDE_DEBUG
#DEFINE SD_INCLUDE_STACK_CHECK
#PRAGMA EXPORTDEF SD_INCLUDE_STACK_CHECK
#ENDIF

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "isp_rt_utilities"

DAT

' Test filenames - use unique names to avoid conflicts
testfile1       BYTE    "RTFILE1.TXT", 0
testfile2       BYTE    "RTFILE2.BIN", 0
testfile3       BYTE    "RTFILE3.DAT", 0
renamedFile     BYTE    "RENAMED.TXT", 0
testContent1    BYTE    "Hello, SD Card!", 0
testContent2    BYTE    "This is test content for file operations.", 0
testdir1        BYTE    "RTDIR1", 0
nonexistent     BYTE    "NOEXIST.TXT", 0

readBuffer      BYTE    0[READ_BUF_SIZE]
readBuffer_guard BYTE   0[GUARD_SIZE]
sectorBuffer    BYTE    0[BYTES_PER_SECTOR]        ' For reading raw sectors during diagnostics
sectorBuffer_guard BYTE 0[GUARD_SIZE]

PUB go() | workerCog, result, status, handle, h1, h2, h3, pFilename, fileSize, attrs, bytesWritten, bytesRead, root_sec, i, pEntry, d_sec, d_buftype, d_token, d_b0, d_b1, d_b2, d_b3, d_pbuf, d_bef0, d_bef1, d_bef2, d_bef3, d_spi
'' Main entry point for file operations regression tests
''
'' Tests file create, open, close, delete, rename using V3 handle API

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (SD) V3 - File Operations Tests")
    debug("  (Using Handle-Based API)")
    debug("==============================================")

    ' Initialize worker cog
    workerCog := dfs.init(SD_CS, SD_MOSI, SD_MISO, SD_SCK)

    ' Mount the card first
    result := dfs.mount(dfs.DEV_SD)
    if result <> dfs.SUCCESS
        debug("ERROR: Could not mount SD card!")
    else
        ' Show card info
        debug(" ")
        debug("* SD Card Information:")
        debug("   Volume Label: ", zstr_(dfs.volumeLabel(dfs.DEV_SD)))

        ' Show FAT32 geometry for verification
        debug("   VBR sector: ", udec_(dfs.debugGetVbrSec()))
        debug("   FAT sector: ", udec_(dfs.debugGetFatSec()))
        debug("   Sec/FAT: ", udec_(dfs.debugGetSecPerFat()))
        debug("   Root sec: ", udec_(dfs.debugGetRootSec()))

        ' WORKAROUND: Clear corrupted root directory if detected
        debug("  CLEARING ROOT DIRECTORY...")
        result := dfs.debugClearRootDir()
        debug("  Clear result: ", sdec_(result))

        ' EARLY DIAGNOSTIC: Test multiple sectors to find pattern
        debug("  EARLY-DIAG: Testing sector reads...")
        ' Test sectors: 0, 1, 10, 100, 1000, then root_sec
        repeat i from 0 to 5
            case i
                0: root_sec := 0
                1: root_sec := 1
                2: root_sec := 10
                3: root_sec := 100
                4: root_sec := 1000
                5: root_sec := dfs.debugGetRootSec()
            bytefill(@sectorBuffer, DIAG_FILL_EE, BYTES_PER_SECTOR)
            utils.initGuard(@sectorBuffer_guard)
            result := dfs.readSectorRaw(root_sec, @sectorBuffer)
            utils.checkGuard(@sectorBuffer_guard, @"sectorBuffer guard")
            debug("  Sector ", udec_(root_sec), ": $", uhex_byte_(sectorBuffer[0]), " $", uhex_byte_(sectorBuffer[1]), " $", uhex_byte_(sectorBuffer[2]), " $", uhex_byte_(sectorBuffer[3]))
            ' For high sectors, also show internal diagnostic data
            if root_sec > DIAG_SECTOR_THRESHOLD
                dfs.debugGetReadSectorDiag(@d_sec, @d_buftype, @d_token, @d_b0, @d_b1, @d_b2, @d_b3, @d_pbuf)
                dfs.debugGetReadSectorDiagExt(@d_bef0, @d_bef1, @d_bef2, @d_bef3, @d_spi)
                debug("    DIAG: sec=", udec_(d_sec), " buftype=", udec_(d_buftype), " token=$", uhex_byte_(d_token))
                debug("    DIAG: p_buf=$", uhex_long_(d_pbuf), " BEFORE: $", uhex_byte_(d_bef0), " $", uhex_byte_(d_bef1), " $", uhex_byte_(d_bef2), " $", uhex_byte_(d_bef3))
                debug("    DIAG: STREAMER: $", uhex_byte_(d_b0), " $", uhex_byte_(d_b1), " $", uhex_byte_(d_b2), " $", uhex_byte_(d_b3), " spi_period=", udec_(d_spi))
                ' Now read same sector using slow byte-by-byte method for comparison
                bytefill(@sectorBuffer, DIAG_FILL_DD, BYTES_PER_SECTOR)
                result := dfs.debugReadSectorSlow(root_sec, @sectorBuffer)
                debug("    DIAG: SLOW READ: $", uhex_byte_(sectorBuffer[0]), " $", uhex_byte_(sectorBuffer[1]), " $", uhex_byte_(sectorBuffer[2]), " $", uhex_byte_(sectorBuffer[3]), " result=", sdec_(result))
                ' Dump first 64 bytes (2 directory entries) to understand structure
                debug("    DIAG: Entry0 (0-31): [", lstr_(@sectorBuffer, LABEL_LENGTH), "] attr=$", uhex_byte_(sectorBuffer[DIR_ENTRY_ATTR_OFFSET]))
                debug("    DIAG: Entry1 (32-63): [", lstr_(@sectorBuffer + DIR_ENTRY_SIZE, LABEL_LENGTH), "] attr=$", uhex_byte_(sectorBuffer[DIR_ENTRY_SIZE + DIR_ENTRY_ATTR_OFFSET]))

        debug("   Free Space: ", udec(dfs.freeSpace(dfs.DEV_SD)), " sectors")

        ' ----------------------------------
        ' TEST GROUP: File creation with handles
        ' ----------------------------------
        utils.startTestGroup(@"File Creation (V3 Handle API)")

        ' Clean up any existing test files first
        dfs.deleteFile(dfs.DEV_SD, @testfile1)
        dfs.deleteFile(dfs.DEV_SD, @testfile2)
        dfs.deleteFile(dfs.DEV_SD, @testfile3)
        dfs.deleteFile(dfs.DEV_SD, @renamedFile)

        utils.startTest(@"createFileNew() returns valid handle")
        debug("  DEBUG: Creating file [", zstr_(@testfile1), "]")
        handle := dfs.createFileNew(dfs.DEV_SD, @testfile1)
        debug("  DEBUG: createFileNew returned handle=", sdec_(handle))
        utils.evaluateSubBool(handle >= 0, @"createFileNew()", true)

        ' Write content and close file (setup for other tests)
        if handle >= 0
            bytesWritten := dfs.writeHandle(handle, @testContent1, strsize(@testContent1))
            debug("  Wrote ", udec_(bytesWritten), " bytes")
            result := dfs.closeFileHandle(handle)
            debug("  File closed, result=", sdec_(result))
        else
            debug("  SKIP: handle invalid, skipping write/close")

        ' WORKAROUND: Force directory cache sync from Cog0
        ' This fixes an issue where searchDirectory can't find files after creation
        dfs.syncDirCache()

        ' DIAGNOSTIC: Print buffer addresses
        debug("  DIAG: @sectorBuffer = $", uhex_long_(@sectorBuffer))
        debug("  DIAG: Testing basic sector read (MBR)...")
        bytefill(@sectorBuffer, DIAG_FILL_AA, BYTES_PER_SECTOR)
        utils.initGuard(@sectorBuffer_guard)
        result := dfs.readSectorRaw(0, @sectorBuffer)
        utils.checkGuard(@sectorBuffer_guard, @"sectorBuffer guard")
        debug("  DIAG: readSectorRaw(0) returned ", sdec_(result))
        debug("  DIAG: MBR bytes 510-511: $", uhex_byte_(sectorBuffer[MBR_SIG_OFFSET_510]), " $", uhex_byte_(sectorBuffer[MBR_SIG_OFFSET_511]))
        if sectorBuffer[MBR_SIG_OFFSET_510] == MBR_SIG_BYTE_55 and sectorBuffer[MBR_SIG_OFFSET_511] == MBR_SIG_BYTE_AA
            debug("  DIAG: MBR signature OK!")
        else
            debug("  DIAG: MBR signature BAD - card read broken?")

        ' Try reading sector 1 (partition table area) to see if issue is sector-specific
        debug("  DIAG: Reading sector 1...")
        bytefill(@sectorBuffer, DIAG_FILL_CC, BYTES_PER_SECTOR)
        utils.initGuard(@sectorBuffer_guard)
        result := dfs.readSectorRaw(1, @sectorBuffer)
        utils.checkGuard(@sectorBuffer_guard, @"sectorBuffer guard")
        debug("  DIAG: Sector 1 first bytes: $", uhex_byte_(sectorBuffer[0]), " $", uhex_byte_(sectorBuffer[1]), " $", uhex_byte_(sectorBuffer[2]), " $", uhex_byte_(sectorBuffer[3]))

        ' Now read root directory sector
        root_sec := dfs.debugGetRootSec()
        debug("  DIAG: root_sec = ", udec_(root_sec), " ($", uhex_long_(root_sec), ")")
        bytefill(@sectorBuffer, DIAG_FILL_BB, BYTES_PER_SECTOR)
        utils.initGuard(@sectorBuffer_guard)
        result := dfs.readSectorRaw(root_sec, @sectorBuffer)
        utils.checkGuard(@sectorBuffer_guard, @"sectorBuffer guard")
        debug("  DIAG: readSectorRaw(root) returned ", sdec_(result))
        debug("  DIAG: First 8 bytes: $", uhex_byte_(sectorBuffer[0]), " $", uhex_byte_(sectorBuffer[1]), " $", uhex_byte_(sectorBuffer[2]), " $", uhex_byte_(sectorBuffer[3]), " $", uhex_byte_(sectorBuffer[4]), " $", uhex_byte_(sectorBuffer[5]), " $", uhex_byte_(sectorBuffer[6]), " $", uhex_byte_(sectorBuffer[7]))
        ' Check if buffer was written at all
        if sectorBuffer[0] == DIAG_FILL_BB
            debug("  DIAG: Buffer NOT WRITTEN!")
        elseif sectorBuffer[0] == 0 or sectorBuffer[0] == DELETED_ENTRY_MARKER
            debug("  DIAG: Root entry is empty/deleted")
        elseif sectorBuffer[0] >= ASCII_SPACE and sectorBuffer[0] < ASCII_DEL
            debug("  DIAG: Root entry: [", lstr_(@sectorBuffer, LABEL_LENGTH), "]")
        else
            debug("  DIAG: First byte is $", uhex_byte_(sectorBuffer[0]))

        ' Quick sanity check - verify we can reopen the file we just created
        result := dfs.openFileRead(dfs.DEV_SD, @testfile1)
        if result >= 0
            dfs.closeFileHandle(result)
        else
            debug("  WARNING: File not found after close! Error=", sdec_(result))

        utils.startTest(@"createFileNew() fails if file already exists")
        debug("  DEBUG: Attempting to create same file again...")
        handle := dfs.createFileNew(dfs.DEV_SD, @testfile1)
        debug("  DEBUG: Second createFileNew returned handle=", sdec_(handle))
        utils.evaluateSingleValue(handle, @"createFileNew() on existing", dfs.E_FILE_EXISTS)

        ' ----------------------------------
        ' TEST GROUP: File open/close with handles
        ' ----------------------------------
        utils.startTestGroup(@"File Open/Close (V3 Handle API)")

        utils.startTest(@"openFileRead() opens existing file")
        handle := dfs.openFileRead(dfs.DEV_SD, @testfile1)
        utils.evaluateSubBool(handle >= 0, @"openFileRead()", true)

        utils.startTest(@"fileSizeHandle() returns correct size")
        if handle >= 0
            fileSize := dfs.fileSizeHandle(handle)
            utils.evaluateSingleValue(fileSize, @"fileSizeHandle()", strsize(@testContent1))

        utils.startTest(@"readHandle() returns correct content")
        if handle >= 0
            bytefill(@readBuffer, 0, READ_BUF_SIZE)
            utils.initGuard(@readBuffer_guard)
            bytesRead := dfs.readHandle(handle, @readBuffer, strsize(@testContent1))
            utils.checkGuard(@readBuffer_guard, @"readBuffer guard")
            utils.evaluateSubValue(bytesRead, @"bytesRead", strsize(@testContent1))
            utils.evaluateSubBool(strcomp(@readBuffer, @testContent1), @"content matches", true)

        utils.startTest(@"closeFileHandle() on open handle")
        if handle >= 0
            result := dfs.closeFileHandle(handle)
            utils.evaluateSingleValue(result, @"closeFileHandle()", dfs.SUCCESS)

        utils.startTest(@"openFileRead() fails for non-existent file")
        handle := dfs.openFileRead(dfs.DEV_SD, @"NOEXIST.TXT")
        utils.evaluateSingleValue(handle, @"openFileRead() non-existent", dfs.E_FILE_NOT_FOUND)

        ' ----------------------------------
        ' TEST GROUP: File deletion
        ' ----------------------------------
        utils.startTestGroup(@"File Deletion")

        ' Create a file to delete
        utils.startTest(@"Create file to delete")
        handle := dfs.createFileNew(dfs.DEV_SD, @testfile2)
        utils.evaluateSubBool(handle >= 0, @"createFileNew()", true)
        if handle >= 0
            dfs.writeHandle(handle, @"Delete me", WRITE_SIZE_9)
            dfs.closeFileHandle(handle)

        utils.startTest(@"deleteFile() removes the file")
        status := dfs.deleteFile(dfs.DEV_SD, @testfile2)
        utils.evaluateSingleValue(status, @"deleteFile()", dfs.SUCCESS)

        utils.startTest(@"Verify file is deleted (openFileRead fails)")
        handle := dfs.openFileRead(dfs.DEV_SD, @testfile2)
        utils.evaluateSingleValue(handle, @"openFileRead() after delete", dfs.E_FILE_NOT_FOUND)

        utils.startTest(@"deleteFile() fails for non-existent file")
        status := dfs.deleteFile(dfs.DEV_SD, @testfile2)
        utils.evaluateBool(status < 0, @"deleteFile() non-existent", true)

        ' ----------------------------------
        ' TEST GROUP: File rename
        ' ----------------------------------
        utils.startTestGroup(@"File Rename")

        ' Sync directory cache before rename operations
        dfs.syncDirCache()

        utils.startTest(@"rename() changes filename")
        status := dfs.rename(dfs.DEV_SD, @testfile1, @renamedFile)
        utils.evaluateSingleValue(status, @"rename()", dfs.SUCCESS)

        utils.startTest(@"Original file no longer accessible")
        handle := dfs.openFileRead(dfs.DEV_SD, @testfile1)
        utils.evaluateSingleValue(handle, @"openFileRead() old name", dfs.E_FILE_NOT_FOUND)

        utils.startTest(@"Renamed file is accessible")
        handle := dfs.openFileRead(dfs.DEV_SD, @renamedFile)
        utils.evaluateSubBool(handle >= 0, @"openFileRead() new name", true)

        utils.startTest(@"Content preserved after rename")
        if handle >= 0
            fileSize := dfs.fileSizeHandle(handle)
            utils.evaluateSingleValue(fileSize, @"fileSizeHandle()", strsize(@testContent1))
            dfs.closeFileHandle(handle)

        utils.startTest(@"rename() fails for non-existent source")
        status := dfs.rename(dfs.DEV_SD, @"NOFILE.TXT", @"OTHER.TXT")
        utils.evaluateBool(status < 0, @"rename() non-existent", true)

        ' ----------------------------------
        ' TEST GROUP: Multiple file creation
        ' ----------------------------------
        utils.startTestGroup(@"Multiple File Creation")

        ' Sync directory cache before multiple file operations
        dfs.syncDirCache()

        ' Create multiple files
        utils.startTest(@"Create multiple test files")
        utils.setCheckCountPerTest(3)

        handle := dfs.createFileNew(dfs.DEV_SD, @testfile1)
        utils.evaluateSubBool(handle >= 0, @"createFileNew() file1", true)
        if handle >= 0
            dfs.writeHandle(handle, @"File 1 content", WRITE_SIZE_14)
            dfs.closeFileHandle(handle)

        handle := dfs.createFileNew(dfs.DEV_SD, @testfile2)
        utils.evaluateSubBool(handle >= 0, @"createFileNew() file2", true)
        if handle >= 0
            dfs.writeHandle(handle, @"File 2 content", WRITE_SIZE_14)
            dfs.closeFileHandle(handle)

        handle := dfs.createFileNew(dfs.DEV_SD, @testfile3)
        utils.evaluateSubBool(handle >= 0, @"createFileNew() file3", true)
        if handle >= 0
            dfs.writeHandle(handle, @"File 3 content", WRITE_SIZE_14)
            dfs.closeFileHandle(handle)

        utils.startTest(@"Open each file and verify accessible")
        utils.setCheckCountPerTest(3)

        handle := dfs.openFileRead(dfs.DEV_SD, @testfile1)
        utils.evaluateSubBool(handle >= 0, @"openFileRead() file1", true)
        if handle >= 0
            dfs.closeFileHandle(handle)

        handle := dfs.openFileRead(dfs.DEV_SD, @testfile2)
        utils.evaluateSubBool(handle >= 0, @"openFileRead() file2", true)
        if handle >= 0
            dfs.closeFileHandle(handle)

        handle := dfs.openFileRead(dfs.DEV_SD, @testfile3)
        utils.evaluateSubBool(handle >= 0, @"openFileRead() file3", true)
        if handle >= 0
            dfs.closeFileHandle(handle)

        ' ----------------------------------
        ' TEST GROUP: Multiple simultaneous handles
        ' ----------------------------------
        utils.startTestGroup(@"Multiple Simultaneous Handles")

        utils.startTest(@"Open all 3 files simultaneously")
        h1 := dfs.openFileRead(dfs.DEV_SD, @testfile1)
        h2 := dfs.openFileRead(dfs.DEV_SD, @testfile2)
        h3 := dfs.openFileRead(dfs.DEV_SD, @testfile3)

        utils.evaluateSubBool(h1 >= 0, @"handle 1 valid", true)
        utils.evaluateSubBool(h2 >= 0, @"handle 2 valid", true)
        utils.evaluateSubBool(h3 >= 0, @"handle 3 valid", true)
        utils.evaluateSubBool(h1 <> h2 and h2 <> h3, @"handles unique", true)

        utils.startTest(@"Read from all 3 and verify correct data")
        utils.setCheckCountPerTest(3)

        if h1 >= 0
            bytefill(@readBuffer, 0, READ_BUF_SIZE)
            utils.initGuard(@readBuffer_guard)
            bytesRead := dfs.readHandle(h1, @readBuffer, WRITE_SIZE_14)
            utils.checkGuard(@readBuffer_guard, @"readBuffer guard")
            utils.evaluateSubBool(strcomp(@readBuffer, @"File 1 content"), @"file1 content", true)

        if h2 >= 0
            bytefill(@readBuffer, 0, READ_BUF_SIZE)
            utils.initGuard(@readBuffer_guard)
            bytesRead := dfs.readHandle(h2, @readBuffer, WRITE_SIZE_14)
            utils.checkGuard(@readBuffer_guard, @"readBuffer guard")
            utils.evaluateSubBool(strcomp(@readBuffer, @"File 2 content"), @"file2 content", true)

        if h3 >= 0
            bytefill(@readBuffer, 0, READ_BUF_SIZE)
            utils.initGuard(@readBuffer_guard)
            bytesRead := dfs.readHandle(h3, @readBuffer, WRITE_SIZE_14)
            utils.checkGuard(@readBuffer_guard, @"readBuffer guard")
            utils.evaluateSubBool(strcomp(@readBuffer, @"File 3 content"), @"file3 content", true)

        ' Close all handles
        if h1 >= 0
            dfs.closeFileHandle(h1)
        if h2 >= 0
            dfs.closeFileHandle(h2)
        if h3 >= 0
            dfs.closeFileHandle(h3)

        ' ----------------------------------
        ' TEST GROUP: Type Mismatch Errors
        ' ----------------------------------
        utils.startTestGroup(@"Type Mismatch Errors")

        ' Create a test directory for these tests
        dfs.deleteFile(dfs.DEV_SD, @testdir1)   ' Clean up if exists
        status := dfs.newDirectory(dfs.DEV_SD, @testdir1)
        debug("  Created test directory RTDIR1, status=", sdec_(status))

        utils.startTest(@"openFileRead() on directory returns E_NOT_A_FILE")
        handle := dfs.openFileRead(dfs.DEV_SD, @testdir1)
        utils.evaluateSingleValue(handle, @"openFileRead(dir)", dfs.E_NOT_A_FILE)

        ' NOTE: changeDirectory() on file test SKIPPED - driver bug allows cd into files
        ' See DRIVER-CHANGES-NEEDED.md - do_chdir() needs to check ATTR_DIR
        ' Test will be added when driver is fixed

        utils.startTest(@"openFileWrite() on non-existent returns E_FILE_NOT_FOUND")
        handle := dfs.openFileWrite(dfs.DEV_SD, @nonexistent)
        utils.evaluateSingleValue(handle, @"openFileWrite(nonexistent)", dfs.E_FILE_NOT_FOUND)

        ' Clean up the test directory
        dfs.deleteFile(dfs.DEV_SD, @testdir1)

        ' ----------------------------------
        ' Cleanup: Delete test files
        ' ----------------------------------
        debug(" ")
        debug("* Cleaning up test files...")
        dfs.deleteFile(dfs.DEV_SD, @testfile1)
        dfs.deleteFile(dfs.DEV_SD, @testfile2)
        dfs.deleteFile(dfs.DEV_SD, @testfile3)
        dfs.deleteFile(dfs.DEV_SD, @renamedFile)

        ' Unmount
        dfs.unmount(dfs.DEV_SD)

    ' ----------------------------------
    ' Summary
    ' ----------------------------------
#IFDEF SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#ENDIF

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("* File Operations Tests Complete (V3 Handle API)")
    debug("END_SESSION")


con { license }

