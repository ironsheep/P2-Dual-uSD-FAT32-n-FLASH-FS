'' =================================================================================================
''
''   File....... DFS_SD_RT_directory_tests.spin2
''   Purpose.... This object exercises directory operations (create, change, list)
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... JAN 2026
''   Updated.... 16 JAN 2026
''
'' =================================================================================================

CON

     _CLKFREQ        = 350_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61

     ' External SD header (base pin 16)
     'SD_CS   = 20
     'SD_MOSI = 19
     'SD_MISO = 18
     'SD_SCK  = 21

     STRESS_COUNT = 20

     ATTR_DIRECTORY       = $10    ' FAT32 directory attribute bit

' Enable stack depth measurement
#IFDEF __SPINTOOLS__
#DEFINE SD_INCLUDE_STACK_CHECK
#ELSEIFDEF __FLEXSPIN__
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#ELSE
#DEFINE SD_INCLUDE_STACK_CHECK
#PRAGMA EXPORTDEF SD_INCLUDE_STACK_CHECK
#ENDIF

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "isp_rt_utilities"

DAT

' Test directory and file names
testDir1        BYTE    "RTDIR1", 0
testDir2        BYTE    "RTDIR2", 0
subDir1         BYTE    "SUBDIR1", 0
testFile1       BYTE    "FILE1.TXT", 0
testFile2       BYTE    "FILE2.TXT", 0
testContent     BYTE    "Test file content", 0

' Deep nesting directory names
deepDir1        BYTE    "DEEP1", 0
deepDir2        BYTE    "DEEP2", 0
deepDir3        BYTE    "DEEP3", 0
deepDir4        BYTE    "DEEP4", 0
deepDir5        BYTE    "DEEP5", 0

' Max filename (8.3 format)
maxNameFile     BYTE    "12345678.123", 0

' Many files test directory
manyFilesDir    BYTE    "RTMANY", 0

' Stress test
stressDir       BYTE    "RTSTRESS", 0
stressContent   BYTE    "Stress file data", 0

' Buffer for generated filenames
genFileName     BYTE    0[16]

PUB go() | workerCog, status, pEntry, pFilename, attrs, fileCount, idx, handle, created
'' Main entry point for directory regression tests
''
'' Tests directory creation, navigation, listing, and nested directories

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (SD) - Directory Tests")
    debug("==============================================")

    ' Initialize worker cog
    workerCog := dfs.init(SD_CS, SD_MOSI, SD_MISO, SD_SCK)

    ' Mount the card first
    status := dfs.mount(dfs.DEV_SD)
    if status <> dfs.SUCCESS
        debug("ERROR: Could not mount SD card!")
    else
        ' Show card info
        debug(" ")
        debug("* SD Card Information:")
        debug("   Volume Label: ", zstr_(dfs.volumeLabel(dfs.DEV_SD)))
        debug("   Free Space: ", udec(dfs.freeSpace(dfs.DEV_SD)), " sectors")

        ' Clean up any existing test directories/files
        cleanupTestItems()

        ' ----------------------------------
        ' TEST GROUP: Directory creation
        ' ----------------------------------
        utils.startTestGroup(@"Directory Creation")

        utils.startTest(@"newDirectory() creates a directory")
        status := dfs.newDirectory(dfs.DEV_SD, @testDir1)
        utils.evaluateSingleValue(status, @"newDirectory()", dfs.SUCCESS)

        utils.startTest(@"newDirectory() fails if directory exists")
        status := dfs.newDirectory(dfs.DEV_SD, @testDir1)
        utils.evaluateBool(status < 0, @"newDirectory() existing", true)

        utils.startTest(@"Create second directory")
        status := dfs.newDirectory(dfs.DEV_SD, @testDir2)
        utils.evaluateSingleValue(status, @"newDirectory() second", dfs.SUCCESS)

        ' ----------------------------------
        ' TEST GROUP: Change directory
        ' ----------------------------------
        utils.startTestGroup(@"Change Directory")

        utils.startTest(@"changeDirectory() to new directory")
        status := dfs.changeDirectory(dfs.DEV_SD, @testDir1)
        utils.evaluateSingleValue(status, @"changeDirectory()", dfs.SUCCESS)

        utils.startTest(@"Create file in subdirectory")
        handle := dfs.createFileNew(dfs.DEV_SD, @testFile1)
        utils.evaluateBool(handle >= 0, @"newFile() in subdir", true)
        dfs.writeHandle(handle, @testContent, strsize(@testContent))
        dfs.closeFileHandle(handle)

        utils.startTest(@"changeDirectory() back to parent with ..")
        status := dfs.changeDirectory(dfs.DEV_SD, @"..")
        utils.evaluateSingleValue(status, @"changeDirectory(..) ", dfs.SUCCESS)

        utils.startTest(@"changeDirectory() to root with /")
        status := dfs.changeDirectory(dfs.DEV_SD, @"/")
        utils.evaluateSingleValue(status, @"changeDirectory(/)", dfs.SUCCESS)

        utils.startTest(@"changeDirectory() fails for non-existent")
        status := dfs.changeDirectory(dfs.DEV_SD, @"NOEXIST")
        utils.evaluateBool(status < 0, @"changeDirectory() non-existent", true)

        utils.startTest(@"changeDirectory() fails on a file (not a directory)")
        dfs.changeDirectory(dfs.DEV_SD, @testDir1)                                             ' Go to RTDIR1 where FILE1.TXT exists
        status := dfs.changeDirectory(dfs.DEV_SD, @testFile1)                                  ' Should fail - FILE1.TXT is not a directory
        utils.evaluateBool(status < 0, @"changeDirectory() on file", true)
        dfs.changeDirectory(dfs.DEV_SD, @"/")                                                  ' Return to root

        ' ----------------------------------
        ' TEST GROUP: Nested directories
        ' ----------------------------------
        utils.startTestGroup(@"Nested Directories")

        utils.startTest(@"Change to first directory")
        status := dfs.changeDirectory(dfs.DEV_SD, @testDir1)
        utils.evaluateSingleValue(status, @"changeDirectory()", dfs.SUCCESS)

        utils.startTest(@"Create subdirectory")
        status := dfs.newDirectory(dfs.DEV_SD, @subDir1)
        utils.evaluateSingleValue(status, @"newDirectory() nested", dfs.SUCCESS)

        utils.startTest(@"Change to nested subdirectory")
        status := dfs.changeDirectory(dfs.DEV_SD, @subDir1)
        utils.evaluateSingleValue(status, @"changeDirectory() nested", dfs.SUCCESS)

        utils.startTest(@"Create file in nested directory")
        handle := dfs.createFileNew(dfs.DEV_SD, @testFile2)
        utils.evaluateBool(handle >= 0, @"newFile() nested", true)
        dfs.writeHandle(handle, @"Nested file content", strsize(@"Nested file content"))
        dfs.closeFileHandle(handle)

        utils.startTest(@"Navigate back to root")
        dfs.changeDirectory(dfs.DEV_SD, @"/")
        status := dfs.changeDirectory(dfs.DEV_SD, @"/")  ' Should succeed
        utils.evaluateSingleValue(status, @"changeDirectory(/)", dfs.SUCCESS)

        ' ----------------------------------
        ' TEST GROUP: Path navigation
        ' ----------------------------------
        utils.startTestGroup(@"Path Navigation")

        utils.startTest(@"Open file with path: /RTDIR1/FILE1.TXT")
        handle := dfs.openFileRead(dfs.DEV_SD, @"/RTDIR1/FILE1.TXT")
        utils.evaluateBool(handle >= 0, @"openFile() with path", true)
        dfs.closeFileHandle(handle)

        utils.startTest(@"Open nested file: /RTDIR1/SUBDIR1/FILE2.TXT")
        handle := dfs.openFileRead(dfs.DEV_SD, @"/RTDIR1/SUBDIR1/FILE2.TXT")
        utils.evaluateBool(handle >= 0, @"openFile() nested path", true)
        dfs.closeFileHandle(handle)

        utils.startTest(@"Ensure back at root after path operations")
        status := dfs.changeDirectory(dfs.DEV_SD, @"/")
        utils.evaluateSingleValue(status, @"changeDirectory(/)", dfs.SUCCESS)

        ' ----------------------------------
        ' TEST GROUP: Directory listing
        ' ----------------------------------
        utils.startTestGroup(@"Directory Listing")

        utils.startTest(@"readDirectory() enumerates entries")
        fileCount := 0
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            pFilename := dfs.fileName()
            attrs := dfs.attributes()
            debug("  Entry ", udec_(idx), ": [", zstr_(pFilename), "] attr=$", uhex_(attrs))
            fileCount++
            idx++
        utils.evaluateRange(fileCount, @"directory entries found", 2, 100)  ' At least our 2 test dirs

        utils.startTest(@"List subdirectory contents")
        dfs.changeDirectory(dfs.DEV_SD, @testDir1)
        fileCount := 0
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            pFilename := dfs.fileName()
            attrs := dfs.attributes()
            debug("  Entry ", udec_(idx), ": [", zstr_(pFilename), "] attr=$", uhex_(attrs))
            fileCount++
            idx++
        ' Should have FILE1.TXT and SUBDIR1
        utils.evaluateRange(fileCount, @"subdir entries", 2, 10)
        dfs.changeDirectory(dfs.DEV_SD, @"/")

        ' ----------------------------------
        ' TEST GROUP: Move file between directories
        ' ----------------------------------
        utils.startTestGroup(@"Move File")

        ' Create a file in root to move
        utils.startTest(@"Create file in root to move")
        handle := dfs.createFileNew(dfs.DEV_SD, @"MOVEME.TXT")
        utils.evaluateBool(handle >= 0, @"createFileNew()", true)
        dfs.writeHandle(handle, @"File to be moved", strsize(@"File to be moved"))
        dfs.closeFileHandle(handle)

        utils.startTest(@"moveFile() to subdirectory")
        status := dfs.moveFile(dfs.DEV_SD, @"MOVEME.TXT", @testDir2)
        utils.evaluateSingleValue(status, @"moveFile()", dfs.SUCCESS)

        utils.startTest(@"File no longer in root")
        handle := dfs.openFileRead(dfs.DEV_SD, @"MOVEME.TXT")
        utils.evaluateBool(handle >= 0, @"openFile() old location", false)

        utils.startTest(@"File exists in new location")
        dfs.changeDirectory(dfs.DEV_SD, @testDir2)
        handle := dfs.openFileRead(dfs.DEV_SD, @"MOVEME.TXT")
        utils.evaluateBool(handle >= 0, @"openFile() new location", true)
        dfs.closeFileHandle(handle)
        dfs.changeDirectory(dfs.DEV_SD, @"/")

        ' ----------------------------------
        ' TEST GROUP: Directory Boundary Conditions
        ' ----------------------------------
        utils.startTestGroup(@"Directory Boundary Conditions")

        ' Test: Deep nesting (5 levels)
        utils.startTest(@"Deep nesting - create 5-level directory structure")
        dfs.changeDirectory(dfs.DEV_SD, @"/")
        status := dfs.newDirectory(dfs.DEV_SD, @deepDir1)
        utils.evaluateSubValue(status, @"create DEEP1", dfs.SUCCESS)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir1)
        status := dfs.newDirectory(dfs.DEV_SD, @deepDir2)
        utils.evaluateSubValue(status, @"create DEEP2", dfs.SUCCESS)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir2)
        status := dfs.newDirectory(dfs.DEV_SD, @deepDir3)
        utils.evaluateSubValue(status, @"create DEEP3", dfs.SUCCESS)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir3)
        status := dfs.newDirectory(dfs.DEV_SD, @deepDir4)
        utils.evaluateSubValue(status, @"create DEEP4", dfs.SUCCESS)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir4)
        status := dfs.newDirectory(dfs.DEV_SD, @deepDir5)
        utils.evaluateSubValue(status, @"create DEEP5", dfs.SUCCESS)

        utils.startTest(@"Navigate to deepest level and create file")
        dfs.changeDirectory(dfs.DEV_SD, @deepDir5)
        handle := dfs.createFileNew(dfs.DEV_SD, @"DEEP.TXT")
        utils.evaluateSubBool(handle >= 0, @"create file at depth 5", true)
        dfs.writeHandle(handle, @"Deep file", strsize(@"Deep file"))
        dfs.closeFileHandle(handle)

        utils.startTest(@"Navigate back to root using ..")
        dfs.changeDirectory(dfs.DEV_SD, @"..")  ' DEEP4
        dfs.changeDirectory(dfs.DEV_SD, @"..")  ' DEEP3
        dfs.changeDirectory(dfs.DEV_SD, @"..")  ' DEEP2
        dfs.changeDirectory(dfs.DEV_SD, @"..")  ' DEEP1
        dfs.changeDirectory(dfs.DEV_SD, @"..")  ' root
        status := dfs.changeDirectory(dfs.DEV_SD, @"/")
        utils.evaluateSingleValue(status, @"back at root", dfs.SUCCESS)

        ' Test: Empty directory listing
        utils.startTest(@"Empty directory listing")
        dfs.changeDirectory(dfs.DEV_SD, @"/")
        status := dfs.newDirectory(dfs.DEV_SD, @manyFilesDir)
        dfs.changeDirectory(dfs.DEV_SD, @manyFilesDir)
        fileCount := 0
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            fileCount++
            idx++
        ' FAT32 empty directories contain . and .. entries (2 entries)
        utils.evaluateSingleValue(fileCount, @"empty dir entries (. and ..)", 2)
        dfs.changeDirectory(dfs.DEV_SD, @"/")

        ' Test: Max filename length (8.3 format)
        utils.startTest(@"Max filename length (8.3)")
        dfs.changeDirectory(dfs.DEV_SD, @manyFilesDir)
        handle := dfs.createFileNew(dfs.DEV_SD, @maxNameFile)
        utils.evaluateSubBool(handle >= 0, @"create 12345678.123", true)
        dfs.writeHandle(handle, @"Max name file content", strsize(@"Max name file content"))
        dfs.closeFileHandle(handle)

        ' Verify can open and read it
        handle := dfs.openFileRead(dfs.DEV_SD, @maxNameFile)
        utils.evaluateSubBool(handle >= 0, @"open 12345678.123", true)
        dfs.closeFileHandle(handle)
        dfs.changeDirectory(dfs.DEV_SD, @"/")

        ' Clean up boundary test items
        dfs.changeDirectory(dfs.DEV_SD, @manyFilesDir)
        dfs.deleteFile(dfs.DEV_SD, @maxNameFile)
        dfs.changeDirectory(dfs.DEV_SD, @"/")
        dfs.deleteFile(dfs.DEV_SD, @manyFilesDir)

        ' Clean up deep directories (must delete from deepest first)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir1)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir2)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir3)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir4)
        dfs.changeDirectory(dfs.DEV_SD, @deepDir5)
        dfs.deleteFile(dfs.DEV_SD, @"DEEP.TXT")
        dfs.changeDirectory(dfs.DEV_SD, @"..")
        dfs.deleteFile(dfs.DEV_SD, @deepDir5)
        dfs.changeDirectory(dfs.DEV_SD, @"..")
        dfs.deleteFile(dfs.DEV_SD, @deepDir4)
        dfs.changeDirectory(dfs.DEV_SD, @"..")
        dfs.deleteFile(dfs.DEV_SD, @deepDir3)
        dfs.changeDirectory(dfs.DEV_SD, @"..")
        dfs.deleteFile(dfs.DEV_SD, @deepDir2)
        dfs.changeDirectory(dfs.DEV_SD, @"/")
        dfs.deleteFile(dfs.DEV_SD, @deepDir1)

        ' ----------------------------------
        ' TEST GROUP: Many File Stress Test
        ' ----------------------------------
        utils.startTestGroup(@"Many File Stress Test")

        ' Create stress test directory
        dfs.changeDirectory(dfs.DEV_SD, @"/")
        dfs.deleteFile(dfs.DEV_SD, @stressDir)
        status := dfs.newDirectory(dfs.DEV_SD, @stressDir)
        utils.evaluateSubValue(status, @"create stress dir", dfs.SUCCESS)
        dfs.changeDirectory(dfs.DEV_SD, @stressDir)

        ' Create 20 files: STR00.TXT through STR19.TXT
        utils.startTest(@"Create 20 files in stress directory")
        created := 0
        repeat idx from 0 to STRESS_COUNT - 1
            makeStressName(idx)
            handle := dfs.createFileNew(dfs.DEV_SD, @genFileName)
            if handle >= 0
                dfs.writeHandle(handle, @stressContent, strsize(@stressContent))
                dfs.closeFileHandle(handle)
                created++
        utils.evaluateSingleValue(created, @"files created", STRESS_COUNT)

        ' Enumerate and count files
        utils.startTest(@"Enumerate finds all 20 files")
        fileCount := 0
        handle := dfs.openDirectory(dfs.DEV_SD, @".")
        if handle >= 0
            repeat
                pEntry := dfs.readDirectoryHandle(handle)
                if pEntry == 0
                    quit
                pFilename := dfs.fileName()
                attrs := BYTE[pEntry + 11]
                if attrs & ATTR_DIRECTORY == 0 and BYTE[pFilename] <> "."
                    fileCount++
            dfs.closeDirectoryHandle(handle)
        utils.evaluateSingleValue(fileCount, @"enumerated files", STRESS_COUNT)

        ' Verify each file can be opened
        utils.startTest(@"All 20 files can be opened for read")
        created := 0
        repeat idx from 0 to STRESS_COUNT - 1
            makeStressName(idx)
            handle := dfs.openFileRead(dfs.DEV_SD, @genFileName)
            if handle >= 0
                created++
                dfs.closeFileHandle(handle)
        utils.evaluateSingleValue(created, @"files opened", STRESS_COUNT)

        ' Clean up stress test files
        repeat idx from 0 to STRESS_COUNT - 1
            makeStressName(idx)
            dfs.deleteFile(dfs.DEV_SD, @genFileName)
        dfs.changeDirectory(dfs.DEV_SD, @"/")
        dfs.deleteFile(dfs.DEV_SD, @stressDir)

        ' ----------------------------------
        ' Cleanup
        ' ----------------------------------
        debug(" ")
        debug("* Cleaning up test items...")
        cleanupTestItems()

        ' Unmount
        dfs.unmount(dfs.DEV_SD)

    ' ----------------------------------
    ' Summary
    ' ----------------------------------
#IFDEF SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#ENDIF

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("* Directory Tests Complete")
    debug("END_SESSION")


PRI cleanupTestItems()
' Delete test files and directories
'
' Note: Must delete files before directories, and nested items first

    ' Clean nested items
    dfs.changeDirectory(dfs.DEV_SD, @"/")
    dfs.changeDirectory(dfs.DEV_SD, @testDir1)
    dfs.changeDirectory(dfs.DEV_SD, @subDir1)
    dfs.deleteFile(dfs.DEV_SD, @testFile2)
    dfs.changeDirectory(dfs.DEV_SD, @"..")
    dfs.deleteFile(dfs.DEV_SD, @testFile1)
    dfs.deleteFile(dfs.DEV_SD, @subDir1)  ' Try to delete as file (won't work for dir, but harmless)
    dfs.changeDirectory(dfs.DEV_SD, @"/")

    ' Clean testDir2 contents
    dfs.changeDirectory(dfs.DEV_SD, @testDir2)
    dfs.deleteFile(dfs.DEV_SD, @"MOVEME.TXT")
    dfs.changeDirectory(dfs.DEV_SD, @"/")

    ' Delete root-level test items
    dfs.deleteFile(dfs.DEV_SD, @testDir1)  ' Try (won't work if has contents)
    dfs.deleteFile(dfs.DEV_SD, @testDir2)


PRI makeStressName(n)
' Generate stress test filename "STRnn.TXT" into genFileName buffer.
'
' @param n - File number (0-99)

    genFileName[0] := "S"
    genFileName[1] := "T"
    genFileName[2] := "R"
    genFileName[3] := "0" + (n / 10)
    genFileName[4] := "0" + (n // 10)
    genFileName[5] := "."
    genFileName[6] := "T"
    genFileName[7] := "X"
    genFileName[8] := "T"
    genFileName[9] := 0


con { license }

