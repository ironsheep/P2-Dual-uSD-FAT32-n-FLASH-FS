'' =================================================================================================
''
''   File....... DFS_SD_RT_volume_tests.spin2
''   Purpose.... This object tests volume operations, sync, date, and VBR access
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... FEB 2026
''   Updated.... 18 FEB 2026
''
'' =================================================================================================
''
'' Tests the following APIs:
''   - setVolumeLabel() / volumeLabel()
''   - syncAllHandles()
''   - sync() (legacy)
''   - setDate() with timestamp verification
''   - VBR access via readSectorRaw() and readVBRRaw()
''
'' =================================================================================================

CON

     _CLKFREQ        = 270_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61

     ' External SD header (base pin 16)
     'SD_CS   = 20
     'SD_MOSI = 19
     'SD_MISO = 18
     'SD_SCK  = 21

     MBR_SIGNATURE = $AA55

     ' Named constants (Rule 4 - no magic numbers)
     GUARD_SIZE           = 16
     BYTES_PER_SECTOR     = 512
     LABEL_BUF_SIZE       = 12          ' 11 chars + null

     ' MBR/VBR structure offsets
     MBR_SIG_OFFSET       = $1FE        ' Boot signature location
     MBR_PART_LBA_OFFSET  = $1C6        ' Partition 1 LBA start (4-byte LE)
     VBR_BPS_OFFSET       = $0B         ' Bytes per sector (WORD)
     VBR_OEM_OFFSET       = $03         ' OEM name (8 bytes)
     OEM_NAME_LENGTH      = 8

     ' ASCII range for printable check
     ASCII_SPACE          = $20
     ASCII_TILDE          = $7E

     ' FAT directory entry offsets
     DIR_WRITE_DATE_OFFSET = 24
     DIR_WRITE_TIME_OFFSET = 22

     ' FAT date/time field shifts and masks
     FAT_DATE_YEAR_SHIFT  = 9
     FAT_DATE_YEAR_MASK   = $7F
     FAT_DATE_MONTH_SHIFT = 5
     FAT_DATE_MONTH_MASK  = $0F
     FAT_TIME_HOUR_SHIFT  = 11
     FAT_TIME_HOUR_MASK   = $1F
     FAT_YEAR_BASE        = 1980

     ' Expected year field values
     YEAR_2026_FIELD      = 46          ' 2026 - 1980
     YEAR_2025_FIELD      = 45          ' 2025 - 1980
     YEAR_2000_FIELD      = 20          ' 2000 - 1980

     ' VBR sector sanity limit
     VBR_SECTOR_MAX       = 100_000

#IFDEF __SPINTOOLS__
#DEFINE SD_INCLUDE_REGISTERS
#DEFINE SD_INCLUDE_RAW
#DEFINE SD_INCLUDE_STACK_CHECK
#ELSEIFDEF __FLEXSPIN__
#define SD_INCLUDE_REGISTERS
#pragma exportdef SD_INCLUDE_REGISTERS
#define SD_INCLUDE_RAW
#pragma exportdef SD_INCLUDE_RAW
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#ELSE
'' Enable register access and raw sector access for VBR verification
#PRAGMA EXPORTDEF SD_INCLUDE_REGISTERS
#PRAGMA EXPORTDEF SD_INCLUDE_RAW
#DEFINE SD_INCLUDE_STACK_CHECK
#PRAGMA EXPORTDEF SD_INCLUDE_STACK_CHECK
#ENDIF

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "isp_rt_utilities"

DAT

' Test filenames
vlTestFile1     BYTE    "VLTEST1.TXT", 0
vlTestFile2     BYTE    "VLTEST2.TXT", 0
vlTestFile3     BYTE    "VLTEST3.TXT", 0
vlSyncFile      BYTE    "VLSYNC.TXT", 0
vlDateFile      BYTE    "VLDATE1.TXT", 0
vlDateFile2     BYTE    "VLDATE2.TXT", 0
vlDateDir       BYTE    "VLDTDIR", 0
vlLegacyFile    BYTE    "VLLEGCY.TXT", 0

' Volume label test strings
newLabel        BYTE    "TESTLABEL  ", 0
maxLabel        BYTE    "12345678901", 0

' File content
testContent     BYTE    "Volume test content data", 0
syncContent     BYTE    "Sync test data chunk one", 0

' Buffers
vbrBuf          BYTE    0[BYTES_PER_SECTOR]
vbrBuf_guard    BYTE    0[GUARD_SIZE]
vbrBuf2         BYTE    0[BYTES_PER_SECTOR]
vbrBuf2_guard   BYTE    0[GUARD_SIZE]
readBuffer      BYTE    0[256]
readBuffer_guard BYTE   0[GUARD_SIZE]

' Saved original label
origLabel       BYTE    0[LABEL_BUF_SIZE]

PUB go() | workerCog, result, status, handle, h1, h2, h3, bytesWritten, bytesRead, pLabel, idx, pEntry, wrtDate, wrtTime, fileSize, vbrSector, found
'' Main entry point for volume operation regression tests

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (SD) V3 - Volume Operation Tests")
    debug("==============================================")

    ' Initialize worker cog
    workerCog := dfs.init(SD_CS, SD_MOSI, SD_MISO, SD_SCK)

    ' Mount the card first
    result := dfs.mount(dfs.DEV_SD)
    if result <> dfs.SUCCESS
        debug("ERROR: Could not mount SD card!")
    else
        ' Show card info
        debug(" ")
        debug("* SD Card Information:")
        debug("   Volume Label: ", zstr_(dfs.volumeLabel(dfs.DEV_SD)))
        debug("   Free Space: ", udec(dfs.freeSpace(dfs.DEV_SD)), " sectors")

        ' Save original volume label
        pLabel := dfs.volumeLabel(dfs.DEV_SD)
        bytefill(@origLabel, 0, LABEL_BUF_SIZE)
        bytemove(@origLabel, pLabel, strsize(pLabel))
        debug("   Original Label saved: [", zstr_(@origLabel), "]")

        ' Clean up any existing test files
        cleanupTestFiles()

        ' ======================================================================
        ' TEST GROUP: setVolumeLabel
        ' ======================================================================
        utils.startTestGroup(@"setVolumeLabel")

        ' Test: Set a new volume label
        utils.startTest(@"setVolumeLabel() changes label")
        status := dfs.setVolumeLabel(dfs.DEV_SD, @newLabel)
        utils.evaluateSingleValue(status, @"setVolumeLabel()", dfs.SUCCESS)

        ' Test: volumeLabel() returns the new label
        utils.startTest(@"volumeLabel() returns new label after set")
        pLabel := dfs.volumeLabel(dfs.DEV_SD)
        debug("   New label: [", zstr_(pLabel), "]")
        result := strncmp(pLabel, @"TESTLABEL", 9)
        utils.evaluateBool(result, @"label matches TESTLABEL", true)

        ' Test: Max length label (11 chars)
        utils.startTest(@"setVolumeLabel() accepts 11-char label")
        status := dfs.setVolumeLabel(dfs.DEV_SD, @maxLabel)
        utils.evaluateSingleValue(status, @"setVolumeLabel(11 chars)", dfs.SUCCESS)

        ' Test: Label persists through unmount/remount
        utils.startTest(@"Label persists through unmount/remount")
        dfs.unmount(dfs.DEV_SD)
        result := dfs.mount(dfs.DEV_SD)
        utils.evaluateSubValue(result, @"remount succeeds", dfs.SUCCESS)
        pLabel := dfs.volumeLabel(dfs.DEV_SD)
        debug("   Label after remount: [", zstr_(pLabel), "]")
        result := strncmp(pLabel, @"12345678901", 11)
        utils.evaluateSubBool(result, @"label persisted", true)

        ' Test: Restore original label
        utils.startTest(@"Restore original volume label")
        status := dfs.setVolumeLabel(dfs.DEV_SD, @origLabel)
        utils.evaluateSingleValue(status, @"restore label", dfs.SUCCESS)
        pLabel := dfs.volumeLabel(dfs.DEV_SD)
        debug("   Restored label: [", zstr_(pLabel), "]")

        ' ======================================================================
        ' TEST GROUP: Wrong Device Guards
        ' ======================================================================
        utils.startTestGroup(@"Wrong Device Guards")

        ' Test: setVolumeLabel(DEV_FLASH) returns E_NOT_SUPPORTED
        utils.startTest(@"setVolumeLabel(DEV_FLASH) returns E_NOT_SUPPORTED")
        status := dfs.setVolumeLabel(dfs.DEV_FLASH, @newLabel)
        utils.evaluateSingleValue(status, @"setVolumeLabel(FLASH)", dfs.E_NOT_SUPPORTED)

        ' Test: volumeLabel(DEV_FLASH) returns 0
        utils.startTest(@"volumeLabel(DEV_FLASH) returns 0")
        result := dfs.volumeLabel(dfs.DEV_FLASH)
        utils.evaluateSingleValue(result, @"volumeLabel(FLASH)", 0)

        ' ======================================================================
        ' TEST GROUP: syncAllHandles
        ' ======================================================================
        utils.startTestGroup(@"syncAllHandles")

        ' Test: syncAllHandles with no handles open
        utils.startTest(@"syncAllHandles() with no handles open")
        result := dfs.syncAllHandles()
        utils.evaluateSingleValue(result, @"syncAllHandles() no handles", dfs.SUCCESS)

        ' Test: syncAllHandles flushes single write handle
        utils.startTest(@"syncAllHandles() flushes single write handle")
        dfs.deleteFile(dfs.DEV_SD, @vlSyncFile)
        h1 := dfs.createFileNew(dfs.DEV_SD, @vlSyncFile)
        utils.evaluateSubBool(h1 >= 0, @"create file", true)
        if h1 >= 0
            bytesWritten := dfs.writeHandle(h1, @syncContent, strsize(@syncContent))
            result := dfs.syncAllHandles()
            utils.evaluateSubValue(result, @"syncAllHandles()", dfs.SUCCESS)
            ' File should still be writable
            bytesWritten := dfs.writeHandle(h1, @syncContent, strsize(@syncContent))
            utils.evaluateSubBool(bytesWritten > 0, @"write after sync", true)
            dfs.closeFileHandle(h1)

        ' Test: syncAllHandles flushes multiple write handles
        utils.startTest(@"syncAllHandles() flushes multiple write handles")
        dfs.deleteFile(dfs.DEV_SD, @vlTestFile1)
        dfs.deleteFile(dfs.DEV_SD, @vlTestFile2)
        h1 := dfs.createFileNew(dfs.DEV_SD, @vlTestFile1)
        h2 := dfs.createFileNew(dfs.DEV_SD, @vlTestFile2)
        if h1 >= 0
            dfs.writeHandle(h1, @testContent, strsize(@testContent))
        if h2 >= 0
            dfs.writeHandle(h2, @testContent, strsize(@testContent))
        result := dfs.syncAllHandles()
        utils.evaluateSingleValue(result, @"syncAllHandles() multi", dfs.SUCCESS)
        if h1 >= 0
            dfs.closeFileHandle(h1)
        if h2 >= 0
            dfs.closeFileHandle(h2)

        ' Test: syncAllHandles with mixed read+write handles
        utils.startTest(@"syncAllHandles() with read+write mix")
        h1 := dfs.openFileRead(dfs.DEV_SD, @vlTestFile1)
        dfs.deleteFile(dfs.DEV_SD, @vlTestFile3)
        h2 := dfs.createFileNew(dfs.DEV_SD, @vlTestFile3)
        if h2 >= 0
            dfs.writeHandle(h2, @testContent, strsize(@testContent))
        result := dfs.syncAllHandles()
        utils.evaluateSingleValue(result, @"syncAllHandles() mix", dfs.SUCCESS)
        if h1 >= 0
            dfs.closeFileHandle(h1)
        if h2 >= 0
            dfs.closeFileHandle(h2)

        ' ======================================================================
        ' TEST GROUP: sync (legacy)
        ' ======================================================================
        utils.startTestGroup(@"sync (legacy)")

        ' Test: sync flushes handle-based write
        utils.startTest(@"sync() flushes handle write")
        dfs.deleteFile(dfs.DEV_SD, @vlLegacyFile)
        handle := dfs.createFileNew(dfs.DEV_SD, @vlLegacyFile)
        utils.evaluateSubBool(handle >= 0, @"createFileNew()", true)
        dfs.writeHandle(handle, @testContent, strsize(@testContent))
        result := dfs.syncHandle(handle)
        utils.evaluateSubValue(result, @"syncHandle()", dfs.SUCCESS)
        dfs.closeFileHandle(handle)

        ' Test: sync with no file open
        utils.startTest(@"sync() with no file open")
        status := dfs.sync()
        utils.evaluateSingleValue(status, @"sync() no file", dfs.SUCCESS)

        ' ======================================================================
        ' TEST GROUP: setDate
        ' ======================================================================
        utils.startTestGroup(@"setDate")

        ' Test: Timestamp on new file
        utils.startTest(@"setDate() sets timestamp on new file")
        dfs.setDate(2026, 2, 18, 14, 30, 0)
        dfs.deleteFile(dfs.DEV_SD, @vlDateFile)
        h1 := dfs.createFileNew(dfs.DEV_SD, @vlDateFile)
        if h1 >= 0
            dfs.writeHandle(h1, @testContent, strsize(@testContent))
            dfs.closeFileHandle(h1)
        ' Verify timestamp via directory entry
        wrtDate := 0
        wrtTime := 0
        found := false
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            pLabel := dfs.fileName()
            if strcomp(pLabel, @"VLDATE1.TXT")
                ' FAT date: bits 15-9=year-1980, 8-5=month, 4-0=day
                wrtDate := WORD[pEntry + DIR_WRITE_DATE_OFFSET]
                ' FAT time: bits 15-11=hour, 10-5=minute, 4-0=second/2
                wrtTime := WORD[pEntry + DIR_WRITE_TIME_OFFSET]
                found := true
                quit
            idx++
        debug("   found=", sdec_(found), " wrtDate=$", uhex_(wrtDate), " wrtTime=$", uhex_(wrtTime))
        utils.evaluateSubBool(found, @"file found in dir", true)
        utils.evaluateSubBool(wrtDate <> 0, @"date stamp non-zero", true)
        utils.evaluateSubBool(wrtTime <> 0, @"time stamp non-zero", true)
        ' Verify year field (bits 15-9) = 46 (2026-1980)
        result := (wrtDate >> FAT_DATE_YEAR_SHIFT) & FAT_DATE_YEAR_MASK
        utils.evaluateSubValue(result, @"year field (2026-1980)", YEAR_2026_FIELD)

        ' Test: Midnight Jan 1, 2000
        utils.startTest(@"setDate() midnight Jan 1 2000")
        dfs.setDate(2000, 1, 1, 0, 0, 0)
        dfs.deleteFile(dfs.DEV_SD, @vlDateFile2)
        h1 := dfs.createFileNew(dfs.DEV_SD, @vlDateFile2)
        if h1 >= 0
            dfs.writeHandle(h1, @testContent, strsize(@testContent))
            dfs.closeFileHandle(h1)
        found := false
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            pLabel := dfs.fileName()
            if strcomp(pLabel, @"VLDATE2.TXT")
                wrtDate := WORD[pEntry + DIR_WRITE_DATE_OFFSET]
                wrtTime := WORD[pEntry + DIR_WRITE_TIME_OFFSET]
                found := true
                quit
            idx++
        debug("   found=", sdec_(found), " wrtDate=$", uhex_(wrtDate))
        utils.evaluateSubBool(found, @"file found in dir", true)
        ' Year=2000-1980=20, month=1, day=1
        result := (wrtDate >> FAT_DATE_YEAR_SHIFT) & FAT_DATE_YEAR_MASK
        utils.evaluateSubValue(result, @"year field (2000-1980)", YEAR_2000_FIELD)
        ' Time at midnight should be 0
        utils.evaluateSubValue(wrtTime, @"midnight time", 0)

        ' Test: End-of-day Dec 31
        utils.startTest(@"setDate() end-of-day Dec 31")
        dfs.setDate(2025, 12, 31, 23, 59, 58)
        dfs.deleteFile(dfs.DEV_SD, @vlDateFile2)
        h1 := dfs.createFileNew(dfs.DEV_SD, @vlDateFile2)
        if h1 >= 0
            dfs.writeHandle(h1, @testContent, strsize(@testContent))
            dfs.closeFileHandle(h1)
        found := false
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            pLabel := dfs.fileName()
            if strcomp(pLabel, @"VLDATE2.TXT")
                wrtDate := WORD[pEntry + DIR_WRITE_DATE_OFFSET]
                wrtTime := WORD[pEntry + DIR_WRITE_TIME_OFFSET]
                found := true
                quit
            idx++
        debug("   found=", sdec_(found), " wrtDate=$", uhex_(wrtDate), " wrtTime=$", uhex_(wrtTime))
        utils.evaluateSubBool(found, @"file found in dir", true)
        ' Year=2025-1980=45
        result := (wrtDate >> FAT_DATE_YEAR_SHIFT) & FAT_DATE_YEAR_MASK
        utils.evaluateSubValue(result, @"year field (2025-1980)", YEAR_2025_FIELD)
        ' Month=12
        result := (wrtDate >> FAT_DATE_MONTH_SHIFT) & FAT_DATE_MONTH_MASK
        utils.evaluateSubValue(result, @"month field (12)", 12)
        ' Hour=23, minute=59, second/2=29
        result := (wrtTime >> FAT_TIME_HOUR_SHIFT) & FAT_TIME_HOUR_MASK
        utils.evaluateSubValue(result, @"hour field (23)", 23)  ' 23 is the expected hour value, not a magic number

        ' Test: setDate via V3 createFileNew
        utils.startTest(@"setDate() timestamp on V3 createFileNew")
        dfs.setDate(2026, 6, 15, 10, 0, 0)
        dfs.deleteFile(dfs.DEV_SD, @vlDateFile)
        h1 := dfs.createFileNew(dfs.DEV_SD, @vlDateFile)
        if h1 >= 0
            dfs.writeHandle(h1, @testContent, strsize(@testContent))
            dfs.closeFileHandle(h1)
        found := false
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            pLabel := dfs.fileName()
            if strcomp(pLabel, @"VLDATE1.TXT")
                wrtDate := WORD[pEntry + DIR_WRITE_DATE_OFFSET]
                found := true
                quit
            idx++
        debug("   found=", sdec_(found), " wrtDate=$", uhex_(wrtDate))
        utils.evaluateSubBool(found, @"file found in dir", true)
        ' Year=2026-1980=46, month=6
        result := (wrtDate >> FAT_DATE_YEAR_SHIFT) & FAT_DATE_YEAR_MASK
        utils.evaluateSubValue(result, @"V3 year field", YEAR_2026_FIELD)
        result := (wrtDate >> FAT_DATE_MONTH_SHIFT) & FAT_DATE_MONTH_MASK
        utils.evaluateSubValue(result, @"V3 month field", 6)

        ' Test: setDate on new directory
        utils.startTest(@"setDate() timestamp on new directory")
        dfs.setDate(2026, 3, 1, 8, 0, 0)
        dfs.newDirectory(dfs.DEV_SD, @vlDateDir)
        found := false
        idx := 0
        repeat
            pEntry := dfs.readDirectory(idx)
            if pEntry == 0
                quit
            pLabel := dfs.fileName()
            if strcomp(pLabel, @"VLDTDIR")
                wrtDate := WORD[pEntry + DIR_WRITE_DATE_OFFSET]
                found := true
                quit
            idx++
        debug("   found=", sdec_(found), " wrtDate=$", uhex_(wrtDate))
        utils.evaluateSubBool(found, @"dir found in listing", true)
        ' Year=2026-1980=46, month=3
        result := (wrtDate >> FAT_DATE_YEAR_SHIFT) & FAT_DATE_YEAR_MASK
        utils.evaluateSubValue(result, @"dir year field", YEAR_2026_FIELD)
        result := (wrtDate >> FAT_DATE_MONTH_SHIFT) & FAT_DATE_MONTH_MASK
        utils.evaluateSubValue(result, @"dir month field", 3)

        ' ======================================================================
        ' TEST GROUP: VBR Access (via readSectorRaw and readVBRRaw)
        ' ======================================================================
        utils.startTestGroup(@"VBR Access via readSectorRaw")

        ' Read MBR (sector 0) to find VBR sector
        utils.startTest(@"Read MBR to find VBR sector")
        bytefill(@vbrBuf, 0, BYTES_PER_SECTOR)
        utils.initGuard(@vbrBuf_guard)
        status := dfs.readSectorRaw(0, @vbrBuf)
        utils.checkGuard(@vbrBuf_guard, @"vbrBuf guard")
        utils.evaluateSingleValue(status, @"readSectorRaw(0)", dfs.SUCCESS)

        ' Get VBR sector from partition table (offset $1C6 = 454, 4-byte LE)
        utils.startTest(@"MBR partition table has valid VBR sector")
        vbrSector := LONG[@vbrBuf + MBR_PART_LBA_OFFSET]
        debug("   VBR sector: ", udec_(vbrSector))
        utils.evaluateSubBool(vbrSector > 0, @"VBR sector > 0", true)
        utils.evaluateSubBool(vbrSector < VBR_SECTOR_MAX, @"VBR sector reasonable", true)

        ' Read VBR sector
        utils.startTest(@"VBR has boot signature $AA55")
        bytefill(@vbrBuf, 0, BYTES_PER_SECTOR)
        utils.initGuard(@vbrBuf_guard)
        status := dfs.readSectorRaw(vbrSector, @vbrBuf)
        utils.checkGuard(@vbrBuf_guard, @"vbrBuf guard")
        if status == dfs.SUCCESS
            result := WORD[@vbrBuf + MBR_SIG_OFFSET]
            utils.evaluateSingleValueHex(result, @"boot signature", MBR_SIGNATURE)
        else
            utils.evaluateBool(false, @"VBR read failed", true)

        ' Test: Bytes per sector == 512
        utils.startTest(@"VBR bytes-per-sector == 512")
        result := WORD[@vbrBuf + VBR_BPS_OFFSET]
        utils.evaluateSingleValue(result, @"bytes per sector", BYTES_PER_SECTOR)

        ' Test: OEM name is readable (8 bytes at offset 3)
        utils.startTest(@"VBR OEM name is readable")
        ' OEM name is 8 bytes at offset 3, should be printable ASCII
        result := true
        repeat idx from 0 to OEM_NAME_LENGTH - 1
            if vbrBuf[VBR_OEM_OFFSET + idx] < ASCII_SPACE or vbrBuf[VBR_OEM_OFFSET + idx] > ASCII_TILDE
                result := false
                quit
        debug("   OEM: ", lstr_(@vbrBuf + VBR_OEM_OFFSET, OEM_NAME_LENGTH))
        utils.evaluateBool(result, @"OEM name printable", true)

        ' Test: readVBRRaw() succeeds after mount
        utils.startTest(@"readVBRRaw() returns VBR data")
        bytefill(@vbrBuf2, 0, BYTES_PER_SECTOR)
        utils.initGuard(@vbrBuf2_guard)
        status := dfs.readVBRRaw(@vbrBuf2)
        utils.checkGuard(@vbrBuf2_guard, @"vbrBuf2 guard")
        utils.evaluateSingleValue(status, @"readVBRRaw()", dfs.SUCCESS)

        ' Test: readVBRRaw() matches readSectorRaw(vbrSector) data
        utils.startTest(@"readVBRRaw() matches readSectorRaw(VBR)")
        found := true
        repeat idx from 0 to BYTES_PER_SECTOR - 1
            if vbrBuf[idx] <> vbrBuf2[idx]
                debug("   Mismatch at offset ", udec_(idx), ": $", uhex_byte_(vbrBuf[idx]), " vs $", uhex_byte_(vbrBuf2[idx]))
                found := false
                quit
        utils.evaluateBool(found, @"readVBRRaw matches readSectorRaw", true)

        ' ======================================================================
        ' Cleanup and Summary
        ' ======================================================================
        cleanupTestFiles()

        dfs.unmount(dfs.DEV_SD)

#IFDEF SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#ENDIF

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("END_SESSION")

PRI cleanupTestFiles()
' Delete all test files

    dfs.deleteFile(dfs.DEV_SD, @vlTestFile1)
    dfs.deleteFile(dfs.DEV_SD, @vlTestFile2)
    dfs.deleteFile(dfs.DEV_SD, @vlTestFile3)
    dfs.deleteFile(dfs.DEV_SD, @vlSyncFile)
    dfs.deleteFile(dfs.DEV_SD, @vlDateFile)
    dfs.deleteFile(dfs.DEV_SD, @vlDateFile2)
    dfs.deleteFile(dfs.DEV_SD, @vlLegacyFile)
    dfs.deleteFile(dfs.DEV_SD, @vlDateDir)

PRI strncmp(pStr1, pStr2, maxLen) : match | idx
' Compare first maxLen bytes of two strings.
'
' @param pStr1 - Pointer to first string
' @param pStr2 - Pointer to second string
' @param maxLen - Number of bytes to compare
' @returns match - TRUE if first maxLen bytes match
'
' @local idx - Loop counter

    match := true
    repeat idx from 0 to maxLen - 1
        if BYTE[pStr1][idx] <> BYTE[pStr2][idx]
            match := false
            quit


con { license }

