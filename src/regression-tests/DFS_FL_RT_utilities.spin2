'' =================================================================================================
''
''   File....... DFS_FL_RT_utilities.spin2
''   Purpose.... Regression test utilities for Flash tests against dual_sd_fat32_flash_fs unified driver
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... FEB 2026
''   Updated.... 27 FEB 2026
''
'' =================================================================================================
''
'' Based on isp_rt_utilities.spin2 (SD framework) extended with Flash-specific evaluation methods
'' adapted from RT_utilities.spin2 (Flash reference test utility).
''
'' Key differences from RT_utilities.spin2:
''   - Uses dfs : "dual_sd_fat32_flash_fs" instead of flash : "flash_fs"
''   - Per-cog VAR arrays (indexed by cogid()) for multi-cog test safety
''   - All flash.* calls replaced with dfs.* equivalents
''   - Error codes use unified dfs.E_* namespace
''   - Includes buffer pattern/guard utilities from isp_rt_utilities
''
'' =================================================================================================

CON

  MAX_OPEN_FILES = 6          ' Default (match dual_sd_fat32_flash_fs default); overridable by parent OBJ

#IFDEF __SPINTOOLS__
#DEFINE MAX_OPEN_FILES
#ELSEIFDEF __FLEXSPIN__
#define MAX_OPEN_FILES
#pragma exportdef MAX_OPEN_FILES
#ELSE
#PRAGMA EXPORTDEF MAX_OPEN_FILES
#ENDIF

  TEST_SIGNATURE = $12345678

  GUARD_SIZE    = 16          ' Guard bytes after each buffer
  GUARD_BYTE    = $CC         ' Sentinel value (distinct from $00, $FF, $AA, $55)

  MAX_P2_COGS         = 8    ' P2 has 8 cogs
  HEXDUMP_LINE_BYTES  = 16   ' Bytes per hex dump row
  ASCII_PRINTABLE_MIN = 32   ' Space - first printable ASCII
  ASCII_PRINTABLE_MAX = 126  ' Tilde - last printable ASCII

  ' P2 Edge module SD slot pins
  SD_CS   = 60
  SD_MOSI = 59
  SD_MISO = 58
  SD_SCK  = 61

OBJ

  dfs : "dual_sd_fat32_flash_fs"

VAR { test stats vars }

  LONG    numberTests[MAX_P2_COGS]
  LONG    subTestPer[MAX_P2_COGS]
  LONG    passCount[MAX_P2_COGS]
  LONG    failCount[MAX_P2_COGS]
  LONG    passCountSub[MAX_P2_COGS]
  LONG    failCountSub[MAX_P2_COGS]

  LONG    varSignature[MAX_P2_COGS]

  byte    filename[128]

PUB null()
'' This is not an application

PRI initIfNotAlready()
' Initialize test counters if not already done

    if varSignature[cogid()] <> TEST_SIGNATURE
        numberTests[cogid()] := 0
        subTestPer[cogid()] := 1
        passCount[cogid()] := 0
        failCount[cogid()] := 0
        passCountSub[cogid()] := 0
        failCountSub[cogid()] := 0
        varSignature[cogid()] := TEST_SIGNATURE
        debug("* init VAR")

' ===============================================================================
' FRAMEWORK METHODS -- Test structure and lifecycle
' ===============================================================================

PUB startTestGroup(pDescription)
'' Start a new test group with heading
''
'' @param pDescription - pointer to description string

    initIfNotAlready()
    showSubTestResults()

    debug(" ")
    debug(" ")
    debug(" ------------------------------------------------------------")
    debug("* Test Group: ", zstr_(pDescription))

PUB startTest(pDescription) | ecGot, ecExpected, passScaled, failScaled, total
'' Start a new test with description
''
'' @param pDescription - pointer to test description string

    initIfNotAlready()
    showSubTestResults()

    numberTests[cogid()]++
    debug(" ")
    debug("* Test #", udec_(numberTests[cogid()]), ": ", zstr_(pDescription))

PUB showSubTestResults() | passScaled, failScaled, total, pPassFail
'' Display accumulated sub-test results and reset counters

    if failCountSub[cogid()] <> 0 or passCountSub[cogid()] <> 0
        total := (passCountSub[cogid()] + failCountSub[cogid()]) / subTestPer[cogid()]
        passScaled := passCountSub[cogid()] / subTestPer[cogid()]
        failScaled := total - passScaled
        debug("  Sub-Test Results: count=", udec_(total), ", Pass: ", udec_(passScaled), ", Fail: ", udec_(failScaled))
        if failScaled < 0
          debug("  Sub-Test (", udec(passCountSub[cogid()], failCountSub[cogid()]), ")")

        if failCountSub[cogid()] <> 0
            failCount[cogid()]++
        else
            passCount[cogid()]++
        pPassFail := failCountSub[cogid()] <> 0 ? @"FAIL" : @"pass"
        debug("   -> ", zstr_(pPassFail))
        passCountSub[cogid()] := 0
        failCountSub[cogid()] := 0

PUB ShowTestEndCounts() | pMsg
'' Display final summary of all tests with pass/fail counts

    showSubTestResults()

    debug(" ")
    debug(" ============================================================")
    debug("* ", udec_(numberTests[cogid()]), " Tests - Pass: ", udec_(passCount[cogid()]), ", Fail: ", udec_(failCount[cogid()]))
    if numberTests[cogid()] <> passCount[cogid()] + failCount[cogid()]
      pMsg := (numberTests[cogid()] > passCount[cogid()] + failCount[cogid()]) ? @"missing" : @"extra"
      debug("*  BAD TEST COUNTS: ", udec_(numberTests[cogid()]), " <> ", udec_(passCount[cogid()] + failCount[cogid()]), " (", zstr_(pMsg), " ", udec_(abs(numberTests[cogid()] - (passCount[cogid()] + failCount[cogid()]))), " tests)")
    debug(" ============================================================")

PUB ShowMultiCogTestEndCounts() | cogIdx, totalTests, totalPass, totalFail
'' Display combined multi-cog test summary (sums across all cogs)

    showSubTestResults()

    totalTests := 0
    totalPass := 0
    totalFail := 0
    repeat cogIdx from 0 to MAX_P2_COGS - 1
        totalTests += numberTests[cogIdx]
        totalPass += passCount[cogIdx]
        totalFail += failCount[cogIdx]

    debug(" ")
    debug(" ============================================================")
    debug("* ALL COGS: ", udec_(totalTests), " Tests - Pass: ", udec_(totalPass), ", Fail: ", udec_(totalFail))
    debug(" ============================================================")

PUB setCheckCountPerTest(countTests)
'' Set the number of subtests per record/group
''
'' @param countTests - the number of checks per item tested

    subTestPer[cogid()] := countTests

' ===============================================================================
' EVALUATION METHODS -- Generic value/bool comparisons
' ===============================================================================

PUB evaluateSubValue(result, pMessage, expectedResult) | bPassed, pPassFail
'' Evaluate a sub-test value (for multiple checks within a test)
''
'' @param result - the actual result value
'' @param pMessage - pointer to description string
'' @param expectedResult - the expected value

    bPassed := result == expectedResult
    pPassFail := !bPassed ? @"Sub-FAIL" : @"pass"
    ifnot bPassed
        failCountSub[cogid()]++
    else
        passCountSub[cogid()]++
    ifnot bPassed
        debug("  Sub-Test: ", zstr_(pMessage))
        debug("  Value: ", sdec_long_(result), " (expected ", sdec_long_(expectedResult), ")")
        debug("   -> ", zstr_(pPassFail))

PUB evaluateSubValueHex(result, pMessage, expectedResult) | bPassed, pPassFail
'' Evaluate a sub-test value in hex format

    bPassed := result == expectedResult
    pPassFail := !bPassed ? @"Sub-FAIL" : @"pass"
    ifnot bPassed
        failCountSub[cogid()]++
    else
        passCountSub[cogid()]++
    ifnot bPassed
        debug("  Sub-Test: ", zstr_(pMessage))
        debug("  Value: $", uhex_long_(result), " (expected $", uhex_long_(expectedResult), ")")
        debug("   -> ", zstr_(pPassFail))

PUB evaluateSubBool(result, pMessage, expectedResult) | bPassed, pPassFail
'' Evaluate a sub-test boolean value

    bPassed := (result <> 0) == (expectedResult <> 0)
    pPassFail := !bPassed ? @"Sub-FAIL" : @"pass"
    ifnot bPassed
        failCountSub[cogid()]++
    else
        passCountSub[cogid()]++
    ifnot bPassed
        debug("  Sub-Test: ", zstr_(pMessage))
        debug("  Value: ", udec_(result <> 0), " (expected ", udec_(expectedResult <> 0), ")")
        debug("   -> ", zstr_(pPassFail))

PUB evaluateBool(result, pMessage, expectedResult) | bPassed, pPassFail
'' Evaluate a boolean result (true/false)

    bPassed := (result <> 0) == (expectedResult <> 0)
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": ", udec_(result <> 0), " (expected ", udec_(expectedResult <> 0), ")")
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": ", udec_(result <> 0))
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB recordPass()
'' Record a pass for a test that doesn't use evaluate functions

    initIfNotAlready()
    passCount[cogid()]++
    debug("   -> pass")

PUB recordFail()
'' Record a fail for a test that doesn't use evaluate functions

    initIfNotAlready()
    failCount[cogid()]++
    debug("   -> FAIL")

PUB evaluateSingleValue(result, pMessage, expectedResult) | bPassed, pPassFail
'' Evaluate a single test result value

    bPassed := result == expectedResult
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": ", sdec_long_(result), " (expected ", sdec_long_(expectedResult), ")")
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": ", sdec_long_(result))
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateSingleValueHex(result, pMessage, expectedResult) | bPassed, pPassFail
'' Evaluate a single test result value in hex

    bPassed := result == expectedResult
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": $", uhex_long_(result), " (expected $", uhex_long_(expectedResult), ")")
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": $", uhex_long_(result))
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateRange(result, pMessage, minExpected, maxExpected) | bPassed, pPassFail
'' Evaluate that result is within a range

    bPassed := result >= minExpected and result <= maxExpected
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": ", sdec_long_(result), " (expected ", sdec_long_(minExpected), " to ", sdec_long_(maxExpected), ")")
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": ", sdec_long_(result))
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateNotZero(result, pMessage) | bPassed, pPassFail
'' Evaluate that result is not zero

    bPassed := result <> 0
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": ", sdec_long_(result), " (expected non-zero)")
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": ", sdec_long_(result))
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateStringMatch(pResult, pMessage, pExpected) | bPassed, pPassFail
'' Evaluate that two strings match

    bPassed := strcomp(pResult, pExpected)
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": [", zstr_(pResult), "] (expected [", zstr_(pExpected), "])")
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": [", zstr_(pResult), "]")
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateBufferMatch(pBuffer1, pBuffer2, length, pMessage) | bPassed, pPassFail, idx, mismatchIdx
'' Evaluate that two buffers match

    bPassed := true
    mismatchIdx := -1
    repeat idx from 0 to length - 1
        if BYTE[pBuffer1][idx] <> BYTE[pBuffer2][idx]
            bPassed := false
            mismatchIdx := idx
            quit
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": mismatch at offset ", udec_(mismatchIdx))
        debug("    Got: $", uhex_(BYTE[pBuffer1][mismatchIdx]), " Expected: $", uhex_(BYTE[pBuffer2][mismatchIdx]))
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": ", udec_(length), " bytes match")
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

' ===============================================================================
' FLASH-SPECIFIC EVALUATION METHODS -- Error status and filesystem stats
' ===============================================================================

PUB evaluateSubStatus(result, pMessage, expectedResult) | ecGot, ecExpected, bPassed, pPassFail
'' Evaluate a sub-test error status with human-readable error names
''
'' @param result - the actual error code
'' @param pMessage - pointer to description string
'' @param expectedResult - the expected error code

    ecGot := dfs.string_for_error(result)
    ecExpected := dfs.string_for_error(expectedResult)
    bPassed := result == expectedResult
    pPassFail := !bPassed ? @"Sub-FAIL" : @"pass"
    ifnot bPassed
        failCountSub[cogid()]++
    else
        passCountSub[cogid()]++
    ifnot bPassed
        debug("  Status: ", zstr_(ecGot), "(", sdec_(result), "),  (expected ", zstr_(ecExpected), "(", sdec_(expectedResult), "))")
        debug("   -> ", zstr_(pPassFail))

PUB evaluateResultNegError(result, expectedResult) | ecGot, ecExpected, bPassed, pPassFail
'' Evaluate a result that may be a value (>=0) or error code (<0)
''
'' @param result - actual result (positive value or negative error)
'' @param expectedResult - expected result

    bPassed := result == expectedResult
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    if result > 0
        ifnot bPassed
            if expectedResult < 0
                ecExpected := dfs.string_for_error(expectedResult)
                debug("  Result: ", sdec_(result), " (expected ", zstr_(ecExpected), ")")
            else
                debug("  Result: ", udec_(result), " (expected ", udec_(expectedResult), ")")
            failCount[cogid()]++
        else
            debug("  Result: ", udec_(result))
            passCount[cogid()]++
    else
        ecGot := dfs.string_for_error(result)
        ecExpected := dfs.string_for_error(expectedResult)
        ifnot bPassed
            debug("   ECode: ", zstr_(ecGot), " (expected ", zstr_(ecExpected), ")")
            failCount[cogid()]++
        else
            debug("   ECode: ", zstr_(ecGot))
            passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateHandle(resultHandle, pMessage) | bPassed, pPassFail
'' Evaluate that a handle is valid (>= 0)
''
'' @param resultHandle - handle returned from open/create
'' @param pMessage - pointer to description string

    bPassed := resultHandle >= 0
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        debug("  ", zstr_(pMessage), ": ", sdec_long_(resultHandle), " (expected >= 0)")
        failCount[cogid()]++
    else
        debug("  ", zstr_(pMessage), ": ", sdec_long_(resultHandle))
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateFSStats(pMessage, expectedFileCount, expectedBlocksUsed) | blocksUsed, blocksFree, fileCount, bPassed, pPassFail
'' Report on expected vs. actual filesystem stats
''
'' @param pMessage - intro message
'' @param expectedFileCount - count of files expected
'' @param expectedBlocksUsed - count of blocks used expected

    debug("* ", zstr_(pMessage))
    blocksUsed, blocksFree, fileCount := dfs.stats(dfs.DEV_FLASH)
    debug("  # FileSystem: ", udec_(blocksUsed, blocksFree, fileCount))
    bPassed := expectedFileCount == fileCount and expectedBlocksUsed == blocksUsed
    if fileCount <> expectedFileCount
        debug("  # files: ", udec_(fileCount), " (expected ", udec_(expectedFileCount), ")")
    else
        debug("  # files: ", udec_(fileCount))
    if blocksUsed <> expectedBlocksUsed
        debug("  # blocks used: ", udec_(blocksUsed), " (expected ", udec_(expectedBlocksUsed), ")")
    else
        debug("  # blocks used: ", udec_(blocksUsed))
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        failCount[cogid()]++
    else
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateFileStats(pfilename, expectedBlockCount, expectedBytesUsed) | bytesUsed, bytesFree, blockCount, bPassed, pPassFail
'' Report on expected vs. actual file stats
''
'' @param pfilename - name of file
'' @param expectedBlockCount - size in blocks expected
'' @param expectedBytesUsed - size in bytes expected

    bytesUsed, bytesFree, blockCount := dfs.TEST_count_file_bytes(pfilename)
    if bytesUsed < 0
        debug("  # Error: ", zstr_(dfs.string_for_error(bytesUsed)))
        bPassed := false
    else
        bPassed := expectedBlockCount == blockCount and expectedBytesUsed == bytesUsed
        if blockCount <> expectedBlockCount
            debug("  # blocks: ", udec_(blockCount), " (expected ", udec_(expectedBlockCount), ")")
        else
            debug("  # blocks: ", udec_(blockCount))
        if bytesUsed <> expectedBytesUsed
            debug("  # bytes used: ", udec_(bytesUsed), " (expected ", udec_(expectedBytesUsed), ")")
        else
            debug("  # bytes used: ", udec_(bytesUsed))
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        failCount[cogid()]++
    else
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

PUB evaluateFileStatsRange(pfilename, expectedBlockCount, expectedMinBytesUsed, expectedBytesUsed) | bytesUsed, bytesFree, blockCount, maxBytesUsed, bPassed, pPassFail
'' Report file statistics against expectation with range checking
''
'' @param pfilename - address of filename zstring
'' @param expectedBlockCount - expected size of file in blocks
'' @param expectedMinBytesUsed - minimum size of file in bytes
'' @param expectedBytesUsed - expected size of file in bytes

    bytesUsed, bytesFree, blockCount := dfs.TEST_count_file_bytes(pfilename)
    maxBytesUsed := dfs.BYTES_IN_HEAD_BLOCK
    maxBytesUsed += (dfs.BYTES_IN_BODY_BLOCK * (expectedBlockCount - 1))
    if bytesUsed < 0
        debug("  # Error: ", zstr_(dfs.string_for_error(bytesUsed)))
        bPassed := false
    else
        bPassed := expectedBlockCount == blockCount and bytesUsed >= expectedMinBytesUsed and bytesUsed <= maxBytesUsed
        if blockCount <> expectedBlockCount
            debug("  # blocks: ", udec_(blockCount), " (expected ", udec_(expectedBlockCount), ")")
        else
            debug("  # blocks: ", udec_(blockCount))
        if bytesUsed < expectedMinBytesUsed or bytesUsed > maxBytesUsed
            debug("  # bytes used: ", udec_(bytesUsed), " (expected ", udec_(expectedBytesUsed), " [", udec_(expectedMinBytesUsed), "-", udec_(maxBytesUsed), "])")
        else
            debug("  # bytes used: ", udec_(bytesUsed), ", ", udec(expectedBytesUsed))
    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        failCount[cogid()]++
    else
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

' ===============================================================================
' FLASH DIAGNOSTIC METHODS -- Display filesystem information
' ===============================================================================

PUB showChipAndDriverVersion() | sn_hi, sn_lo
'' Display Flash chip serial number and driver version

    sn_hi, sn_lo := dfs.serial_number(dfs.DEV_FLASH)
    debug("  Flash Serial: $", uhex_long_(sn_hi), "_$", uhex_long_(sn_lo))
    debug("  Driver Version: ", udec_(dfs.version(dfs.DEV_FLASH)))

PUB showError(pCaller, errorCode)
'' Display an error with human-readable name
''
'' @param pCaller - pointer to caller name string
'' @param errorCode - error code to display

    debug("EEEE ", zstr_(pCaller), " error: ", zstr_(dfs.string_for_error(errorCode)))

PUB ShowStats() | blocksUsed, blocksFree, fileCount
'' Display filesystem stats

    blocksUsed, blocksFree, fileCount := dfs.stats(dfs.DEV_FLASH)
    debug(udec(blocksUsed, blocksFree, fileCount))

PUB showFileDetails(pFilename) | bytesUsed, bytes_free, block_count
'' Display file details (bytes, free, blocks)
''
'' @param pFilename - pointer to filename string

    debug(" ")
    bytesUsed, bytes_free, block_count := dfs.TEST_count_file_bytes(pFilename)
    if bytesUsed < 0
        debug("  File: [", zstr_(pFilename), "]")
        debug("  # Error: ", zstr_(dfs.string_for_error(bytesUsed)))
    else
        debug("  File: [", zstr_(pFilename), "], ", udec(bytesUsed, bytes_free, block_count))

PUB showFiles() | blockID, byteCount, byte Buff[30], BlocksUsed
'' Display all files on Flash device

    debug(" ")
    debug("  All Files:")
    blockID := 0
    repeat
        dfs.directory(dfs.DEV_FLASH, @blockID, @filename, @byteCount)
        BlocksUsed := blockCountForFileSize(byteCount)
        if filename[0]
            ReadFile(@filename, @Buff, 30)
            if isZstr(@Buff, 30)
                debug(zstr_(@filename), udec(byteCount, blockID, BlocksUsed), zstr(@Buff))
            else
                debug(zstr_(@filename), udec(byteCount, blockID, BlocksUsed), ", @Buff={binary data}")
        else
            quit

PUB ensureEmptyDirectory() | blockID, byteCount, bPassed, pPassFail
'' Validate that Flash directory is empty

    blockID := 0
    dfs.directory(dfs.DEV_FLASH, @blockID, @filename, @byteCount)
    bPassed := true
    if filename[0]
        bPassed := false
    pPassFail := !bPassed ? @"FAIL" : @"pass"

    ifnot bPassed
        debug("  # Error Found file: [", zstr_(@filename), "] (expected: no files)")
        failCount[cogid()]++
    else
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

' ===============================================================================
' FLASH FILE SIZE CALCULATION UTILITIES
' ===============================================================================

PUB blockCountForFileSize(fileSizeInBytes) : blockCount | remainingSize, overflowBodyCount
'' Return number of blocks needed for given file size
''
'' @param fileSizeInBytes - total file size
'' @returns blockCount - number of 4KB blocks required

    blockCount := 1 ' head block
    if fileSizeInBytes > dfs.BYTES_IN_HEAD_BLOCK
        remainingSize := fileSizeInBytes - dfs.BYTES_IN_HEAD_BLOCK
        blockCount += remainingSize / dfs.BYTES_IN_BODY_BLOCK
        overflowBodyCount := remainingSize +// dfs.BYTES_IN_BODY_BLOCK
        if overflowBodyCount > 0
            blockCount++

PUB bytesAllocatedFor(sizeInBytes) : maxAllocationBytes | bodyBlocks
'' Return max allocation size for circular file
''
'' @param sizeInBytes - requested file size
'' @returns maxAllocationBytes - actual bytes allocated (rounded up to block boundary)

    maxAllocationBytes := dfs.BYTES_IN_HEAD_BLOCK
    if sizeInBytes > dfs.BYTES_IN_HEAD_BLOCK
        bodyBlocks := ((sizeInBytes - dfs.BYTES_IN_HEAD_BLOCK) + (dfs.BYTES_IN_BODY_BLOCK - 1)) / dfs.BYTES_IN_BODY_BLOCK
        maxAllocationBytes += bodyBlocks * dfs.BYTES_IN_BODY_BLOCK

PUB bytesAllocatedInBlocks(numberBlocks) : sizeInBytes
'' Return max number of bytes stored in given number of blocks
''
'' @param numberBlocks - number of blocks
'' @returns sizeInBytes - maximum bytes that fit

    sizeInBytes := dfs.BYTES_IN_HEAD_BLOCK
    if numberBlocks > 1
        sizeInBytes += (numberBlocks - 1) * dfs.BYTES_IN_BODY_BLOCK

PUB bytesInLastBlock(totalBytes) : bytesInLast
'' Calculate bytes stored in the last block of a file
''
'' @param totalBytes - total file size
'' @returns bytesInLast - bytes in the final block

    bytesInLast := totalBytes
    if totalBytes > dfs.BYTES_IN_HEAD_BLOCK
        bytesInLast -= dfs.BYTES_IN_HEAD_BLOCK
    if bytesInLast > dfs.BYTES_IN_BODY_BLOCK
        bytesInLast := bytesInLast +// dfs.BYTES_IN_BODY_BLOCK

PUB checkMatchingEntries(pDirEntries) | blockID, byteCount, bPassed, pPassFail, refFileCount, foundFileCount, pCurrRefDir, pRefFilename, refByteCount, refBlocks, calcBlocks, bBadEntry
'' Verify directory contents match expected entries
'' Structure: LONG[ptr_filename, byte_count, block_count, ...] terminated by ptr=0
{
        ' structure for directory checking
        ' (pDirEntries := @dirEntr1)
dirEntr1        LONG    @testfile1     ' pointer to filename
fileBytes1      LONG    10             ' length in bytes
fileBlocks1     LONG    1              ' number of blocks allocated
dirEntr2        LONG    @testfile2     ' pointer to filename
fileBytes2      LONG    20             ' length in bytes
fileBlocks2     LONG    1              ' number of blocks allocated
dirEnd          LONG    0              ' ptr = NULL, no more entries
}
    bPassed := true
    pCurrRefDir := pDirEntries
    refFileCount := 0
    foundFileCount := 0
    blockID := 0
    repeat
        pRefFilename := LONG[pCurrRefDir][0]
        refByteCount := LONG[pCurrRefDir][1]
        refBlocks    := LONG[pCurrRefDir][2]
        dfs.directory(dfs.DEV_FLASH, @blockID, @filename, @byteCount)
        if pRefFilename == 0
        else
            refFileCount++
        if filename[0] == 0
        else
            foundFileCount++
        if pRefFilename == 0 && filename[0] == 0
            quit

        if pRefFilename <> 0 && filename[0] <> 0
            calcBlocks := blockCountForFileSize(byteCount)
            bBadEntry := false
            if strcomp(@filename, pRefFilename) == false
                debug(" - BAD filenames!")
                bBadEntry := true
            if byteCount <> refByteCount
                debug(" - BAD byte count!")
                bBadEntry := true
            if calcBlocks <> refBlocks
                debug(" - BAD block count!")
                bBadEntry := true
            if bBadEntry
                debug("  #    Found: [", zstr_(@filename), "], bytes=(", udec_(byteCount), "), blocks(", udec_(calcBlocks), ")")
                debug("  # Expected: [", zstr_(pRefFilename), "], bytes=(", udec_(refByteCount), "), blocks(", udec_(refBlocks), ")")
                bPassed := false
        if pRefFilename <> 0
            pCurrRefDir := @LONG[pCurrRefDir][3]

    if foundFileCount <> refFileCount
        debug("  # Found ", udec_(foundFileCount), " files (expected ", udec_(refFileCount), ")")
        bPassed := false

    pPassFail := !bPassed ? @"FAIL" : @"pass"
    ifnot bPassed
        failCount[cogid()]++
    else
        passCount[cogid()]++
    debug("   -> ", zstr_(pPassFail))

' ===============================================================================
' FILE TYPE UTILITIES
' ===============================================================================

PUB isBinaryFile(pFilename) : bIsBinaryStatus | pFileType
'' Check if filename has .bin extension

    pFileType := fileTypePtr(pFilename)
    bIsBinaryStatus := strcomp(pFileType, @"bin")

PUB isStringsFile(pFilename) : bIsStringStatus | pFileType
'' Check if filename has .zstr extension

    pFileType := fileTypePtr(pFilename)
    bIsStringStatus := strcomp(pFileType, @"zstr")

PUB fileTypePtr(pFilename) : pFileType | byteIdx
'' Get pointer to file extension portion of filename

    pFileType := 0
    repeat byteIdx from 0 to strsize(pFilename) - 1
        if pFilename[byteIdx] == "."
            pFileType := @pFilename[byteIdx + 1]
            quit

PUB isZstr(pBffr, count) : bIsStringStatus | bytIdx
'' Check if buffer contains a valid zero-terminated string

    bIsStringStatus := false
    repeat bytIdx from 0 to count - 1
        if pBffr[bytIdx] == 0
            bIsStringStatus := true
            quit
        if pBffr[bytIdx] < ASCII_PRINTABLE_MIN or pBffr[bytIdx] > ASCII_PRINTABLE_MAX
            quit

PUB ReadFile(pFilename, pStr, maxlen) | handle, byteCount
'' Read a string file into buffer
''
'' @param pFilename - pointer to filename
'' @param pStr - pointer to output buffer
'' @param maxlen - max bytes to read

    if isStringsFile(pFilename)
        handle := dfs.open(dfs.DEV_FLASH, pFilename, dfs.FILEMODE_READ)
        if handle >= 0
            byteCount := dfs.rd_str(handle, pStr, maxlen)
            if byteCount < 0
                showError(@"rd_str()", byteCount)
            dfs.close(handle)
    else
        bytefill(pStr, $ff, maxlen)

' ===============================================================================
' MEMORY DUMP UTILITIES
' ===============================================================================

PUB dbgMemDump(pMessage, pBytes, lenBytes) | rowCount, rowLen, pCurrByte, lastRowByteCount, bytesSoFar, offset
'' Dump memory contents in hex format with offset prefix

    if pMessage
        debug("** ", zstr_(pMessage), ":")

    offset := 0
    rowCount := lenBytes / HEXDUMP_LINE_BYTES
    lastRowByteCount := lenBytes - (rowCount * HEXDUMP_LINE_BYTES)
    pCurrByte := pBytes
    bytesSoFar := 0

    if rowCount > 0
        repeat rowCount
            dbgMemDumpRow(pCurrByte, HEXDUMP_LINE_BYTES, offset)
            offset += HEXDUMP_LINE_BYTES
            pCurrByte += HEXDUMP_LINE_BYTES
            bytesSoFar += HEXDUMP_LINE_BYTES

    if bytesSoFar < lenBytes
        dbgMemDumpRow(pCurrByte, lastRowByteCount, offset)

PUB dbgMemDumpAbs(pMessage, pBytes, lenBytes) | rowCount, rowLen, pCurrByte, lastRowByteCount, bytesSoFar
'' Dump rows of hex values with absolute address prefix

    if pMessage
        debug("** ", zstr_(pMessage), ":")

    rowCount := lenBytes / HEXDUMP_LINE_BYTES
    lastRowByteCount := lenBytes - (rowCount * HEXDUMP_LINE_BYTES)
    pCurrByte := pBytes
    bytesSoFar := 0

    if rowCount > 0
        repeat rowCount
            debug(" ", uhex_long_(pCurrByte), ": ", uhex_byte_array_(pCurrByte, HEXDUMP_LINE_BYTES))
            pCurrByte += HEXDUMP_LINE_BYTES
            bytesSoFar += HEXDUMP_LINE_BYTES

    if bytesSoFar < lenBytes
        debug(" ", uhex_long_(pCurrByte), ": ", uhex_byte_array_(pCurrByte, lastRowByteCount))

PRI dbgMemDumpRow(pBytes, lenBytes, offset)
' Emit a single row of memory dump

    debug(" ", uhex_long_(offset), ": ", uhex_byte_array_(pBytes, lenBytes))

' ===============================================================================
' TEST DATA GENERATION UTILITIES
' ===============================================================================

PUB fillBufferWithPattern(pBuffer, length, startValue) | idx
'' Fill buffer with incrementing pattern (0-255 repeating)

    repeat idx from 0 to length - 1
        BYTE[pBuffer][idx] := (startValue + idx) & $FF

PUB fillBufferWithValue(pBuffer, length, value) | idx
'' Fill buffer with constant value

    bytefill(pBuffer, value, length)

PUB fillBufferWithRandom(pBuffer, length) | idx
'' Fill buffer with random values

    repeat idx from 0 to length - 1
        BYTE[pBuffer][idx] := getrnd() & $FF

PUB verifyBufferPattern(pBuffer, length, startValue) : bMatch | idx, expected
'' Verify buffer contains incrementing pattern

    bMatch := true
    repeat idx from 0 to length - 1
        expected := (startValue + idx) & $FF
        if BYTE[pBuffer][idx] <> expected
            bMatch := false
            debug("  Pattern mismatch at ", udec_(idx), ": got $", uhex_(BYTE[pBuffer][idx]), " expected $", uhex_(expected))
            quit

PUB verifyBufferValue(pBuffer, length, value) : bMatch | idx
'' Verify buffer contains constant value

    bMatch := true
    repeat idx from 0 to length - 1
        if BYTE[pBuffer][idx] <> value
            bMatch := false
            debug("  Value mismatch at ", udec_(idx), ": got $", uhex_(BYTE[pBuffer][idx]), " expected $", uhex_(value))
            quit

' ===============================================================================
' BUFFER OVERFLOW GUARD UTILITIES
' ===============================================================================

PUB initGuard(pGuardStart)
'' Fill guard zone with sentinel bytes

    bytefill(pGuardStart, GUARD_BYTE, GUARD_SIZE)

PUB checkGuard(pGuardStart, pMessage) : bIntact | idx
'' Verify all guard bytes are intact

    bIntact := true
    repeat idx from 0 to GUARD_SIZE - 1
        if BYTE[pGuardStart][idx] <> GUARD_BYTE
            bIntact := false
            debug("  GUARD VIOLATION: ", zstr_(pMessage), " at offset ", udec_(idx), ": $", uhex_byte_(BYTE[pGuardStart][idx]), " (expected $CC)")
            quit
    ifnot bIntact
        debug("   -> GUARD FAIL")

PUB initAndCheckGuard(pGuardStart, pMessage) : bIntact
'' Combined check + re-init for use inside loops

    bIntact := checkGuard(pGuardStart, pMessage)
    initGuard(pGuardStart)

' ===============================================================================
' CRC UTILITY
' ===============================================================================

PUB record_crc(p_record_buffer, record_length) : crc
'' Calculate CRC-32 of a record buffer (excludes last 4 bytes where CRC is stored).
'' Uses P2 hardware GETCRC matching the reference flash_fs test utilities.
''
'' @param p_record_buffer - pointer to record data
'' @param record_length - total record size in bytes (CRC field is last 4 bytes)
'' @returns crc - CRC-32 value

  crc := getcrc(p_record_buffer, $AD0424F3 rev 31, record_length - 4)

con { license }

