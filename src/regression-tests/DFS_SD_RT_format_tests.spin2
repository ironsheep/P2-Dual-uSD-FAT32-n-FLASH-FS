'' =================================================================================================
''
''   File....... DFS_SD_RT_format_tests.spin2
''   Purpose.... Regression tests for SD card FAT32 formatter - Cross-OS Compatibility
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... JAN 2026
''   Updated.... 16 JAN 2026
''
'' =================================================================================================
''
''  This test formats a blank SD card and verifies the FAT32 structure is correct for
''  cross-OS compatibility (Windows, macOS, Linux).
''
''  REQUIREMENTS:
''    - A BLANK SD card (all data will be erased!)
''    - Card must be at least 64MB for FAT32
''
''  WARNING: This test ERASES ALL DATA on the card!
''
'' =================================================================================================

CON

    _CLKFREQ        = 350_000_000
    DEBUG_BAUD      = 2_000_000

    ' P2 Edge module SD slot pins
    SD_CS   = 60
    SD_MOSI = 59
    SD_MISO = 58
    SD_SCK  = 61

    ' External SD header (base pin 16)
    'SD_CS   = 20
    'SD_MOSI = 19
    'SD_MISO = 18
    'SD_SCK  = 21

    ' Expected FAT32 constants
    MBR_SIGNATURE       = $AA55
    PARTITION_TYPE_FAT32_LBA = $0C
    FSINFO_SIG1         = $41615252  ' "RRaA"
    FSINFO_SIG2         = $61417272  ' "rrAa"
    FSINFO_TRAIL_SIG    = $AA550000  ' Trail signature (stored little-endian)
    FAT32_MEDIA_TYPE    = $F8        ' Fixed disk
    EXT_BOOT_SIG        = $29        ' Extended boot signature
    PARTITION_START     = 8192       ' 4MB alignment

    ' Named constants (Rule 4 - no magic numbers)
    GUARD_SIZE           = 16
    BYTES_PER_SECTOR     = 512
    SECTORS_PER_MB       = 2048

    ' MBR structure offsets
    MBR_SIG_OFFSET       = $1FE        ' Boot signature (WORD)
    MBR_PART_BOOT_OFFSET = $1BE        ' Partition 1 boot flag
    MBR_PART_TYPE_OFFSET = $1C2        ' Partition 1 type
    MBR_PART_LBA_OFFSET  = $1C6        ' Partition 1 LBA start (LONG)
    MBR_PART_SIZE_OFFSET = $1CA        ' Partition 1 size in sectors (LONG)
    BOOT_FLAG_INACTIVE   = $00
    BOOT_FLAG_ACTIVE     = $80

    ' VBR structure offsets
    VBR_JUMP_EB          = $EB         ' Short jump
    VBR_JUMP_E9          = $E9         ' Near jump
    VBR_OEM_OFFSET       = $03         ' OEM name (8 bytes)
    VBR_BPS_OFFSET       = $0B         ' Bytes per sector (WORD)
    VBR_SPC_OFFSET       = $0D         ' Sectors per cluster (BYTE)
    VBR_RSVD_OFFSET      = $0E         ' Reserved sectors (WORD)
    VBR_NUMFATS_OFFSET   = $10         ' Number of FATs (BYTE)
    VBR_ROOTENT_OFFSET   = $11         ' Root entry count (WORD)
    VBR_TOTSEC16_OFFSET  = $13         ' Total sectors 16-bit (WORD)
    VBR_MEDIA_OFFSET     = $15         ' Media type (BYTE)
    VBR_FATSZ16_OFFSET   = $16         ' FAT size 16-bit (WORD)
    VBR_HIDDEN_OFFSET    = $1C         ' Hidden sectors (LONG)
    VBR_TOTSEC32_OFFSET  = $20         ' Total sectors 32-bit (LONG)
    VBR_FATSZ32_OFFSET   = $24         ' FAT32 sectors per FAT (LONG)
    VBR_ROOTCLUS_OFFSET  = $2C         ' Root cluster number (LONG)
    VBR_FSINFO_OFFSET    = $30         ' FSInfo sector location (WORD)
    VBR_BKBOOT_OFFSET    = $32         ' Backup boot sector (WORD)
    VBR_EXTBOOTSIG_OFFSET = $42        ' Extended boot signature (BYTE)
    VBR_FSTYPE_OFFSET    = $52         ' File system type string (8 bytes)
    OEM_NAME_LENGTH      = 8
    MAX_SPC              = 128         ' Max sectors per cluster
    RESERVED_SECTORS     = 32
    NUM_FATS             = 2
    ROOT_CLUSTER         = 2
    FSINFO_SECTOR        = 1
    BACKUP_VBR_SECTOR    = 6
    BACKUP_FSINFO_SECTOR = 7

    ' FSInfo structure offsets
    FSINFO_SIG2_OFFSET   = 484
    FSINFO_TRAIL_OFFSET  = $1FC
    FSINFO_FREE_OFFSET   = 488
    FSINFO_NEXT_OFFSET   = 492
    FIRST_FREE_CLUSTER   = 3           ' First free after root
    FAT_UNKNOWN          = $FFFFFFFF

    ' FAT table entries
    FAT_MEDIA_ENTRY      = $0FFFFFF8   ' FAT[0] media type
    FAT_EOC              = $0FFFFFFF   ' End of chain marker
    FAT_ENTRY_SIZE       = 4           ' Bytes per FAT32 entry

    ' Directory entry structure
    DIR_ATTR_OFFSET      = $0B
    ATTR_VOLUME_LABEL    = $08
    LABEL_LENGTH         = 11
    DIR_ENTRY_SIZE       = 32
    SECOND_ENTRY_OFFSET  = $20         ' Offset of 2nd entry in sector
    THIRD_ENTRY_OFFSET   = $40         ' Start after 2 entries
    END_OF_DIR_MARKER    = $00
    DELETED_ENTRY_MARKER = $E5

    ' ASCII
    ASCII_SPACE          = $20
    ASCII_TILDE          = $7E

#ifdef __SPINTOOLS__
#define SD_INCLUDE_ALL
#define SD_INCLUDE_STACK_CHECK
#elseifdef __FLEXSPIN__
#define SD_INCLUDE_ALL
#pragma exportdef SD_INCLUDE_ALL
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#else
'' Enable full driver features for format testing
#pragma exportdef SD_INCLUDE_ALL
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#endif

OBJ

    utils : "DFS_RT_utilities"
    fmt   : "isp_format_utility"
    dfs   : "dual_sd_fat32_flash_fs"

VAR

    BYTE    sectorBuf[BYTES_PER_SECTOR]
    BYTE    sectorBuf_guard[GUARD_SIZE]
    BYTE    sectorBuf2[BYTES_PER_SECTOR]
    BYTE    sectorBuf2_guard[GUARD_SIZE]
    LONG    sectorsPerFat
    LONG    totalSectors
    LONG    partitionStart

PUB go() | workerCog, fieldValue, dataStart, fat1Start, fat2Start, idx, mismatch, cardSectors
'' Main entry point for FAT32 format regression tests
''
'' WARNING: This test ERASES ALL DATA on the card!
'' Tests FAT32 formatting and cross-OS compatibility verification

    debug("==============================================")
    debug("  Dual FS (SD) - FAT32 Format Tests")
    debug("  (Cross-OS Compatibility Verification)")
    debug("==============================================")
    debug(" ")
    debug("WARNING: This test will ERASE ALL DATA on the card!")
    debug(" ")

    ' ----------------------------------------
    ' TEST 1: Format card with default label
    ' ----------------------------------------
    utils.startTestGroup(@"Format Operation")
    utils.startTest(@"Format card with default label")

    fieldValue := fmt.format()
    utils.evaluateSingleValue(fieldValue, @"format() returns SUCCESS", dfs.SUCCESS)

    ' Release format utility's worker cog before using dfs driver for verification
    fmt.stop()

    ' Initialize unified driver worker cog
    workerCog := dfs.init()

    ' Initialize card for raw access (no filesystem mount)
    fieldValue := dfs.initCardOnly()
    if fieldValue == dfs.SUCCESS

        cardSectors := dfs.cardSizeSectors()
        debug("  Card size: ", udec(cardSectors), " sectors (", udec(cardSectors / SECTORS_PER_MB), " MB)")

        ' ========================================
        ' MBR VERIFICATION (Sector 0)
        ' ========================================
        utils.startTestGroup(@"MBR Verification")

        utils.initGuard(@sectorBuf_guard)
        dfs.readSectorRaw(0, @sectorBuf)
        utils.checkGuard(@sectorBuf_guard, @"buf guard")

        utils.startTest(@"MBR boot signature")
        fieldValue := WORD[@sectorBuf + MBR_SIG_OFFSET]
        utils.evaluateBool(fieldValue == MBR_SIGNATURE, @"$AA55 at offset $1FE", TRUE)

        utils.startTest(@"Partition 1 bootable flag")
        fieldValue := sectorBuf[MBR_PART_BOOT_OFFSET]
        utils.evaluateBool(fieldValue == BOOT_FLAG_INACTIVE OR fieldValue == BOOT_FLAG_ACTIVE, @"$00 or $80", TRUE)

        utils.startTest(@"Partition 1 type")
        fieldValue := sectorBuf[MBR_PART_TYPE_OFFSET]
        utils.evaluateBool(fieldValue == PARTITION_TYPE_FAT32_LBA, @"$0C (FAT32 LBA)", TRUE)

        utils.startTest(@"Partition 1 start sector")
        partitionStart := LONG[@sectorBuf + MBR_PART_LBA_OFFSET]
        utils.evaluateBool(partitionStart == PARTITION_START, @"8192 (4MB aligned)", TRUE)

        utils.startTest(@"Partition 1 size")
        fieldValue := LONG[@sectorBuf + MBR_PART_SIZE_OFFSET]
        ' Partition size should be card size minus partition start
        utils.evaluateBool(fieldValue > 0, @"Size > 0", TRUE)
        debug("  Partition size: ", udec(fieldValue), " sectors")

        ' ========================================
        ' VBR VERIFICATION (Primary Boot Sector)
        ' ========================================
        utils.startTestGroup(@"VBR Verification")

        utils.initGuard(@sectorBuf_guard)
        dfs.readSectorRaw(partitionStart, @sectorBuf)
        utils.checkGuard(@sectorBuf_guard, @"buf guard")

        utils.startTest(@"VBR jump instruction")
        ' Must start with $EB xx $90 or $E9 xx xx
        fieldValue := sectorBuf[0]
        utils.evaluateBool(fieldValue == VBR_JUMP_EB OR fieldValue == VBR_JUMP_E9, @"Jump ($EB or $E9)", TRUE)

        utils.startTest(@"VBR boot signature")
        fieldValue := WORD[@sectorBuf + MBR_SIG_OFFSET]
        utils.evaluateBool(fieldValue == MBR_SIGNATURE, @"$AA55 at offset $1FE", TRUE)

        utils.startTest(@"OEM name present")
        ' OEM name at offset $03, should be printable ASCII
        fieldValue := sectorBuf[VBR_OEM_OFFSET]
        utils.evaluateBool(fieldValue >= ASCII_SPACE AND fieldValue <= ASCII_TILDE, @"Printable OEM name", TRUE)
        debug("  OEM name: ", lstr_(@sectorBuf + VBR_OEM_OFFSET, OEM_NAME_LENGTH))

        utils.startTest(@"Bytes per sector")
        fieldValue := WORD[@sectorBuf + VBR_BPS_OFFSET]
        utils.evaluateBool(fieldValue == BYTES_PER_SECTOR, @"512 bytes/sector", TRUE)

        utils.startTest(@"Sectors per cluster")
        fieldValue := sectorBuf[VBR_SPC_OFFSET]
        ' Must be power of 2: 1, 2, 4, 8, 16, 32, 64, 128
        utils.evaluateBool(fieldValue >= 1 AND fieldValue <= MAX_SPC AND (fieldValue & (fieldValue - 1)) == 0, @"Power of 2", TRUE)
        debug("  Sectors per cluster: ", udec(fieldValue))

        utils.startTest(@"Reserved sectors")
        fieldValue := WORD[@sectorBuf + VBR_RSVD_OFFSET]
        utils.evaluateBool(fieldValue == RESERVED_SECTORS, @"32 reserved sectors", TRUE)

        utils.startTest(@"Number of FATs")
        fieldValue := sectorBuf[VBR_NUMFATS_OFFSET]
        utils.evaluateBool(fieldValue == NUM_FATS, @"2 FATs", TRUE)

        utils.startTest(@"Root entry count (must be 0 for FAT32)")
        fieldValue := WORD[@sectorBuf + VBR_ROOTENT_OFFSET]
        utils.evaluateBool(fieldValue == 0, @"0 (FAT32 requirement)", TRUE)

        utils.startTest(@"Total sectors 16-bit (must be 0 for FAT32)")
        fieldValue := WORD[@sectorBuf + VBR_TOTSEC16_OFFSET]
        utils.evaluateBool(fieldValue == 0, @"0 (FAT32 uses 32-bit)", TRUE)

        utils.startTest(@"Media type")
        fieldValue := sectorBuf[VBR_MEDIA_OFFSET]
        utils.evaluateBool(fieldValue == FAT32_MEDIA_TYPE, @"$F8 (fixed disk)", TRUE)

        utils.startTest(@"FAT size 16-bit (must be 0 for FAT32)")
        fieldValue := WORD[@sectorBuf + VBR_FATSZ16_OFFSET]
        utils.evaluateBool(fieldValue == 0, @"0 (FAT32 uses 32-bit)", TRUE)

        utils.startTest(@"Hidden sectors match partition start")
        fieldValue := LONG[@sectorBuf + VBR_HIDDEN_OFFSET]
        utils.evaluateBool(fieldValue == partitionStart, @"Matches partition start", TRUE)

        utils.startTest(@"Total sectors 32-bit")
        totalSectors := LONG[@sectorBuf + VBR_TOTSEC32_OFFSET]
        utils.evaluateBool(totalSectors > 0, @"Total sectors > 0", TRUE)
        debug("  Total sectors: ", udec(totalSectors))

        utils.startTest(@"FAT32 sectors per FAT")
        sectorsPerFat := LONG[@sectorBuf + VBR_FATSZ32_OFFSET]
        utils.evaluateBool(sectorsPerFat > 0, @"Sectors per FAT > 0", TRUE)
        debug("  Sectors per FAT: ", udec(sectorsPerFat))

        utils.startTest(@"Root cluster number")
        fieldValue := LONG[@sectorBuf + VBR_ROOTCLUS_OFFSET]
        utils.evaluateBool(fieldValue == ROOT_CLUSTER, @"Root cluster = 2", TRUE)

        utils.startTest(@"FSInfo sector location")
        fieldValue := WORD[@sectorBuf + VBR_FSINFO_OFFSET]
        utils.evaluateBool(fieldValue == FSINFO_SECTOR, @"FSInfo at sector 1", TRUE)

        utils.startTest(@"Backup boot sector location")
        fieldValue := WORD[@sectorBuf + VBR_BKBOOT_OFFSET]
        utils.evaluateBool(fieldValue == BACKUP_VBR_SECTOR, @"Backup at sector 6", TRUE)

        utils.startTest(@"Extended boot signature")
        fieldValue := sectorBuf[VBR_EXTBOOTSIG_OFFSET]
        utils.evaluateBool(fieldValue == EXT_BOOT_SIG, @"$29", TRUE)

        utils.startTest(@"File system type string")
        ' At offset $52, should be "FAT32   " (8 bytes)
        fieldValue := TRUE
        if sectorBuf[VBR_FSTYPE_OFFSET] <> "F" OR sectorBuf[VBR_FSTYPE_OFFSET + 1] <> "A" OR sectorBuf[VBR_FSTYPE_OFFSET + 2] <> "T" OR sectorBuf[VBR_FSTYPE_OFFSET + 3] <> "3" OR sectorBuf[VBR_FSTYPE_OFFSET + 4] <> "2"
            fieldValue := FALSE
        utils.evaluateBool(fieldValue, @"FAT32 string at $52", TRUE)
        debug("  FS Type: ", lstr_(@sectorBuf + VBR_FSTYPE_OFFSET, OEM_NAME_LENGTH))

        ' ========================================
        ' BACKUP VBR VERIFICATION
        ' ========================================
        utils.startTestGroup(@"Backup VBR Verification")

        utils.startTest(@"Backup VBR matches primary")
        ' Read backup boot sector at partition + 6
        utils.initGuard(@sectorBuf2_guard)
        dfs.readSectorRaw(partitionStart + BACKUP_VBR_SECTOR, @sectorBuf2)
        utils.checkGuard(@sectorBuf2_guard, @"buf2 guard")

        ' Compare the two boot sectors
        mismatch := false
        repeat idx from 0 to BYTES_PER_SECTOR - 1
            if sectorBuf[idx] <> sectorBuf2[idx]
                mismatch := true
                debug("  Mismatch at offset ", udec(idx), ": $", uhex_(sectorBuf[idx]), " vs $", uhex_(sectorBuf2[idx]))
                quit
        utils.evaluateBool(mismatch == false, @"Primary and backup match", TRUE)

        ' ========================================
        ' FSINFO VERIFICATION
        ' ========================================
        utils.startTestGroup(@"FSInfo Verification")

        utils.initGuard(@sectorBuf_guard)
        dfs.readSectorRaw(partitionStart + FSINFO_SECTOR, @sectorBuf)
        utils.checkGuard(@sectorBuf_guard, @"buf guard")

        utils.startTest(@"FSInfo lead signature")
        fieldValue := LONG[@sectorBuf + 0]
        utils.evaluateBool(fieldValue == FSINFO_SIG1, @"$41615252 (RRaA)", TRUE)

        utils.startTest(@"FSInfo structure signature")
        fieldValue := LONG[@sectorBuf + FSINFO_SIG2_OFFSET]
        utils.evaluateBool(fieldValue == FSINFO_SIG2, @"$61417272 (rrAa)", TRUE)

        utils.startTest(@"FSInfo trail signature")
        fieldValue := LONG[@sectorBuf + FSINFO_TRAIL_OFFSET]
        utils.evaluateBool(fieldValue == FSINFO_TRAIL_SIG, @"$AA550000 at $1FC", TRUE)

        utils.startTest(@"FSInfo free cluster count")
        fieldValue := LONG[@sectorBuf + FSINFO_FREE_OFFSET]
        ' Can be $FFFFFFFF (unknown) or actual count
        utils.evaluateBool(fieldValue <> 0, @"Free count set", TRUE)
        debug("  Free clusters: ", udec(fieldValue))

        utils.startTest(@"FSInfo next free cluster hint")
        fieldValue := LONG[@sectorBuf + FSINFO_NEXT_OFFSET]
        ' Should be 3 (first free after root) or $FFFFFFFF (unknown)
        utils.evaluateBool(fieldValue == FIRST_FREE_CLUSTER OR fieldValue == FAT_UNKNOWN, @"Next free = 3 or unknown", TRUE)
        debug("  Next free hint: ", udec(fieldValue))

        utils.startTest(@"Backup FSInfo matches primary")
        utils.initGuard(@sectorBuf2_guard)
        dfs.readSectorRaw(partitionStart + BACKUP_FSINFO_SECTOR, @sectorBuf2)
        utils.checkGuard(@sectorBuf2_guard, @"buf2 guard")
        mismatch := false
        repeat idx from 0 to BYTES_PER_SECTOR - 1
            if sectorBuf[idx] <> sectorBuf2[idx]
                mismatch := true
                quit
        utils.evaluateBool(mismatch == false, @"Primary and backup FSInfo match", TRUE)

        ' ========================================
        ' FAT TABLE VERIFICATION
        ' ========================================
        utils.startTestGroup(@"FAT Table Verification")

        fat1Start := partitionStart + RESERVED_SECTORS
        fat2Start := fat1Start + sectorsPerFat

        ' Read FAT1 first sector for multiple tests
        utils.initGuard(@sectorBuf_guard)
        dfs.readSectorRaw(fat1Start, @sectorBuf)
        utils.checkGuard(@sectorBuf_guard, @"buf guard")

        utils.startTest(@"FAT[0] media type entry")
        fieldValue := LONG[@sectorBuf + 0]
        utils.evaluateBool(fieldValue == FAT_MEDIA_ENTRY, @"FAT[0] = $0FFFFFF8", TRUE)

        utils.startTest(@"FAT[1] end of chain marker")
        fieldValue := LONG[@sectorBuf + 1 * FAT_ENTRY_SIZE]
        utils.evaluateBool(fieldValue == FAT_EOC, @"FAT[1] = $0FFFFFFF (EOC)", TRUE)

        utils.startTest(@"FAT[2] root directory EOC")
        fieldValue := LONG[@sectorBuf + 2 * FAT_ENTRY_SIZE]
        utils.evaluateBool(fieldValue == FAT_EOC, @"FAT[2] = $0FFFFFFF (root EOC)", TRUE)

        utils.startTest(@"FAT[3] first free cluster")
        fieldValue := LONG[@sectorBuf + 3 * FAT_ENTRY_SIZE]
        utils.evaluateBool(fieldValue == 0, @"FAT[3] = 0 (free)", TRUE)

        utils.startTest(@"FAT2 mirrors FAT1 (first sector)")
        utils.initGuard(@sectorBuf2_guard)
        dfs.readSectorRaw(fat2Start, @sectorBuf2)
        utils.checkGuard(@sectorBuf2_guard, @"buf2 guard")
        mismatch := false
        repeat idx from 0 to BYTES_PER_SECTOR - 1
            if sectorBuf[idx] <> sectorBuf2[idx]
                mismatch := true
                debug("  FAT mismatch at offset ", udec(idx))
                quit
        utils.evaluateBool(mismatch == false, @"FAT1 and FAT2 identical", TRUE)

        utils.startTest(@"FAT1 second sector is zeroed")
        utils.initGuard(@sectorBuf_guard)
        dfs.readSectorRaw(fat1Start + 1, @sectorBuf)
        utils.checkGuard(@sectorBuf_guard, @"buf guard")
        mismatch := false
        repeat idx from 0 to BYTES_PER_SECTOR - 1
            if sectorBuf[idx] <> 0
                mismatch := true
                quit
        utils.evaluateBool(mismatch == false, @"All zeros", TRUE)

        utils.startTest(@"FAT2 second sector is zeroed")
        utils.initGuard(@sectorBuf_guard)
        dfs.readSectorRaw(fat2Start + 1, @sectorBuf)
        utils.checkGuard(@sectorBuf_guard, @"buf guard")
        mismatch := false
        repeat idx from 0 to BYTES_PER_SECTOR - 1
            if sectorBuf[idx] <> 0
                mismatch := true
                quit
        utils.evaluateBool(mismatch == false, @"All zeros", TRUE)

        ' ========================================
        ' ROOT DIRECTORY VERIFICATION
        ' ========================================
        utils.startTestGroup(@"Root Directory Verification")

        dataStart := partitionStart + RESERVED_SECTORS + NUM_FATS * sectorsPerFat
        debug("  Data region starts at sector ", udec(dataStart))

        utils.initGuard(@sectorBuf_guard)
        dfs.readSectorRaw(dataStart, @sectorBuf)
        utils.checkGuard(@sectorBuf_guard, @"buf guard")

        utils.startTest(@"Volume label entry present")
        ' First entry should be volume label
        fieldValue := sectorBuf[DIR_ATTR_OFFSET]
        utils.evaluateBool(fieldValue == ATTR_VOLUME_LABEL, @"Attr = $08 (volume label)", TRUE)

        utils.startTest(@"Volume label name")
        debug("  Volume label: ", lstr_(@sectorBuf, LABEL_LENGTH))
        ' Check first char is printable
        fieldValue := sectorBuf[0]
        utils.evaluateBool(fieldValue >= ASCII_SPACE AND fieldValue <= ASCII_TILDE, @"Valid label chars", TRUE)

        utils.startTest(@"Second entry is end marker or empty")
        fieldValue := sectorBuf[SECOND_ENTRY_OFFSET]
        ' Should be $00 (end) or another valid entry
        utils.evaluateBool(fieldValue == END_OF_DIR_MARKER OR fieldValue == DELETED_ENTRY_MARKER OR (fieldValue >= ASCII_SPACE AND fieldValue <= ASCII_TILDE), @"Valid second entry", TRUE)

        utils.startTest(@"Rest of root cluster is zeroed")
        mismatch := false
        repeat idx from THIRD_ENTRY_OFFSET to BYTES_PER_SECTOR - 1  ' Start after possible 2nd entry
            if sectorBuf[idx] <> 0
                mismatch := true
                quit
        utils.evaluateBool(mismatch == false, @"Remaining bytes zero", TRUE)

        ' ========================================
        ' MOUNT AND USABILITY TEST
        ' ========================================
        utils.startTestGroup(@"Mount and Usability")

        utils.startTest(@"Mount formatted card")
        fieldValue := dfs.mount(dfs.DEV_SD)
        utils.evaluateSingleValue(fieldValue, @"mount() succeeds", dfs.SUCCESS)

        utils.startTest(@"Read volume label")
        debug("  Mounted volume: ", zstr_(dfs.volumeLabel(dfs.DEV_SD)))
        fieldValue := dfs.volumeLabel(dfs.DEV_SD)
        utils.evaluateBool(fieldValue <> 0, @"Label pointer valid", TRUE)

        utils.startTest(@"Check free space reported")
        fieldValue := dfs.freeSpace(dfs.DEV_SD)
        utils.evaluateBool(fieldValue > 0, @"Free space > 0", TRUE)
        debug("  Free space: ", udec(fieldValue), " sectors")

        dfs.unmount(dfs.DEV_SD)

    ' ----------------------------------------
    ' Summary
    ' ----------------------------------------
#ifdef SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#endif

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("END_SESSION")

CON { license }

