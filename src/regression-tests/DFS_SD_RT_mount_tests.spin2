'' =================================================================================================
''
''   File....... DFS_SD_RT_mount_tests.spin2
''   Purpose.... This object exercises mount/unmount and basic card operations
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... JAN 2026
''   Updated.... 16 JAN 2026
''
'' =================================================================================================

CON

     _CLKFREQ        = 350_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61

     GUARD_SIZE  = 16

     ' External SD header (base pin 16)
     'SD_CS   = 20
     'SD_MOSI = 19
     'SD_MISO = 18
     'SD_SCK  = 21


#ifdef __SPINTOOLS__
#define SD_INCLUDE_RAW
#define SD_INCLUDE_DEBUG
#define SD_INCLUDE_STACK_CHECK
#elseifdef __FLEXSPIN__
#define SD_INCLUDE_RAW
#pragma exportdef SD_INCLUDE_RAW
#define SD_INCLUDE_DEBUG
#pragma exportdef SD_INCLUDE_DEBUG
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#else
'' Enable raw sector access for diagnostic tests
#pragma exportdef SD_INCLUDE_RAW
'' Enable debug diagnostics (CMD13, CRC counters)
#pragma exportdef SD_INCLUDE_DEBUG
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#endif

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "DFS_RT_utilities"

DAT

testfile1       BYTE    "TEST1.TXT", 0
sectorBuffer    BYTE    0[dfs.SECTOR_SIZE]
sectorBuffer_guard BYTE 0[GUARD_SIZE]

PUB go() | workerCog, mountResult, opStatus, pLabel, freeSpace, fileHndl
'' Main entry point for mount/unmount regression tests
''
'' Tests SD card mount, unmount, and basic card operations

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (SD) - Mount/Unmount Tests")
    debug("==============================================")

    ' Initialize worker cog
    workerCog := dfs.init()

    ' ----------------------------------
    ' TEST GROUP: Operations before mount
    ' ----------------------------------
    utils.startTestGroup(@"Operations before mount should fail gracefully")

    ' These operations should not crash when card isn't mounted
    utils.startTest(@"openFile() before mount")
    fileHndl := dfs.openFileRead(dfs.DEV_SD, @testfile1)
    utils.evaluateBool(fileHndl >= 0, @"openFileRead()", FALSE)

    utils.startTest(@"closeFile() before mount")
    opStatus := dfs.closeFileHandle(fileHndl)
    utils.evaluateSingleValue(opStatus, @"closeFileHandle(bad)", dfs.E_INVALID_HANDLE)

    utils.startTest(@"freeSpace() before mount")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateSingleValue(freeSpace, @"freeSpace()", 0)

    ' ----------------------------------
    ' TEST GROUP: Pre-Mount Error Validation (V3 Handle API)
    ' ----------------------------------
    utils.startTestGroup(@"Pre-Mount Error Validation (V3 Handle API)")

    utils.startTest(@"openFileRead() before mount returns E_NOT_MOUNTED")
    fileHndl := dfs.openFileRead(dfs.DEV_SD, @testfile1)
    utils.evaluateSingleValue(fileHndl, @"openFileRead()", dfs.E_NOT_MOUNTED)

    utils.startTest(@"createFileNew() before mount returns E_NOT_MOUNTED")
    fileHndl := dfs.createFileNew(dfs.DEV_SD, @testfile1)
    utils.evaluateSingleValue(fileHndl, @"createFileNew()", dfs.E_NOT_MOUNTED)

    utils.startTest(@"readSectorRaw() before mount returns error")
    utils.initGuard(@sectorBuffer_guard)
    opStatus := dfs.readSectorRaw(0, @sectorBuffer)
    utils.checkGuard(@sectorBuffer_guard, @"sectorBuffer guard")
    utils.evaluateSingleValue(opStatus, @"readSectorRaw()", dfs.E_NOT_MOUNTED)

    utils.startTest(@"changeDirectory() before mount returns error")
    opStatus := dfs.changeDirectory(dfs.DEV_SD, @"TESTDIR")
    utils.evaluateSingleValue(opStatus, @"changeDirectory()", dfs.E_NOT_MOUNTED)

    ' ----------------------------------
    ' TEST GROUP: Mount card
    ' ----------------------------------
    utils.startTestGroup(@"Mount SD card")

    utils.startTest(@"mount() with valid pins")
    mountResult := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"mount()", dfs.SUCCESS)

    ' DIAGNOSTIC: Show CMD13 and CRC state after mount attempt
    debug(" ")
    debug("  DIAG: error()=", sdec_(dfs.error()))
    debug("  DIAG: lastCMD13=$", uhex_(dfs.getLastCMD13()), " lastCMD13Error=$", uhex_(dfs.getLastCMD13Error()))
    debug("  DIAG: CRC match=", udec_(dfs.getCRCMatchCount()), " mismatch=", udec_(dfs.getCRCMismatchCount()), " retry=", udec_(dfs.getCRCRetryCount()))
    debug("  DIAG: recvCRC=$", uhex_(dfs.getLastReceivedCRC()), " calcCRC=$", uhex_(dfs.getLastCalculatedCRC()))
    ' Read sector 0 raw to inspect MBR partition table bytes
    utils.initGuard(@sectorBuffer_guard)
    if dfs.readSectorRaw(0, @sectorBuffer) == dfs.SUCCESS
      utils.checkGuard(@sectorBuffer_guard, @"sectorBuffer guard")
      debug("  DIAG MBR: sig=$", uhex_byte_(sectorBuffer[$1FE]), " $", uhex_byte_(sectorBuffer[$1FF]))
      debug("  DIAG MBR: part1 type=$", uhex_byte_(sectorBuffer[$1C2]), " lba=$", uhex_byte_(sectorBuffer[$1C9]), uhex_byte_(sectorBuffer[$1C8]), uhex_byte_(sectorBuffer[$1C7]), uhex_byte_(sectorBuffer[$1C6]))
      debug("  DIAG MBR[0..7]: $", uhex_byte_(sectorBuffer[0]), " $", uhex_byte_(sectorBuffer[1]), " $", uhex_byte_(sectorBuffer[2]), " $", uhex_byte_(sectorBuffer[3]), " $", uhex_byte_(sectorBuffer[4]), " $", uhex_byte_(sectorBuffer[5]), " $", uhex_byte_(sectorBuffer[6]), " $", uhex_byte_(sectorBuffer[7]))
    else
      debug("  DIAG: readSectorRaw(0) FAILED")

    utils.startTest(@"Verify card is accessible - get volume label")
    pLabel := dfs.volumeLabel(dfs.DEV_SD)
    utils.evaluateNotZero(pLabel, @"volumeLabel() pointer")

    utils.startTest(@"Verify free space is reasonable")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateRange(freeSpace, @"freeSpace()", 1, $7FFF_FFFF)

    debug(" ")
    debug("  Card Info:")
    debug("    Volume Label: ", zstr_(pLabel))
    debug("    Free Space: ", udec_(freeSpace), " sectors (", udec_(freeSpace / 2048), " MB)")

    ' ----------------------------------
    ' TEST GROUP: Unmount card
    ' ----------------------------------
    utils.startTestGroup(@"Unmount SD card")

    utils.startTest(@"unmount() card")
    mountResult := dfs.unmount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"unmount()", dfs.SUCCESS)

    utils.startTest(@"Operations after unmount should fail")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateSingleValue(freeSpace, @"freeSpace() after unmount", 0)

    ' ----------------------------------
    ' TEST GROUP: Remount card
    ' ----------------------------------
    utils.startTestGroup(@"Remount SD card")

    utils.startTest(@"mount() again")
    mountResult := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"mount() second time", dfs.SUCCESS)

    ' DIAGNOSTIC: Show CMD13 and CRC state after remount attempt
    debug("  DIAG2: error()=", sdec_(dfs.error()))
    debug("  DIAG2: lastCMD13=$", uhex_(dfs.getLastCMD13()), " lastCMD13Error=$", uhex_(dfs.getLastCMD13Error()))
    debug("  DIAG2: CRC match=", udec_(dfs.getCRCMatchCount()), " mismatch=", udec_(dfs.getCRCMismatchCount()), " retry=", udec_(dfs.getCRCRetryCount()))

    utils.startTest(@"Card still accessible after remount")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateRange(freeSpace, @"freeSpace() after remount", 1, $7FFF_FFFF)

    ' ----------------------------------
    ' TEST GROUP: Multiple mount calls
    ' ----------------------------------
    utils.startTestGroup(@"Multiple mount/unmount cycles")

    utils.startTest(@"unmount()")
    mountResult := dfs.unmount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"unmount()", dfs.SUCCESS)

    utils.startTest(@"mount() cycle 1")
    mountResult := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"mount()", dfs.SUCCESS)

    utils.startTest(@"unmount()")
    mountResult := dfs.unmount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"unmount()", dfs.SUCCESS)

    utils.startTest(@"mount() cycle 2")
    mountResult := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"mount()", dfs.SUCCESS)

    utils.startTest(@"unmount()")
    mountResult := dfs.unmount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"unmount()", dfs.SUCCESS)

    utils.startTest(@"mount() cycle 3")
    mountResult := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountResult, @"mount()", dfs.SUCCESS)

    utils.startTest(@"Card still works after 3 mount/unmount cycles")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateRange(freeSpace, @"freeSpace()", 1, $7FFF_FFFF)

    ' Final unmount
    dfs.unmount(dfs.DEV_SD)

    ' ----------------------------------
    ' Summary
    ' ----------------------------------
#ifdef SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#endif

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("* Mount/Unmount Tests Complete")
    debug("END_SESSION")


con { license }

