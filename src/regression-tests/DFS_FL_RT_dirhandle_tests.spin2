'' =================================================================================================
''
''   File....... DFS_FL_RT_dirhandle_tests.spin2
''   Purpose.... Flash directory handle enumeration tests via dual_sd_fat32_flash_fs
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... 04 MAR 2026
''   Updated.... 04 MAR 2026
''
'' =================================================================================================
''
'' Tests the Flash directory handle API (openDirectory/readDirectoryHandle/closeDirectoryHandle):
''   - Basic enumeration (root, subdirectory, close/reopen)
''   - Entry inspection (fileName, attributes, fileSize)
''   - Error conditions (invalid handle, non-existent path)
''   - Subdirectory dedup (multiple files produce single dir pseudo-entry)
''   - CWD independence (handle prefix vs caller CWD)
''   - Handle pool interaction (dir + file handles coexist)
''
''   ~20 tests across 6 groups
''
'' =================================================================================================

CON

     _CLKFREQ        = 320_000_000
     DEBUG_BAUD       = 2_000_000

' Enable stack depth measurement
#ifdef __SPINTOOLS__
#define SD_INCLUDE_STACK_CHECK
#elseifdef __FLEXSPIN__
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#else
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#endif

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "DFS_RT_utilities"

CON
    ' P2 Edge module SD slot pins (needed for dfs.init)
    SD_CS   = 60
    SD_MOSI = 59
    SD_MISO = 58
    SD_SCK  = 61

    ' FAT32 directory attributes
    ATTR_DIRECTORY       = $10
    ATTR_ARCHIVE         = $20

DAT

' Test file paths (stored on Flash with "/" separators for directory emulation)
dhRootFile      BYTE    "dhrootfl.dat", 0
dhPoolFile2     BYTE    "dhpool2.dat", 0
dhPoolFile3     BYTE    "dhpool3.dat", 0
dhPoolFile4     BYTE    "dhpool4.dat", 0
dhPoolFile5     BYTE    "dhpool5.dat", 0
dhDirFile1      BYTE    "dhtdir/dh1.dat", 0
dhDirFile2      BYTE    "dhtdir/dh2.dat", 0
dhDirFile3      BYTE    "dhtdir/dh3.dat", 0
dhSubFile       BYTE    "dhtdir/dhsub/sub1.dat", 0

' Directory names for openDirectory
dhDirName       BYTE    "dhtdir", 0
dhSubDirName    BYTE    "dhtdir/dhsub", 0
dhAbsRoot       BYTE    "/", 0
dhDot           BYTE    ".", 0
dhEmpty         BYTE    0

' CWD navigation
cwdRoot         BYTE    "/", 0

' Test data
dhContent       BYTE    "DirHandle test content", 0

PUB go() | workerCog, status, dirHndl, dirHndl2, fileHndl1, fileHndl2, fileHndl3, p_entry, p_name, attrib, fsize, entryCount, foundFiles, foundDirs, bValidHndl
'' Run Flash directory handle regression tests.
''
' @local workerCog - Driver worker cog ID
' @local status - Operation status
' @local dirHndl - Directory handle
' @local dirHndl2 - Second directory handle
' @local fileHndl1..fileHndl3 - File handles for pool tests
' @local p_entry - Pointer to entry buffer
' @local p_name - Pointer to filename string
' @local attrib - Entry attribute byte
' @local fsize - File size
' @local entryCount - Entry counter
' @local foundFiles - File entry counter
' @local foundDirs - Directory entry counter

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (Flash) - Directory Handle Tests")
    debug("==============================================")

    ' Initialize driver
    workerCog := dfs.init()

    ' Mount Flash
    status := dfs.mount(dfs.DEV_FLASH)
    if status == dfs.SUCCESS

        ' Show mount status
        debug(" ")
        debug("* Flash mounted OK")

        ' Clean up any existing test files
        cleanupTestFiles()

        ' Create test file structure
        createTestFiles()

        ' ======================================================================
        ' TEST GROUP 1: Basic Enumeration (5 tests)
        ' ======================================================================
        utils.startTestGroup(@"Basic Enumeration")

        ' Test: openDirectory("") enumerates root
        utils.startTest(@"openDirectory('') enumerates root")
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhEmpty)
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"openDirectory('') succeeds", TRUE)
        if bValidHndl == TRUE
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                entryCount++
            ' Root has: dhrootfl.dat + dhtdir/ pseudo-entry = at least 2
            utils.evaluateSubBool(entryCount >= 2, @"root has >= 2 entries", TRUE)
            dfs.closeDirectoryHandle(dirHndl)

        ' Test: openDirectory(".") enumerates root
        utils.startTest(@"openDirectory(.) enumerates root")
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDot)
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"openDirectory(.) succeeds", TRUE)
        if bValidHndl == TRUE
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                entryCount++
            utils.evaluateSubBool(entryCount >= 2, @"root via . has >= 2 entries", TRUE)
            dfs.closeDirectoryHandle(dirHndl)

        ' Test: openDirectory("dhtdir") enumerates subdir
        utils.startTest(@"openDirectory(dhtdir) enumerates subdir")
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"openDirectory(dhtdir) succeeds", TRUE)
        if bValidHndl == TRUE
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                entryCount++
            ' dhtdir has: dh1.dat, dh2.dat, dh3.dat + dhsub/ = 4 entries
            utils.evaluateSubBool(entryCount >= 4, @"dhtdir has >= 4 entries", TRUE)
            dfs.closeDirectoryHandle(dirHndl)

        ' Test: closeDirectoryHandle releases handle
        utils.startTest(@"closeDirectoryHandle releases handle slot")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDot)
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"first open succeeds", TRUE)
        dfs.closeDirectoryHandle(dirHndl)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDot)
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"reopen after close succeeds", TRUE)
        if bValidHndl == TRUE
            dfs.closeDirectoryHandle(dirHndl)

        ' Test: Enumerate dhtdir finds 3 files and 1 subdir
        utils.startTest(@"Enumerate dhtdir finds 3 files and 1 subdir")
        utils.setCheckCountPerTest(4)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            foundFiles := 0
            foundDirs := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                attrib := dfs.attributes()
                if attrib & ATTR_DIRECTORY
                    foundDirs++
                else
                    foundFiles++
            utils.evaluateSubBool(foundFiles >= 3, @"found >= 3 files", TRUE)
            utils.evaluateSubBool(foundDirs >= 1, @"found >= 1 subdir", TRUE)
            dfs.closeDirectoryHandle(dirHndl)
        else
            utils.evaluateSubBool(FALSE, @"found >= 3 files", TRUE)
            utils.evaluateSubBool(FALSE, @"found >= 1 subdir", TRUE)
        utils.setCheckCountPerTest(1)

        ' ======================================================================
        ' TEST GROUP 2: Entry Inspection (4 tests)
        ' ======================================================================
        utils.startTestGroup(@"Entry Inspection")

        ' Test: fileName() returns valid names
        utils.startTest(@"fileName() returns valid names during enumeration")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                p_name := dfs.fileName()
                utils.evaluateSubBool(strsize(p_name) > 0, @"filename non-empty", TRUE)
                entryCount++
            dfs.closeDirectoryHandle(dirHndl)

        ' Test: attributes() distinguishes file vs directory
        utils.startTest(@"attributes() distinguishes file vs directory")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            foundFiles := 0
            foundDirs := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                attrib := dfs.attributes()
                if attrib & ATTR_DIRECTORY
                    foundDirs++
                else
                    foundFiles++
            utils.evaluateSubBool(foundFiles > 0, @"has file entries", TRUE)
            utils.evaluateSubBool(foundDirs > 0, @"has dir entries", TRUE)
            dfs.closeDirectoryHandle(dirHndl)

        ' Test: Nested subdirectory enumeration
        utils.startTest(@"Nested subdirectory enumeration finds file")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhSubDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            foundFiles := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                attrib := dfs.attributes()
                if (attrib & ATTR_DIRECTORY) == 0
                    foundFiles++
            utils.evaluateSubBool(foundFiles >= 1, @"nested subdir has file", TRUE)
            dfs.closeDirectoryHandle(dirHndl)
        else
            utils.evaluateSubBool(FALSE, @"nested subdir has file", TRUE)

        ' Test: fileSize() returns correct size for files
        utils.startTest(@"fileSize() returns correct size for files")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            foundFiles := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                attrib := dfs.attributes()
                if (attrib & ATTR_DIRECTORY) == 0
                    fsize := dfs.fileSize()
                    if fsize > 0
                        foundFiles++
            utils.evaluateSubBool(foundFiles >= 1, @"file has size > 0", TRUE)
            dfs.closeDirectoryHandle(dirHndl)

        ' ======================================================================
        ' TEST GROUP 3: Error Conditions (3 tests)
        ' ======================================================================
        utils.startTestGroup(@"Error Conditions")

        ' Test: readDirectoryHandle with invalid handle returns 0
        utils.startTest(@"readDirectoryHandle(-1) returns 0")
        p_entry := dfs.readDirectoryHandle(-1)
        utils.evaluateSingleValue(p_entry, @"readDirectoryHandle(-1)", 0)

        ' Test: readDirectoryHandle with MAX handle returns 0
        utils.startTest(@"readDirectoryHandle(MAX) returns 0")
        p_entry := dfs.readDirectoryHandle(dfs.MAX_OPEN_FILES)
        utils.evaluateSingleValue(p_entry, @"readDirectoryHandle(MAX)", 0)

        ' Test: closeDirectoryHandle with invalid handle is no-op
        utils.startTest(@"closeDirectoryHandle(-1) no crash")
        dfs.closeDirectoryHandle(-1)
        utils.recordPass()  ' If we get here, pass

        ' ======================================================================
        ' TEST GROUP 4: Subdirectory Dedup (3 tests)
        ' ======================================================================
        utils.startTestGroup(@"Subdirectory Dedup")

        ' Test: Multiple files in subdir produce single dir pseudo-entry
        utils.startTest(@"Multiple files produce single dir entry")
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            foundDirs := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                attrib := dfs.attributes()
                if attrib & ATTR_DIRECTORY
                    foundDirs++
            ' dhtdir has 1 subdir (dhsub) with 1 file, should produce exactly 1 dir entry
            utils.evaluateSingleValue(foundDirs, @"exactly 1 subdir entry", 1)
            dfs.closeDirectoryHandle(dirHndl)

        ' Test: Dedup survives full enumeration (re-enumerate gives same count)
        utils.startTest(@"Re-enumerate gives same count")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                entryCount++
            dfs.closeDirectoryHandle(dirHndl)
        ' Second enumeration
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            foundFiles := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                foundFiles++
            dfs.closeDirectoryHandle(dirHndl)
        utils.evaluateSingleValue(foundFiles, @"second enum matches first", entryCount)

        ' Test: Root shows subdirectory pseudo-entry
        utils.startTest(@"Root shows subdirectory pseudo-entry")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhAbsRoot)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            foundDirs := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                attrib := dfs.attributes()
                if attrib & ATTR_DIRECTORY
                    foundDirs++
            utils.evaluateSubBool(foundDirs >= 1, @"root has dir entry", TRUE)
            dfs.closeDirectoryHandle(dirHndl)

        ' ======================================================================
        ' TEST GROUP 5: CWD Independence (3 tests)
        ' ======================================================================
        utils.startTestGroup(@"CWD Independence")

        ' Test: Handle prefix independent of CWD changes
        utils.startTest(@"Handle prefix independent of CWD change")
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDot)  ' Opens root
        ' Now change CWD to dhtdir
        dfs.changeDirectory(dfs.DEV_FLASH, @dhDirName)
        ' readDirectoryHandle should still return root entries
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                entryCount++
            ' Root has fewer entries than dhtdir (root: 2, dhtdir: 4)
            ' This verifies the handle used root prefix, not current CWD
            utils.evaluateSubBool(entryCount >= 1, @"root entries from handle", TRUE)
            dfs.closeDirectoryHandle(dirHndl)
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

        ' Test: Absolute path ignores CWD
        utils.startTest(@"Absolute path ignores CWD")
        dfs.changeDirectory(dfs.DEV_FLASH, @dhDirName)  ' CWD = dhtdir
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhAbsRoot)  ' Should open root
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                entryCount++
            utils.evaluateSubBool(entryCount >= 1, @"abs / returns root entries", TRUE)
            dfs.closeDirectoryHandle(dirHndl)
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

        ' Test: Two handles enumerate different directories
        utils.startTest(@"Two handles enumerate different dirs")
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDot)       ' root
        dirHndl2 := dfs.openDirectory(dfs.DEV_FLASH, @dhDirName)  ' dhtdir
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"root handle OK", TRUE)
        bValidHndl := (dirHndl2 >= 0)
        utils.evaluateSubBool(bValidHndl, @"dhtdir handle OK", TRUE)
        bValidHndl := (dirHndl >= 0 and dirHndl2 >= 0)
        if bValidHndl == TRUE
            ' Count root entries
            entryCount := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl)
                if p_entry == 0
                    quit
                entryCount++
            ' Count dhtdir entries
            foundFiles := 0
            repeat
                p_entry := dfs.readDirectoryHandle(dirHndl2)
                if p_entry == 0
                    quit
                foundFiles++
            ' Root (2 entries) and dhtdir (4 entries) should differ
            utils.evaluateSubBool(entryCount <> foundFiles, @"different entry counts", TRUE)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            dfs.closeDirectoryHandle(dirHndl)
        bValidHndl := (dirHndl2 >= 0)
        if bValidHndl == TRUE
            dfs.closeDirectoryHandle(dirHndl2)

        ' ======================================================================
        ' TEST GROUP 6: Handle Pool Interaction (2 tests)
        ' ======================================================================
        utils.startTestGroup(@"Handle Pool Interaction")

        ' Test: Dir handle coexists with file handles
        ' Flash has MAX_FLASH_BUFFERS=3 limit on simultaneous file opens.
        ' Dir handles do NOT consume a Flash buffer, so they should work
        ' even when all file buffers are in use.
        utils.startTest(@"Dir handle shares pool with file handles")
        utils.setCheckCountPerTest(2)
        dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
        ' Open 3 file handles (MAX_FLASH_BUFFERS=3, must be distinct files)
        fileHndl1 := dfs.open(dfs.DEV_FLASH, @dhRootFile, dfs.FILEMODE_READ)
        fileHndl2 := dfs.open(dfs.DEV_FLASH, @dhPoolFile2, dfs.FILEMODE_READ)
        fileHndl3 := dfs.open(dfs.DEV_FLASH, @dhPoolFile3, dfs.FILEMODE_READ)
        bValidHndl := (fileHndl1 >= 0 and fileHndl2 >= 0 and fileHndl3 >= 0)
        utils.evaluateSubBool(bValidHndl, @"3 file handles OK", TRUE)
        ' Dir handle should still work (no Flash buffer needed)
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDot)
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"dir handle with files open", TRUE)
        ' Clean up
        bValidHndl := (fileHndl1 >= 0)
        if bValidHndl == TRUE
            dfs.close(fileHndl1)
        bValidHndl := (fileHndl2 >= 0)
        if bValidHndl == TRUE
            dfs.close(fileHndl2)
        bValidHndl := (fileHndl3 >= 0)
        if bValidHndl == TRUE
            dfs.close(fileHndl3)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            dfs.closeDirectoryHandle(dirHndl)
        utils.setCheckCountPerTest(1)

        ' Test: Close dir handle frees slot for file open
        utils.startTest(@"Close dir handle frees slot for file open")
        dirHndl := dfs.openDirectory(dfs.DEV_FLASH, @dhDot)
        bValidHndl := (dirHndl >= 0)
        utils.evaluateSubBool(bValidHndl, @"dir handle allocated", TRUE)
        bValidHndl := (dirHndl >= 0)
        if bValidHndl == TRUE
            dfs.closeDirectoryHandle(dirHndl)
        ' Now open a file - should succeed (slot freed)
        fileHndl1 := dfs.open(dfs.DEV_FLASH, @dhRootFile, dfs.FILEMODE_READ)
        bValidHndl := (fileHndl1 >= 0)
        utils.evaluateSubBool(bValidHndl, @"file handle after dir close", TRUE)
        bValidHndl := (fileHndl1 >= 0)
        if bValidHndl == TRUE
            dfs.close(fileHndl1)

        ' ======================================================================
        ' Cleanup and Summary
        ' ======================================================================
        cleanupTestFiles()

#ifdef SD_INCLUDE_STACK_CHECK
        debug(" ")
        debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#endif

        dfs.unmount(dfs.DEV_FLASH)

    else
        debug("* Flash mount FAILED: ", sdec_(status))

    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("END_SESSION")

PRI createTestFiles() | fileHndl, bValidHndl
' Create test file structure on Flash:
'   dhrootfl.dat          (root level)
'   dhtdir/dh1.dat        (subdir file)
'   dhtdir/dh2.dat        (subdir file)
'   dhtdir/dh3.dat        (subdir file)
'   dhtdir/dhsub/sub1.dat (nested subdir file)

    debug(" ")
    debug("* Creating test file structure...")

    dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

    ' Root file
    fileHndl := dfs.open(dfs.DEV_FLASH, @dhRootFile, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    ' dhtdir/dh1.dat - using full paths from root
    fileHndl := dfs.open(dfs.DEV_FLASH, @dhDirFile1, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    ' dhtdir/dh2.dat
    fileHndl := dfs.open(dfs.DEV_FLASH, @dhDirFile2, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    ' dhtdir/dh3.dat
    fileHndl := dfs.open(dfs.DEV_FLASH, @dhDirFile3, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    ' dhtdir/dhsub/sub1.dat
    fileHndl := dfs.open(dfs.DEV_FLASH, @dhSubFile, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    ' Pool test files (distinct files needed since Flash can't open same file twice)
    fileHndl := dfs.open(dfs.DEV_FLASH, @dhPoolFile2, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    fileHndl := dfs.open(dfs.DEV_FLASH, @dhPoolFile3, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    fileHndl := dfs.open(dfs.DEV_FLASH, @dhPoolFile4, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    fileHndl := dfs.open(dfs.DEV_FLASH, @dhPoolFile5, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @dhContent)
        dfs.close(fileHndl)

    dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

    debug("* Test structure created")
    debug(" ")

PRI cleanupTestFiles()
' Delete all test files (Flash has no real directories to clean)

    dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

    dfs.deleteFile(dfs.DEV_FLASH, @dhRootFile)
    dfs.deleteFile(dfs.DEV_FLASH, @dhPoolFile2)
    dfs.deleteFile(dfs.DEV_FLASH, @dhPoolFile3)
    dfs.deleteFile(dfs.DEV_FLASH, @dhPoolFile4)
    dfs.deleteFile(dfs.DEV_FLASH, @dhPoolFile5)
    dfs.deleteFile(dfs.DEV_FLASH, @dhDirFile1)
    dfs.deleteFile(dfs.DEV_FLASH, @dhDirFile2)
    dfs.deleteFile(dfs.DEV_FLASH, @dhDirFile3)
    dfs.deleteFile(dfs.DEV_FLASH, @dhSubFile)


