'' =================================================================================================
''
''   File....... DFS_RT_dual_device_tests.spin2
''   Purpose.... Dual-device verification: Flash mount, bus switching, SD integrity after Flash ops
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... FEB 2026
''   Updated.... 28 FEB 2026
''
'' =================================================================================================
''
'' Tests dual-device aspects of the unified driver:
''   - Flash mount state tracking (mounted before/after, SD survives Flash mount)
''   - Flash serial number
''   - SD file I/O works after Flash mount (bus switching verification)
''   - Flash unmount/remount cycle
''   - mount(DEV_BOTH) / unmount(DEV_BOTH)
''   - SD data integrity after heavy Flash file operations
''   - Worker cog stack guard
''
'' 37 tests total
''
'' =================================================================================================

CON

     _CLKFREQ        = 350_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61


     BUFFER_SIZE          = 512  ' Sector buffer size in bytes
     FL_READ_BUF_SIZE     = 64   ' Flash read buffer fill size
     FL_READ_COUNT        = 4    ' Bytes to read in Flash round-trip
     FL_TEST_FILE_SIZE    = 100  ' Size for Flash create_file test
     SD_TAG_LENGTH        = 3    ' Length of "SD1", "SD2", "SD3" tags
     GUARD_SIZE           = 16   ' Guard bytes after each buffer

#ifdef __SPINTOOLS__
#define SD_INCLUDE_DEBUG
#define SD_INCLUDE_STACK_CHECK
#elseifdef __FLEXSPIN__
#define SD_INCLUDE_DEBUG
#pragma exportdef SD_INCLUDE_DEBUG
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#else
'' Enable debug diagnostics
#pragma exportdef SD_INCLUDE_DEBUG
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#endif

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "DFS_RT_utilities"

DAT

testfile1       BYTE    "TEST2.TXT", 0
testdata        BYTE    "Hello from dual_sd_fat32_flash_fs Phase 2!", 0

' SD regression test file (survives Flash operations)
sd_regfile      BYTE    "SDREG.TXT", 0
sd_regdata      BYTE    "SD regression data for bus switching", 0

' Flash test files (for heavy Flash I/O before SD regression check)
fl_testfile     BYTE    "FLTEST1", 0
fl_testfile2    BYTE    "FLTEST2", 0
fl_renamed      BYTE    "FLRNAME", 0
fl_testdata     BYTE    "Flash bus switching test data!", 0

' Handle pool test files
hp_sd_file1     BYTE    "HPSD1.TXT", 0
hp_sd_file2     BYTE    "HPSD2.TXT", 0
hp_sd_file3     BYTE    "HPSD3.TXT", 0
hp_fl_file1     BYTE    "HPFL1", 0
hp_fl_file2     BYTE    "HPFL2", 0
hp_fl_file3     BYTE    "HPFL3", 0
hp_fl_file4     BYTE    "HPFL4", 0

readBuffer      BYTE    0[512]
readBuf_guard   BYTE    0[GUARD_SIZE]

PUB go() | opStatus, mountStatus, freeSpace, fileHndl, bytesRead, bytesWritten, pLabel, sn_hi, sn_lo, hndl1, hndl2, hndl3, hndl4, hndl5, hndl6, hndl7, errorCount, bValidHndl
'' Main entry point for dual-device verification tests
''
'' Tests dual_sd_fat32_flash_fs.spin2 Flash mount, serial number, bus switching,
'' and SD integrity after Flash file operations

    debug(" ")
    debug("==============================================")
    debug("  Dual FS Dual-Device Verification Tests")
    debug("  (Flash mount + bus switching + SD integrity)")
    debug("==============================================")

    ' ----------------------------------
    ' TEST GROUP: SD regression -- init and mount still work
    ' ----------------------------------
    utils.startTestGroup(@"SD regression: init and mount")

    utils.startTest(@"init() with valid pins")
    opStatus := dfs.init()
    utils.evaluateRange(opStatus, @"init() returns cog ID", 0, dfs.MAX_P2_COGS - 1)

    utils.startTest(@"mount(DEV_SD)")
    mountStatus := dfs.mount(dfs.DEV_SD)
    utils.evaluateSingleValue(mountStatus, @"mount(DEV_SD)", dfs.SUCCESS)

    utils.startTest(@"mounted(DEV_SD) after mount")
    opStatus := dfs.mounted(dfs.DEV_SD)
    utils.evaluateBool(opStatus, @"mounted(DEV_SD)", TRUE)

    ' Save SD free space for later regression check
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    debug(" ")
    debug("  SD freeSpace before Flash mount: ", udec_(freeSpace), " sectors")

    ' ----------------------------------
    ' TEST GROUP: Flash mount
    ' ----------------------------------
    utils.startTestGroup(@"Flash mount")

    utils.startTest(@"mounted(DEV_FLASH) before mount")
    opStatus := dfs.mounted(dfs.DEV_FLASH)
    utils.evaluateBool(opStatus, @"mounted(DEV_FLASH)", FALSE)

    utils.startTest(@"mount(DEV_FLASH)")
    mountStatus := dfs.mount(dfs.DEV_FLASH)
    utils.evaluateSingleValue(mountStatus, @"mount(DEV_FLASH)", dfs.SUCCESS)

    utils.startTest(@"mounted(DEV_FLASH) after mount")
    opStatus := dfs.mounted(dfs.DEV_FLASH)
    utils.evaluateBool(opStatus, @"mounted(DEV_FLASH)", TRUE)

    utils.startTest(@"mounted(DEV_SD) still true after Flash mount")
    opStatus := dfs.mounted(dfs.DEV_SD)
    utils.evaluateBool(opStatus, @"mounted(DEV_SD)", TRUE)

    ' ----------------------------------
    ' TEST GROUP: Flash serial number
    ' ----------------------------------
    utils.startTestGroup(@"Flash serial number")

    utils.startTest(@"serial_number(DEV_FLASH) returns non-zero")
    sn_hi, sn_lo := dfs.serial_number(dfs.DEV_FLASH)
    utils.evaluateBool(sn_hi <> 0 or sn_lo <> 0, @"serial_number non-zero", TRUE)

    debug(" ")
    debug("  Flash Serial Number: $", uhex_(sn_hi), "_", uhex_(sn_lo))

    ' ----------------------------------
    ' TEST GROUP: SD operations after Flash mount (bus switching)
    ' ----------------------------------
    utils.startTestGroup(@"SD ops after Flash mount (bus switching)")

    utils.startTest(@"freeSpace(DEV_SD) still valid")
    opStatus := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateRange(opStatus, @"freeSpace(DEV_SD)", 1, $7FFF_FFFF)

    utils.startTest(@"volumeLabel(DEV_SD) still works")
    pLabel := dfs.volumeLabel(dfs.DEV_SD)
    utils.evaluateNotZero(pLabel, @"volumeLabel() pointer")

    ' Write/read round-trip on SD after Flash mount
    dfs.deleteFile(dfs.DEV_SD, @testfile1)

    utils.startTest(@"createFileNew(DEV_SD) after Flash mount")
    fileHndl := dfs.createFileNew(dfs.DEV_SD, @testfile1)
    utils.evaluateRange(fileHndl, @"createFileNew() handle", 0, dfs.MAX_OPEN_FILES - 1)

    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      utils.startTest(@"writeHandle() test data")
      bytesWritten := dfs.writeHandle(fileHndl, @testdata, strsize(@testdata))
      utils.evaluateSingleValue(bytesWritten, @"writeHandle() bytes", strsize(@testdata))

      utils.startTest(@"closeFileHandle() after write")
      opStatus := dfs.closeFileHandle(fileHndl)
      utils.evaluateSingleValue(opStatus, @"closeFileHandle()", dfs.SUCCESS)

    utils.startTest(@"openFileRead(DEV_SD) after Flash mount")
    fileHndl := dfs.openFileRead(dfs.DEV_SD, @testfile1)
    utils.evaluateRange(fileHndl, @"openFileRead() handle", 0, dfs.MAX_OPEN_FILES - 1)

    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      utils.startTest(@"readHandle() returns correct data")
      utils.initGuard(@readBuf_guard)
      bytefill(@readBuffer, 0, BUFFER_SIZE)
      bytesRead := dfs.readHandle(fileHndl, @readBuffer, BUFFER_SIZE)
      utils.checkGuard(@readBuf_guard, @"readBuf guard")
      utils.evaluateSingleValue(bytesRead, @"readHandle() bytes", strsize(@testdata))

      utils.startTest(@"Data matches what was written")
      utils.evaluateBufferMatch(@readBuffer, @testdata, strsize(@testdata), @"read vs written")

      utils.startTest(@"closeFileHandle() after read")
      opStatus := dfs.closeFileHandle(fileHndl)
      utils.evaluateSingleValue(opStatus, @"closeFileHandle()", dfs.SUCCESS)

    ' Clean up
    dfs.deleteFile(dfs.DEV_SD, @testfile1)

    ' ----------------------------------
    ' TEST GROUP: Flash unmount/remount
    ' ----------------------------------
    utils.startTestGroup(@"Flash unmount and remount")

    utils.startTest(@"unmount(DEV_FLASH)")
    mountStatus := dfs.unmount(dfs.DEV_FLASH)
    utils.evaluateSingleValue(mountStatus, @"unmount(DEV_FLASH)", dfs.SUCCESS)

    utils.startTest(@"mounted(DEV_FLASH) after unmount")
    opStatus := dfs.mounted(dfs.DEV_FLASH)
    utils.evaluateBool(opStatus, @"mounted(DEV_FLASH)", FALSE)

    utils.startTest(@"mount(DEV_FLASH) again")
    mountStatus := dfs.mount(dfs.DEV_FLASH)
    utils.evaluateSingleValue(mountStatus, @"mount(DEV_FLASH)", dfs.SUCCESS)

    utils.startTest(@"mounted(DEV_FLASH) after remount")
    opStatus := dfs.mounted(dfs.DEV_FLASH)
    utils.evaluateBool(opStatus, @"mounted(DEV_FLASH)", TRUE)

    ' ----------------------------------
    ' TEST GROUP: mount(DEV_BOTH) in one call
    ' ----------------------------------
    utils.startTestGroup(@"mount(DEV_BOTH) in one call")

    ' First unmount both
    dfs.unmount(dfs.DEV_BOTH)

    utils.startTest(@"mounted(DEV_SD) after unmount both")
    opStatus := dfs.mounted(dfs.DEV_SD)
    utils.evaluateBool(opStatus, @"mounted(DEV_SD)", FALSE)

    utils.startTest(@"mounted(DEV_FLASH) after unmount both")
    opStatus := dfs.mounted(dfs.DEV_FLASH)
    utils.evaluateBool(opStatus, @"mounted(DEV_FLASH)", FALSE)

    utils.startTest(@"mount(DEV_BOTH)")
    mountStatus := dfs.mount(dfs.DEV_BOTH)
    utils.evaluateSingleValue(mountStatus, @"mount(DEV_BOTH)", dfs.SUCCESS)

    utils.startTest(@"mounted(DEV_SD) after mount both")
    opStatus := dfs.mounted(dfs.DEV_SD)
    utils.evaluateBool(opStatus, @"mounted(DEV_SD)", TRUE)

    utils.startTest(@"mounted(DEV_FLASH) after mount both")
    opStatus := dfs.mounted(dfs.DEV_FLASH)
    utils.evaluateBool(opStatus, @"mounted(DEV_FLASH)", TRUE)

    ' ----------------------------------
    ' TEST GROUP: SD integrity after Flash file operations
    ' ----------------------------------
    utils.startTestGroup(@"SD integrity after Flash file ops")

    ' Setup: write an SD file, then do heavy Flash I/O
    dfs.deleteFile(dfs.DEV_SD, @sd_regfile)
    fileHndl := dfs.createFileNew(dfs.DEV_SD, @sd_regfile)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl <> TRUE
      debug("SETUP ERROR: createFileNew(SD) failed: ", sdec_(fileHndl))
      errorCount++
    else
      bytesWritten := dfs.writeHandle(fileHndl, @sd_regdata, strsize(@sd_regdata))
      if bytesWritten <> strsize(@sd_regdata)
        debug("SETUP ERROR: writeHandle(SD) wrote ", sdec_(bytesWritten), " expected ", udec_(strsize(@sd_regdata)))
        errorCount++
      dfs.closeFileHandle(fileHndl)

    ' Setup: create Flash file, write data, seek, delete, rename
    dfs.deleteFile(dfs.DEV_FLASH, @fl_testfile)
    dfs.deleteFile(dfs.DEV_FLASH, @fl_testfile2)
    dfs.deleteFile(dfs.DEV_FLASH, @fl_renamed)

    fileHndl := dfs.open(dfs.DEV_FLASH, @fl_testfile, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl <> TRUE
      debug("SETUP ERROR: open(Flash, WRITE) failed: ", sdec_(fileHndl))
      errorCount++
    else
      dfs.writeHandle(fileHndl, @fl_testdata, strsize(@fl_testdata))
      dfs.closeFileHandle(fileHndl)

    fileHndl := dfs.open(dfs.DEV_FLASH, @fl_testfile, dfs.FILEMODE_READ)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl <> TRUE
      debug("SETUP ERROR: open(Flash, READ) failed: ", sdec_(fileHndl))
      errorCount++
    else
      dfs.seekHandle(fileHndl, 6)
      bytefill(@readBuffer, 0, FL_READ_BUF_SIZE)
      dfs.readHandle(fileHndl, @readBuffer, FL_READ_COUNT)
      dfs.closeFileHandle(fileHndl)

    dfs.deleteFile(dfs.DEV_FLASH, @fl_testfile)

    opStatus := dfs.create_file(dfs.DEV_FLASH, @fl_testfile2, $00, FL_TEST_FILE_SIZE)
    if opStatus < 0
      debug("SETUP ERROR: create_file(Flash) failed: ", sdec_(opStatus))
      errorCount++
    opStatus := dfs.rename(dfs.DEV_FLASH, @fl_testfile2, @fl_renamed)
    if opStatus < 0
      debug("SETUP ERROR: rename(Flash) failed: ", sdec_(opStatus))
      errorCount++
    dfs.deleteFile(dfs.DEV_FLASH, @fl_renamed)

    ' Tracked: Verify SD file is still intact after all that Flash activity
    utils.startTest(@"freeSpace(DEV_SD) still valid")
    freeSpace := dfs.freeSpace(dfs.DEV_SD)
    utils.evaluateRange(freeSpace, @"freeSpace(DEV_SD)", 1, $7FFF_FFFF)

    utils.startTest(@"openFileRead(SD) still works")
    fileHndl := dfs.openFileRead(dfs.DEV_SD, @sd_regfile)
    utils.evaluateRange(fileHndl, @"openFileRead(SD) handle", 0, dfs.MAX_OPEN_FILES - 1)

    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      utils.startTest(@"readHandle(SD) after Flash ops")
      bytefill(@readBuffer, 0, BUFFER_SIZE)
      bytesRead := dfs.readHandle(fileHndl, @readBuffer, BUFFER_SIZE)
      utils.evaluateSingleValue(bytesRead, @"readHandle(SD) bytes", strsize(@sd_regdata))

      utils.startTest(@"SD data matches after Flash ops")
      utils.evaluateBufferMatch(@readBuffer, @sd_regdata, strsize(@sd_regdata), @"SD read vs written")

      dfs.closeFileHandle(fileHndl)

    ' Clean up
    dfs.deleteFile(dfs.DEV_SD, @sd_regfile)

    ' ----------------------------------
    ' TEST GROUP: Cross-device handle pool
    ' ----------------------------------
    utils.startTestGroup(@"Cross-device handle pool")

    ' Setup: create SD and Flash test files for handle pool tests
    dfs.deleteFile(dfs.DEV_SD, @hp_sd_file1)
    dfs.deleteFile(dfs.DEV_SD, @hp_sd_file2)
    dfs.deleteFile(dfs.DEV_SD, @hp_sd_file3)
    fileHndl := dfs.createFileNew(dfs.DEV_SD, @hp_sd_file1)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      dfs.writeHandle(fileHndl, @"SD1", SD_TAG_LENGTH)
      dfs.closeFileHandle(fileHndl)
    fileHndl := dfs.createFileNew(dfs.DEV_SD, @hp_sd_file2)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      dfs.writeHandle(fileHndl, @"SD2", SD_TAG_LENGTH)
      dfs.closeFileHandle(fileHndl)
    fileHndl := dfs.createFileNew(dfs.DEV_SD, @hp_sd_file3)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      dfs.writeHandle(fileHndl, @"SD3", SD_TAG_LENGTH)
      dfs.closeFileHandle(fileHndl)

    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file1)
    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file2)
    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file3)
    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file4)
    fileHndl := dfs.open(dfs.DEV_FLASH, @hp_fl_file1, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      dfs.wr_str(fileHndl, @"FL1")
      dfs.close(fileHndl)
    fileHndl := dfs.open(dfs.DEV_FLASH, @hp_fl_file2, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      dfs.wr_str(fileHndl, @"FL2")
      dfs.close(fileHndl)
    fileHndl := dfs.open(dfs.DEV_FLASH, @hp_fl_file3, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      dfs.wr_str(fileHndl, @"FL3")
      dfs.close(fileHndl)
    fileHndl := dfs.open(dfs.DEV_FLASH, @hp_fl_file4, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
      dfs.wr_str(fileHndl, @"FL4")
      dfs.close(fileHndl)

    ' Test: Open 3 SD file handles simultaneously
    utils.startTest(@"Open 3 SD handles simultaneously")
    hndl1 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file1)
    hndl2 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file2)
    hndl3 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file3)
    utils.evaluateBool(hndl1 >= 0 and hndl2 >= 0 and hndl3 >= 0, @"3 SD handles valid", TRUE)

    ' Test: Open 3 Flash handles (total 6 = max)
    utils.startTest(@"Open 3 Flash handles (total 6)")
    hndl4 := dfs.open(dfs.DEV_FLASH, @hp_fl_file1, dfs.FILEMODE_READ)
    hndl5 := dfs.open(dfs.DEV_FLASH, @hp_fl_file2, dfs.FILEMODE_READ)
    hndl6 := dfs.open(dfs.DEV_FLASH, @hp_fl_file3, dfs.FILEMODE_READ)
    utils.evaluateBool(hndl4 >= 0 and hndl5 >= 0 and hndl6 >= 0, @"3 Flash handles valid", TRUE)

    ' Test: 7th handle should fail (pool exhausted)
    utils.startTest(@"7th handle returns error (pool full)")
    hndl7 := dfs.open(dfs.DEV_FLASH, @hp_fl_file4, dfs.FILEMODE_READ)
    utils.evaluateBool(hndl7 < 0, @"7th handle fails", TRUE)

    ' Test: Close one Flash handle, open new Flash handle in freed slot
    ' (Flash open needs both a handle slot AND a flash buffer; closing an SD handle
    '  frees a handle slot but not a flash buffer, so we must close a Flash handle)
    utils.startTest(@"Pool reclaim across devices")
    dfs.closeFileHandle(hndl4)
    hndl7 := dfs.open(dfs.DEV_FLASH, @hp_fl_file4, dfs.FILEMODE_READ)
    utils.evaluateBool(hndl7 >= 0, @"Flash handle in freed Flash slot", TRUE)

    ' Test: Close all, verify all 6 slots available again
    utils.startTest(@"All 6 slots available after close all")
    dfs.closeFileHandle(hndl1)
    dfs.closeFileHandle(hndl2)
    dfs.closeFileHandle(hndl3)
    dfs.closeFileHandle(hndl5)
    dfs.closeFileHandle(hndl6)
    bValidHndl := (hndl7 >= 0)
    if bValidHndl == TRUE
      dfs.closeFileHandle(hndl7)
    ' Open 6 fresh handles to confirm all slots free
    hndl1 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file1)
    hndl2 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file2)
    hndl3 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file3)
    hndl4 := dfs.open(dfs.DEV_FLASH, @hp_fl_file1, dfs.FILEMODE_READ)
    hndl5 := dfs.open(dfs.DEV_FLASH, @hp_fl_file2, dfs.FILEMODE_READ)
    hndl6 := dfs.open(dfs.DEV_FLASH, @hp_fl_file3, dfs.FILEMODE_READ)
    utils.evaluateBool(hndl1 >= 0 and hndl2 >= 0 and hndl3 >= 0 and hndl4 >= 0 and hndl5 >= 0 and hndl6 >= 0, @"all 6 re-opened", TRUE)
    dfs.closeFileHandle(hndl1)
    dfs.closeFileHandle(hndl2)
    dfs.closeFileHandle(hndl3)
    dfs.closeFileHandle(hndl4)
    dfs.closeFileHandle(hndl5)
    dfs.closeFileHandle(hndl6)

    ' Test: Interleaved open/close SD and Flash
    utils.startTest(@"Interleaved open/close SD and Flash")
    hndl1 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file1)
    hndl2 := dfs.open(dfs.DEV_FLASH, @hp_fl_file1, dfs.FILEMODE_READ)
    hndl3 := dfs.openFileRead(dfs.DEV_SD, @hp_sd_file2)
    hndl4 := dfs.open(dfs.DEV_FLASH, @hp_fl_file2, dfs.FILEMODE_READ)
    utils.evaluateBool(hndl1 >= 0 and hndl2 >= 0 and hndl3 >= 0 and hndl4 >= 0, @"interleaved 4 handles", TRUE)
    dfs.closeFileHandle(hndl1)
    dfs.closeFileHandle(hndl2)
    dfs.closeFileHandle(hndl3)
    dfs.closeFileHandle(hndl4)

    ' Cleanup
    dfs.deleteFile(dfs.DEV_SD, @hp_sd_file1)
    dfs.deleteFile(dfs.DEV_SD, @hp_sd_file2)
    dfs.deleteFile(dfs.DEV_SD, @hp_sd_file3)
    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file1)
    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file2)
    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file3)
    dfs.deleteFile(dfs.DEV_FLASH, @hp_fl_file4)

    ' ----------------------------------
    ' TEST GROUP: Worker cog health
    ' ----------------------------------
    utils.startTestGroup(@"Worker cog health")

    ' NOTE: When SD_INCLUDE_STACK_CHECK is defined, prepStackForCheck() overwrites
    ' the $CC guard sentinel with its own DO_NOT_WRITE_MARK ($ADDEE5E5).
    ' checkStackGuard() looks for $CC, so it will always return FALSE in that case.
    ' The stack check utility has its own overflow detection via reportStackDepth().
#ifndef SD_INCLUDE_STACK_CHECK
    utils.startTest(@"checkStackGuard() intact")
    opStatus := dfs.checkStackGuard()
    utils.evaluateBool(opStatus, @"stack guard intact", TRUE)
#endif

    ' Final cleanup
    dfs.unmount(dfs.DEV_BOTH)
#ifdef SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#endif

    dfs.stop()

    ' ----------------------------------
    ' Summary
    ' ----------------------------------
    utils.ShowTestEndCounts()

    debug(" ")
    debug("* Dual-Device Verification Tests Complete")
    debug("END_SESSION")


con { license }

