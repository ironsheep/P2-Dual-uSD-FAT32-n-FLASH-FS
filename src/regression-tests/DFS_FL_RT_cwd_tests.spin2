'' =================================================================================================
''
''   File....... DFS_FL_RT_cwd_tests.spin2
''   Purpose.... Flash CWD (current working directory) emulation tests via dual_sd_fat32_flash_fs
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... 28 FEB 2026
''   Updated.... 28 FEB 2026
''
''   Tests the Flash CWD prefix emulation: changeDirectory(), directory listing
''   with CWD filtering, and CWD-aware file operations (open, exists, delete, rename).
''   Flash has no real directories -- CWD is emulated by prepending a prefix to filenames.
''
''   34 tests across 9 groups
''
'' =================================================================================================

CON

     _CLKFREQ        = 320_000_000
     DEBUG_BAUD       = 2_000_000

' Enable stack depth measurement
#ifdef __SPINTOOLS__
#define SD_INCLUDE_STACK_CHECK
#elseifdef __FLEXSPIN__
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#else
#define SD_INCLUDE_STACK_CHECK
#pragma exportdef SD_INCLUDE_STACK_CHECK
#endif

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "DFS_RT_utilities"

CON
    ' P2 Edge module SD slot pins (needed for dfs.init)
    SD_CS   = 60
    SD_MOSI = 59
    SD_MISO = 58
    SD_SCK  = 61

DAT

' Files created at root level (no prefix)
rootFile1       BYTE    "rootfile.dat", 0
rootFile2       BYTE    "rootother.dat", 0

' CWD prefix names (used as directory names)
cwdDirA         BYTE    "dirA", 0
cwdDirB         BYTE    "dirB", 0
cwdDirDeep1     BYTE    "deep1", 0
cwdDirDeep2     BYTE    "deep2", 0
cwdRoot         BYTE    "/", 0
cwdDotDot       BYTE    "..", 0

' Bare filenames (used within CWD context)
cwdFileAlpha    BYTE    "alpha.dat", 0
cwdFileBeta     BYTE    "beta.dat", 0
cwdFileGamma    BYTE    "gamma.dat", 0

' Test data
cwdTestData     BYTE    "CWD-TEST-DATA", 0
cwdRenameTarget BYTE    "renamed.dat", 0
cwdMoveFile     BYTE    "moveme.dat", 0
cwdEmptyStr     BYTE    0

' Absolute path test strings
absPathDirATest BYTE    "/dirA/abstest.dat", 0
absPathDirBFile BYTE    "/dirB/absfile.dat", 0
absPathRootFile BYTE    "/rootabs.dat", 0
absPathDirAAlph BYTE    "/dirA/alpha.dat", 0
absPathDirBGamm BYTE    "/dirB/gamma.dat", 0
absPathRename   BYTE    "/dirA/absrename.dat", 0
absTestFile     BYTE    "abstest.dat", 0
absFile         BYTE    "absfile.dat", 0
rootAbsFile     BYTE    "rootabs.dat", 0
absRenameFile   BYTE    "absrename.dat", 0
absTestData     BYTE    "ABS-PATH-DATA", 0

PUB go() | workerCog, fileSize, found, lenBytes, byte filename[dfs.FL_FILENAME_SIZE], handle, status, testValue, bValidHndl
'' Run Flash current working directory regression tests.
''
' @local workerCog - Driver worker cog ID
' @local blockId - Flash block ID
' @local fileSize - File size in bytes
' @local found - TRUE if file was found
' @local lenBytes - Length in bytes
' @local byte - TBD - byte

    workerCog := dfs.init()

    status := dfs.format(dfs.DEV_FLASH)
    if status < 0
        utils.showErrorCode(@"format()", status)
    else
        status := dfs.mount(dfs.DEV_FLASH)
        if status < 0
            utils.showErrorCode(@"mount()", status)
        else
            utils.ShowStats()
            utils.showFiles()
            utils.showChipAndDriverVersion()

            utils.startTest(@"Ensure we have no files at start")
            utils.ensureEmptyDirectory()

            ' ----------------------------------
            ' Setup: create files in different "directories" from root context
            '   rootfile.dat          (root level)
            '   dirA/alpha.dat        (in dirA)
            '   dirA/beta.dat         (in dirA)
            '   dirB/gamma.dat        (in dirB)
            '   deep1/deep2/alpha.dat (nested)
            ' ----------------------------------
            setup_test_files()

            ' ==============================================================
            ' GROUP 1: changeDirectory() basics (4 tests)
            ' ==============================================================
            utils.startTestGroup(@"changeDirectory() basics")

            utils.startTest(@"cd to dirA succeeds")
            status := dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            utils.evaluateSingleValue(status, @"changeDirectory(dirA)", dfs.SUCCESS)

            utils.startTest(@"exists() sees file in dirA via CWD")
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileAlpha)
            utils.evaluateBool(found, @"exists(alpha.dat) in dirA", TRUE)

            utils.startTest(@"root file NOT visible from dirA")
            found := dfs.exists(dfs.DEV_FLASH, @rootFile1)
            utils.evaluateBool(found, @"exists(rootfile.dat) from dirA", FALSE)

            utils.startTest(@"cd to root restores root view")
            status := dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            utils.evaluateSubValue(status, @"changeDirectory(/)", dfs.SUCCESS)
            found := dfs.exists(dfs.DEV_FLASH, @rootFile1)
            utils.evaluateSubBool(found, @"exists(rootfile.dat) at root", TRUE)

            ' ==============================================================
            ' GROUP 2: changeDirectory("..") parent navigation (4 tests)
            ' ==============================================================
            utils.startTestGroup(@"changeDirectory(..) parent navigation")

            utils.startTest(@"cd dirA then .. returns to root")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            status := dfs.changeDirectory(dfs.DEV_FLASH, @cwdDotDot)
            utils.evaluateSubValue(status, @"changeDirectory(..)", dfs.SUCCESS)
            found := dfs.exists(dfs.DEV_FLASH, @rootFile1)
            utils.evaluateSubBool(found, @"root file visible after ..", TRUE)

            utils.startTest(@".. from root is no-op")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            status := dfs.changeDirectory(dfs.DEV_FLASH, @cwdDotDot)
            utils.evaluateSubValue(status, @"changeDirectory(..) at root", dfs.SUCCESS)
            found := dfs.exists(dfs.DEV_FLASH, @rootFile1)
            utils.evaluateSubBool(found, @"root file still visible", TRUE)

            utils.startTest(@"nested cd deep1/deep2 then .. goes to deep1")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep1)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep2)
            ' Now at deep1/deep2 -- alpha.dat should be visible
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileAlpha)
            utils.evaluateSubBool(found, @"alpha.dat at deep1/deep2", TRUE)
            ' Go up one level to deep1
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDotDot)
            ' deep1/deep2/alpha.dat should NOT be visible (it has a "/" after deep1 prefix)
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileAlpha)
            utils.evaluateSubBool(found, @"alpha.dat not at deep1", FALSE)

            utils.startTest(@"multiple .. from deep navigates to root")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep1)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep2)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDotDot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDotDot)
            found := dfs.exists(dfs.DEV_FLASH, @rootFile1)
            utils.evaluateBool(found, @"root file after double ..", TRUE)

            ' ==============================================================
            ' GROUP 3: changeDirectory("/") reset (2 tests)
            ' ==============================================================
            utils.startTestGroup(@"changeDirectory(/) reset to root")

            utils.startTest(@"/ from nested dir goes to root")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep1)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep2)
            status := dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            utils.evaluateSubValue(status, @"changeDirectory(/)", dfs.SUCCESS)
            found := dfs.exists(dfs.DEV_FLASH, @rootFile1)
            utils.evaluateSubBool(found, @"root file visible after /", TRUE)

            utils.startTest(@"directory() at root shows only root files")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            ' Count files visible at root -- should be rootfile.dat and rootother.dat
            testValue := count_visible_files(@filename)
            utils.evaluateSingleValue(testValue, @"root file count", 2)

            ' ==============================================================
            ' GROUP 4: CWD file isolation (4 tests)
            ' ==============================================================
            utils.startTestGroup(@"CWD file isolation")

            utils.startTest(@"file in dirA not visible from dirB")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileAlpha)
            utils.evaluateBool(found, @"alpha.dat NOT in dirB", FALSE)

            utils.startTest(@"file in dirB not visible from dirA")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileGamma)
            utils.evaluateBool(found, @"gamma.dat NOT in dirA", FALSE)

            utils.startTest(@"directory() in dirA shows only dirA files")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            testValue := count_visible_files(@filename)
            utils.evaluateSingleValue(testValue, @"dirA file count", 2)

            utils.startTest(@"directory() in dirB shows only dirB files")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            testValue := count_visible_files(@filename)
            utils.evaluateSingleValue(testValue, @"dirB file count", 1)

            ' ==============================================================
            ' GROUP 5: openDirectory(DEV_FLASH) basic (3 tests)
            ' ==============================================================
            utils.startTestGroup(@"openDirectory(DEV_FLASH) basic")

            utils.startTest(@"openDirectory(.) succeeds")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            handle := dfs.openDirectory(dfs.DEV_FLASH, @".")
            bValidHndl := (handle >= 0)
            utils.evaluateSubBool(bValidHndl, @"handle >= 0", TRUE)
            if bValidHndl == TRUE
              dfs.closeDirectoryHandle(handle)

            utils.startTest(@"readDirectoryHandle enumerates root files")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            handle := dfs.openDirectory(dfs.DEV_FLASH, @".")
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
              testValue := 0
              repeat
                if dfs.readDirectoryHandle(handle) == 0
                  quit
                testValue++
              dfs.closeDirectoryHandle(handle)
            ' Root has rootFile1 + dirA/ pseudo-entry + dirB/ pseudo-entry = at least 3
            utils.evaluateSubBool(testValue >= 3, @"root has >= 3 entries", TRUE)

            utils.startTest(@"closeDirectoryHandle releases handle")
            handle := dfs.openDirectory(dfs.DEV_FLASH, @".")
            bValidHndl := (handle >= 0)
            utils.evaluateSubBool(bValidHndl, @"first open ok", TRUE)
            if bValidHndl == TRUE
              dfs.closeDirectoryHandle(handle)
            handle := dfs.openDirectory(dfs.DEV_FLASH, @".")
            bValidHndl := (handle >= 0)
            utils.evaluateSubBool(bValidHndl, @"reopen after close ok", TRUE)
            if bValidHndl == TRUE
              dfs.closeDirectoryHandle(handle)

            ' ==============================================================
            ' GROUP 6: CWD-aware file operations (4 tests)
            ' ==============================================================
            utils.startTestGroup(@"CWD-aware file operations")

            ' Test: open + read in CWD context
            utils.startTest(@"open + read file via CWD")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            handle := dfs.open(dfs.DEV_FLASH, @cwdFileAlpha, dfs.FILEMODE_READ)
            utils.evaluateSubHandle(handle, @"open(alpha.dat) in dirA")
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                lenBytes := dfs.rd_str(handle, @filename, dfs.FL_FILENAME_SIZE)
                utils.evaluateSubStringMatch(@filename, @"rd_str()", @cwdTestData)
                dfs.close(handle)

            ' Test: delete via CWD
            utils.startTest(@"delete file via CWD only affects CWD prefix")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            status := dfs.deleteFile(dfs.DEV_FLASH, @cwdFileBeta)
            utils.evaluateSubValue(status, @"deleteFile(beta.dat) in dirA", dfs.SUCCESS)
            ' Verify beta gone from dirA
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileBeta)
            utils.evaluateSubBool(found, @"beta.dat gone from dirA", FALSE)
            ' Verify dirB file still exists
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileGamma)
            utils.evaluateSubBool(found, @"gamma.dat still in dirB", TRUE)

            ' Test: rename via CWD
            utils.startTest(@"rename file respects CWD prefix")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            status := dfs.rename(dfs.DEV_FLASH, @cwdFileAlpha, @cwdRenameTarget)
            utils.evaluateSubValue(status, @"rename(alpha->renamed) in dirA", dfs.SUCCESS)
            ' Verify renamed file exists in dirA
            found := dfs.exists(dfs.DEV_FLASH, @cwdRenameTarget)
            utils.evaluateSubBool(found, @"renamed.dat exists in dirA", TRUE)
            ' Verify old name gone
            found := dfs.exists(dfs.DEV_FLASH, @cwdFileAlpha)
            utils.evaluateSubBool(found, @"alpha.dat gone from dirA", FALSE)

            ' Test: exists on non-existent file in valid CWD
            utils.startTest(@"exists returns false for missing file in valid CWD")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            found := dfs.exists(dfs.DEV_FLASH, @rootFile1)
            utils.evaluateBool(found, @"rootfile.dat NOT in dirA", FALSE)

            ' ==============================================================
            ' GROUP 7: moveFile() on Flash (4 tests)
            ' ==============================================================
            utils.startTestGroup(@"moveFile() on Flash")

            ' Re-setup: recreate dirA/alpha.dat (was renamed in group 6)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            handle := dfs.open(dfs.DEV_FLASH, @cwdFileAlpha, dfs.FILEMODE_WRITE)
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                dfs.wr_str(handle, @cwdTestData)
                dfs.close(handle)

            ' Create moveme.dat in dirA
            handle := dfs.open(dfs.DEV_FLASH, @cwdMoveFile, dfs.FILEMODE_WRITE)
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                dfs.wr_str(handle, @cwdTestData)
                dfs.close(handle)

            utils.startTest(@"moveFile from dirA to dirB")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            status := dfs.moveFile(dfs.DEV_FLASH, @cwdMoveFile, @cwdDirB)
            utils.evaluateSubValue(status, @"moveFile(moveme.dat, dirB)", dfs.SUCCESS)
            ' Verify gone from dirA
            found := dfs.exists(dfs.DEV_FLASH, @cwdMoveFile)
            utils.evaluateSubBool(found, @"moveme.dat gone from dirA", FALSE)
            ' Verify present in dirB
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            found := dfs.exists(dfs.DEV_FLASH, @cwdMoveFile)
            utils.evaluateSubBool(found, @"moveme.dat now in dirB", TRUE)

            utils.startTest(@"moveFile from dirB to root")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            status := dfs.moveFile(dfs.DEV_FLASH, @cwdMoveFile, @cwdEmptyStr)
            utils.evaluateSubValue(status, @"moveFile(moveme.dat, root)", dfs.SUCCESS)
            ' Verify gone from dirB
            found := dfs.exists(dfs.DEV_FLASH, @cwdMoveFile)
            utils.evaluateSubBool(found, @"moveme.dat gone from dirB", FALSE)
            ' Verify present at root
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            found := dfs.exists(dfs.DEV_FLASH, @cwdMoveFile)
            utils.evaluateSubBool(found, @"moveme.dat now at root", TRUE)

            utils.startTest(@"moveFile to same dir returns error")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            ' moveme.dat is at root, move to root (empty dest)
            status := dfs.moveFile(dfs.DEV_FLASH, @cwdMoveFile, @cwdEmptyStr)
            utils.evaluateSingleValue(status, @"moveFile same dir", dfs.E_FLASH_FILE_EXISTS)

            utils.startTest(@"moveFile preserves file content")
            ' Move moveme.dat from root back to dirA, then read it
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            status := dfs.moveFile(dfs.DEV_FLASH, @cwdMoveFile, @cwdDirA)
            utils.evaluateSubValue(status, @"moveFile(moveme.dat, dirA)", dfs.SUCCESS)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            handle := dfs.open(dfs.DEV_FLASH, @cwdMoveFile, dfs.FILEMODE_READ)
            utils.evaluateSubHandle(handle, @"open moved file for read")
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                lenBytes := dfs.rd_str(handle, @filename, dfs.FL_FILENAME_SIZE)
                utils.evaluateSubStringMatch(@filename, @"moved file content", @cwdTestData)
                dfs.close(handle)

            ' Cleanup: delete the moved file
            dfs.deleteFile(dfs.DEV_FLASH, @cwdMoveFile)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

            ' ==============================================================
            ' GROUP 8: Absolute path basics (5 tests)
            ' ==============================================================
            utils.startTestGroup(@"Absolute path basics")

            ' Re-setup: recreate dirA/alpha.dat (was renamed in group 6)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            handle := dfs.open(dfs.DEV_FLASH, @cwdFileAlpha, dfs.FILEMODE_WRITE)
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                dfs.wr_str(handle, @cwdTestData)
                dfs.close(handle)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

            utils.startTest(@"exists() via absolute path from root CWD")
            found := dfs.exists(dfs.DEV_FLASH, @absPathDirAAlph)
            utils.evaluateBool(found, @"exists(/dirA/alpha.dat) from root", TRUE)

            utils.startTest(@"exists() via absolute path ignores CWD")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            found := dfs.exists(dfs.DEV_FLASH, @absPathDirAAlph)
            utils.evaluateBool(found, @"exists(/dirA/alpha.dat) from dirB", TRUE)

            utils.startTest(@"file_size() via absolute path from any CWD")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            fileSize := dfs.file_size(dfs.DEV_FLASH, @absPathDirAAlph)
            status := dfs.error()
            utils.evaluateSubValue(fileSize, @"file_size(/dirA/alpha.dat)", strsize(@cwdTestData) + 1)
            utils.evaluateSubStatus(status, @"file_size() status", dfs.SUCCESS)

            utils.startTest(@"create file via absolute path while CWD is different")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            handle := dfs.open(dfs.DEV_FLASH, @absPathDirBFile, dfs.FILEMODE_WRITE)
            utils.evaluateSubHandle(handle, @"open(/dirB/absfile.dat) from dirA")
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                dfs.wr_str(handle, @absTestData)
                dfs.close(handle)
            ' Verify it's in dirB
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            found := dfs.exists(dfs.DEV_FLASH, @absFile)
            utils.evaluateSubBool(found, @"absfile.dat visible in dirB", TRUE)

            utils.startTest(@"deleteFile() via absolute path from any CWD")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            status := dfs.deleteFile(dfs.DEV_FLASH, @absPathDirBFile)
            utils.evaluateSubValue(status, @"deleteFile(/dirB/absfile.dat)", dfs.SUCCESS)
            ' Verify it's gone
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            found := dfs.exists(dfs.DEV_FLASH, @absFile)
            utils.evaluateSubBool(found, @"absfile.dat gone from dirB", FALSE)

            ' ==============================================================
            ' GROUP 9: Absolute path edge cases (5 tests)
            ' ==============================================================
            utils.startTestGroup(@"Absolute path edge cases")

            utils.startTest(@"Root absolute path /rootabs.dat")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            handle := dfs.open(dfs.DEV_FLASH, @absPathRootFile, dfs.FILEMODE_WRITE)
            utils.evaluateSubHandle(handle, @"open(/rootabs.dat)")
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                dfs.wr_str(handle, @absTestData)
                dfs.close(handle)
            ' Verify visible at root
            found := dfs.exists(dfs.DEV_FLASH, @rootAbsFile)
            utils.evaluateSubBool(found, @"rootabs.dat visible at root", TRUE)

            utils.startTest(@"Absolute path ignores CWD - no double prefix")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            ' Opening /dirB/gamma.dat from dirA should NOT look for dirA/dirB/gamma.dat
            found := dfs.exists(dfs.DEV_FLASH, @absPathDirBGamm)
            utils.evaluateBool(found, @"exists(/dirB/gamma.dat) from dirA", TRUE)

            utils.startTest(@"Absolute vs relative isolation")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            ' Create abstest.dat in dirA via absolute path
            handle := dfs.open(dfs.DEV_FLASH, @absPathDirATest, dfs.FILEMODE_WRITE)
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                dfs.wr_str(handle, @absTestData)
                dfs.close(handle)
            ' Verify via CWD (relative) -- cd to dirA, check abstest.dat
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            found := dfs.exists(dfs.DEV_FLASH, @absTestFile)
            utils.evaluateSubBool(found, @"abstest.dat visible via relative in dirA", TRUE)
            ' Verify NOT visible in dirB
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            found := dfs.exists(dfs.DEV_FLASH, @absTestFile)
            utils.evaluateSubBool(found, @"abstest.dat NOT visible in dirB", FALSE)

            utils.startTest(@"Rename via absolute paths from non-root CWD")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            status := dfs.rename(dfs.DEV_FLASH, @absPathDirATest, @absPathRename)
            utils.evaluateSubValue(status, @"rename(/dirA/abstest->/dirA/absrename)", dfs.SUCCESS)
            ' Verify new name exists
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
            found := dfs.exists(dfs.DEV_FLASH, @absRenameFile)
            utils.evaluateSubBool(found, @"absrename.dat visible in dirA", TRUE)

            utils.startTest(@"Round-trip: write via absolute, read via absolute")
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
            handle := dfs.open(dfs.DEV_FLASH, @absPathRename, dfs.FILEMODE_READ)
            utils.evaluateSubHandle(handle, @"open(/dirA/absrename.dat) from dirB")
            bValidHndl := (handle >= 0)
            if bValidHndl == TRUE
                lenBytes := dfs.rd_str(handle, @filename, dfs.FL_FILENAME_SIZE)
                utils.evaluateSubStringMatch(@filename, @"rd_str() content", @absTestData)
                dfs.close(handle)

            ' --------------------------------------------------------------
            ' Cleanup: return to root
            dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

#ifdef SD_INCLUDE_STACK_CHECK
    debug(" ")
    debug("* Worker cog stack: ", udec_(dfs.reportStackDepth()), " of ", udec_(dfs.STACK_SIZE), " longs used")
#endif

    dfs.stop()

    utils.ShowTestEndCounts()

    debug("* CWD Tests Complete")
    debug("END_SESSION")


PRI setup_test_files() | fileHndl, bValidHndl
' Create test files at various "directory" levels using full paths from root context.
' Flash CWD starts at root (empty prefix), so we create files with embedded "/" paths.

    ' Ensure at root
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)

    ' rootfile.dat (root level)
    fileHndl := dfs.open(dfs.DEV_FLASH, @rootFile1, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @cwdTestData)
        dfs.close(fileHndl)

    ' rootother.dat (root level)
    fileHndl := dfs.open(dfs.DEV_FLASH, @rootFile2, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @cwdTestData)
        dfs.close(fileHndl)

    ' dirA/alpha.dat -- cd to dirA, then create alpha.dat
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirA)
    fileHndl := dfs.open(dfs.DEV_FLASH, @cwdFileAlpha, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @cwdTestData)
        dfs.close(fileHndl)

    ' dirA/beta.dat -- still in dirA
    fileHndl := dfs.open(dfs.DEV_FLASH, @cwdFileBeta, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @cwdTestData)
        dfs.close(fileHndl)

    ' dirB/gamma.dat -- cd to dirB
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirB)
    fileHndl := dfs.open(dfs.DEV_FLASH, @cwdFileGamma, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @cwdTestData)
        dfs.close(fileHndl)

    ' deep1/deep2/alpha.dat -- nested cd
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep1)
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdDirDeep2)
    fileHndl := dfs.open(dfs.DEV_FLASH, @cwdFileAlpha, dfs.FILEMODE_WRITE)
    bValidHndl := (fileHndl >= 0)
    if bValidHndl == TRUE
        dfs.wr_str(fileHndl, @cwdTestData)
        dfs.close(fileHndl)

    ' Return to root for tests
    dfs.changeDirectory(dfs.DEV_FLASH, @cwdRoot)


PRI count_visible_files(p_filename) : count | blockId, fileSize
' Count the number of files visible via directory() in the current CWD.
' @param p_filename - pointer to FL_FILENAME_SIZE-byte buffer for filename (reused)
' @returns count - number of files visible

    count := 0
    blockId := 0
    repeat
        dfs.directory(dfs.DEV_FLASH, @blockId, p_filename, @fileSize)
        if BYTE[p_filename][0] == 0
            quit
        count++


