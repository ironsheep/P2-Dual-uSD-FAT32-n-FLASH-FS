'' =================================================================================================
''
''   File....... DFS_SD_RT_subdir_ops_tests.spin2
''   Purpose.... Regression tests for file operations in subdirectories
''               Tests cross-buffer cache coherence, empty file handling,
''               and interleaved create/dir/delete sequences
''   Author..... Stephen M Moraco
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... FEB 2026
''   Updated.... 23 FEB 2026
''
'' =================================================================================================
''
'' These tests specifically target edge cases missed by SD_RT_file_ops_tests:
''   1. File operations in subdirectories (not just root)
''   2. Cross-buffer cache coherence (BUF_DIR vs BUF_DATA)
''   3. Empty file (0-byte) create/delete/rename
''   4. Interleaved create + dir + delete sequences
''   5. Dir enumeration immediately after file creation
''
'' =================================================================================================

CON

     _CLKFREQ        = 350_000_000
     DEBUG_BAUD      = 2_000_000

     ' P2 Edge module SD slot pins
     SD_CS   = 60
     SD_MOSI = 59
     SD_MISO = 58
     SD_SCK  = 61

     ' External SD header (base pin 16)
     'SD_CS   = 20
     'SD_MOSI = 19
     'SD_MISO = 18
     'SD_SCK  = 21

     ' V3 Error codes
     E_FILE_EXISTS     = -41
     E_FILE_NOT_FOUND  = -40
     E_NOT_A_FILE      = -42
     E_NOT_A_DIR       = -43

#IFDEF __SPINTOOLS__
#DEFINE SD_INCLUDE_RAW
#DEFINE SD_INCLUDE_DEBUG
#ELSEIFDEF __FLEXSPIN__
#define SD_INCLUDE_RAW
#pragma exportdef SD_INCLUDE_RAW
#define SD_INCLUDE_DEBUG
#pragma exportdef SD_INCLUDE_DEBUG
#ELSE
'' Enable raw sector access and debug methods for diagnostic tests
#PRAGMA EXPORTDEF SD_INCLUDE_RAW
#PRAGMA EXPORTDEF SD_INCLUDE_DEBUG
#ENDIF

OBJ
    dfs   : "dual_sd_fat32_flash_fs"
    utils : "isp_rt_utilities"

DAT

' Test directory and filenames - unique to avoid conflicts with other tests
testdir        BYTE    "RTSUB1", 0
testfile1      BYTE    "RTSF1.TXT", 0
testfile2      BYTE    "RTSF2.TXT", 0
testfile3      BYTE    "RTSF3.TXT", 0
emptyFile      BYTE    "EMPTY.TXT", 0
renamedEmpty   BYTE    "RENAMED.TXT", 0
dotPath        BYTE    ".", 0
dotdotPath     BYTE    "..", 0
testContent1   BYTE    "Hello from subdir", 0

PUB go() | workerCog, result, status, handle, dh, count, pEntry, i
'' Main entry point for subdirectory operations regression tests

    debug(" ")
    debug("==============================================")
    debug("  Dual FS (SD) V3 - Subdirectory Ops Tests")
    debug("  (Cross-Buffer Cache + Edge Cases)")
    debug("==============================================")

    ' Initialize worker cog
    workerCog := dfs.init(SD_CS, SD_MOSI, SD_MISO, SD_SCK)

    ' Mount the card first
    result := dfs.mount(dfs.DEV_SD)
    if result == false
        debug("ERROR: Could not mount SD card!")
        dfs.stop()
        debug("END_SESSION")
        return

    ' Show card info
    debug(" ")
    debug("* SD Card Information:")
    debug("   Volume Label: ", zstr_(dfs.volumeLabel(dfs.DEV_SD)))

    ' Clear root directory for clean slate
    debug("  CLEARING ROOT DIRECTORY...")
    result := dfs.debugClearRootDir()
    debug("  Clear result: ", sdec_(result))

    ' ══════════════════════════════════════════════════════════════════════
    ' TEST GROUP: Empty file operations in root directory
    ' ══════════════════════════════════════════════════════════════════════
    utils.startTestGroup(@"Empty File Operations (Root)")

    ' Test #1: Create empty file (0 bytes, like touch)
    utils.startTest(@"createFileNew() empty file returns valid handle")
    handle := dfs.createFileNew(dfs.DEV_SD, @emptyFile)
    utils.evaluateSubBool(handle >= 0, @"createFileNew() empty", true)
    if handle >= 0
        dfs.closeFileHandle(handle)                                                 ' Close immediately - no data written
    utils.showSubTestResults()

    ' Test #2: Verify empty file size is 0
    utils.startTest(@"Empty file has size 0")
    handle := dfs.openFileRead(dfs.DEV_SD, @emptyFile)
    if handle >= 0
        result := dfs.fileSizeHandle(handle)
        utils.evaluateSingleValue(result, @"fileSizeHandle()", 0)
        dfs.closeFileHandle(handle)
    else
        utils.evaluateSingleValue(handle, @"openFileRead() empty", 0)

    ' Test #3: Delete empty file succeeds
    utils.startTest(@"deleteFile() on empty file succeeds")
    status := dfs.deleteFile(dfs.DEV_SD, @emptyFile)
    utils.evaluateSingleValue(status, @"deleteFile() empty", dfs.SUCCESS)

    ' Test #4: Verify empty file is deleted
    utils.startTest(@"Verify empty file deleted (openFileRead fails)")
    handle := dfs.openFileRead(dfs.DEV_SD, @emptyFile)
    utils.evaluateSingleValue(handle, @"openFileRead() after delete", E_FILE_NOT_FOUND)

    ' ══════════════════════════════════════════════════════════════════════
    ' TEST GROUP: Dir enumeration immediately after file creation
    ' ══════════════════════════════════════════════════════════════════════
    utils.startTestGroup(@"Dir After Create (Cache Coherence)")

    ' Test #5: Create file then immediately enumerate directory
    utils.startTest(@"Dir sees file immediately after createFileNew")
    handle := dfs.createFileNew(dfs.DEV_SD, @testfile1)
    if handle >= 0
        dfs.closeFileHandle(handle)
    ' Now enumerate root directory and count entries
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    utils.evaluateSubBool(count >= 1, @"dir sees created file", true)
    utils.showSubTestResults()

    ' Clean up
    dfs.deleteFile(dfs.DEV_SD, @testfile1)

    ' Test #6: Create file, dir, create another, dir again - both visible
    utils.startTest(@"Second create visible in dir without re-mount")
    utils.setCheckCountPerTest(2)
    handle := dfs.createFileNew(dfs.DEV_SD, @testfile1)
    if handle >= 0
        dfs.closeFileHandle(handle)
    ' Dir - should see testfile1
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    utils.evaluateSubBool(count >= 1, @"first file in dir", true)
    ' Create second file
    handle := dfs.createFileNew(dfs.DEV_SD, @testfile2)
    if handle >= 0
        dfs.closeFileHandle(handle)
    ' Dir again - should see both
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    utils.evaluateSubBool(count >= 2, @"both files in dir", true)
    utils.showSubTestResults()

    ' Clean up
    dfs.deleteFile(dfs.DEV_SD, @testfile1)
    dfs.deleteFile(dfs.DEV_SD, @testfile2)

    ' ══════════════════════════════════════════════════════════════════════
    ' TEST GROUP: Subdirectory creation and file operations
    ' ══════════════════════════════════════════════════════════════════════
    utils.startTestGroup(@"Subdirectory File Operations")

    ' Test #7: mkdir and cd into subdirectory
    utils.startTest(@"mkdir and cd into subdirectory")
    utils.setCheckCountPerTest(2)
    status := dfs.newDirectory(dfs.DEV_SD, @testdir)
    utils.evaluateSubValue(status, @"newDirectory()", dfs.SUCCESS)
    status := dfs.changeDirectory(dfs.DEV_SD, @testdir)
    utils.evaluateSubValue(status, @"changeDirectory()", dfs.SUCCESS)
    utils.showSubTestResults()

    ' Test #8: Create file in subdirectory
    utils.startTest(@"createFileNew() in subdirectory")
    handle := dfs.createFileNew(dfs.DEV_SD, @testfile1)
    utils.evaluateSubBool(handle >= 0, @"createFileNew() in subdir", true)
    if handle >= 0
        dfs.closeFileHandle(handle)
    utils.showSubTestResults()

    ' Test #9: Dir in subdirectory sees file immediately after create
    ' This is the CRITICAL test for cross-buffer cache coherence:
    '   - createFileNew writes directory entry via BUF_DIR
    '   - readDirectoryHandle reads directory entries via BUF_DATA
    '   - If writeSector doesn't cross-invalidate BUF_DATA cache, dir misses the file
    utils.startTest(@"Dir sees file in subdirectory after create")
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    debug("  dir count in subdir: ", udec_(count))
    ' Expected: at least 3 entries (., .., testfile1)
    utils.evaluateSubBool(count >= 3, @"subdir has . + .. + file", true)
    utils.showSubTestResults()

    ' Test #10: Create second file and verify both visible
    utils.startTest(@"Second file visible in subdirectory dir")
    utils.setCheckCountPerTest(2)
    handle := dfs.createFileNew(dfs.DEV_SD, @testfile2)
    utils.evaluateSubBool(handle >= 0, @"createFileNew() #2 in subdir", true)
    if handle >= 0
        dfs.writeHandle(handle, @testContent1, strsize(@testContent1))
        dfs.closeFileHandle(handle)
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    debug("  dir count after 2nd file: ", udec_(count))
    ' Expected: at least 4 entries (., .., testfile1, testfile2)
    utils.evaluateSubBool(count >= 4, @"subdir has . + .. + 2 files", true)
    utils.showSubTestResults()

    ' Test #11: Dir then create then dir again (cache pollution scenario)
    ' This tests the specific scenario:
    '   1. Dir loads subdir sector into BUF_DATA cache
    '   2. Create writes new entry via BUF_DIR
    '   3. Dir again - BUF_DATA cache must not return stale data
    utils.startTest(@"Dir-Create-Dir shows new file (cache invalidation)")
    ' First dir - loads BUF_DATA cache with current subdir sector
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    debug("  before create: ", udec_(count), " entries")
    ' Now create a third file (writes via BUF_DIR, BUF_DATA has stale data)
    handle := dfs.createFileNew(dfs.DEV_SD, @testfile3)
    if handle >= 0
        dfs.closeFileHandle(handle)
    ' Dir again - must see the new file despite BUF_DATA cache
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    result := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            result++
        dfs.closeDirectoryHandle(dh)
    debug("  after create: ", udec_(result), " entries")
    utils.evaluateSubBool(result > count, @"new file visible after cache", true)
    utils.showSubTestResults()

    ' ══════════════════════════════════════════════════════════════════════
    ' TEST GROUP: Delete in subdirectory
    ' ══════════════════════════════════════════════════════════════════════
    utils.startTestGroup(@"Delete in Subdirectory")

    ' Test #12: Delete empty file in subdirectory
    utils.startTest(@"Delete empty file in subdirectory")
    status := dfs.deleteFile(dfs.DEV_SD, @testfile1)
    utils.evaluateSingleValue(status, @"deleteFile() empty in subdir", dfs.SUCCESS)

    ' Test #13: Verify deleted file not found
    utils.startTest(@"Deleted file not found in subdirectory")
    handle := dfs.openFileRead(dfs.DEV_SD, @testfile1)
    utils.evaluateSingleValue(handle, @"openFileRead() after del", E_FILE_NOT_FOUND)

    ' Test #14: Delete file with data in subdirectory
    utils.startTest(@"Delete file with data in subdirectory")
    status := dfs.deleteFile(dfs.DEV_SD, @testfile2)
    utils.evaluateSingleValue(status, @"deleteFile() data in subdir", dfs.SUCCESS)

    ' Test #15: Dir after delete shows fewer entries
    utils.startTest(@"Dir after delete shows correct count")
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    debug("  entries after deletes: ", udec_(count))
    ' Expected: 3 entries (., .., testfile3) - two files deleted
    utils.evaluateSubBool(count == 3, @"correct count after deletes", true)
    utils.showSubTestResults()

    ' ══════════════════════════════════════════════════════════════════════
    ' TEST GROUP: Rename in subdirectory
    ' ══════════════════════════════════════════════════════════════════════
    utils.startTestGroup(@"Rename in Subdirectory")

    ' Test #16: Create empty file and rename it
    utils.startTest(@"Create empty file then rename in subdir")
    utils.setCheckCountPerTest(2)
    handle := dfs.createFileNew(dfs.DEV_SD, @emptyFile)
    utils.evaluateSubBool(handle >= 0, @"createFileNew() empty", true)
    if handle >= 0
        dfs.closeFileHandle(handle)
    status := dfs.rename(dfs.DEV_SD, @emptyFile, @renamedEmpty)
    utils.evaluateSubValue(status, @"rename() empty file", dfs.SUCCESS)
    utils.showSubTestResults()

    ' Test #17: Original name gone, new name accessible
    utils.startTest(@"Renamed file accessible under new name")
    utils.setCheckCountPerTest(2)
    handle := dfs.openFileRead(dfs.DEV_SD, @emptyFile)
    utils.evaluateSubValue(handle, @"old name gone", E_FILE_NOT_FOUND)
    handle := dfs.openFileRead(dfs.DEV_SD, @renamedEmpty)
    utils.evaluateSubBool(handle >= 0, @"new name accessible", true)
    if handle >= 0
        dfs.closeFileHandle(handle)
    utils.showSubTestResults()

    ' ══════════════════════════════════════════════════════════════════════
    ' TEST GROUP: Navigation and operations across directories
    ' ══════════════════════════════════════════════════════════════════════
    utils.startTestGroup(@"Cross-Directory Operations")

    ' Test #18: cd .. then cd back, files still visible
    utils.startTest(@"cd .. then cd back preserves dir contents")
    utils.setCheckCountPerTest(3)
    status := dfs.changeDirectory(dfs.DEV_SD, @dotdotPath)
    utils.evaluateSubValue(status, @"cd ..", dfs.SUCCESS)
    status := dfs.changeDirectory(dfs.DEV_SD, @testdir)
    utils.evaluateSubValue(status, @"cd back", dfs.SUCCESS)
    ' Dir should still show files
    dh := dfs.openDirectory(dfs.DEV_SD, @dotPath)
    count := 0
    if dh >= 0
        repeat
            pEntry := dfs.readDirectoryHandle(dh)
            if pEntry == 0
                quit
            count++
        dfs.closeDirectoryHandle(dh)
    debug("  entries after cd round-trip: ", udec_(count))
    utils.evaluateSubBool(count >= 3, @"files survived cd round-trip", true)
    utils.showSubTestResults()

    ' ══════════════════════════════════════════════════════════════════════
    ' CLEANUP
    ' ══════════════════════════════════════════════════════════════════════
    debug(" ")
    debug("* Cleaning up test files...")

    ' Delete remaining files in subdirectory
    dfs.deleteFile(dfs.DEV_SD, @testfile3)
    dfs.deleteFile(dfs.DEV_SD, @renamedEmpty)

    ' cd back to root and remove test directory
    dfs.changeDirectory(dfs.DEV_SD, @dotdotPath)
    dfs.deleteFile(dfs.DEV_SD, @testdir)                                                        ' rmdir

    ' Unmount
    dfs.unmount(dfs.DEV_SD)

    ' Show results
    dfs.stop()

    utils.ShowTestEndCounts()

    debug(" ")
    debug("* Subdirectory Ops Tests Complete")
    debug("END_SESSION")
