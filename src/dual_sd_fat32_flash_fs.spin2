{Spin2_v46}
'' =================================================================================================
''
''   File....... dual_sd_fat32_flash_fs.spin2
''   Purpose.... Unified dual filesystem driver -- SD FAT32 + onboard Flash for P2 Edge Module
''   Author..... Stephen M Moraco
''               Based on: Chris Gadd SD V3, Chip Gracey flash_fs
''               -- see below for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... 2023
''   Updated.... 18 MAR 2026
''
'' =================================================================================================
{{
  Unified SD + Flash filesystem driver for the P2 Edge Module.
  Both devices share SPI bus (P58-P61) with P60/P61 role-swapping.
  See DUAL-DRIVER-TUTORIAL.md for usage examples.
}}

'' ===============================================================================
'' CONDITIONAL COMPILATION - Optional Feature Modules
'' ===============================================================================
'' Default: MINIMAL driver (core file operations only)
'' To enable optional features, use #pragma exportdef in your top-level file:
''
'' Hardware Access Flags:
''   #pragma exportdef SD_INCLUDE_RAW        ' Raw sector access
''   #pragma exportdef SD_INCLUDE_REGISTERS  ' Card register access (CID/CSD/SCR)
''   #pragma exportdef SD_INCLUDE_SPEED      ' High-speed mode control (requires REGISTERS)
''   #pragma exportdef SD_INCLUDE_DEBUG      ' Debug/diagnostic methods & CRC getters
''
'' User-Selectable Feature Flags:
''   #pragma exportdef SD_INCLUDE_ASYNC      ' Non-blocking I/O: startRead/WriteHandle, isComplete, getResult
''   #pragma exportdef SD_INCLUDE_DEFRAG     ' Defragmentation: fileFragments, compactFile, createFileContiguous
''
'' Diagnostic:
''   #pragma exportdef SD_INCLUDE_STACK_CHECK ' Worker cog stack depth measurement
''
''   OBJ
''       fs : "dual_sd_fat32_flash_fs"
''
'' Or define SD_INCLUDE_ALL to include everything (except STACK_CHECK):
''   #pragma exportdef SD_INCLUDE_ALL
'' ===============================================================================

#ifdef SD_INCLUDE_ALL
#ifndef SD_INCLUDE_RAW
#define SD_INCLUDE_RAW
#endif
#ifndef SD_INCLUDE_REGISTERS
#define SD_INCLUDE_REGISTERS
#endif
#ifndef SD_INCLUDE_SPEED
#define SD_INCLUDE_SPEED
#endif
#ifndef SD_INCLUDE_DEBUG
#define SD_INCLUDE_DEBUG
#endif
#ifndef SD_INCLUDE_ASYNC
#define SD_INCLUDE_ASYNC
#endif
#ifndef SD_INCLUDE_DEFRAG
#define SD_INCLUDE_DEFRAG
#endif
#endif

' SD_INCLUDE_SPEED requires SD_INCLUDE_REGISTERS (checkCMD6Support -> readSCRRaw)
#ifdef SD_INCLUDE_SPEED
#ifndef SD_INCLUDE_REGISTERS
#define SD_INCLUDE_REGISTERS
#endif
#endif


CON ' ---- P2 Edge Module SPI Pin Assignments (fixed hardware) ----
  PIN_SD_CS   = 60    ' SD chip select (also Flash SCK)
  PIN_MOSI    = 59    ' Shared MOSI
  PIN_MISO    = 58    ' Shared MISO
  PIN_SD_SCK  = 61    ' SD serial clock (also Flash CS)
  PIN_FL_CS   = 61    ' Flash chip select (= SD SCK pin)
  PIN_FL_SCK  = 60    ' Flash serial clock (= SD CS pin)

CON ' ---- Device Constants ----
    ' DEVICE CONSTANTS - Target device for path-based and device-level calls
    ' ===========================================================================
  DEV_SD    = 0       ' microSD card (FAT32)
  DEV_FLASH = 1       ' Onboard 16MB Flash chip
  DEV_BOTH  = 2       ' Both devices (for mount/unmount)

  DFS_VERSION   = 1_03_00  ' Dual FS driver version 1.3.0
  SD_VERSION    = 1_05_00  ' SD sub-driver version 1.5.0
  FLASH_VERSION = 2_00_00  ' Flash sub-driver version 2.0.0

CON ' ---- Flash File Open Mode Constants ----
    ' FLASH FILE OPEN MODE CONSTANTS
    ' ===========================================================================
  FILEMODE_READ            = $72      ' "r"
  FILEMODE_WRITE           = $77      ' "w"
  FILEMODE_APPEND          = $61      ' "a"
  FILEMODE_READ_EXTENDED   = $2B72    ' "r+"
  FILEMODE_WRITE_EXTENDED  = $2B77    ' "w+"

CON ' ---- Debug Channel Assignments for Selective Debug Output ----
    ' Channels 0-9 match the standalone SD driver for cross-project consistency.
    ' Channels 10-11 are Flash-unique operations with no SD equivalent.
    ' Enable 2-3 channels at a time to stay under the 255 debug record limit.
    ' Set DEBUG_MASK = 0 for production builds (zero debug overhead).
  CH_INIT    = 0              ' Card/device initialization, pin setup, speed config
  CH_MOUNT   = 1              ' Mount/unmount, filesystem geometry, FSInfo
  CH_FILE    = 2              ' File handle operations: open, close, read, write, seek, sync
  CH_DIR     = 3              ' Directory operations: search, create, rename, move, CWD
  CH_SECTOR  = 4              ' Sector I/O, FAT chain walking, cluster allocation
  CH_STATUS  = 5              ' CMD13/CMD23 probe and runtime status checks
  CH_IDENT   = 6              ' Card/device identity: CID/CSD/SCR, Flash serial number
  CH_HSPEED  = 7              ' High-speed mode: CMD6 query, switch, verification
  CH_API     = 8              ' Public API entry points, worker cog dispatch, stack guard
  CH_RECOVER = 9              ' Error recovery: CMD12, bus recovery, SPI bus switching
  CH_FL_BLOCK = 10            ' Flash block-level I/O: read/write/erase 4KB blocks, wear leveling
  CH_FL_CIRC  = 11            ' Flash circular files: froncate, wrap, old-format detection

  DEBUG_MASK = 0   ' All channels off for committed code (see DECISION-002)

CON  ' flags
  F_NEWDIR  = decod 1
  F_MOUNTED = decod 3

CON ' driver mode (enforces valid command sequences)
  MODE_NONE       = 0       ' Not initialized - only mount() or initCardOnly() allowed
  MODE_RAW        = 1       ' Raw sector access only - initCardOnly() was called
  MODE_FILESYSTEM = 2       ' Full filesystem access - mount() was called

CON ' command codes for worker cog
  CMD_NONE      = 0         ' Idle / command complete
  CMD_MOUNT     = 1         ' Mount filesystem
  CMD_UNMOUNT   = 2         ' Unmount filesystem
  CMD_NEWDIR    = 9         ' Create new directory: param0=dirname ptr
  CMD_DELETE    = 10        ' Delete file: param0=filename ptr
  CMD_RENAME    = 11        ' Rename: param0=oldname, param1=newname
  CMD_CHDIR     = 12        ' Change directory: param0=dirname ptr
  CMD_READDIR   = 13        ' Read directory entry: param0=index
  CMD_FILESIZE  = 14        ' Get file size
  CMD_FREESPACE = 15        ' Get free space
  CMD_SYNC      = 16        ' Flush buffers
  CMD_MOVEFILE  = 17        ' Move file: param0=name, param1=dest folder
#ifdef SD_INCLUDE_DEBUG
  CMD_DEBUG_SLOW_READ  = 25 ' DEBUG: Byte-by-byte sector read (no streamer)
  CMD_DEBUG_CLEAR_ROOT = 26 ' DEBUG: Clear root directory (fixes corruption)
#endif

  CMD_READ_SECTOR_RAW  = 20 ' Raw single sector read (infrastructure -- used across multiple feature flags)

#ifdef SD_INCLUDE_RAW
  CMD_INIT_CARD_ONLY = 22   ' Initialize card without filesystem (raw mode)
  CMD_GET_CARD_SIZE  = 23   ' Get card size in sectors: returns in data0
  CMD_READ_SECTORS  = 18    ' Raw multi-block read: param0=start_sector, param1=count, param2=buffer ptr
  CMD_WRITE_SECTORS = 19    ' Raw multi-block write: param0=start_sector, param1=count, param2=buffer ptr
  CMD_WRITE_SECTOR_RAW = 21 ' Raw single sector write: param0=sector, param1=buffer ptr
  CMD_TEST_CMD13       = 82 ' Test CMD13: returns R2 response in data0
#endif

#ifdef SD_INCLUDE_REGISTERS
  CMD_READ_SCR       = 24   ' Read SCR register: param0=buffer ptr
  CMD_READ_CID         = 27 ' Read CID register: param0=buffer ptr
  CMD_READ_CSD         = 28 ' Read CSD register: param0=buffer ptr
  CMD_READ_SD_STATUS   = 29 ' Read SD Status (ACMD13): 64-byte register via CMD55+CMD13
#endif

#ifdef SD_INCLUDE_SPEED
  CMD_ATTEMPT_HIGH_SPEED  = 83 ' Attempt 50 MHz high-speed: returns data0=boolean
  CMD_CHECK_HS_CAPABILITY = 84 ' Check CMD6 high-speed support: returns data0=boolean
  CMD_SET_SPI_SPEED       = 85 ' Set SPI clock frequency: param0=freq in Hz
#endif

#ifdef SD_INCLUDE_STACK_CHECK
  CMD_STACK_DEPTH         = 86 ' DIAG: Report stack depth used (high-water mark)
#endif

#ifdef SD_INCLUDE_DEFRAG
  CMD_CREATE_CONTIGUOUS   = 87 ' Create file with pre-allocated contiguous chain: param0=path ptr, param1=file_size, returns data0=handle
  CMD_COMPACT_FILE        = 88 ' Defragment a single file: param0=path ptr
  CMD_FILE_FRAGMENTS      = 89 ' Count file fragmentation: param0=path ptr, returns data0=fragment_count
#endif

  ' ===========================================================================
  ' V3 Handle-Based File Commands (multi-file support)
  ' ===========================================================================
  CMD_OPEN_READ   = 30      ' Open file for reading: param0=path ptr, returns data0=handle
  CMD_OPEN_WRITE  = 31      ' Open file for writing (append): param0=path ptr, returns data0=handle
  CMD_CREATE      = 32      ' Create new file for writing: param0=path ptr, returns data0=handle
  CMD_CLOSE_H     = 33      ' Close file handle: param0=handle
  CMD_READ_H      = 34      ' Read from handle: param0=handle, param1=buffer ptr, param2=count, returns data0=bytes_read
  CMD_WRITE_H     = 35      ' Write to handle: param0=handle, param1=buffer ptr, param2=count, returns data0=bytes_written
  CMD_SEEK_H      = 36      ' Seek in handle: param0=handle, param1=position
  CMD_TELL_H      = 37      ' Get position: param0=handle, returns data0=position
  CMD_FILESIZE_H  = 38      ' Get file size: param0=handle, returns data0=size
  CMD_SYNC_H      = 39      ' Sync handle buffer to disk: param0=handle
  CMD_SYNC_ALL    = 40      ' Sync all open file handles
  CMD_EOF_H       = 41      ' Check end of file: param0=handle, returns data0=true/false
  CMD_OPEN_DIR    = 43      ' Open directory: param0=path ptr, returns data0=handle
  CMD_READ_DIR_H  = 44      ' Read next dir entry: param0=handle, returns data0=ptr
  CMD_CLOSE_DIR_H = 45      ' Close directory handle: param0=handle
  CMD_SET_VOL_LABEL = 46    ' Set volume label: param0=new label string ptr
  CMD_SD_EXISTS     = 47    ' Check if SD file exists: param0=name ptr, returns data0=true/false
  CMD_SD_FILE_SIZE  = 48    ' Get SD file size by name: param0=name ptr, returns data0=size
  CMD_SD_FILE_SIZE_UNUSED = 49 ' Get SD file slack space: param0=name ptr, returns data0=unused bytes
  ' Note: CMD 50+ reserved for Flash commands

  ' ===========================================================================
  ' Flash-Specific Commands (Phase 2+)
  ' ===========================================================================
  CMD_FLASH_MOUNT       = 50       ' Mount Flash filesystem
  CMD_FLASH_FORMAT      = 51       ' Format Flash filesystem
  CMD_FLASH_OPEN        = 52       ' Open Flash file with mode
  CMD_FLASH_OPEN_CIRC   = 53       ' Open Flash circular file
  CMD_FLASH_CLOSE       = 54       ' Close Flash file handle
  CMD_FLASH_READ        = 55       ' Read from Flash handle
  CMD_FLASH_WRITE       = 56       ' Write to Flash handle
  CMD_FLASH_SEEK        = 57       ' Seek in Flash handle
  CMD_FLASH_FLUSH       = 58       ' Flush Flash handle
  CMD_FLASH_DELETE      = 59       ' Delete Flash file
  CMD_FLASH_RENAME      = 60       ' Rename Flash file
  CMD_FLASH_EXISTS      = 61       ' Check if Flash file exists
  CMD_FLASH_CREATE_FILE = 62       ' Pre-allocate Flash file
  CMD_FLASH_FILE_SIZE   = 63       ' Get Flash file size by name
  CMD_FLASH_STATS       = 64       ' Get Flash device stats
  CMD_FLASH_DIRECTORY   = 65       ' Open Flash directory iteration
  ' Unified device queries:
  CMD_SERIAL_NUMBER     = 67       ' Get device serial number
  ' Flash byte-level I/O:
  CMD_FL_WR_BYTE        = 71       ' Write single byte to Flash handle
  CMD_FL_RD_BYTE        = 72       ' Read single byte from Flash handle
  CMD_FL_RD_STR         = 73       ' Read string from Flash handle (seeks terminator)
  ' Flash extended:
  CMD_FL_FILE_SIZE_UNUSED = 79     ' Get unused bytes in last block of Flash file
  CMD_FL_CAN_MOUNT        = 81     ' Non-destructive Flash mount check
  CMD_FL_COUNT_BYTES    = 80       ' Count file bytes (TEST_ diagnostic)


CON ' buffer types for sector read/write (diagnostic: separate buffers to isolate conflicts)
  BUF_DIR  = 0      ' Directory sector buffer
  BUF_FAT  = 1      ' FAT sector buffer
  BUF_DATA = 2      ' Data sector buffer

CON ' error codes
  SUCCESS           = 0
  E_TIMEOUT         = -1        ' Card didn't respond in time
  E_NO_RESPONSE     = -2        ' Card not responding
  E_BAD_RESPONSE    = -3        ' Unexpected response from card
  E_CRC_ERROR       = -4        ' Data CRC mismatch
  E_WRITE_REJECTED  = -5        ' Card rejected write operation
  E_CARD_BUSY       = -6        ' Card busy
  E_IO_ERROR        = -7        ' General I/O error during read/write
  E_NO_CARD         = -8        ' No card detected in slot (MISO idle during CMD0 probe)
  E_NOT_MOUNTED     = -20       ' Filesystem not mounted
  E_INIT_FAILED     = -21       ' Card initialization failed
  E_NOT_FAT32       = -22       ' Card not formatted as FAT32
  E_BAD_SECTOR_SIZE = -23       ' Sector size not 512 bytes
  E_FILE_NOT_FOUND  = -40       ' File doesn't exist
  E_FILE_EXISTS     = -41       ' File already exists
  E_NOT_A_FILE      = -42       ' Expected file, found directory
  E_NOT_A_DIR       = -43       ' Expected directory, found file
  E_FILE_NOT_OPEN   = -45       ' File not open
  E_END_OF_FILE     = -46       ' Read past end of file
  E_DISK_FULL       = -60       ' No free clusters
  E_NO_LOCK         = -64       ' Couldn't allocate hardware lock

  ' ===========================================================================
  ' V3 Multi-File Handle Error Codes
  ' ===========================================================================
  E_TOO_MANY_FILES    = -90     ' All file handles are in use
  E_INVALID_HANDLE    = -91     ' Handle out of range or not open
  E_FILE_ALREADY_OPEN = -92     ' File is already open for writing (single-writer policy)
  E_NOT_A_DIR_HANDLE  = -93     ' Handle is not a directory handle (or vice versa)
  E_INVALID_PARAM     = -94     ' Parameter value out of valid range
  E_ASYNC_BUSY        = -95     ' An async operation is already in flight
  E_NO_ASYNC_OP       = -96     ' No async operation to get result from

  ' ===========================================================================
  ' Unified Flash Error Codes (ADR-7: single unified error code table)
  ' Mapped from flash_fs.spin2 error codes into non-overlapping range
  ' ===========================================================================
  E_FLASH_BAD_HANDLE       = -100  ' Flash handle is invalid
  E_FLASH_NO_HANDLE        = -101  ' Out of available Flash handles
  E_FLASH_DRIVE_FULL       = -102  ' Out of space on Flash chip
  E_FLASH_FILE_WRITING     = -103  ' Flash file is open for writing
  E_FLASH_FILE_READING     = -104  ' Flash file is open for reading
  E_FLASH_FILE_OPEN        = -105  ' Flash file is open
  E_FLASH_FILE_MODE        = -106  ' Flash file not opened in desired mode
  E_FLASH_FILE_SEEK        = -107  ' Attempted seek past either end of Flash file
  E_FLASH_BAD_BLOCKS       = -108  ' Block bit failure detected, bad blocks removed
  E_FLASH_TRUNCATED_STR    = -109  ' Buffer full before reaching string terminator
  E_FLASH_INCOMPLETE_STR   = -110  ' End of file reached before string terminator
  E_FLASH_BAD_FILE_LENGTH  = -112  ' File length given is negative or zero
  E_FLASH_BAD_SEEK_ARG     = -113  ' Invalid seek argument
  E_FLASH_FILE_EXISTS      = -114  ' Flash file already exists (rename/create_file target)
  E_FLASH_NO_BUFFER        = -115  ' No Flash buffer available (all in use)

  ' ===========================================================================
  ' Unified Device Error Codes
  ' ===========================================================================
  E_BAD_DEVICE             = -120  ' Invalid device parameter (not DEV_SD or DEV_FLASH)
  E_DEVICE_NOT_MOUNTED     = -121  ' Requested device not mounted
  E_NOT_SUPPORTED          = -122  ' Operation not supported on this device
  E_STACK_OVERFLOW         = -130  ' Worker cog stack overflow detected

#ifdef SD_INCLUDE_DEFRAG
  E_NO_CONTIGUOUS_SPACE    = -131  ' No contiguous run of sufficient length
  E_FILE_OPEN_FOR_COMPACT  = -132  ' File is open (cannot compact while open)
  E_VERIFY_FAILED          = -133  ' Read-back verification failed after compact
  CONTIGUOUS_FRAGMENTS     = 1     ' A file with 1 fragment is contiguous (named constant for intent)
#endif

CON ' V3 multi-file handle configuration
  ' ===========================================================================
  ' FILE HANDLE SYSTEM - V3 supports multiple simultaneously open files
  ' User can override MAX_OPEN_FILES and MAX_FLASH_BUFFERS in OBJ declaration:
  '   fs : "dual_sd_fat32_flash_fs" | MAX_OPEN_FILES = 4, MAX_FLASH_BUFFERS = 2
  '
  ' MAX_OPEN_FILES  - Total handles shared between SD and Flash devices.
  '                   Drives SD sector buffers (512 B each) + Flash handle state (~148 B each).
  '                   Default 6 covers 2-3 cogs with mixed file/directory operations.
  '
  ' MAX_FLASH_BUFFERS - How many Flash files can be open simultaneously.
  '                     Drives Flash block buffers (4096 B each). Independent of handle count.
  '                     Flash directory/exists/stats/delete/rename ops need zero buffers.
  '                     Default 3 (read + write + spare for Flash-to-Flash copy).
  '                     Set to 0 for SD-only builds (Flash mount still works, open fails).
  ' ===========================================================================
  MAX_OPEN_FILES = 6            ' Default number of handles (user-overridable)
  MAX_FLASH_BUFFERS = 3         ' Default Flash buffer pool size (user-overridable)

  ' Handle state flags (stored in h_flags array)
  HF_FREE   = 0                 ' Handle slot is available
  HF_READ   = 1                 ' Handle is open for reading
  HF_WRITE  = 2                 ' Handle is open for writing
  HF_DIR    = 4                 ' Handle is a directory enumeration handle
  HF_DIRTY  = $80               ' Handle's buffer has pending writes (OR'd with mode)

CON ' worker cog stack size
  STACK_SIZE = 160              ' 160 longs = 640 bytes (sized from audit: peak 127 + 25% headroom)
  STACK_GUARD_LONGS = 4         ' 4 longs = 16 bytes guard zone after stack
  STACK_GUARD_BYTE  = $CC       ' Sentinel value (matches isp_rt_utilities convention)

CON ' ---- Sector Arithmetic ----
  SECTOR_SIZE           = 512
  SECTOR_BITS           = 9           ' log2(SECTOR_SIZE) for shift operations
  SECTOR_MASK           = SECTOR_SIZE - 1
  SECTOR_LONGS          = SECTOR_SIZE / 4
  MAX_P2_COGS           = 8           ' P2 hardware maximum cog count

CON ' ---- FAT32 Structure Constants ----
  DIR_ENTRY_SIZE        = 32
  ENTRIES_PER_SECTOR    = SECTOR_SIZE / DIR_ENTRY_SIZE
  FAT_ENTRY_SHIFT       = 2           ' Each FAT entry is 4 bytes (1 << 2)
  CLUSTERS_PER_FAT_SEC  = SECTOR_SIZE / 4

  ' Directory entry field offsets (from start of 32-byte entry)
  DIR_ATTR_OFFSET       = 11
  DIR_CRT_TIME_OFFSET   = 14
  DIR_CLUS_HI_OFFSET    = 20
  DIR_WRT_TIME_OFFSET   = 22
  DIR_CLUS_LO_OFFSET    = 26

  ' Directory attribute bits
  DIR_ATTR_DIRECTORY    = $10
  DIR_ATTR_ARCHIVE      = $20

  ' FAT chain safety limits
  MAX_CHAIN_WALK        = 100_000       ' Maximum FAT chain walk iterations (safety limit)

  ' FAT chain markers
  ROOT_CLUSTER          = 2             ' First usable cluster in FAT32
  FAT_EOC_MASK          = $0FFF_FFFF    ' 28-bit cluster chain marker (also used as EOC write value)
  FAT_EOC_MIN           = $0FFF_FFF8    ' Minimum end-of-chain marker
  FAT_BAD               = $0FFF_FFF7    ' Bad cluster marker
  FAT_HIGH_BITS_MASK    = $F000_0000

  ' 8.3 filename
  FILENAME_83_LEN       = 11          ' 8 name + 3 extension bytes

CON ' ---- FAT32 Date/Time Encoding ----
  FAT_YEAR_BASE         = 1980
  FAT_YEAR_SHIFT        = 25
  FAT_MONTH_SHIFT       = 21
  FAT_DAY_SHIFT         = 16
  FAT_HOUR_SHIFT        = 11
  FAT_MINUTE_SHIFT      = 5

CON ' ---- Idle Flush and Async Constants ----
  IDLE_FLUSH_MS     = 200       ' Milliseconds idle before auto-flush
  PENDING           = 1         ' Returned by start*() to indicate async operation launched

CON ' ---- Timeout and Speed Constants ----
  INIT_TIMEOUT_SEC      = 2           ' Card initialization timeout (ACMD41)
  RESPONSE_TIMEOUT_DIV  = 10          ' clkfreq / 10 = 100ms timeout
  SD_INIT_SPEED_HZ      = 400_000     ' Card init speed per SD spec
  SD_FALLBACK_SPEED_HZ  = 25_000_000  ' Safe fallback / max SPI speed
  GPIO_FLUSH_CYCLES     = 4096        ' Clock cycles for GPIO SPI recovery (512 bytes * 8 bits)

CON ' ---- Flash Page/Block Constants ----
  PAGES_PER_FLASH_BLOCK = 16
  FLASH_PAGE_SIZE       = 256

CON ' ---- SD Register Sizes ----
  CSD_CID_BYTES         = 16          ' CSD and CID register size
  SD_STATUS_BYTES       = 64

CON ' ---- Hex Dump Display ----
  HEX_BYTES_PER_ROW     = 16          ' Bytes displayed per row in hex dump

CON ' streamer configuration (compile-time constants for bulk sector transfers)
  ' Reference: flash_loader.spin2 pattern, P2 Silicon Doc streamer section
  ' Using explicit hex values from working flash_loader code:
  ' Mode word: [31:28]=mode [27:24]=options [23:17]=pin [16:0]=count
  ' $C0 = 1-pin input to WFBYTE (RX), $80 = RFBYTE to 1-pin output (TX)
  ' $81 = X_ALT_ON (MSB-first, bit 7) + X_WRITE_ON/X_PINS_ON (bit 0)
  STREAM_RX_BASE = $C081_0000   ' 1-pin input to hub, MSB-first (flash_loader wmode)
  STREAM_TX_BASE = $8081_0000   ' hub to 1-pin output, MSB-first (flash_loader rmode)

CON ' CRC-16-CCITT configuration (using P2 GETCRC instruction)
  ' Replaces 512-byte lookup table with hardware GETCRC + transformation
  ' Formula: crc := ((GETCRC(@data, CRC_POLY, 512) ^ CRC_BASE_512) REV 31) >> 16
  CRC_POLY_REFLECTED = $8408    ' CRC-16-CCITT in LSB-first (reflected) form
  CRC_BASE_512       = $2C68    ' GETCRC of 512 zero bytes with poly $8408

CON ' CRC retry configuration
  MAX_READ_CRC_RETRIES = 3       ' Number of read retries on CRC mismatch (industry standard)

CON ' Flash filesystem geometry and constants
  ' Block geometry (16MB Flash chip, first 512KB reserved for boot image)
  FIRST_BLOCK      = $080                           ' Physical address of first FS block
  LAST_BLOCK       = $FFF                           ' Physical address of last FS block
  FL_BLOCKS        = LAST_BLOCK - FIRST_BLOCK + 1   ' 3968 blocks available
  BLOCK_SIZE       = $1000                           ' 4KB block size
  BLOCK_SIZE_EXP   = encod BLOCK_SIZE

  ' Filename storage
  FL_FILENAME_SIZE = $088 - $008                    ' 128 bytes (127 chars + null)

  ' Translation table sizes (derived from FL_BLOCKS)
  ID_TO_BLOCKS_SZ  = (FL_BLOCKS * 12 + 15) / 16   ' 12-bit fields in WORD array
  FL_FLAGS_SIZE    = (FL_BLOCKS * 1 + 7) / 8       ' 1-bit fields in BYTE array
  FL_STATES_SIZE   = (FL_BLOCKS * 2 + 7) / 8       ' 2-bit fields in BYTE array

  ' Block states (2-bit, stored in fl_BlockStates)
  B_FREE = %00                                      ' Block is not in use
  B_TEMP = %01                                      ' Block is being put to use (temp during mount)
  B_HEAD = %10                                      ' Block is head of a file (contains filename)
  B_BODY = %11                                      ' Block is body of a file (data continuation)

  ' Flash handle status flags (stored in fl_hStatus)
  FL_H_READ    = %0001                              ' Existing file is being read
  FL_H_WRITE   = %0010                              ' New file is being written
  FL_H_FORK    = %0100                              ' Existing file is being rewritten/appended
  FL_H_MODIFY  = %1000                              ' Existing file is being modified
  FL_H_APPEND  = FL_H_WRITE | FL_H_FORK
  FL_H_READWRITE = FL_H_WRITE | FL_H_MODIFY
  FL_H_READ_WRITE = FL_H_READ | FL_H_WRITE

  ' Flash handle sentinel and special values
  FL_NOT_VALID = -30                                ' Uninitialized handle marker
  FL_NOT_ENABLED = -1                               ' Feature not enabled (e.g., seeking)
  FL_FILENAME_SIZE_EXP = 7                          ' encod 128 (for shift-based offset calc)

  ' Flash seek whence constants
  #0, SK_Unknown, SK_FILE_START, SK_CURRENT_POSN

  ' Data capacity per block type
  BYTES_IN_HEAD_BLOCK = 3956                        ' Head block: 4096 - 140 bytes overhead
  BYTES_IN_BODY_BLOCK = 4088                        ' Body block: 4096 - 8 bytes overhead
  LONGS_IN_HEAD_BLOCK = BYTES_IN_HEAD_BLOCK / 4     ' 989 longs per head block
  LONGS_IN_BODY_BLOCK = BYTES_IN_BODY_BLOCK / 4     ' 1022 longs per body block

CON ' SD card command codes and tokens for multi-block operations
  ' ===========================================================================
  ' SD SPI Commands (reference: SD Physical Layer Spec)
  ' ===========================================================================
  CMD0   = 0                    ' GO_IDLE_STATE - reset card to idle state
  CMD6   = 6                    ' SWITCH_FUNC - check/switch card function (high-speed mode)
  CMD9   = 9                    ' SEND_CSD - read Card Specific Data register (16 bytes)
  CMD10  = 10                   ' SEND_CID - read Card Identification register (16 bytes)
  CMD12  = 12                   ' STOP_TRANSMISSION - terminates multi-block read/write
  CMD13  = 13                   ' SEND_STATUS - get card status register (R2 response)
  CMD18  = 18                   ' READ_MULTIPLE_BLOCK - read consecutive sectors
  CMD23  = 23                   ' SET_BLOCK_COUNT - pre-define sector count for CMD18/CMD25
  CMD25  = 25                   ' WRITE_MULTIPLE_BLOCK - write consecutive sectors
  CMD55  = 55                   ' APP_CMD - prefix for application-specific commands (ACMD*)
  ACMD51 = 51                   ' SEND_SCR - read SD Configuration Register (8 bytes)

  ' ===========================================================================
  ' Pre-computed CRC-7 bytes for fixed-argument commands
  ' ===========================================================================
  CRC_CMD9   = $AF              ' CRC for CMD9 (SEND_CSD, arg=0)
  CRC_CMD10  = $1B              ' CRC for CMD10 (SEND_CID, arg=0)
  CRC_CMD12  = $61              ' CRC for CMD12 (STOP_TRANSMISSION)
  CRC_ACMD51 = $55              ' CRC for ACMD51 (SEND_SCR, arg=0)
  CRC_NONE   = $FF              ' CRC not validated in SPI mode after init (CMD6, ACMD13)

CON ' SD card initialization constants
  CMD0_MAX_RETRIES    = 5       ' Maximum CMD0 attempts during card init
  CMD_RETRY_DELAY_MS  = 10      ' Delay between CMD0 retries (milliseconds)
  R1_IN_IDLE          = $01     ' R1 response: card in idle state (bit 0 set)

  ' ===========================================================================
  ' Card Status Register (CSR) bits - returned by CMD13 (R2 response = R1 + status byte)
  ' Reference: SD Physical Layer Spec section 4.10.1
  ' ===========================================================================
  ' R2 response is 2 bytes: first byte = R1, second byte = status flags
  ' Status byte bit definitions (directly from SD spec):
  CSR_CARD_IS_LOCKED    = $01  ' Bit 0: Card is locked
  CSR_WP_ERASE_SKIP     = $02  ' Bit 1: Write protect erase skip / lock/unlock cmd failed
  CSR_ERROR             = $04  ' Bit 2: General/unknown error
  CSR_CC_ERROR          = $08  ' Bit 3: Card controller error
  CSR_CARD_ECC_FAILED   = $10  ' Bit 4: Card internal ECC failed
  CSR_WP_VIOLATION      = $20  ' Bit 5: Write protect violation
  CSR_ERASE_PARAM       = $40  ' Bit 6: Invalid erase parameter
  CSR_OUT_OF_RANGE      = $80  ' Bit 7: Out of range / CSD overwrite error

  ' ===========================================================================
  ' SD SPI Data Tokens (reference: SD Physical Layer Spec section 7.3.3)
  ' ===========================================================================
  TOKEN_START_BLOCK      = $FE ' Start token for single-block read/write and multi-block read
  TOKEN_START_MULTI_WRITE = $FC ' Start token for each block in multi-block WRITE
  TOKEN_STOP_TRAN        = $FD ' Stop token to terminate multi-block WRITE (not CMD12!)

  ' Data Response Token format (after each block write): xxx0sss1
  ' sss = status: 010 = accepted, 101 = CRC error, 110 = write error
  DATA_ACCEPTED          = $05 ' Lower 5 bits = xxx00101 = data accepted

CON ' card warning/capability flags (bitmask, returned by cardWarnings())
  CW_NONE              = $00     ' No warnings or capabilities
  CW_CMD13_UNRELIABLE  = $01     ' CMD13 probe failed at init; status checks disabled for this card
  CW_CMD23_SUPPORTED   = $02     ' CMD23 (SET_BLOCK_COUNT) confirmed working in SPI mode

CON ' struct types - SD card register and FAT32 on-disk data structures
  ' ===========================================================================
  ' Struct type definitions for card registers, filesystem structures, and
  ' directory entries. Exported automatically to consumer objects via OBJ.
  ' All structs are packed (Spin2 default) - offsets match hardware/on-disk layouts.
  ' ===========================================================================

  ' --- SD Card Registers ---

  STRUCT cid_t(BYTE mid, BYTE oid[2], BYTE pnm[5], BYTE prv, BYTE psn[4], BYTE mdt[2], BYTE crc)
  '  CID register: 1+2+5+1+4+2+1 = 16 bytes (big-endian from card)

  STRUCT csd_t(BYTE csdStruct, BYTE taac, BYTE nsac, BYTE tranSpeed, ...
    BYTE ccc_hi, BYTE ccc_lo_bllen, BYTE csize_hi, BYTE csize_mid, ...
    BYTE csize_lo_vdd, BYTE currMinMax, BYTE eraseBlk, BYTE eraseSecSize, ...
    BYTE wpGrpSize, BYTE wpFlags, BYTE wrSpeed, BYTE crc)
  '  CSD register: 16 bytes (big-endian from card, bit fields within bytes)

  STRUCT scr_t(BYTE sdSpec, BYTE sdSecurity, BYTE sdSpec3Ext, BYTE sdSpecXLo, BYTE reserved[4])
  '  SCR register: 4+4 = 8 bytes (big-endian from card)

  ' --- FAT32 On-Disk Structures ---

  STRUCT dir_entry_t(BYTE name[8], BYTE ext[3], BYTE attr, BYTE ntRes, BYTE crtTenth, ...
    WORD crtTime, WORD crtDate, WORD accDate, WORD clusHI, ...
    WORD wrtTime, WORD wrtDate, WORD clusLO, LONG fileSize)
  '  FAT32 directory entry: 8+3+1+1+1+2+2+2+2+2+2+2+4 = 32 bytes (little-endian)

  STRUCT mbr_partition_t(BYTE bootFlag, BYTE chsStart[3], BYTE partType, ...
    BYTE chsEnd[3], LONG lbaStart, LONG lbaSize)
  '  MBR partition entry: 1+3+1+3+4+4 = 16 bytes (little-endian)

  STRUCT vbr_t(BYTE jumpBoot[3], BYTE oemName[8], WORD bytesPerSec, BYTE secPerClus, ...
    WORD reservedSec, BYTE numFats, WORD rootEntCnt, WORD totalSec16, ...
    BYTE mediaType, WORD secPerFat16, WORD secPerTrack, WORD numHeads, ...
    LONG hiddenSec, LONG totalSec32, LONG secPerFat32, WORD extFlags, ...
    WORD fsVersion, LONG rootCluster, WORD fsInfoSec, WORD backBootSec, ...
    BYTE reserved2[12], BYTE driveNum, BYTE reserved3, BYTE bootSig, ...
    LONG volSerialNum, BYTE volLabel[11], BYTE fsTypeLabel[8], ...
    BYTE bootCode[420], WORD bootSignature)
  '  VBR (FAT32 BPB): 3+8+2+1+2+1+2+2+1+2+2+2+4+4+4+2+2+4+2+2+12+1+1+1+4+11+8+420+2 = 512 bytes

  STRUCT fsinfo_t(LONG leadSig, BYTE reserved1[480], LONG structSig, ...
    LONG freeClusters, LONG nextFreeHint, BYTE reserved2[12], LONG trailSig)
  '  FSInfo sector: 4+480+4+4+4+12+4 = 512 bytes

DAT ' version string buffer
  verBuf        BYTE    0[8]            ' "XX.YY.ZZ" + null (max 8 bytes)

DAT ' singleton control - SHARED across all object instances
  ' =======================================================================
  ' SINGLETON CONTROL - Must be initialized to "not started" state
  ' =======================================================================
  cog_id        LONG    -1              ' Worker cog ID (-1 = not started)
  api_lock      LONG    -1              ' Hardware lock ID (-1 = not allocated)
  driver_mode   LONG    0               ' Current mode: MODE_NONE, MODE_RAW, or MODE_FILESYSTEM
  sd_mounted    LONG    0               ' TRUE if SD filesystem is mounted
  flash_mounted LONG    0               ' TRUE if Flash filesystem is mounted
  last_init_error LONG  0               ' Specific error from last initCard() failure

  ' =======================================================================
  ' CMD13 STATUS STAGING - Preserved for diagnostic inspection
  ' =======================================================================
  last_cmd13_r1     BYTE    0           ' Last R1 byte from CMD13
  last_cmd13_status BYTE    0           ' Last STATUS byte from CMD13
  last_cmd13_error  WORD    0           ' Last non-zero R2 (preserved until next error)

  ' =======================================================================
  ' CMD12/18/23 DIAGNOSTIC STATE - Card warning flags and multi-block diagnostics
  ' =======================================================================
  cmd13_reliable    BYTE    TRUE        ' FALSE if CMD13 probe failed at init (default: enabled)
  cmd23_supported   BYTE    FALSE       ' TRUE if card accepts CMD23 in SPI mode
  card_warning_flags BYTE   CW_NONE    ' Advisory bitmask (queried via cardWarnings())

  ' CMD18 (READ_MULTIPLE_BLOCK) diagnostics
  last_cmd18_r1     BYTE    0           ' Last R1 byte from CMD18
  last_cmd18_token  BYTE    0           ' Last data token or error token from CMD18 waitDataToken()
  last_cmd18_result BYTE    0           ' Last waitDataToken() result: 0=ok, 1=timeout, 2=error token
  last_cmd18_fail   BYTE    0           ' Failure path: 0=none, 1=R1 reject, 2=data token, 3=CMD12, 4=CMD13, 5=CMD12 tolerated
  last_cmd18_sread  BYTE    0           ' sectors_read at end of loop (before CMD12/CMD13)

  ' CMD12 (STOP_TRANSMISSION) diagnostics
  last_cmd12_r1     BYTE    0           ' Last R1 from CMD12 sendStopTransmission()
  last_cmd12_busy   BYTE    0           ' CMD12 busy result: 0=ok, 1=timeout, 2=R1 error, 3=busy timeout
  cmd12_capture_len BYTE    0           ' Number of bytes captured in cmd12_capture[]
  cmd12_capture     BYTE    0[16]       ' Raw byte stream after CMD12 stuff byte (for framing analysis)
  cmd12_pre_capture BYTE    0[7]        ' MISO bytes received DURING CMD12 command transmission (full-duplex)

  ' CMD13 (SEND_STATUS) full-duplex capture - for sendCmd13Transaction() diagnostics
  cmd13_pre_capture BYTE    0[7]        ' MISO bytes received DURING CMD13 command transmission (6 cmd + 1 pad)
  cmd13_capture     BYTE    0[8]        ' Raw post-command byte stream (R1 + STATUS + trailing)
  cmd13_capture_len BYTE    0           ' Number of bytes before R1 appeared (NCR gap length)

  ' CMD23 (SET_BLOCK_COUNT) diagnostics
  last_cmd23_r1     BYTE    0           ' Last R1 from CMD23: $00=accepted, $FF=not sent
  last_cmd23_verify BYTE    0           ' Post-read verification byte: $FF=card stopped, other=still streaming
  last_cmd23_used   BYTE    FALSE       ' TRUE if CMD23 path was used for last multi-block read

  ' =======================================================================
  ' PARAMETER BLOCK - Communication between API and worker cog
  ' =======================================================================
  pb_cmd        LONG    0               ' Command (0 = idle/done)
  pb_status     LONG    0               ' Result status code
  pb_caller     LONG    0               ' Caller's cog ID (for COGATN signal)
  pb_param0     LONG    0               ' Parameter 0 (varies by command)
  pb_param1     LONG    0               ' Parameter 1
  pb_param2     LONG    0               ' Parameter 2
  pb_param3     LONG    0               ' Parameter 3
  pb_data0      LONG    0               ' Result data 0 (handle, count, etc.)
  pb_data1      LONG    0               ' Result data 1
  pb_data2      LONG    0               ' Result data 2 (third return value, e.g., stats)
  ' Per-cog saved copies of pb_data (captured before lock release, multi-cog safe)
  saved_data0   LONG    0[8]            ' Snapshot of pb_data0, one per cog
  saved_data1   LONG    0[8]            ' Snapshot of pb_data1, one per cog
  saved_data2   LONG    0[8]            ' Snapshot of pb_data2, one per cog

  ' =======================================================================
  ' WORKER LOOP STATE (idle flush + clock tick)
  ' =======================================================================
  idle_timer        LONG    0           ' getct() at last command completion
  idle_flush_clocks LONG    0           ' Threshold in clock ticks (set at mount time)
  flush_done        BYTE    false       ' TRUE after idle flush completes (reset on next command)
  ct_active         BYTE    0           ' TRUE when live clock is enabled
  ct_last_tick      LONG    0           ' getct() at last clock tick
  ct_tick_clocks    LONG    0           ' clkfreq * 2 (set at mount time)

#ifdef SD_INCLUDE_ASYNC
  ' =======================================================================
  ' ASYNC STATE (non-blocking I/O)
  ' =======================================================================
  async_active      BYTE    0           ' TRUE when an async operation is in flight
  async_caller      BYTE    0           ' Cog ID of the async caller
#endif

  ' =======================================================================
  ' WORKER COG STACK
  ' =======================================================================
  cog_stack     LONG    0[STACK_SIZE]   ' Worker cog stack
  cog_stack_guard LONG  0[STACK_GUARD_LONGS]  ' Stack overflow sentinel ($CC fill)

  ' =======================================================================
  ' SPI PIN CONFIGURATION (fixed hardware - see CON PIN_* constants)
  ' SD pins: PIN_SD_CS=P60, PIN_MOSI=P59, PIN_MISO=P58, PIN_SD_SCK=P61
  ' Flash pins derived from swap: PIN_FL_CS=P61 (SD SCK), PIN_FL_SCK=P60 (SD CS)
  ' =======================================================================

  ' =======================================================================
  ' SMART PIN SPI CONFIGURATION (Phase 1 Performance Sprint)
  ' P_TRANSITION for clock, P_SYNC_TX for transmit, P_SYNC_RX for receive
  ' B-input offset links MOSI/MISO to SCK for synchronized operation
  ' =======================================================================
  spi_clk_mode  LONG    0               ' P_PULSE | P_OE for SCK
  spi_tx_mode   LONG    0               ' P_SYNC_TX | P_OE for MOSI
  spi_rx_mode   LONG    0               ' P_SYNC_RX for MISO
  spi_period    LONG    0               ' Current SPI half-period (for sysclk-independent timing)
  spi_freq      LONG    0               ' Actual achieved SPI frequency (Hz)
  spi_event     LONG    0               ' Event config for waitse1 (%01_000000 | PIN_SD_SCK)
  use_smartpin  LONG    0               ' 0 = bit-bang (fallback), 1 = smart pin mode
  sp_debug_ctr  LONG    0               ' Debug counter for sp_transfer_8

  ' =======================================================================
  ' FILESYSTEM STATE (moved from VAR)
  ' =======================================================================
  fat_sec       LONG    0               ' Starting sector of FAT
  fat2_sec      LONG    0               ' Starting sector of FAT2 (mirror)
  sec_per_fat   LONG    0               ' Sectors per FAT
  sec_per_clus  LONG    0               ' Sectors per cluster
  root_sec      LONG    0               ' Starting sector of root directory
  cluster_offset LONG   0               ' Cluster offset calculation
  cog_dir_sec   LONG    0[8]            ' Per-cog current directory sector
  entry_address LONG    0               ' Current entry byte address
  date_stamp    LONG    0               ' Live packed FAT32 date+time

  ' FIELD pointers into date_stamp (initialized in worker startup)
  fld_yr        LONG    0               ' ^@date_stamp.[31..25]
  fld_mon       LONG    0               ' ^@date_stamp.[24..21]
  fld_day       LONG    0               ' ^@date_stamp.[20..16]
  fld_hr        LONG    0               ' ^@date_stamp.[15..11]
  fld_min       LONG    0               ' ^@date_stamp.[10..5]
  fld_sec       LONG    0               ' ^@date_stamp.[4..0]
  days_table    BYTE    31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31

  n_sec         LONG    0               ' Current sector number
  flags         LONG    0               ' Open/new file flags
  dir_sec_in_buf LONG   0               ' Directory sector currently in dir_buf
  fat_sec_in_buf LONG   0               ' FAT sector currently in fat_buf
  sec_in_buf    LONG    0               ' Data sector currently in buf
  bit_delay     LONG    0               ' SPI bit delay
  hcs           LONG    0               ' High capacity support flag
  fsinfo_sec    LONG    0               ' FSInfo sector number
  fsi_free_count LONG   0               ' Cached free cluster count
  fsi_nxt_free  LONG    0               ' Cached next free cluster hint
  test_max_clusters LONG 0              ' Test hook: artificial cluster limit (0 = disabled)
  vbr_sec       LONG    0               ' Volume Boot Record sector
  ocr_value     LONG    0               ' Cached OCR register (from CMD58)

  ' =======================================================================
  ' ADAPTIVE TIMING (Phase 2 - Card identification and speed adjustment)
  ' =======================================================================
  card_mfr_id   LONG    0               ' Manufacturer ID from CID (byte 0)
  card_serial_number LONG 0            ' Product serial number from CID (PSN, bytes 9-12)
  card_max_speed_hz LONG 0              ' Maximum speed from CSD TRAN_SPEED (Hz)
  saved_acmd41_arg LONG 0              ' ACMD41 argument saved from initial init (for reinitCard)
  card_read_timeout_ms  LONG  100       ' Read timeout in ms (from CSD or spec default)
  card_write_timeout_ms LONG  500       ' Write timeout in ms (from CSD or spec default)

  ' =======================================================================
  ' PER-COG ERROR STORAGE (for thread-safe error reporting)
  ' =======================================================================
  last_error    LONG    0[8]            ' One slot per possible cog

  ' =======================================================================
  ' DIAGNOSTIC: Capture data inside readSector for debugging from test cog
  ' =======================================================================
  diag_last_sector   LONG    0          ' Last sector read
  diag_last_buftype  LONG    0          ' Last buf_type used
  diag_last_token    LONG    0          ' Last start token received
  diag_buf_byte0     LONG    0          ' First byte of buffer after streamer
  diag_buf_byte1     LONG    0          ' Second byte
  diag_buf_byte2     LONG    0          ' Third byte
  diag_buf_byte3     LONG    0          ' Fourth byte
  diag_p_buf         LONG    0          ' Buffer pointer used
  diag_before_b0     LONG    0          ' Buffer byte 0 BEFORE streamer
  diag_before_b1     LONG    0          ' Buffer byte 1 BEFORE streamer
  diag_before_b2     LONG    0          ' Buffer byte 2 BEFORE streamer
  diag_before_b3     LONG    0          ' Buffer byte 3 BEFORE streamer
  diag_spi_period    LONG    0          ' SPI period at time of read
  diag_recv_crc      WORD    0          ' CRC-16 received from card (high byte first)
  diag_calc_crc      WORD    0          ' CRC-16 calculated from data
  diag_sent_crc      WORD    0          ' CRC-16 sent with write data
  diag_crc_matches   LONG    0          ' Count of CRC matches (reads)
  diag_crc_mismatches LONG   0          ' Count of CRC mismatches (reads)
  diag_crc_retries   LONG    0          ' Count of CRC retry attempts
  diag_crc_enabled   BYTE    1          ' CRC validation enabled (1=on, 0=off)

  ' =======================================================================
  ' WRITE DIAGNOSTICS (set by writeSector, readable from any cog)
  ' Codes: 0=not called, 1=CMD24 fatal, 2=data-response timeout,
  '        3=data CRC reject, 4=data write-err reject, 5=data unknown reject,
  '        6=busy timeout, 7=success
  ' =======================================================================
  diag_write_result  LONG    0          ' Outcome code of last writeSector call
  diag_write_r1      LONG    0          ' CMD24 R1 response byte
  diag_write_dresp   LONG    0          ' Data response token from card
  diag_write_sector  LONG    0          ' Sector number attempted

  ' TEST HOOKS: Error injection for CRC validation testing
  test_force_read_crc_error   BYTE    0  ' Counter: force N read CRC mismatches
  test_force_write_crc_error  BYTE    0  ' Flag: corrupt next write CRC (one-shot)
  test_error_count            LONG    0  ' Count of injected errors triggered

  ' =======================================================================
  ' BUFFERS (must be in DAT for worker cog access)
  ' DIAGNOSTIC: Separate buffers for each sector type to isolate conflicts
  ' =======================================================================
  dir_buf       BYTE    0[512]          ' Directory sector buffer
  fat_buf       BYTE    0[512]          ' FAT sector buffer
  buf           BYTE    0[512]          ' Data sector buffer
  entry_buffer  dir_entry_t
                BYTE    0[14]           ' name[8], ext[3], attr, ntRes, crtTenth
                WORD    0[7]            ' crtTime, crtDate, accDate, clusHI, wrtTime, wrtDate, clusLO
                LONG    0              ' fileSize
  vol_label     BYTE    0[12]           ' Volume label (11 chars + null)
  copy_buf      BYTE    0[512]          ' Scratch buffer for copyFile() operations

  ' ===========================================================================
  ' V3 FILE HANDLE TABLE - 28 bytes per handle
  ' Each handle tracks an independently open file with its own state
  ' ===========================================================================
  h_device      BYTE    0[MAX_OPEN_FILES]     ' Device: DEV_SD or DEV_FLASH (for routing handle ops)
  h_flags       BYTE    0[MAX_OPEN_FILES]     ' Handle state: HF_FREE, HF_READ, HF_WRITE (| HF_DIRTY)
  h_attr        BYTE    0[MAX_OPEN_FILES]     ' FAT directory entry attributes byte
  h_dir_offset  WORD    0[MAX_OPEN_FILES]     ' Offset of dir entry within sector (0-511)
  h_position    LONG    0[MAX_OPEN_FILES]     ' Current byte position in file
  h_sector      LONG    0[MAX_OPEN_FILES]     ' Current sector number being accessed
  h_start_clus  LONG    0[MAX_OPEN_FILES]     ' First cluster of file (from dir entry)
  h_size        LONG    0[MAX_OPEN_FILES]     ' File size in bytes
  h_dir_sector  LONG    0[MAX_OPEN_FILES]     ' Sector containing directory entry
  h_cluster     LONG    0[MAX_OPEN_FILES]     ' Current cluster in FAT chain

  ' ===========================================================================
  ' V3 PER-HANDLE DATA BUFFERS - 512 bytes per handle
  ' Each handle has its own buffer to eliminate thrashing when switching files
  ' Cost: 512 bytes per handle, but provides significant performance benefit
  ' ===========================================================================
  h_buf         BYTE    0[512 * MAX_OPEN_FILES]   ' Per-handle sector buffers
  h_buf_sector  LONG    0[MAX_OPEN_FILES]         ' Sector currently in each buffer (-1 = invalid)
#ifdef SD_INCLUDE_DEFRAG
  h_prealloc_end LONG   0[MAX_OPEN_FILES]         ' Last pre-allocated cluster (0 = normal handle)
#endif

  ' ===========================================================================
  ' FLASH FILESYSTEM STATE (Phase 2)
  ' Translation tables, handle state, and block buffers for Flash device
  ' ===========================================================================

  ' SPI bus device tracking
  current_spi_device  LONG  -1                    ' Currently configured SPI device (-1=none, 0=SD, 1=Flash)

  ' Translation tables (~7.2 KB total)
  fl_IDToBlocks    WORD    0[ID_TO_BLOCKS_SZ]     ' 12-bit block address per ID
  fl_IDToBlock     LONG    0                       ' field pointer for 12-bit variables
  fl_IDValids      BYTE    0[FL_FLAGS_SIZE]        ' 1-bit valid flag per ID
  fl_IDValid       LONG    0                       ' field pointer for 1-bit variables
  fl_BlockStates   BYTE    0[FL_STATES_SIZE]       ' 2-bit state per block
  fl_BlockState    LONG    0                       ' field pointer for 2-bit variables

  ' Flash handle state (parallel arrays, indexed by unified handle)
  fl_hStatus       BYTE    0[MAX_OPEN_FILES]       ' FL_H_READ, FL_H_WRITE, etc.
  fl_hHeadBlockID  WORD    FL_NOT_VALID[MAX_OPEN_FILES]
  fl_hChainBlockID WORD    0[MAX_OPEN_FILES]
  fl_hChainBlockAddr WORD  0[MAX_OPEN_FILES]
  fl_hChainLifeCycle BYTE  0[MAX_OPEN_FILES]
  fl_hModified     BYTE    0[MAX_OPEN_FILES]
  fl_hEndPtr       WORD    0[MAX_OPEN_FILES]
  fl_hSeekPtr      LONG    -1[MAX_OPEN_FILES]      ' NOT_ENABLED = -1
  fl_hSeekFileOffset LONG  0[MAX_OPEN_FILES]
  fl_hCircularLength LONG  0[MAX_OPEN_FILES]
  fl_hFilename     BYTE    0[MAX_OPEN_FILES * FL_FILENAME_SIZE]

  ' Flash buffer pool management (decoupled from handle count)
  fl_buf_owner     BYTE    $FF[MAX_FLASH_BUFFERS]    ' Handle owning each buffer ($FF = free)
  fl_hBufIndex     BYTE    $FF[MAX_OPEN_FILES]       ' Buffer index per handle ($FF = none)

  ' Flash block buffers -- sized by MAX_FLASH_BUFFERS, not MAX_OPEN_FILES
  fl_hBlockBuff    BYTE    0[MAX_FLASH_BUFFERS * BLOCK_SIZE]

  ' Temporary block buffer (mount scanning, block moves)
  fl_tmpBlockBuff  BYTE    0[BLOCK_SIZE]

  ' Flash debug flag
  fl_showRTdebug   LONG    false

  ' Flash error code (worker cog only - no per-cog indexing needed)
  fl_errorCode     LONG    0

  ' Flash serial number buffer (DAT for reliable wrfast target)
  fl_sn_buf        LONG    0[2]

  ' Per-cog Flash CWD prefix string (128 bytes per cog, 8 cogs = 1KB)
  ' Empty string = root directory. Example: "subdir" or "dir1/dir2"
  fl_cog_cwd       BYTE    0[8 * FL_FILENAME_SIZE]

#ifdef SD_INCLUDE_STACK_CHECK
OBJ
    stackUtils : "isp_stack_check"
#endif

CON ' ---- Lifecycle Methods ----
    ' LIFECYCLE METHODS
    ' =============================================================================
PUB null()
'' This is not a top-level object - placeholder to indicate driver must be instantiated as OBJ.

CON ' ---- Multi-Cog Lifecycle Methods ----
    ' MULTI-COG LIFECYCLE METHODS
    ' ===========================================================================

PUB init() : workerCog
'' Initialize the unified filesystem driver (singleton).
'' Allocates hardware lock and starts the worker cog.
'' Pin assignments are fixed CON constants for the P2 Edge Module.
'' Does NOT mount any filesystem -- call mount() after init().
''
'' @returns workerCog - Cog ID (0-7) on success, -1 on failure

  ' Check if already started (singleton pattern)
  if cog_id <> -1
    debug[CH_INIT]("  [init] Already started (cog ", udec_(cog_id), ")")
    workerCog := cog_id

  else
    ' Clear mount state
    sd_mounted := FALSE
    flash_mounted := FALSE

    ' Allocate hardware lock for API serialization
    api_lock := locknew()
    if api_lock == -1
      debug[CH_INIT]("  [init] FAIL: Could not allocate lock")
      workerCog := set_error(E_NO_LOCK)

    ' Initialize parameter block
    else
      pb_cmd := CMD_NONE
      pb_status := SUCCESS
      sec_in_buf := -1                                                              ' Invalidate buffer

      ' Initialize stack guard zone before launching worker
      bytefill(@cog_stack_guard, STACK_GUARD_BYTE, STACK_GUARD_LONGS * 4)

#ifdef SD_INCLUDE_STACK_CHECK
      stackUtils.prepStackForCheck(@cog_stack, STACK_SIZE)
#endif

      ' Launch worker cog
      cog_id := cogspin(NEWCOG, fs_worker(), @cog_stack)
      if cog_id == -1
        lockret(api_lock)
        api_lock := -1
        debug[CH_INIT]("  [init] FAIL: Could not start worker cog")
        workerCog := set_error(E_NO_LOCK)

      else
        debug[CH_INIT]("  [init] Worker cog ", udec_(cog_id), " started, lock ", udec_(api_lock))
        workerCog := cog_id

PUB stop()
'' Stop worker cog - cleanly shut down the worker cog and release resources.
'' Safe to call even if not started.

  if cog_id <> -1
    ' Send unmount command if mounted
    if flags & F_MOUNTED
      send_command(CMD_UNMOUNT, 0, 0, 0, 0)

    ' Stop the worker cog
    cogstop(cog_id)
    debug[CH_INIT]("  [stop] Worker cog ", udec_(cog_id), " stopped")
    cog_id := -1

  ' Release hardware lock
  if api_lock <> -1
    lockret(api_lock)
    api_lock := -1

  ' Clear state
  driver_mode := MODE_NONE   ' Reset mode so next init/mount starts fresh
  flags := 0
  sd_mounted := FALSE
  flash_mounted := FALSE
  sec_in_buf := -1

PUB mount(dev) : status
'' Mount one or both filesystems (multi-cog safe).
'' Requires init() to have been called first (worker cog must be running).
'' Use DEV_SD to mount SD card, DEV_FLASH to mount Flash chip, DEV_BOTH for both.
''
'' @param dev - Target device (DEV_SD, DEV_FLASH, or DEV_BOTH)
'' @returns status - SUCCESS or negative error code

  ' Require init() to have been called
  if cog_id == -1
    debug[CH_MOUNT]("  [mount] ERROR: init() not called, worker not running")
    set_error(E_NOT_MOUNTED)
    status := E_NOT_MOUNTED

  ' Mount SD if requested
  else
    if dev == DEV_SD or dev == DEV_BOTH
      if sd_mounted
        debug[CH_MOUNT]("  [mount] SD already mounted")
      else
        ' MODE_RAW -> MODE_FILESYSTEM upgrade is allowed
        if driver_mode == MODE_RAW
          debug[CH_MOUNT]("  [mount] Upgrading from RAW to FILESYSTEM mode")
        status := send_command(CMD_MOUNT, 0, 0, 0, 0)
        if status == SUCCESS
          sd_mounted := TRUE
          debug[CH_MOUNT]("  [mount] SD mount successful")
        else
          debug[CH_MOUNT]("  [mount] SD mount failed with error ", sdec_(status))
          set_error(status)

    ' Mount Flash if requested
    if dev == DEV_FLASH or dev == DEV_BOTH
      if flash_mounted
        debug[CH_MOUNT]("  [mount] Flash already mounted")
      else
        status := send_command(CMD_FLASH_MOUNT, 0, 0, 0, 0)
        if status == SUCCESS
          flash_mounted := TRUE
          debug[CH_MOUNT]("  [mount] Flash mount successful")
        else
          debug[CH_MOUNT]("  [mount] Flash mount failed with error ", sdec_(status))
          set_error(status)

    ' Set final status based on mounted state
    ' Preserve specific error (e.g. E_NO_CARD) if mount already failed
    case dev
      DEV_SD:
        if sd_mounted
          status := SUCCESS
        elseif status == SUCCESS
          status := E_NOT_MOUNTED
      DEV_FLASH:
        if flash_mounted
          status := SUCCESS
        elseif status == SUCCESS
          status := E_NOT_MOUNTED
      DEV_BOTH:
        if sd_mounted and flash_mounted
          status := SUCCESS
        elseif status == SUCCESS
          status := E_NOT_MOUNTED
      other:
        set_error(E_BAD_DEVICE)
        status := E_BAD_DEVICE

PUB unmount(dev) : status | did_unmount
'' Unmount one or both filesystems (multi-cog safe).
'' Flushes pending data and updates filesystem metadata.
''
'' @param dev - Target device (DEV_SD, DEV_FLASH, or DEV_BOTH)
'' @returns status - SUCCESS or negative error code
' @local did_unmount - TRUE if unmount operation succeeded

  did_unmount := FALSE

  if dev == DEV_SD or dev == DEV_BOTH
    if sd_mounted
      status := send_command(CMD_UNMOUNT, 0, 0, 0, 0)
      sd_mounted := FALSE
      did_unmount := TRUE
      debug[CH_MOUNT]("  [unmount] SD unmounted")
    elseif dev == DEV_SD
      status := set_error(E_NOT_MOUNTED)

  if status <> E_NOT_MOUNTED
    if dev == DEV_FLASH or dev == DEV_BOTH
      if flash_mounted
        ' Clear Flash handle state
        bytefill(@fl_hStatus, 0, MAX_OPEN_FILES)
        wordfill(@fl_hHeadBlockID, FL_NOT_VALID, MAX_OPEN_FILES)
        ' Reset Flash buffer pool
        bytefill(@fl_buf_owner, $FF, MAX_FLASH_BUFFERS)
        bytefill(@fl_hBufIndex, $FF, MAX_OPEN_FILES)
        flash_mounted := FALSE
        did_unmount := TRUE
        debug[CH_MOUNT]("  [unmount] Flash unmounted")
      elseif dev == DEV_FLASH
        status := set_error(E_NOT_MOUNTED)

    if status <> E_NOT_MOUNTED
      if dev == DEV_BOTH and not did_unmount
        status := set_error(E_NOT_MOUNTED)
      else
        status := SUCCESS

PUB mounted(dev) : is_mounted
'' Check if a device is currently mounted.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @returns is_mounted - TRUE if device is mounted, FALSE otherwise

  case dev
    DEV_SD:    is_mounted := sd_mounted
    DEV_FLASH: is_mounted := flash_mounted
    other:     is_mounted := false

PUB canMount(dev) : is_mountable
'' Non-destructive check if a device can be mounted (requires init, not mount).
'' For SD: checks card presence and FAT32 validity.
'' For Flash: scans blocks non-destructively (Phase 2+).
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @returns is_mountable - TRUE if device appears mountable, FALSE otherwise

  if cog_id == -1
    is_mountable := false
  else
    case dev
      DEV_SD:
        ' TODO: implement non-destructive SD card check
        is_mountable := false
      DEV_FLASH:
        send_command(CMD_FL_CAN_MOUNT, 0, 0, 0, 0)
        is_mountable := LONG[@saved_data0][COGID()]
      other:
        is_mountable := false

PUB cardWarnings() : warning_flags
'' Get card capability and advisory flags discovered during mount.
'' Returns bitmask of conditions probed at init time.
'' Check after mount() to learn what the card actually supports in SPI mode.
''
''   CW_CMD13_UNRELIABLE ($01) - CMD13 status checks disabled (broken SPI implementation)
''   CW_CMD23_SUPPORTED  ($02) - CMD23 SET_BLOCK_COUNT confirmed working in SPI mode
''
'' @returns warning_flags - Bitmask of CW_* constants (CW_NONE if no flags set)

  warning_flags := card_warning_flags

PUB version(dev) : ver
'' Get driver version for a device as encoded integer.
'' Format: major * 10000 + minor * 100 + patch (e.g., 1_03_00 = v1.3.0).
''
'' @param dev - Target device (DEV_SD, DEV_FLASH, or DEV_BOTH)
'' @returns ver - Encoded version integer

  case dev
    DEV_SD:    ver := SD_VERSION
    DEV_FLASH: ver := FLASH_VERSION
    DEV_BOTH:  ver := DFS_VERSION
    other:     ver := DFS_VERSION

PUB versionStr(dev) : p_str | ver, pos
'' Get driver version as a formatted "X.Y.Z" string pointer.
''
'' @param dev - Target device (DEV_SD, DEV_FLASH, or DEV_BOTH)
'' @returns p_str - Pointer to null-terminated version string (e.g., "1.3.0")

  ver := version(dev)
  pos := 0
  pos := fmtVerPart(ver / 1_00_00, pos)
  BYTE[@verBuf][pos++] := "."
  pos := fmtVerPart(ver / 1_00 // 1_00, pos)
  BYTE[@verBuf][pos++] := "."
  pos := fmtVerPart(ver // 1_00, pos)
  BYTE[@verBuf][pos] := 0
  p_str := @verBuf

PRI fmtVerPart(val, pos) : npos
'' Format a version part (0-99) into verBuf at pos, no leading zeros.
  if val >= 10
    BYTE[@verBuf][pos++] := "0" + val / 10
  BYTE[@verBuf][pos++] := "0" + val // 10
  npos := pos

PUB format(dev) : status
'' Format one device (destructive!).
'' SD: full FAT32 format. Flash: cancel all active blocks.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @returns status - SUCCESS or negative error code

  case dev
    DEV_SD:
      ' SD format is handled by external utility (SD_format_card)
      debug[CH_MOUNT]("  [format] SD format not supported in driver (use SD_format_card utility)")
      set_error(E_NOT_SUPPORTED)
      status := E_NOT_SUPPORTED
    DEV_FLASH:
      if cog_id == -1
        debug[CH_MOUNT]("  [format] ERROR: init() not called")
        set_error(E_NOT_MOUNTED)
        status := E_NOT_MOUNTED
      else
        status := send_command(CMD_FLASH_FORMAT, 0, 0, 0, 0)
        if status == SUCCESS
          debug[CH_MOUNT]("  [format] Flash formatted and remounted")
        else
          debug[CH_MOUNT]("  [format] Flash format failed")
    other:
      set_error(E_BAD_DEVICE)
      status := E_BAD_DEVICE

PUB sync() : status
'' Flush buffers (multi-cog safe) - flushes pending writes without closing file.
'' Use to checkpoint data during long operations.
''
'' @returns status - SUCCESS or negative error code

  status := send_command(CMD_SYNC, 0, 0, 0, 0)
  debug[CH_FILE]("  [sync] Buffers flushed")
  if status <> SUCCESS
    set_error(status)

' ===========================================================================
' V3 HANDLE-BASED PUBLIC API
' Multi-file support with independent file handles
' ===========================================================================


CON ' ---- File I/O Methods ----
    ' FILE I/O METHODS
    ' =============================================================================
PUB open(dev, p_filename, mode) : handle | fl_path[32]
'' Open file with mode (Flash-style). Modes: FILEMODE_READ, FILEMODE_WRITE,
'' FILEMODE_APPEND, FILEMODE_READ_EXTENDED, FILEMODE_WRITE_EXTENDED.
'' Flash: CWD prefix is automatically prepended to the filename.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_filename - Pointer to filename string
'' @param mode - File open mode constant
'' @returns handle - Handle on success, negative error code on failure
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      ' Map Flash-style modes to SD handle operations
      case mode
        FILEMODE_READ:
          handle := openFileRead(DEV_SD, p_filename)
        FILEMODE_WRITE:
          ' Truncate: delete existing file (if any), then create fresh
          deleteFile(DEV_SD, p_filename)                                        ' Ignore error (file may not exist)
          handle := createFileNew(DEV_SD, p_filename)
        FILEMODE_APPEND:
          handle := openFileWrite(DEV_SD, p_filename)
        other:
          set_error(E_NOT_SUPPORTED)
          handle := E_NOT_SUPPORTED
    DEV_FLASH:
      ifnot flash_mounted
        handle := set_error(E_NOT_MOUNTED)
      else
        fl_prepend_cwd(@fl_path, p_filename)
        send_command(CMD_FLASH_OPEN, @fl_path, mode, 0, 0)
        handle := LONG[@saved_data0][COGID()]
        if handle < 0
          set_error(handle)
    other:
      set_error(E_BAD_DEVICE)
      handle := E_BAD_DEVICE

PUB open_circular(dev, p_filename, mode, max_file_length) : handle | fl_path[32]
'' Open circular file (Flash-specific, Phase 2+).
'' Flash: CWD prefix is automatically prepended to the filename.
''
'' @param dev - Target device (DEV_FLASH only)
'' @param p_filename - Pointer to filename string
'' @param mode - File open mode
'' @param max_file_length - Maximum file size in bytes
'' @returns handle - Handle on success, negative error code on failure
' @local fl_path - Flash-prefixed path string

  if dev <> DEV_FLASH
    set_error(E_NOT_SUPPORTED)
    handle := E_NOT_SUPPORTED
  elseifnot flash_mounted
    handle := set_error(E_NOT_MOUNTED)
  else
    fl_prepend_cwd(@fl_path, p_filename)
    send_command(CMD_FLASH_OPEN_CIRC, @fl_path, mode, max_file_length, 0)
    handle := LONG[@saved_data0][COGID()]
    if handle < 0
      set_error(handle)

PUB create_file(dev, p_filename, fill_value, byte_count) : status | fl_path[32]
'' Pre-allocate Flash file (Flash-specific, Phase 2+).
'' Flash: CWD prefix is automatically prepended to the filename.
''
'' @param dev - Target device (DEV_FLASH only)
'' @param p_filename - Pointer to filename string
'' @param fill_value - Fill byte value
'' @param byte_count - File size to pre-allocate
'' @returns status - SUCCESS or negative error code
' @local fl_path - Flash-prefixed path string

  if dev <> DEV_FLASH
    set_error(E_NOT_SUPPORTED)
    status := E_NOT_SUPPORTED
  elseifnot flash_mounted
    status := set_error(E_NOT_MOUNTED)
  else
    fl_prepend_cwd(@fl_path, p_filename)
    status := send_command(CMD_FLASH_CREATE_FILE, @fl_path, fill_value, byte_count, 0)
    if status <> SUCCESS
      set_error(status)

PUB close(handle) : status
'' Close file handle (Flash API compatibility).
''
'' @param handle - Valid file handle
'' @returns status - SUCCESS or negative error code

  ifnot flash_mounted
    status := set_error(E_NOT_MOUNTED)
  elseifnot validateHandle(handle)
    status := set_error(E_FLASH_BAD_HANDLE)
  else
    status := closeFileHandle(handle)

PUB flush(handle) : status
'' Flush handle without closing (Flash API compatibility).
''
'' @param handle - Valid file handle
'' @returns status - SUCCESS or negative error code

  ifnot flash_mounted
    status := set_error(E_NOT_MOUNTED)
  elseifnot validateHandle(handle)
    status := set_error(E_FLASH_BAD_HANDLE)
  else
    status := syncHandle(handle)

CON ' ---- Cross-Device Operations ----
    ' CROSS-DEVICE OPERATIONS
    ' ===========================================================================

PUB openFileRead(dev, p_path) : handle | fl_path[32]
'' Open file for reading (V3 multi-file) - opens existing file and returns handle.
'' Multiple files can be open simultaneously with independent positions.
'' Flash: CWD prefix is automatically prepended to the filename.
'' Use closeFileHandle() when done.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - File handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      send_command(CMD_OPEN_READ, p_path, 0, 0, 0)
      handle := LONG[@saved_data0][COGID()]
    DEV_FLASH:
      fl_prepend_cwd(@fl_path, p_path)
      send_command(CMD_FLASH_OPEN, @fl_path, FILEMODE_READ, 0, 0)
      handle := LONG[@saved_data0][COGID()]
    other:
      handle := set_error(E_BAD_DEVICE)
  if handle >= 0
    debug[CH_FILE]("  [openFileRead] Opened handle ", udec_(handle))
  else
    debug[CH_FILE]("  [openFileRead] Failed: ", sdec_(handle))
    set_error(handle)

PUB openFileWrite(dev, p_path) : handle | fl_path[32]
'' Open file for writing/append (V3 multi-file) - opens for appending.
'' SD: opens for append. Flash: opens for write (overwrites).
'' Flash: CWD prefix is automatically prepended to the filename.
'' Use closeFileHandle() when done to flush data.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - File handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      send_command(CMD_OPEN_WRITE, p_path, 0, 0, 0)
      handle := LONG[@saved_data0][COGID()]
    DEV_FLASH:
      fl_prepend_cwd(@fl_path, p_path)
      send_command(CMD_FLASH_OPEN, @fl_path, FILEMODE_WRITE, 0, 0)
      handle := LONG[@saved_data0][COGID()]
    other:
      handle := set_error(E_BAD_DEVICE)
  if handle >= 0
    debug[CH_FILE]("  [openFileWrite] Opened handle ", udec_(handle))
  else
    debug[CH_FILE]("  [openFileWrite] Failed: ", sdec_(handle))
    set_error(handle)

PUB createFileNew(dev, p_path) : handle | fl_path[32]
'' Create new file for writing (V3 multi-file) - creates and opens for writing.
'' SD: returns error if file exists. Flash: opens for write (overwrites if exists).
'' Flash: CWD prefix is automatically prepended to the filename.
'' Use closeFileHandle() when done to flush data and finalize size.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - File handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      send_command(CMD_CREATE, p_path, 0, 0, 0)
      handle := LONG[@saved_data0][COGID()]
    DEV_FLASH:
      fl_prepend_cwd(@fl_path, p_path)
      send_command(CMD_FLASH_OPEN, @fl_path, FILEMODE_WRITE, 0, 0)
      handle := LONG[@saved_data0][COGID()]
    other:
      handle := set_error(E_BAD_DEVICE)
  if handle >= 0
    debug[CH_FILE]("  [createFileNew] Created handle ", udec_(handle))
  else
    debug[CH_FILE]("  [createFileNew] Failed: ", sdec_(handle))
    set_error(handle)

PUB closeFileHandle(handle) : status
'' Close file handle (V3 multi-file) - closes handle, flushing pending writes.
'' For write handles, updates directory with final file size.
'' After close, handle is invalid and slot is available for reuse.
''
'' @param handle - Valid file handle
'' @returns status - SUCCESS or negative error code

  ifnot validateHandle(handle)
    status := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      status := send_command(CMD_FLASH_CLOSE, handle, 0, 0, 0)
    else
      status := send_command(CMD_CLOSE_H, handle, 0, 0, 0)
    if status == SUCCESS
      debug[CH_FILE]("  [closeFileHandle] Closed handle ", udec_(handle))
    else
      debug[CH_FILE]("  [closeFileHandle] Failed: ", sdec_(status))
      set_error(status)

PUB readHandle(handle, p_buffer, count) : bytes_read
'' Read from file handle (V3 multi-file) - reads up to count bytes into buffer.
'' Returns actual bytes read (may be less at EOF). Returns 0 at EOF.
'' Position advances by the number of bytes read.
''
'' @param handle - Valid file handle open for read
'' @param p_buffer - Pointer to destination buffer
'' @param count - Maximum bytes to read
'' @returns bytes_read - Bytes actually read (0 at EOF), negative on error

  ifnot validateHandle(handle)
    bytes_read := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      send_command(CMD_FLASH_READ, handle, p_buffer, count, 0)
    else
      send_command(CMD_READ_H, handle, p_buffer, count, 0)
    bytes_read := LONG[@saved_data0][COGID()]
    if bytes_read < 0
      debug[CH_FILE]("  [readHandle] Failed: ", sdec_(bytes_read))
      set_error(bytes_read)
    ' Note: send_command already propagates negative pb_status via set_error()

PUB writeHandle(handle, p_buffer, count) : bytes_written
'' Write to file handle (V3 multi-file) - writes count bytes from buffer.
'' File grows as needed with automatic cluster allocation.
'' Position advances by the number of bytes written.
''
'' @param handle - Valid file handle open for write
'' @param p_buffer - Pointer to source data
'' @param count - Bytes to write
'' @returns bytes_written - Bytes actually written, negative on error

  ifnot validateHandle(handle)
    bytes_written := set_error(E_INVALID_HANDLE)

  elseif count == 0
    set_error(SUCCESS)
    bytes_written := 0

  else
    if h_device[handle] == DEV_FLASH
      send_command(CMD_FLASH_WRITE, handle, p_buffer, count, 0)
    else
      send_command(CMD_WRITE_H, handle, p_buffer, count, 0)
    bytes_written := LONG[@saved_data0][COGID()]
    if bytes_written < 0
      debug[CH_FILE]("  [writeHandle] Failed: ", sdec_(bytes_written))
      set_error(bytes_written)

#ifdef SD_INCLUDE_ASYNC
PUB startReadHandle(handle, p_buffer, count) : status
'' Begin an asynchronous read. Returns immediately with PENDING (1).
'' The api_lock is held until getResult() or cancelAsync() is called.
''
'' @param handle - Valid file handle open for read
'' @param p_buffer - Pointer to destination buffer
'' @param count - Bytes to read
'' @returns status - PENDING, E_ASYNC_BUSY, or E_NOT_MOUNTED

  if async_active
    return set_error(E_ASYNC_BUSY)
  if cog_id == -1
    return set_error(E_NOT_MOUNTED)

  repeat until locktry(api_lock)

  pb_caller := COGID()
  pb_param0 := handle
  pb_param1 := p_buffer
  pb_param2 := count
  pb_cmd := CMD_READ_H

  async_active := true
  async_caller := COGID()
  status := PENDING

PUB startWriteHandle(handle, p_buffer, count) : status
'' Begin an asynchronous write. Returns immediately with PENDING (1).
'' The api_lock is held until getResult() or cancelAsync() is called.
''
'' @param handle - Valid file handle open for write
'' @param p_buffer - Pointer to source data
'' @param count - Bytes to write
'' @returns status - PENDING, E_ASYNC_BUSY, or E_NOT_MOUNTED

  if async_active
    return set_error(E_ASYNC_BUSY)
  if cog_id == -1
    return set_error(E_NOT_MOUNTED)

  repeat until locktry(api_lock)

  pb_caller := COGID()
  pb_param0 := handle
  pb_param1 := p_buffer
  pb_param2 := count
  pb_cmd := CMD_WRITE_H

  async_active := true
  async_caller := COGID()
  status := PENDING

PUB isComplete() : done
'' Non-blocking poll for async operation completion. Safe to call repeatedly.
''
'' @returns done - TRUE if async operation has completed, FALSE otherwise

  done := async_active and (pb_cmd == CMD_NONE)

PUB getResult() : status
'' Get the result of an async operation and release the lock. If the operation
'' hasn't finished yet, blocks until it does.
'' CRITICAL: Drains stale COGATN before releasing lock to prevent silent
'' data corruption in subsequent blocking calls.
''
'' @returns status - Bytes read/written on success, or negative error code

  if not async_active
    return set_error(E_NO_ASYNC_OP)

  repeat until pb_cmd == CMD_NONE

  if pb_status < 0
    status := pb_status
    set_error(pb_status)
  else
    status := pb_data0

  async_active := false
  if POLLATN()                           ' CRITICAL: drain stale COGATN from worker
  lockrel(api_lock)

PUB cancelAsync() : status
'' Wait for async operation to finish, discard result, release lock.
'' Use when the caller no longer needs the result.
''
'' @returns status - SUCCESS, or E_NO_ASYNC_OP

  if not async_active
    return set_error(E_NO_ASYNC_OP)

  repeat until pb_cmd == CMD_NONE

  async_active := false
  if POLLATN()                           ' CRITICAL: drain stale COGATN
  lockrel(api_lock)
  status := SUCCESS
#endif

PUB seekHandle(handle, position) : status
'' Seek to position in file (V3 multi-file) - seeks to absolute byte position.
'' Position must be <= file size (cannot seek past EOF).
''
'' @param handle - Valid file handle
'' @param position - Absolute byte position to seek to
'' @returns status - SUCCESS or negative error code

  ifnot validateHandle(handle)
    status := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      send_command(CMD_FLASH_SEEK, handle, position, SK_FILE_START, 0)
      status := LONG[@saved_data0][COGID()] < 0 ? LONG[@saved_data0][COGID()] : SUCCESS
    else
      status := send_command(CMD_SEEK_H, handle, position, 0, 0)
    if status <> SUCCESS
      debug[CH_FILE]("  [seekHandle] Failed: ", sdec_(status))
      set_error(status)

PUB seek(handle, position, whence) : end_position | abs_pos
'' Seek within a file with whence parameter (SD or Flash).
'' SK_FILE_START: absolute seek to position.
'' SK_CURRENT_POSN: relative seek by offset from current position.
''
'' @param handle - Valid file handle
'' @param position - Byte position (absolute) or offset (relative)
'' @param whence - SK_FILE_START (1) or SK_CURRENT_POSN (2)
'' @returns end_position - Resulting position, or negative error code
' @local abs_pos - Absolute file position in bytes

  ifnot validateHandle(handle)
    end_position := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      send_command(CMD_FLASH_SEEK, handle, position, whence, 0)
      end_position := LONG[@saved_data0][COGID()]
    else
      ' SD: compute absolute position based on whence
      if whence == SK_CURRENT_POSN
        abs_pos := tellHandle(handle)
        if abs_pos < 0
          end_position := abs_pos
        else
          abs_pos += position
      else
        abs_pos := position
      if send_command(CMD_SEEK_H, handle, abs_pos, 0, 0) == SUCCESS
        end_position := abs_pos
      else
        end_position := error()
    if end_position < 0
      set_error(end_position)

PUB flashSeek(handle, position, whence) : end_position
'' Seek within a Flash file with whence parameter (SK_FILE_START or SK_CURRENT_POSN).
'' Deprecated -- use seek(handle, position, whence) instead (works for both devices).
''
'' @param handle - Valid file handle
'' @param position - Byte position (absolute) or offset (relative)
'' @param whence - SK_FILE_START (1) or SK_CURRENT_POSN (2)
'' @returns end_position - Resulting position, or negative error code

  ifnot flash_mounted
    end_position := set_error(E_NOT_MOUNTED)
  elseifnot validateHandle(handle)
    end_position := set_error(E_FLASH_BAD_HANDLE)
  else
    end_position := seek(handle, position, whence)

PUB tellHandle(handle) : position | cmd_status
'' Get current position (V3 multi-file) - returns current byte position in file.
''
'' @param handle - Valid file handle
'' @returns position - Current position (0-based), negative on error
' @local cmd_status - Command status from send_command()

  ifnot validateHandle(handle)
    position := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      send_command(CMD_FLASH_SEEK, handle, 0, SK_CURRENT_POSN, 0)
      position := LONG[@saved_data0][COGID()]
    else
      cmd_status := send_command(CMD_TELL_H, handle, 0, 0, 0)
      if cmd_status == SUCCESS
        position := LONG[@saved_data0][COGID()]
      else
        position := cmd_status
        set_error(position)

PUB eofHandle(handle) : is_eof | cur_pos, fsize, cmd_status
'' Check if at end of file (V3 multi-file) - returns TRUE if at or past EOF.
''
'' @param handle - Valid file handle
'' @returns is_eof - TRUE if at EOF, FALSE if not, negative on error
' @local cur_pos - Current file position in bytes
' @local fsize - File size in bytes from directory entry
' @local cmd_status - Command status from send_command()

  ifnot validateHandle(handle)
    is_eof := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      ' Flash EOF: compare current seek position to file size
      cur_pos := tellHandle(handle)
      fsize := fileSizeHandle(handle)
      if cur_pos < 0
        is_eof := cur_pos
      elseif fsize < 0
        is_eof := fsize
      else
        is_eof := cur_pos >= fsize
    else
      cmd_status := send_command(CMD_EOF_H, handle, 0, 0, 0)
      if cmd_status == SUCCESS
        is_eof := LONG[@saved_data0][COGID()] <> 0
      else
        is_eof := cmd_status
        set_error(is_eof)

PUB fileSizeHandle(handle) : size | cmd_status
'' Get file size (V3 multi-file) - returns total size in bytes.
'' For write handles, reflects current size including pending writes.
''
'' @param handle - Valid file handle
'' @returns size - File size in bytes, negative on error
' @local cmd_status - Command status from send_command()

  ifnot validateHandle(handle)
    size := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      ' Flash: seek to end (POSX) returns file length
      send_command(CMD_FLASH_SEEK, handle, POSX, SK_FILE_START, 0)
      size := LONG[@saved_data0][COGID()]
    else
      cmd_status := send_command(CMD_FILESIZE_H, handle, 0, 0, 0)
      if cmd_status == SUCCESS
        size := LONG[@saved_data0][COGID()]
      else
        size := cmd_status
        set_error(size)

PUB syncHandle(handle) : status
'' Flush handle to disk (V3 multi-file) - flushes pending writes and updates directory.
'' File remains open for further operations.
''
'' @param handle - Valid file handle
'' @returns status - SUCCESS or negative error code

  ifnot validateHandle(handle)
    status := set_error(E_INVALID_HANDLE)

  else
    if h_device[handle] == DEV_FLASH
      status := send_command(CMD_FLASH_FLUSH, handle, 0, 0, 0)
    else
      status := send_command(CMD_SYNC_H, handle, 0, 0, 0)
    if status <> SUCCESS
      debug[CH_FILE]("  [syncHandle] Failed: ", sdec_(status))
      set_error(status)

PUB syncAllHandles() : status
'' Flush all handles to disk (V3 multi-file) - flushes all open write handles.
'' Useful before risky operations or for periodic safety.
''
'' @returns status - SUCCESS or negative error code

  status := send_command(CMD_SYNC_ALL, 0, 0, 0, 0)
  if status <> SUCCESS
    debug[CH_FILE]("  [syncAllHandles] Failed: ", sdec_(status))
    set_error(status)

PUB copyFile(srcDev, p_src_path, dstDev, p_dst_path) : status | srcHandle, dstHandle, bytes_read, bytes_written
'' Copy file between devices.
'' Opens source for read, creates destination for write, copies data in 512-byte
'' chunks, then closes both handles. Works for SD-to-Flash, Flash-to-SD, or
'' same-device copies.
''
'' @param srcDev - Source device (DEV_SD or DEV_FLASH)
'' @param p_src_path - Source filename
'' @param dstDev - Destination device (DEV_SD or DEV_FLASH)
'' @param p_dst_path - Destination filename
'' @returns status - SUCCESS or negative error code

  ' Validate devices
' @local srcHandle - Source file handle for copy operation
' @local dstHandle - Destination file handle for copy operation
' @local bytes_read - Number of bytes read in current transfer
' @local bytes_written - Number of bytes written in current transfer
  if srcDev <> DEV_SD and srcDev <> DEV_FLASH
    status := set_error(E_BAD_DEVICE)
  elseif dstDev <> DEV_SD and dstDev <> DEV_FLASH
    status := set_error(E_BAD_DEVICE)

  ' Open source for read
  else
    srcHandle := openFileRead(srcDev, p_src_path)
    if srcHandle < 0
      status := srcHandle

    ' Create/open destination for write
    else
      if dstDev == DEV_SD
        dstHandle := createFileNew(dstDev, p_dst_path)
      else
        dstHandle := open(dstDev, p_dst_path, FILEMODE_WRITE)
      if dstHandle < 0
        closeFileHandle(srcHandle)
        status := dstHandle

      ' Copy loop: read from source, write to destination
      else
        status := SUCCESS
        repeat
          bytes_read := readHandle(srcHandle, @copy_buf, SECTOR_SIZE)
          if bytes_read < 0
            status := bytes_read
            quit
          if bytes_read == 0
            quit
          bytes_written := writeHandle(dstHandle, @copy_buf, bytes_read)
          if bytes_written < 0
            status := bytes_written
            quit
          if bytes_written <> bytes_read
            status := E_IO_ERROR
            quit

        ' Close both handles (always, even on error)
        closeFileHandle(dstHandle)
        closeFileHandle(srcHandle)

        if status < 0
          set_error(status)

CON ' ---- Error Reporting ----
    ' ERROR REPORTING
    ' ===========================================================================


CON ' ---- Directory Methods ----
    ' DIRECTORY METHODS
    ' =============================================================================
PUB getFlashCwd() : p_cwd
'' Return pointer to calling cog's Flash CWD prefix string.
'' Empty string means root directory. Example: "dir1" or "dir1/dir2".
''
'' @returns p_cwd - Pointer to null-terminated CWD string

  p_cwd := fl_get_cwd()

PUB openDirectory(dev, p_path) : handle
'' Open directory for enumeration (multi-cog safe) - returns handle for iterating entries.
'' Use readDirectoryHandle() to get entries, closeDirectoryHandle() when done.
'' Pass "" or "." to enumerate calling cog's current working directory.
'' Handles share the existing file handle pool (MAX_OPEN_FILES total).
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_path - Pointer to null-terminated path string
'' @returns handle - Handle on success, negative error code on failure

  case dev
    DEV_SD:
      send_command(CMD_OPEN_DIR, p_path, 0, 0, 0)
      handle := LONG[@saved_data0][COGID()]
    DEV_FLASH:
      handle := fl_open_directory(p_path)
    other:
      set_error(E_BAD_DEVICE)
      handle := E_BAD_DEVICE

PUB readDirectoryHandle(handle) : p_entry
'' Read next entry from directory handle (multi-cog safe) - returns pointer to entry data.
'' Skips deleted, LFN, and hidden/system entries automatically.
'' After each call, use fileName() and attributes() to inspect the returned entry.
''
'' @param handle - Valid directory handle
'' @returns p_entry - Pointer to entry_buffer on success, 0 at end of directory

  if handle < 0 or handle >= MAX_OPEN_FILES or h_flags[handle] == HF_FREE
    p_entry := 0
  elseif h_device[handle] == DEV_FLASH
    if fl_read_dir_handle(handle) == SUCCESS
      p_entry := @entry_buffer
    else
      p_entry := 0
  else
    ' SD path (existing)
    if send_command(CMD_READ_DIR_H, handle, 0, 0, 0) == SUCCESS
      p_entry := @entry_buffer
    else
      p_entry := 0

PUB closeDirectoryHandle(handle)
'' Close directory handle (multi-cog safe) - releases handle back to pool.
''
'' @param handle - Valid directory handle

  if handle >= 0 and handle < MAX_OPEN_FILES
    if h_device[handle] == DEV_FLASH
      repeat until locktry(api_lock)
      freeHandle(handle)
      lockrel(api_lock)
    else
      send_command(CMD_CLOSE_DIR_H, handle, 0, 0, 0)

CON ' ---- Unified Device-Level Methods ----
    ' UNIFIED DEVICE-LEVEL METHODS (ADR-9)
    ' ===========================================================================

PUB readDirectory(entry) : p_entry
'' Read directory entry (multi-cog safe) - iterates through directory entries.
''
'' @param entry - Entry index to read (0-based)
'' @returns p_entry - Pointer to entry_buffer on success, 0 if entry doesn't exist

  if send_command(CMD_READDIR, entry, 0, 0, 0) == SUCCESS
    p_entry := @entry_buffer
  else
    p_entry := 0

PUB newDirectory(dev, name_ptr) : status
'' Create a new directory (multi-cog safe) in current directory.
'' SD: creates a FAT32 directory entry.
'' Flash: no-op success (directories are implicit from path-segmented filenames).
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param name_ptr - Pointer to null-terminated directory name string
'' @returns status - SUCCESS or negative error code

  case dev
    DEV_SD:
      status := send_command(CMD_NEWDIR, name_ptr, 0, 0, 0)
      if status <> SUCCESS
        set_error(status)
    DEV_FLASH:
      ' Flash directories are implicit -- they exist when files with matching path prefixes exist.
      ' mkdir just validates the request and succeeds. Empty directories vanish naturally.
      ifnot flash_mounted
        status := set_error(E_NOT_MOUNTED)
      else
        status := SUCCESS
    other:
      status := set_error(E_BAD_DEVICE)

PUB changeDirectory(dev, name_ptr) : status
'' Change directory (multi-cog safe) - changes current directory.
'' SD: navigates FAT32 directory tree via worker cog.
'' Flash: updates per-cog CWD prefix string (caller-side, no worker command).
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param name_ptr - Pointer to null-terminated directory name string
'' @returns status - SUCCESS or negative error code

  case dev
    DEV_SD:
      status := send_command(CMD_CHDIR, name_ptr, 0, 0, 0)
      if status <> SUCCESS
        set_error(status)
    DEV_FLASH:
      ifnot flash_mounted
        status := set_error(E_NOT_MOUNTED)
      else
        fl_change_cwd(name_ptr)
        status := SUCCESS
    other:
      status := set_error(E_BAD_DEVICE)

PUB directory(dev, p_block_id, p_filename, p_file_size) : status | tmpName[32]
'' Get next Flash directory entry (iterates files), filtered by CWD.
'' Flash only -- caller sets LONG[p_block_id] to 0 before first call, auto-incremented.
'' When no more files, p_filename[0] will be 0.
'' Only returns files that are direct children of the current working directory.
'' The CWD prefix is stripped -- p_filename receives the bare filename only.
''
'' @param dev - Target device (DEV_FLASH only)
'' @param p_block_id - Pointer to LONG block ID counter (auto-advanced)
'' @param p_filename - Pointer to 128-byte buffer for filename (receives bare name)
'' @param p_file_size - Pointer to LONG receiving file size
'' @returns status - SUCCESS or negative error code
' @local tmpName - Temporary filename buffer for path construction

  if dev <> DEV_FLASH
    status := set_error(E_BAD_DEVICE)
  elseif cog_id == -1
    status := set_error(E_NOT_MOUNTED)
  elseifnot flash_mounted
    status := set_error(E_NOT_MOUNTED)

  ' Loop until we find a CWD-matching file or exhaust directory
  else
    repeat
      send_command(CMD_FLASH_DIRECTORY, p_block_id, @tmpName, p_file_size, 0)
      if BYTE[@tmpName][0] == 0
        ' No more files
        BYTE[p_filename][0] := 0
        status := SUCCESS
        quit
      else
        if fl_cwd_matches(@tmpName, p_filename)
          ' Match found -- p_filename now has the bare (CWD-stripped) name
          status := SUCCESS
          quit


CON ' ---- Metadata Methods ----
    ' METADATA METHODS
    ' =============================================================================
PUB exists(dev, p_filename) : found | fl_path[32]
'' Check if file exists on device.
'' Flash: CWD prefix is automatically prepended to the filename.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_filename - Pointer to filename string
'' @returns found - TRUE if file exists
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      if send_command(CMD_SD_EXISTS, p_filename, 0, 0, 0) == SUCCESS
        found := LONG[@saved_data0][COGID()] <> 0
      else
        found := false
    DEV_FLASH:
      ifnot flash_mounted
        set_error(E_NOT_MOUNTED)
        found := false
      else
        fl_prepend_cwd(@fl_path, p_filename)
        if send_command(CMD_FLASH_EXISTS, @fl_path, 0, 0, 0) == SUCCESS
          found := LONG[@saved_data0][COGID()] <> 0
        else
          found := false
    other:
      found := false

PUB file_size(dev, p_filename) : size | cmd_status, fl_path[32]
'' Get file size by name (without opening).
'' Flash: CWD prefix is automatically prepended to the filename.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_filename - Pointer to filename string
'' @returns size - File size in bytes, negative on error
' @local cmd_status - Command status from send_command()
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      cmd_status := send_command(CMD_SD_FILE_SIZE, p_filename, 0, 0, 0)
      if cmd_status == SUCCESS
        size := LONG[@saved_data0][COGID()]
      else
        size := cmd_status
    DEV_FLASH:
      ifnot flash_mounted
        size := set_error(E_NOT_MOUNTED)
      else
        fl_prepend_cwd(@fl_path, p_filename)
        cmd_status := send_command(CMD_FLASH_FILE_SIZE, @fl_path, 0, 0, 0)
        if cmd_status == SUCCESS
          size := LONG[@saved_data0][COGID()]
        else
          size := cmd_status
    other:
      size := E_BAD_DEVICE

CON ' ---- Flash-Style API ----
    ' FLASH-STYLE API (Phase 3)
    ' Mode-based open, circular files, create_file, close, flush.
    ' SD operations mapped to SD handle commands where applicable.
    ' ===========================================================================

PUB file_size_unused(dev, p_filename) : size_unused | fl_path[32]
'' Get unused (slack) bytes for a file.
'' SD: allocated cluster space minus actual file size.
'' Flash: unused bytes in last block. CWD prefix is automatically prepended.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param p_filename - Pointer to filename string
'' @returns size_unused - Unused byte count, or negative error code
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      if send_command(CMD_SD_FILE_SIZE_UNUSED, p_filename, 0, 0, 0) == SUCCESS
        size_unused := LONG[@saved_data0][COGID()]
      else
        size_unused := error()
    DEV_FLASH:
      ifnot flash_mounted
        size_unused := set_error(E_NOT_MOUNTED)
      else
        fl_prepend_cwd(@fl_path, p_filename)
        send_command(CMD_FL_FILE_SIZE_UNUSED, @fl_path, 0, 0, 0)
        size_unused := LONG[@saved_data0][COGID()]
    other:
      size_unused := set_error(E_BAD_DEVICE)

PUB rename(dev, old_name, new_name) : status | fl_old[32], fl_new[32]
'' Rename file or directory (multi-cog safe).
'' Flash: CWD prefix is automatically prepended to both names. Renaming a file
'' to a different path prefix effectively moves it between directories. If this
'' was the last file under the old prefix, that directory vanishes (Flash directories
'' are not stored on disk -- they exist only as filename path prefixes).
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param old_name - Pointer to current name string
'' @param new_name - Pointer to new name string
'' @returns status - SUCCESS or negative error code
' @local fl_old - Flash-prefixed old filename for rename
' @local fl_new - Flash-prefixed new filename for rename

  case dev
    DEV_SD:
      status := send_command(CMD_RENAME, old_name, new_name, 0, 0)
    DEV_FLASH:
      ifnot flash_mounted
        status := set_error(E_NOT_MOUNTED)
      else
        fl_prepend_cwd(@fl_old, old_name)
        fl_prepend_cwd(@fl_new, new_name)
        status := send_command(CMD_FLASH_RENAME, @fl_old, @fl_new, 0, 0)
    other:
      status := set_error(E_BAD_DEVICE)
  if status <> SUCCESS
    set_error(status)

PUB deleteFile(dev, name_ptr) : status | fl_path[32]
'' Delete file (multi-cog safe) - deletes file from current directory.
'' Flash: CWD prefix is automatically prepended to the filename.
'' NOTE: Flash directories are not stored on disk -- they exist only because files
'' with matching path prefixes exist. Deleting the last file in a Flash directory
'' causes that directory to vanish. This is an inherent property of the path-prefix
'' emulation model, not an explicit step performed by this method.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param name_ptr - Pointer to null-terminated filename string
'' @returns status - SUCCESS or negative error code
' @local fl_path - Flash-prefixed path string

  case dev
    DEV_SD:
      status := send_command(CMD_DELETE, name_ptr, 0, 0, 0)
    DEV_FLASH:
      ifnot flash_mounted
        status := set_error(E_NOT_MOUNTED)
      else
        fl_prepend_cwd(@fl_path, name_ptr)
        status := send_command(CMD_FLASH_DELETE, @fl_path, 0, 0, 0)
    other:
      status := set_error(E_BAD_DEVICE)
  if status <> SUCCESS
    set_error(status)

PUB moveFile(dev, name_ptr, dest_folder) : status | fl_new_path[32], p_bare, idx, dest_len, bare_len
'' Move file to another directory (multi-cog safe).
'' SD: moves file via FAT32 directory manipulation.
'' Flash: constructs new path from dest_folder + bare filename, then renames.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @param name_ptr - Pointer to filename to move
'' @param dest_folder - Pointer to destination folder name (empty string for root)
'' @returns status - SUCCESS or negative error code
' @local fl_new_path - Buffer for constructed destination path
' @local p_bare - Pointer to bare filename (after last "/")
' @local idx - Loop index for scanning filename
' @local dest_len - Length of destination folder string
' @local bare_len - Length of bare filename

  case dev
    DEV_SD:
      status := send_command(CMD_MOVEFILE, name_ptr, dest_folder, 0, 0)
      if status <> SUCCESS
        set_error(status)
    DEV_FLASH:
      ifnot flash_mounted
        status := set_error(E_NOT_MOUNTED)
      else
        ' Extract bare filename (strip any path prefix)
        p_bare := name_ptr
        idx := 0
        repeat strsize(name_ptr)
          if BYTE[name_ptr][idx] == "/"
            p_bare := name_ptr + idx + 1
          idx++
        ' Build absolute destination path: "/dest_folder/bare_filename"
        ' Leading "/" makes fl_prepend_cwd skip CWD prefix for the new name
        bytefill(@fl_new_path, 0, FL_FILENAME_SIZE)
        dest_len := strsize(dest_folder)
        bare_len := strsize(p_bare)
        idx := 0
        BYTE[@fl_new_path][idx++] := "/"                                        ' Absolute path marker
        if dest_len > 0
          bytemove(@fl_new_path + idx, dest_folder, dest_len)
          idx += dest_len
          BYTE[@fl_new_path][idx++] := "/"                                      ' Separator after folder
        bytemove(@fl_new_path + idx, p_bare, bare_len)
        ' Delegate to rename which handles CWD prepending for old name
        status := rename(DEV_FLASH, name_ptr, @fl_new_path)
    other:
      status := set_error(E_BAD_DEVICE)

PUB freeSpace(dev) : free_count
'' Get free space (multi-cog safe).
'' SD: returns free sectors. Flash: returns free blocks.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @returns free_count - Number of free sectors/blocks, 0 on error

  case dev
    DEV_SD:
      if not sd_mounted
        free_count := 0
      else
        if send_command(CMD_FREESPACE, 0, 0, 0, 0) == SUCCESS
          free_count := LONG[@saved_data0][COGID()]
        else
          free_count := 0
    DEV_FLASH:
      if not flash_mounted
        free_count := 0
      else
        if send_command(CMD_FLASH_STATS, 0, 0, 0, 0) == SUCCESS
          free_count := LONG[@saved_data1][COGID()]  ' free_blocks from fl_stats()
        else
          free_count := 0
    other:
      free_count := 0

PUB stats(dev) : used, free_ct, file_count | dirHandle, p_entry
'' Get device statistics.
'' SD: used/free sectors, file count in CWD.
'' Flash: used/free blocks, file count.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @returns used - Used blocks/sectors
'' @returns free_ct - Free blocks/sectors
'' @returns file_count - Number of files in CWD
' @local dirHandle - Directory handle for enumeration
' @local p_entry - Pointer to directory entry

  case dev
    DEV_SD:
      free_ct := freeSpace(DEV_SD)
      used := 0                                                                 ' Total - free requires SD_INCLUDE_RAW
      ' Count files in current working directory
      file_count := 0
      dirHandle := openDirectory(DEV_SD, @".")
      if dirHandle >= 0
        repeat
          p_entry := readDirectoryHandle(dirHandle)
          if p_entry == 0
            quit
          if not (BYTE[p_entry][DIR_ATTR_OFFSET] & DIR_ATTR_DIRECTORY)             ' Skip directories (., .., subdirs)
            file_count++
        closeDirectoryHandle(dirHandle)
    DEV_FLASH:
      ifnot flash_mounted
        used := set_error(E_NOT_MOUNTED)
      else
        if send_command(CMD_FLASH_STATS, 0, 0, 0, 0) == SUCCESS
          used := LONG[@saved_data0][COGID()]
          free_ct := LONG[@saved_data1][COGID()]
          file_count := LONG[@saved_data2][COGID()]
    other:
      used := 0
      free_ct := 0
      file_count := 0

PUB setDate(year, month, day, hour, minute, second) : status
'' Set the current date and time for new files/folders. Activates the live
'' 2-second clock so timestamps advance automatically.
''
'' @param year - Year (1980-2107)
'' @param month - Month (1-12)
'' @param day - Day (1-31, validated against month/year)
'' @param hour - Hour (0-23)
'' @param minute - Minute (0-59)
'' @param second - Second (0-59)
'' @returns status - SUCCESS or E_INVALID_PARAM

  if year < 1980 or year > 2107
    return set_error(E_INVALID_PARAM)
  if month < 1 or month > 12
    return set_error(E_INVALID_PARAM)
  if day < 1 or day > daysInMonth(year, month)
    return set_error(E_INVALID_PARAM)
  if hour > 23 or minute > 59 or second > 59
    return set_error(E_INVALID_PARAM)

  FIELD[fld_yr][0]  := year - FAT_YEAR_BASE
  FIELD[fld_mon][0] := month
  FIELD[fld_day][0] := day
  FIELD[fld_hr][0]  := hour
  FIELD[fld_min][0] := minute
  FIELD[fld_sec][0] := second >> 1
  ct_active := true
  ct_last_tick := getct()
  status := SUCCESS

PUB getDate() : year, month, day, hour, minute, second
'' Get the current date and time from the live clock.
'' Returns unpacked date/time values read directly from hub RAM.
''
'' @returns year - Year (1980-2107)
'' @returns month - Month (1-12)
'' @returns day - Day (1-31)
'' @returns hour - Hour (0-23)
'' @returns minute - Minute (0-59)
'' @returns second - Second (0-58, even values only due to FAT32 2-second resolution)

  year   := FIELD[fld_yr][0] + FAT_YEAR_BASE
  month  := FIELD[fld_mon][0]
  day    := FIELD[fld_day][0]
  hour   := FIELD[fld_hr][0]
  minute := FIELD[fld_min][0]
  second := FIELD[fld_sec][0] << 1

PUB serial_number(dev) : sn_hi, sn_lo | status
'' Get device serial number.
'' SD: returns 32-bit CID serial (sn_hi=0, sn_lo=serial). Requires SD_INCLUDE_REGISTERS.
'' Flash: returns 64-bit JEDEC unique ID.
''
'' @param dev - Target device (DEV_SD or DEV_FLASH)
'' @returns sn_hi - High 32 bits (Flash only; 0 for SD)
'' @returns sn_lo - Low 32 bits
' @local status - Operation status code

  case dev
    DEV_SD:
      sn_hi := 0
      sn_lo := card_serial_number
    DEV_FLASH:
      if not flash_mounted
        set_error(E_NOT_MOUNTED)
        sn_hi := 0
        sn_lo := 0
      else
        status := send_command(CMD_SERIAL_NUMBER, 0, 0, 0, 0)
        if status == SUCCESS
          sn_hi := LONG[@saved_data0][COGID()]
          sn_lo := LONG[@saved_data1][COGID()]
        else
          set_error(status)
          sn_hi := 0
          sn_lo := 0
    other:
      sn_hi := 0
      sn_lo := 0

PUB TEST_count_file_bytes(p_filename) : bytes_used, bytes_free, block_count | fl_path[32]
'' Diagnostic: count bytes in Flash file by filename.
'' Used by test utilities for file statistics validation.
'' Flash: CWD prefix is automatically prepended to the filename.
''
'' @param p_filename - Pointer to filename string
'' @returns bytes_used - Bytes written to file (or E_FILE_NOT_FOUND)
'' @returns bytes_free - Unused bytes in last block
'' @returns block_count - Total blocks allocated
' @local fl_path - Flash-prefixed path string

  ifnot flash_mounted
    bytes_used := set_error(E_NOT_MOUNTED)
  else
    fl_prepend_cwd(@fl_path, p_filename)
    send_command(CMD_FL_COUNT_BYTES, @fl_path, 0, 0, 0)
    bytes_used := LONG[@saved_data0][COGID()]
    bytes_free := LONG[@saved_data1][COGID()]
    block_count := LONG[@saved_data2][COGID()]


CON ' ---- Byte/Word/Long/String I/O Methods ----
    ' BYTE/WORD/LONG/STRING I/O METHODS
    ' =============================================================================
PUB wr_byte(handle, byte_value) : status | bytes_written
'' Write a byte to file handle (SD or Flash).
''
'' @param handle - Valid file handle open for write
'' @param byte_value - Byte value to write
'' @returns status - SUCCESS or negative error code
' @local bytes_written - Number of bytes written in current transfer

  ifnot validateHandle(handle)
    status := set_error(E_INVALID_HANDLE)
  else
    if h_device[handle] == DEV_FLASH
      status := send_command(CMD_FL_WR_BYTE, handle, byte_value, 0, 0)
    else
      bytes_written := writeHandle(handle, @byte_value, 1)
      status := bytes_written < 0 ? bytes_written : SUCCESS

PUB rd_byte(handle) : byte_value
'' Read next byte from file handle (SD or Flash).
''
'' @param handle - Valid file handle open for read
'' @returns byte_value - Byte [0-255] or negative error code

  ifnot validateHandle(handle)
    byte_value := set_error(E_INVALID_HANDLE)
  else
    if h_device[handle] == DEV_FLASH
      send_command(CMD_FL_RD_BYTE, handle, 0, 0, 0)
      byte_value := LONG[@saved_data0][COGID()]
    else
      byte_value := 0
      if readHandle(handle, @byte_value, 1) < 0
        byte_value := error()

PUB wr_word(handle, word_value) : status | bytes_written
'' Write WORD (16-bit, little-endian) to file handle (SD or Flash).
''
'' @param handle - Valid file handle open for write
'' @param word_value - 16-bit value to write
'' @returns status - SUCCESS or negative error code
' @local bytes_written - Number of bytes written in current transfer

  ifnot validateHandle(handle)
    status := set_error(E_INVALID_HANDLE)
  else
    bytes_written := writeHandle(handle, @word_value, 2)
    status := bytes_written < 0 ? bytes_written : SUCCESS

PUB rd_word(handle) : word_value | bytes_read
'' Read next WORD (16-bit) from file handle (SD or Flash).
''
'' @param handle - Valid file handle open for read
'' @returns word_value - WORD value or negative error code
' @local bytes_read - Number of bytes read in current transfer

  ifnot validateHandle(handle)
    word_value := set_error(E_INVALID_HANDLE)
  else
    word_value := 0
    bytes_read := readHandle(handle, @word_value, 2)
    if bytes_read <> 2
      word_value := error()

PUB wr_long(handle, long_value) : status | bytes_written
'' Write LONG (32-bit, little-endian) to file handle (SD or Flash).
''
'' @param handle - Valid file handle open for write
'' @param long_value - 32-bit value to write
'' @returns status - SUCCESS or negative error code
' @local bytes_written - Number of bytes written in current transfer

  ifnot validateHandle(handle)
    status := set_error(E_INVALID_HANDLE)
  else
    bytes_written := writeHandle(handle, @long_value, 4)
    status := bytes_written < 0 ? bytes_written : SUCCESS

PUB rd_long(handle) : long_value
'' Read next LONG (32-bit) from file handle (SD or Flash).
'' NOTE: Negative LONGs are valid data. Check error() after call.
''
'' @param handle - Valid file handle open for read
'' @returns long_value - LONG value read from file

  ifnot validateHandle(handle)
    set_error(E_INVALID_HANDLE)
    long_value := 0
  else
    long_value := 0
    readHandle(handle, @long_value, 4)

PUB wr_str(handle, p_str) : status | bytes_written
'' Write string including null terminator to file handle (SD or Flash).
''
'' @param handle - Valid file handle open for write
'' @param p_str - Pointer to zero-terminated string
'' @returns status - SUCCESS or negative error code
' @local bytes_written - Number of bytes written in current transfer

  ifnot validateHandle(handle)
    status := set_error(E_INVALID_HANDLE)
  else
    bytes_written := writeHandle(handle, p_str, strsize(p_str) + 1)
    status := bytes_written < 0 ? bytes_written : SUCCESS

PUB rd_str(handle, p_str, count) : bytes_read | ch
'' Read zero-terminated string from file handle (SD or Flash).
'' Reads byte by byte until null terminator found or count reached.
''
'' @param handle - Valid file handle open for read
'' @param p_str - Pointer to destination buffer
'' @param count - Maximum bytes to read (including terminator)
'' @returns bytes_read - String length (not including terminator), or negative on error
' @local ch - Current character being processed

  ifnot validateHandle(handle)
    set_error(E_INVALID_HANDLE)
    bytes_read := 0
  else
    if h_device[handle] == DEV_FLASH
      send_command(CMD_FL_RD_STR, handle, p_str, count, 0)
      bytes_read := LONG[@saved_data0][COGID()]
    else
      ' SD: read byte-by-byte until null terminator or count reached
      bytes_read := 0
      repeat count
        ch := rd_byte(handle)
        if ch < 0
          bytes_read := ch  ' Error
        else
          BYTE[p_str][bytes_read] := ch
          if ch == 0
            quit  ' Found terminator
          bytes_read++
      BYTE[p_str][bytes_read] := 0                                                ' Ensure null termination


CON ' ---- Legacy Methods ----
    ' LEGACY METHODS
    ' =============================================================================
PUB fileName() : p_filename | p_temp, idx
'' Return the 8.3 filename of the currently opened file.
''
'' @returns p_filename - Pointer to filename string
' @local p_temp - Pointer to temporary filename buffer
' @local idx - Loop counter for parsing

  p_temp := @"filename.txt"
  bytemove(p_temp,@entry_buffer,11)
  idx := 0
  repeat until byte[p_temp + idx++] == " " or idx == 9
  bytemove(p_temp + idx,p_temp + 8,3)
  if attributes() & DIR_ATTR_DIRECTORY
    byte[p_temp + idx-1] := $00
  else
    byte[p_temp + idx-1] := "."
    byte[p_temp + idx+3] := $00
  p_filename := p_temp

PUB fileSize() : size_in_bytes
'' Return the size of the currently opened file in bytes.
''
'' @returns size_in_bytes - File size from directory entry

  size_in_bytes := dirEntFileSize(@entry_buffer)

PUB attributes() : attr_byte
'' Return the attribute byte of the currently opened file.
''
'' @returns attr_byte - FAT attribute byte

  attr_byte := dirEntAttr(@entry_buffer)

PUB wrtDate() : date_word
'' Return the modification date of the current directory entry.
'' FAT16 packed format: bits [15:9]=year-1980, [8:5]=month, [4:0]=day
''
'' @returns date_word - FAT16 packed date word

  date_word := WORD[@entry_buffer + DIR_WRT_TIME_OFFSET + 2]

PUB wrtTime() : time_word
'' Return the modification time of the current directory entry.
'' FAT16 packed format: bits [15:11]=hour, [10:5]=minute, [4:0]=second/2
''
'' @returns time_word - FAT16 packed time word

  time_word := WORD[@entry_buffer + DIR_WRT_TIME_OFFSET]

PUB volumeLabel(dev) : p_label
'' Return pointer to volume label string (SD only).
''
'' @param dev - Target device (DEV_SD only)
'' @returns p_label - Pointer to volume label (11 chars + null), 0 if not SD

  if dev <> DEV_SD
    p_label := 0
  else
    p_label := @vol_label

PUB setVolumeLabel(dev, p_label) : status
'' Set the volume label on the mounted SD card.
'' Updates both the BPB and root directory volume label entry.
''
'' @param p_label - Pointer to new volume label string (max 11 chars)
'' @returns status - SUCCESS or negative error code

  if dev <> DEV_SD
    status := set_error(E_NOT_SUPPORTED)
  else
    status := send_command(CMD_SET_VOL_LABEL, p_label, 0, 0, 0)
    if status <> SUCCESS
      set_error(status)

#ifdef SD_INCLUDE_DEFRAG
' =============================================================================
' DEFRAGMENTATION API
' =============================================================================

PUB fileFragments(dev, p_path) : fragment_count
'' Count the number of non-contiguous fragments in a file's cluster chain.
'' A contiguous file returns 1. An empty file returns 0. SD-only.
''
'' @param dev - Target device (must be DEV_SD)
'' @param p_path - Pointer to null-terminated filename string
'' @returns fragment_count - Fragment count (1 = contiguous), 0 if empty, or negative error code

  if dev <> DEV_SD
    fragment_count := set_error(E_NOT_SUPPORTED)
  else
    send_command(CMD_FILE_FRAGMENTS, p_path, 0, 0, 0)
    fragment_count := LONG[@saved_data0][COGID()]

PUB isFileContiguous(dev, p_path) : bContig | fragCnt
'' Check if a file's clusters are stored contiguously on disk.
'' Convenience wrapper around fileFragments(). SD-only.
''
'' @param dev - Target device (must be DEV_SD)
'' @param p_path - Pointer to null-terminated filename string
'' @returns bContig - TRUE if contiguous, FALSE otherwise, or negative error code
'
' @local fragCnt - Intermediate fragment count from fileFragments()

  fragCnt := fileFragments(dev, p_path)
  if fragCnt < 0
    bContig := fragCnt                                                           ' propagate error code
  else
    bContig := (fragCnt == CONTIGUOUS_FRAGMENTS)

PUB createFileContiguous(dev, p_path, expected_size) : handle
'' Create a new file with a pre-allocated contiguous cluster chain. SD-only.
'' The file's clusters are allocated upfront so writeHandle() never fragments.
'' If insufficient contiguous space exists, returns E_NO_CONTIGUOUS_SPACE.
''
'' @param dev - Target device (must be DEV_SD)
'' @param p_path - Pointer to null-terminated filename string
'' @param expected_size - Expected file size in bytes (determines cluster count)
'' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, or negative error code

  if dev <> DEV_SD
    handle := set_error(E_NOT_SUPPORTED)
  else
    send_command(CMD_CREATE_CONTIGUOUS, p_path, expected_size, 0, 0)
    handle := LONG[@saved_data0][COGID()]

PUB compactFile(dev, p_path) : status
'' Relocate a file's clusters into a contiguous chain on disk. SD-only.
'' The file must not be open (no active handles). If already contiguous, returns SUCCESS (no-op).
'' Uses copy-then-free strategy: file is always readable during compaction.
'' Read-back verification is performed after every copy.
''
'' @param dev - Target device (must be DEV_SD)
'' @param p_path - Pointer to null-terminated filename string
'' @returns status - SUCCESS, E_FILE_NOT_FOUND, E_FILE_OPEN_FOR_COMPACT, E_NO_CONTIGUOUS_SPACE, E_VERIFY_FAILED, E_IO_ERROR

  if dev <> DEV_SD
    status := set_error(E_NOT_SUPPORTED)
  else
    status := send_command(CMD_COMPACT_FILE, p_path, 0, 0, 0)

#endif

PUB syncDirCache()
'' Force directory cache invalidation - invalidates the directory sector cache.
'' The next read will re-fetch from card.
'' Use after file operations to ensure consistency when multiple files are accessed.
'' This is safe to call from any cog (just sets a DAT variable to -1).

  dir_sec_in_buf := -1


CON ' ---- Error and Diagnostic Methods ----
    ' ERROR AND DIAGNOSTIC METHODS
    ' =============================================================================
PUB error() : status
'' Get last error for this cog - returns the error code from the most recent operation.
'' Thread-safe: each cog has its own error slot.
''
'' @returns status - Error code from the most recent operation on this cog

  status := LONG[@last_error][COGID()]

PUB string_for_error(code) : p_str
'' Return human-readable string for any unified error code.
''
'' @param code - Error code
'' @returns p_str - Pointer to constant string describing the error

  case code
    SUCCESS:                 p_str := @s_success
    E_TIMEOUT:               p_str := @s_timeout
    E_NO_RESPONSE:           p_str := @s_no_response
    E_BAD_RESPONSE:          p_str := @s_bad_response
    E_CRC_ERROR:             p_str := @s_crc_error
    E_WRITE_REJECTED:        p_str := @s_write_rejected
    E_CARD_BUSY:             p_str := @s_card_busy
    E_IO_ERROR:              p_str := @s_io_error
    E_NO_CARD:               p_str := @s_no_card
    E_NOT_MOUNTED:           p_str := @s_not_mounted
    E_INIT_FAILED:           p_str := @s_init_failed
    E_NOT_FAT32:             p_str := @s_not_fat32
    E_BAD_SECTOR_SIZE:       p_str := @s_bad_sector_size
    E_FILE_NOT_FOUND:        p_str := @s_file_not_found
    E_FILE_EXISTS:           p_str := @s_file_exists
    E_NOT_A_FILE:            p_str := @s_not_a_file
    E_NOT_A_DIR:             p_str := @s_not_a_dir
    E_FILE_NOT_OPEN:         p_str := @s_file_not_open
    E_END_OF_FILE:           p_str := @s_end_of_file
    E_DISK_FULL:             p_str := @s_disk_full
    E_NO_LOCK:               p_str := @s_no_lock
    E_TOO_MANY_FILES:        p_str := @s_too_many_files
    E_INVALID_HANDLE:        p_str := @s_invalid_handle
    E_FILE_ALREADY_OPEN:     p_str := @s_file_already_open
    E_NOT_A_DIR_HANDLE:      p_str := @s_not_a_dir_handle
    E_FLASH_BAD_HANDLE:      p_str := @s_flash_bad_handle
    E_FLASH_NO_HANDLE:       p_str := @s_flash_no_handle
    E_FLASH_DRIVE_FULL:      p_str := @s_flash_drive_full
    E_FLASH_FILE_WRITING:    p_str := @s_flash_file_writing
    E_FLASH_FILE_READING:    p_str := @s_flash_file_reading
    E_FLASH_FILE_OPEN:       p_str := @s_flash_file_open
    E_FLASH_FILE_MODE:       p_str := @s_flash_file_mode
    E_FLASH_FILE_SEEK:       p_str := @s_flash_file_seek
    E_FLASH_BAD_BLOCKS:      p_str := @s_flash_bad_blocks
    E_FLASH_BAD_FILE_LENGTH: p_str := @s_flash_bad_file_len
    E_FLASH_BAD_SEEK_ARG:    p_str := @s_flash_bad_seek_arg
    E_FLASH_FILE_EXISTS:     p_str := @s_flash_file_exists
    E_FLASH_NO_BUFFER:       p_str := @s_flash_no_buffer
    E_BAD_DEVICE:            p_str := @s_bad_device
    E_DEVICE_NOT_MOUNTED:    p_str := @s_device_not_mounted
    E_NOT_SUPPORTED:         p_str := @s_not_supported
    E_STACK_OVERFLOW:        p_str := @s_stack_overflow
    other:                   p_str := @s_unknown_error

DAT ' error strings for string_for_error()
  s_success           BYTE  "Success", 0
  s_timeout           BYTE  "Timeout", 0
  s_no_response       BYTE  "No response", 0
  s_bad_response      BYTE  "Bad response", 0
  s_crc_error         BYTE  "CRC error", 0
  s_write_rejected    BYTE  "Write rejected", 0
  s_card_busy         BYTE  "Card busy", 0
  s_io_error          BYTE  "I/O error", 0
  s_no_card           BYTE  "No card detected", 0
  s_not_mounted       BYTE  "Not mounted", 0
  s_init_failed       BYTE  "Init failed", 0
  s_not_fat32         BYTE  "Not FAT32", 0
  s_bad_sector_size   BYTE  "Bad sector size", 0
  s_file_not_found    BYTE  "File not found", 0
  s_file_exists       BYTE  "File exists", 0
  s_not_a_file        BYTE  "Not a file", 0
  s_not_a_dir         BYTE  "Not a directory", 0
  s_file_not_open     BYTE  "File not open", 0
  s_end_of_file       BYTE  "End of file", 0
  s_disk_full         BYTE  "Disk full", 0
  s_no_lock           BYTE  "No lock available", 0
  s_too_many_files    BYTE  "Too many files open", 0
  s_invalid_handle    BYTE  "Invalid handle", 0
  s_file_already_open BYTE  "File already open", 0
  s_not_a_dir_handle  BYTE  "Not a directory handle", 0
  s_flash_bad_handle  BYTE  "Flash bad handle", 0
  s_flash_no_handle   BYTE  "Flash no handle available", 0
  s_flash_drive_full  BYTE  "Flash drive full", 0
  s_flash_file_writing BYTE "Flash file open for writing", 0
  s_flash_file_reading BYTE "Flash file open for reading", 0
  s_flash_file_open   BYTE  "Flash file is open", 0
  s_flash_file_mode   BYTE  "Flash file mode error", 0
  s_flash_file_seek   BYTE  "Flash seek past end", 0
  s_flash_bad_blocks  BYTE  "Flash bad blocks removed", 0
  s_flash_bad_file_len BYTE "Flash bad file length", 0
  s_flash_bad_seek_arg BYTE "Flash bad seek argument", 0
  s_flash_file_exists BYTE  "Flash file already exists", 0
  s_flash_no_buffer   BYTE  "Flash no buffer available", 0
  s_bad_device        BYTE  "Bad device", 0
  s_device_not_mounted BYTE "Device not mounted", 0
  s_not_supported     BYTE  "Not supported", 0
  s_stack_overflow    BYTE  "Stack overflow", 0
  s_unknown_error     BYTE  "Unknown error", 0

PUB checkStackGuard() : bIntact | idx
'' Verify worker cog stack guard is intact.
'' Returns TRUE if all guard bytes are $CC (no overflow detected).
'' Returns FALSE and reports via debug if any guard byte is corrupted.
''
'' @returns bIntact - TRUE if stack guard is intact, FALSE if overflow detected
' @local idx - Array or table index

  bIntact := true
  repeat idx from 0 to (STACK_GUARD_LONGS * 4) - 1
    if BYTE[@cog_stack_guard][idx] <> STACK_GUARD_BYTE
      bIntact := false
      debug[CH_API]("  STACK GUARD VIOLATION at offset ", udec_(idx), ": $", uhex_byte_(BYTE[@cog_stack_guard][idx]), " (expected $CC)")
      quit

#ifdef SD_INCLUDE_STACK_CHECK

PUB reportStackDepth() : depth
'' DIAG: Ask worker cog to report stack depth used (high-water mark).
'' Returns the number of stack longs used. Compare against STACK_SIZE.
'' Returns -1 if the command failed (e.g., worker not running).
''
'' @returns depth - Number of longs used (high-water mark), or -1 on failure

    if send_command(CMD_STACK_DEPTH, 0, 0, 0, 0) == SUCCESS
        depth := LONG[@saved_data0][COGID()]
    else
        depth := -1

#endif

CON ' ---- Raw Sector Access Methods ----
    ' RAW SECTOR ACCESS METHODS (SD_INCLUDE_RAW)
    ' =============================================================================

#ifdef SD_INCLUDE_RAW
PUB initCardOnly() : status
'' Initialize SD card without mounting filesystem - for raw sector access.
'' Use this for low-level operations like formatting. Does NOT read filesystem.
'' Requires init() to have been called first.
''
'' @returns status - SUCCESS or negative error code

  ' Require init() to have been called
  if cog_id == -1
    debug[CH_API]("  [initCardOnly] FAIL: init() not called, worker not running")
    status := set_error(E_NOT_MOUNTED)

  ' Check if already in filesystem mode - reject (must unmount first)
  elseif driver_mode == MODE_FILESYSTEM
    debug[CH_API]("  [initCardOnly] REJECTED: Already mounted as filesystem, unmount first")
    status := set_error(E_NOT_MOUNTED)

  ' Check if already in raw mode - already initialized
  elseif driver_mode == MODE_RAW
    debug[CH_API]("  [initCardOnly] Already initialized in raw mode")
    status := SUCCESS

  ' Send init command to worker
  else
    status := send_command(CMD_INIT_CARD_ONLY, 0, 0, 0, 0)
    if status == SUCCESS
      debug[CH_API]("  [initCardOnly] Card initialized successfully via worker")
    else
      debug[CH_API]("  [initCardOnly] Card initialization failed, error=", sdec_(status))
      set_error(status)

PUB cardSizeSectors() : sector_count
'' Get total sectors on card via worker cog.
'' Must call initCardOnly() or mount() first.
''
'' @returns sector_count - Total number of 512-byte sectors on the card

  if cog_id == -1
    debug[CH_API]("  [cardSizeSectors] ERROR: Worker not running")
    sector_count := 0
  elseif driver_mode == MODE_NONE
    debug[CH_API]("  [cardSizeSectors] ERROR: SD not initialized")
    sector_count := 0
  else
    send_command(CMD_GET_CARD_SIZE, 0, 0, 0, 0)
    sector_count := LONG[@saved_data0][COGID()]
    debug[CH_API]("  [cardSizeSectors] ", udec(sector_count), " sectors")

PUB testCMD13() : r2_response | r1, status
'' TEST ONLY: Send CMD13 and return raw R2 response via worker cog.
'' For testing/validation of CMD13 (SEND_STATUS) functionality.
'' NOTE: This is a diagnostic method - not for normal operation.
''
'' @returns r2_response - R2 response word ($0000=OK, $FFFF=timeout, other=error)
' @local r1 - R1 response byte (extracted from r2_response)
' @local status - Status byte (extracted from r2_response)

  if cog_id == -1
    r2_response := $FFFF
  else
    send_command(CMD_TEST_CMD13, 0, 0, 0, 0)
    r2_response := LONG[@saved_data0][COGID()]

    ' Decode R2 response for debug output (no SPI -- just reads the returned value)
    r1 := r2_response >> 8
    status := r2_response & $FF

    debug[CH_STATUS]("  [testCMD13] R1=$", uhex_byte_(r1), " STATUS=$", uhex_byte_(status), " -> R2=$", uhex_word_(r2_response))
    if r1 <> 0
      debug[CH_STATUS]("    R1 errors:")
      if r1 & $40
        debug[CH_STATUS]("      -> PARAMETER_ERROR")
      if r1 & $20
        debug[CH_STATUS]("      -> ADDRESS_ERROR")
      if r1 & $10
        debug[CH_STATUS]("      -> ERASE_SEQ_ERROR")
      if r1 & $08
        debug[CH_STATUS]("      -> COM_CRC_ERROR")
      if r1 & $04
        debug[CH_STATUS]("      -> ILLEGAL_COMMAND")
      if r1 & $02
        debug[CH_STATUS]("      -> ERASE_RESET")
      if r1 & $01
        debug[CH_STATUS]("      -> IN_IDLE_STATE")
    if status <> 0
      debug[CH_STATUS]("    STATUS errors:")
      if status & CSR_OUT_OF_RANGE
        debug[CH_STATUS]("      -> OUT_OF_RANGE")
      if status & CSR_ERASE_PARAM
        debug[CH_STATUS]("      -> ERASE_PARAM")
      if status & CSR_WP_VIOLATION
        debug[CH_STATUS]("      -> WP_VIOLATION")
      if status & CSR_CARD_ECC_FAILED
        debug[CH_STATUS]("      -> CARD_ECC_FAILED")
      if status & CSR_CC_ERROR
        debug[CH_STATUS]("      -> CC_ERROR")
      if status & CSR_ERROR
        debug[CH_STATUS]("      -> ERROR")
      if status & CSR_WP_ERASE_SKIP
        debug[CH_STATUS]("      -> WP_ERASE_SKIP")
      if status & CSR_CARD_IS_LOCKED
        debug[CH_STATUS]("      -> CARD_IS_LOCKED")

PUB writeSectorRaw(sector, p_buffer) : status
'' Write a sector at absolute LBA address - low-level for formatting/partitioning.
'' Bypasses filesystem. Requires initCardOnly() or mount() first.
''
'' @param sector - Absolute LBA sector number
'' @param p_buffer - Pointer to 512 bytes of data to write
'' @returns status - SUCCESS or negative error code

  ' Require worker cog to be running (no direct access allowed)
  if cog_id == -1
    debug[CH_SECTOR]("  [writeSectorRaw] ERROR: Worker not running - call initCardOnly() or mount() first")
    status := set_error(E_NOT_MOUNTED)
  ' Require SD card to be initialized (mount or initCardOnly)
  elseif driver_mode == MODE_NONE
    debug[CH_SECTOR]("  [writeSectorRaw] ERROR: SD not initialized - call initCardOnly() or mount() first")
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_WRITE_SECTOR_RAW, sector, p_buffer, 0, 0)
    if status == SUCCESS
      debug[CH_SECTOR]("  [writeSectorRaw] Wrote sector ", udec(sector))
    else
      debug[CH_SECTOR]("  [writeSectorRaw] FAILED to write sector ", udec(sector))
      set_error(status)

PUB readSectorRaw(sector, p_buffer) : status
'' Read a sector at absolute LBA address - low-level for verification.
'' Bypasses filesystem. Requires initCardOnly() or mount() first.
''
'' @param sector - Absolute LBA sector number
'' @param p_buffer - Pointer to 512-byte buffer to receive data
'' @returns status - SUCCESS or negative error code

  ' Require worker cog to be running (no direct access allowed)
  if cog_id == -1
    debug[CH_SECTOR]("  [readSectorRaw] ERROR: Worker not running - call initCardOnly() or mount() first")
    status := set_error(E_NOT_MOUNTED)
  ' Require SD card to be initialized (mount or initCardOnly)
  elseif driver_mode == MODE_NONE
    debug[CH_SECTOR]("  [readSectorRaw] ERROR: SD not initialized - call initCardOnly() or mount() first")
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_READ_SECTOR_RAW, sector, p_buffer, 0, 0)
    if status <> SUCCESS
      set_error(status)
    debug[CH_SECTOR]("  [readSectorRaw] Read sector ", udec(sector))

PUB readSectorsRaw(start_sector, count, p_buffer) : status
'' Read multiple consecutive sectors - multi-block read using CMD18.
'' More efficient than calling readSectorRaw() in a loop.
''
'' @param start_sector - First sector to read (absolute LBA)
'' @param count - Number of sectors to read
'' @param p_buffer - Pointer to buffer (must be count * 512 bytes)
'' @returns status - Number of sectors successfully read

  if cog_id == -1
    set_error(E_NOT_MOUNTED)
    status := 0
  elseif driver_mode == MODE_NONE
    set_error(E_NOT_MOUNTED)
    status := 0
  elseif send_command(CMD_READ_SECTORS, start_sector, count, p_buffer, 0) == SUCCESS
    status := LONG[@saved_data0][COGID()]
  else
    status := 0

PUB writeSectorsRaw(start_sector, count, p_buffer) : status
'' Write multiple consecutive sectors - multi-block write using CMD25.
'' More efficient than calling writeSectorRaw() in a loop.
''
'' @param start_sector - First sector to write (absolute LBA)
'' @param count - Number of sectors to write
'' @param p_buffer - Pointer to buffer with data (must be count * 512 bytes)
'' @returns status - Number of sectors successfully written

  if cog_id == -1
    set_error(E_NOT_MOUNTED)
    status := 0
  elseif driver_mode == MODE_NONE
    set_error(E_NOT_MOUNTED)
    status := 0
  elseif send_command(CMD_WRITE_SECTORS, start_sector, count, p_buffer, 0) == SUCCESS
    status := LONG[@saved_data0][COGID()]
  else
    status := 0

PUB readVBRRaw(p_buf) : status
'' Read Volume Boot Record (512 bytes) into buffer.
'' Card must be mounted for this method to work (VBR location determined at mount).
''
'' @param p_buf - Pointer to 512-byte buffer to receive VBR data
'' @returns status - SUCCESS or negative error code

  if not (flags & F_MOUNTED)
    debug[CH_SECTOR]("  [readVBRRaw] FAILED: Card not mounted")
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_READ_SECTOR_RAW, vbr_sec, p_buf, 0, 0)
    if status <> SUCCESS
      set_error(status)
#endif

#ifdef SD_INCLUDE_REGISTERS
CON ' ---- Card Identification Methods ----
    ' CARD IDENTIFICATION METHODS (for diagnostic tools)
    ' These methods provide raw register access for card characterization.
    ' Call initCardOnly() or mount() before using these methods.
    ''
    ' SD card registers are big-endian (MSB-first). Single-byte fields can be
    ' read directly, but multi-byte fields need endian conversion on the P2
    ' (little-endian). Currently done with manual shift/OR patterns.
    ''
    ' TODO: With {Spin2_v52} compiler, use ENDIANL() and ENDIANW() for
    '   multi-byte big-endian fields:
    '     psn := ENDIANL(LONG[@cid_buf + 9])   ' CID serial number
    '     mdt := ENDIANW(WORD[@cid_buf + 13])   ' CID manufacturing date
    '   Also consider STRUCT (available at v45+) to define cid_t, csd_t, scr_t
    '   types here and export them for consumer objects.
    ' ===========================================================================

#endif

CON ' ---- Card Register Methods ----
    ' CARD REGISTER METHODS (SD_INCLUDE_REGISTERS)
    ' =============================================================================

#ifdef SD_INCLUDE_REGISTERS
PUB readCIDRaw(p_buf) : status
'' Read CID register (16 bytes) into buffer.
'' Contains manufacturer ID, product name, serial number, and manufacturing date.
'' Routes through worker cog which owns the SPI pins.
''
'' @param p_buf - Pointer to cid_t buffer to receive CID data
'' @returns status - SUCCESS or negative error code

  if cog_id == -1
    status := set_error(E_NOT_MOUNTED)
  elseif driver_mode == MODE_NONE
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_READ_CID, p_buf, 0, 0, 0)
    if status == SUCCESS
      debug[CH_IDENT]("  [readCIDRaw] CID read successfully")
    else
      debug[CH_IDENT]("  [readCIDRaw] CID read FAILED")
      set_error(status)

PUB readCSDRaw(p_buf) : status
'' Read CSD register (16 bytes) into buffer.
'' Contains card capacity, speed, and features.
'' Routes through worker cog which owns the SPI pins.
''
'' @param p_buf - Pointer to csd_t buffer to receive CSD data
'' @returns status - SUCCESS or negative error code

  if cog_id == -1
    status := set_error(E_NOT_MOUNTED)
  elseif driver_mode == MODE_NONE
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_READ_CSD, p_buf, 0, 0, 0)
    if status == SUCCESS
      debug[CH_IDENT]("  [readCSDRaw] CSD read successfully")
    else
      debug[CH_IDENT]("  [readCSDRaw] CSD read FAILED")
      set_error(status)

PUB readSCRRaw(p_buf) : status
'' Read SCR register (8 bytes) into buffer.
'' Contains SD spec version and bus widths.
'' Routes through worker cog which owns the SPI pins.
''
'' @param p_buf - Pointer to scr_t buffer to receive SCR data
'' @returns status - SUCCESS or negative error code

  if cog_id == -1
    status := set_error(E_NOT_MOUNTED)
  elseif driver_mode == MODE_NONE
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_READ_SCR, p_buf, 0, 0, 0)
    if status == SUCCESS
      debug[CH_IDENT]("  [readSCRRaw] SCR read successfully")
    else
      debug[CH_IDENT]("  [readSCRRaw] SCR read FAILED")
      set_error(status)

PUB readSDStatusRaw(p_buf) : status
'' Read SD Status register (ACMD13) - returns 64 bytes of card status.
'' Contains Speed Class, UHS Speed Grade, Video Speed Class, and more.
''
'' @param p_buf - Pointer to 64-byte buffer to receive SD Status data
'' @returns status - SUCCESS or negative error code

  if cog_id == -1
    status := set_error(E_NOT_MOUNTED)
  elseif driver_mode == MODE_NONE
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_READ_SD_STATUS, p_buf, 0, 0, 0)
    if status == SUCCESS
      debug[CH_IDENT]("  [readSDStatusRaw] SD Status read successfully")
    else
      debug[CH_IDENT]("  [readSDStatusRaw] SD Status read FAILED")
      set_error(status)

PUB getOCR() : ocr
'' Get cached OCR register value - Operating Conditions Register from card init.
'' Contains card capacity status (CCS) and voltage range.
''
'' @returns ocr - 32-bit OCR value, or 0 if card not initialized

  ocr := ocr_value
  debug[CH_IDENT]("  [getOCR] OCR = $", uhex_long(ocr))

#endif

CON ' ---- High-Speed Mode Methods ----
    ' HIGH-SPEED MODE METHODS (SD_INCLUDE_SPEED)
    ' =============================================================================

#ifdef SD_INCLUDE_SPEED
PUB attemptHighSpeed() : hs_ok
'' Attempt to enable 50 MHz high-speed mode with verification via worker cog.
'' Queries capability, switches mode, verifies with sector read/write.
'' Safe to call - will not break operation on failure.
''
'' @returns hs_ok - TRUE if 50 MHz active, FALSE if fell back to 25 MHz

  if cog_id == -1
    hs_ok := false
  elseif driver_mode == MODE_NONE
    hs_ok := false
  else
    send_command(CMD_ATTEMPT_HIGH_SPEED, 0, 0, 0, 0)
    hs_ok := LONG[@saved_data0][COGID()]

PUB setSPISpeed(freq)
'' Set SPI clock frequency via worker cog.
'' Routes through worker cog which owns the SPI clock smart pin.
''
'' @param freq - Target SPI frequency in Hz (e.g., 400_000 or 25_000_000)

  if cog_id <> -1 and driver_mode <> MODE_NONE
    send_command(CMD_SET_SPI_SPEED, freq, 0, 0, 0)

PUB checkCMD6Support() : supported | scr[2], sd_spec
'' Check if card supports CMD6 command - reads SCR for SD spec version.
'' CMD6 supported by SD 2.0 and later cards (SD_SPEC >= 2).
''
'' @returns supported - TRUE if CMD6 is available
' @local scr - SCR register data (2 longs = 8 bytes)
' @local sd_spec - SD spec version from SCR

  if cog_id == -1
    supported := false
  elseif driver_mode == MODE_NONE
    supported := false
  elseif readSCRRaw(@scr) <> SUCCESS
    debug[CH_HSPEED]("  [checkCMD6Support] Failed to read SCR")
    supported := false
  else
    sd_spec := scr.byte[0] & $0F                                                  '  SD_SPEC in bits [3:0]
    debug[CH_HSPEED]("  [checkCMD6Support] SCR: $", uhex_byte_(scr.byte[0]), " $", uhex_byte_(scr.byte[1]), " SD_SPEC=", udec_(sd_spec))
    supported := sd_spec >= 2  '  CMD6 supported in SD 2.0+

PUB checkHighSpeedCapability() : capable
'' Check if card reports high-speed capability via worker cog.
'' Uses CMD6 mode 0 (check without switch) to query function group 1.
'' Requires CMD6 support - call checkCMD6Support() first.
''
'' @returns capable - TRUE if high-speed function is supported

  if cog_id == -1
    capable := false
  elseif driver_mode == MODE_NONE
    capable := false
  else
    send_command(CMD_CHECK_HS_CAPABILITY, 0, 0, 0, 0)
    capable := LONG[@saved_data0][COGID()]

#endif

PUB getSPIFrequency() : hz
'' Get current SPI clock frequency in Hz.
''
'' @returns hz - Current SPI clock frequency in Hz

  hz := spi_freq

PUB getCardMaxSpeed() : hz
'' Get card's reported maximum speed from CSD TRAN_SPEED field.
''
'' @returns hz - Card's maximum speed in Hz

  hz := card_max_speed_hz

PUB getManufacturerID() : mid
'' Get card manufacturer ID (MID) from CID register.
'' Common IDs: $03=SanDisk, $1D=PNY/AData, $27=Samsung.
''
'' @returns mid - Manufacturer ID byte

  mid := card_mfr_id

PUB getReadTimeout() : ms
'' Get read timeout from CSD register in milliseconds.
'' SDHC/SDXC: Fixed 100ms per spec. SDSC: Calculated from TAAC/NSAC.
''
'' @returns ms - Read timeout in milliseconds

  ms := card_read_timeout_ms

PUB getWriteTimeout() : ms
'' Get write timeout from CSD register in milliseconds.
'' SDHC/SDXC: Fixed 250ms per spec. SDSC: Read timeout * R2W_FACTOR.
''
'' @returns ms - Write timeout in milliseconds

  ms := card_write_timeout_ms

PUB isHighSpeedActive() : active
'' Check if high-speed mode is active (running above standard 25 MHz).
'' Uses 30 MHz threshold to account for P2 SPI clock divider rounding
'' (e.g., 270 MHz P2 clock yields 33.75 MHz max SPI, not 50 MHz).
''
'' @returns active - TRUE if running above standard speed

  active := spi_freq >= 30_000_000


CON ' ---- Debug And Test Methods ----
    ' DEBUG AND TEST METHODS (SD_INCLUDE_DEBUG)
    ' =============================================================================

#ifdef SD_INCLUDE_DEBUG
PUB getLastCMD13() : r2
'' Get last CMD13 result (R1 in high byte, STATUS in low byte).
'' Value is from most recent CMD13, regardless of success/failure.
''
'' @returns r2 - Combined R2 response word

  r2 := (last_cmd13_r1 << 8) | last_cmd13_status

PUB getLastCMD13Error() : r2
'' Get last CMD13 error - returns last non-zero CMD13 result (preserved until next error).
'' Useful for diagnostics - shows most recent error even after recovery.
''
'' @returns r2 - Last non-zero R2 response word

  r2 := last_cmd13_error

PUB getLastReceivedCRC() : crc
'' Get CRC-16 from last sector read - returns the 16-bit CRC received from the SD card
'' after the most recent sector read operation. Use for validating CRC algorithm.
''
'' @returns crc - 16-bit CRC the card calculated and sent

  crc := diag_recv_crc

PUB getLastCalculatedCRC() : crc
'' Get CRC-16 calculated from data - returns the 16-bit CRC we calculated from received data.
'' Should match getLastReceivedCRC() if data transfer was clean.
''
'' @returns crc - 16-bit CRC calculated from data

  crc := diag_calc_crc

PUB getLastSentCRC() : crc
'' Get CRC-16 sent with last write - returns the 16-bit CRC we calculated and sent.
''
'' @returns crc - 16-bit CRC sent with the last write operation

  crc := diag_sent_crc

PUB getCRCMatchCount() : count
'' Get count of CRC matches - returns number of sector reads where CRC matched.
''
'' @returns count - Number of sector reads where calculated CRC matched received CRC

  count := diag_crc_matches

PUB getCRCMismatchCount() : count
'' Get count of CRC mismatches - returns number of sector reads where CRC did NOT match.
'' Non-zero indicates data corruption occurred during transfer.
''
'' @returns count - Number of sector reads where CRC did not match

  count := diag_crc_mismatches

PUB getCRCRetryCount() : count
'' Get count of CRC retry attempts - returns total number of read retries triggered by CRC mismatches.
'' Non-zero indicates transient bus errors were recovered.
''
'' @returns count - Total CRC retry attempts across all sector reads

  count := diag_crc_retries

PUB setCRCValidation(enabled)
'' Enable/disable CRC validation for sector reads.
'' When enabled, each sector read validates CRC and updates match/mismatch counts.
''
'' @param enabled - TRUE (non-zero) enables CRC checking, FALSE (0) disables

  diag_crc_enabled := (enabled <> 0) ? 1 : 0

PUB getWriteDiag() : result_code, r1_resp, data_resp, sector_num
'' Get diagnostic info from last writeSector call.
'' Codes: 0=not called, 1=CMD24 fatal, 2=data-response timeout,
''        3=data CRC reject, 4=data write-err, 5=data unknown reject,
''        6=busy timeout, 7=success
''
'' @returns result_code - Outcome code
'' @returns r1_resp - CMD24 R1 response byte
'' @returns data_resp - Data response token
'' @returns sector_num - Sector number attempted

  result_code := diag_write_result
  r1_resp := diag_write_r1
  data_resp := diag_write_dresp
  sector_num := diag_write_sector

PUB setTestForceReadError(count)
'' Set CRC error injection counter for reads. Each sector read will see a
'' forced CRC mismatch until the counter reaches zero.
'' Set to 1: one retry then success. Set to MAX_READ_CRC_RETRIES (3): all retries fail.
''
'' @param count - Number of read CRC mismatches to force

  test_force_read_crc_error := count

PUB setTestForceWriteError(enabled)
'' Arm one-shot CRC error injection for the next write. The next writeSector()
'' will send a corrupted CRC, causing the card to reject the data.
''
'' @param enabled - Non-zero arms, zero disarms

  test_force_write_crc_error := (enabled <> 0) ? 1 : 0

PUB getTestErrorCount() : count
'' Get count of injected test errors triggered since last clear.
''
'' @returns count - Number of injected errors triggered

  count := test_error_count

PUB clearTestErrors()
'' Reset all test error injection state. Disarms read/write hooks
'' and zeroes the triggered error counter.

  test_force_read_crc_error := 0
  test_force_write_crc_error := 0
  test_error_count := 0

PUB getLastCMD18R1() : r1
'' Get last R1 response from CMD18 (READ_MULTIPLE_BLOCK).
''
'' @returns r1 - R1 response byte ($00=accepted)

  r1 := last_cmd18_r1

PUB getLastCMD18Token() : token
'' Get last data token from CMD18 waitDataToken().
''
'' @returns token - Token byte ($FE=data start, $FF=none received)

  token := last_cmd18_token

PUB getLastCMD18Result() : code
'' Get last waitDataToken() outcome for CMD18.
''
'' @returns code - 0=success ($FE received), 1=timeout, 2=error token

  code := last_cmd18_result

PUB getLastCMD18FailPath() : path
'' Get failure path from last readSectors() call.
''
'' @returns path - 0=none, 1=R1 reject, 2=data token, 3=CMD12 incomplete, 4=CMD13, 5=CMD12 tolerated

  path := last_cmd18_fail

PUB getLastCMD18SectorsRead() : count
'' Get sectors_read snapshot from last readSectors() (captured before CMD12/CMD13).
''
'' @returns count - Number of sectors successfully received

  count := last_cmd18_sread

PUB getLastCMD12R1() : r1
'' Get last R1 response from CMD12 (STOP_TRANSMISSION).
''
'' @returns r1 - R1 byte ($00=ok, -1=no response)

  r1 := last_cmd12_r1

PUB getLastCMD12Result() : code
'' Get CMD12 busy/result outcome.
''
'' @returns code - 0=ok, 1=timeout, 2=R1 error, 3=busy timeout

  code := last_cmd12_busy

PUB getLastCMD12Capture(p_dest) : count
'' Copy 16-byte CMD12 capture buffer to caller buffer.
'' Shows raw byte stream after CMD12 stuff byte for framing analysis.
''
'' @param p_dest - Pointer to caller buffer (at least 16 bytes)
'' @returns count - Position of first non-$FF byte (NCR gap length)

  bytemove(p_dest, @cmd12_capture, 16)
  count := cmd12_capture_len

PUB getLastCMD12PreCapture(p_dest)
'' Copy 7-byte CMD12 pre-capture buffer to caller buffer.
'' Shows MISO bytes received DURING CMD12 command transmission (full-duplex).
'' If byte[0] is $FE, card was streaming next data token when CMD12 arrived.
''
'' @param p_dest - Pointer to caller buffer (at least 7 bytes)

  bytemove(p_dest, @cmd12_pre_capture, 7)

PUB getLastCMD23Used() : used
'' Check if CMD23 path was used for last multi-block read.
''
'' @returns used - TRUE if CMD23 was sent before CMD18, FALSE otherwise

  used := last_cmd23_used

PUB getLastCMD23R1() : r1
'' Get last R1 response from CMD23 (SET_BLOCK_COUNT).
''
'' @returns r1 - $00=accepted, $FF=not sent

  r1 := last_cmd23_r1

PUB getLastCMD23Verify() : verify_byte
'' Get CMD23 auto-stop verification byte (clocked after last sector in CMD23 path).
''
'' @returns verify_byte - $FF=card stopped (idle), other=card still streaming

  verify_byte := last_cmd23_verify

PUB getCmd23Supported() : supported
'' Check if card supports CMD23 (SET_BLOCK_COUNT) in SPI mode.
'' Determined by probeCmd23() during card initialization.
''
'' @returns supported - TRUE if CMD23 confirmed working, FALSE otherwise

  supported := cmd23_supported

PUB debugGetRootSec() : sector_num
'' DEBUG: Return root_sec for diagnostic.
''
'' @returns sector_num - Root directory sector number

  sector_num := root_sec

PUB debugGetDirSec() : sector_num
'' DEBUG: Return calling cog's current directory sector for diagnostic.
''
'' @returns sector_num - Current directory sector number for calling cog

  sector_num := cog_dir_sec[COGID()]

PUB debugGetVbrSec() : sector_num
'' DEBUG: Return VBR sector for diagnostic.
''
'' @returns sector_num - Volume Boot Record sector number

  sector_num := vbr_sec

PUB debugGetFatSec() : sector_num
'' DEBUG: Return FAT sector for diagnostic.
''
'' @returns sector_num - FAT start sector number

  sector_num := fat_sec

PUB debugGetSecPerFat() : count
'' DEBUG: Return sectors per FAT for diagnostic.
''
'' @returns count - Number of sectors per FAT

  count := sec_per_fat

PUB debugClearRootDir() : status
'' DEBUG: Clear root directory (fixes corruption).
'' Clears the root directory by writing zeros to root_sec.
'' Use this to fix a corrupted root directory.
'' WARNING: This DELETES all files and folders!
''
'' @returns status - 0 on success, -1 on error

  if cog_id == -1
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_DEBUG_CLEAR_ROOT, 0, 0, 0, 0)

PUB debugReadSectorSlow(sector, p_buffer) : status
'' DEBUG: Read sector byte-by-byte (no streamer) - for comparison with streamer.
'' This is SLOW but useful for debugging streamer issues.
'' Requires worker cog to be running (SPI pins configured).
''
'' NOTE: This runs in Cog0 and requires SPI smart pins to be configured for this cog.
''       It will NOT work with the normal V3 driver architecture.
''       This is for DIAGNOSTIC USE ONLY.
''
'' @param sector - Absolute LBA sector number
'' @param p_buffer - Pointer to 512-byte destination buffer
'' @returns status - 0 on success, -1 on timeout/error

  if cog_id == -1
    status := set_error(E_NOT_MOUNTED)
  else
    status := send_command(CMD_DEBUG_SLOW_READ, sector, p_buffer, 0, 0)

PUB debugGetReadSectorDiag(p_sector, p_buftype, p_token, p_b0, p_b1, p_b2, p_b3, p_pbuf)
'' DEBUG: Get readSector diagnostic data - copies diagnostic data from last readSector call.
'' Call this after readSectorRaw() to see what happened inside readSector.
''
'' @param p_sector - Pointer to receive last sector number
'' @param p_buftype - Pointer to receive last buffer type
'' @param p_token - Pointer to receive last token ($FE on success)
'' @param p_b0 - Pointer to receive buffer byte 0
'' @param p_b1 - Pointer to receive buffer byte 1
'' @param p_b2 - Pointer to receive buffer byte 2
'' @param p_b3 - Pointer to receive buffer byte 3
'' @param p_pbuf - Pointer to receive buffer pointer

  long[p_sector] := diag_last_sector
  long[p_buftype] := diag_last_buftype
  long[p_token] := diag_last_token
  long[p_b0] := diag_buf_byte0
  long[p_b1] := diag_buf_byte1
  long[p_b2] := diag_buf_byte2
  long[p_b3] := diag_buf_byte3
  long[p_pbuf] := diag_p_buf

PUB debugGetReadSectorDiagExt(p_before0, p_before1, p_before2, p_before3, p_spi_period)
'' DEBUG: Get extended readSector diagnostic data - buffer state BEFORE streamer and SPI timing.
''
'' @param p_before0 - Pointer to receive buffer byte 0 before streamer
'' @param p_before1 - Pointer to receive buffer byte 1 before streamer
'' @param p_before2 - Pointer to receive buffer byte 2 before streamer
'' @param p_before3 - Pointer to receive buffer byte 3 before streamer
'' @param p_spi_period - Pointer to receive SPI period value

  long[p_before0] := diag_before_b0
  long[p_before1] := diag_before_b1
  long[p_before2] := diag_before_b2
  long[p_before3] := diag_before_b3
  long[p_spi_period] := diag_spi_period

PUB debugDumpRootDir() | sec, idx, p_entry, local_buf[128]
'' DEBUG: Dump root directory entries to debug output via worker cog.
'' This is a diagnostic function for debugging. It reads the root directory
'' through the worker cog (which owns SPI pins) and prints each entry's
'' first 11 bytes (filename) and first cluster.
''
' @local sec - Current sector being read
' @local idx - Entry index counter
' @local p_entry - Pointer to current directory entry
' @local local_buf - Local 512-byte buffer for sector data (128 longs)

  if cog_id == -1
    debug[CH_DIR]("  [debugDumpRootDir] ERROR: Worker not running")
  else
    sec := root_sec
    debug[CH_DIR]("  [debugDumpRootDir] root_sec=", udec_(sec), " cog_dir_sec=", udec_(cog_dir_sec[COGID()]))
    if send_command(CMD_READ_SECTOR_RAW, sec, @local_buf, 0, 0) <> SUCCESS
      debug[CH_DIR]("  [debugDumpRootDir] FAILED to read root directory sector")
    else
      debug[CH_DIR]("  [debugDumpRootDir] Read sector ", udec_(sec), " via worker cog")
      repeat idx from 0 to ENTRIES_PER_SECTOR - 1                                     ' First 16 entries
        p_entry := @local_buf + (idx * DIR_ENTRY_SIZE)
        if byte[p_entry] == 0
          debug[CH_DIR]("  Entry ", udec_(idx), ": [END OF DIR]")
          quit
        elseif byte[p_entry] == $E5
          debug[CH_DIR]("  Entry ", udec_(idx), ": [DELETED]")
        else
          debug[CH_DIR]("  Entry ", udec_(idx), ": [", lstr_(p_entry, FILENAME_83_LEN), "] attr=$", uhex_byte_(byte[p_entry+DIR_ATTR_OFFSET]), " clus=", udec_(word[p_entry+DIR_CLUS_LO_OFFSET] | (word[p_entry+DIR_CLUS_HI_OFFSET] << 16)))

PUB displaySector() | address, char, ascii_ptr, idx
'' Display sector in buffer - prints hex dump with ASCII representation.
''
' @local address - Current byte offset in buffer
' @local char - Current character being processed
' @local ascii_ptr - Pointer to ASCII representation string
' @local idx - Loop counter

  ascii_ptr := string("0123456789ABCDEF")
  repeat address from 0 to SECTOR_SIZE - HEX_BYTES_PER_ROW - 1 step HEX_BYTES_PER_ROW
    repeat idx from 0 to HEX_BYTES_PER_ROW - 1
      case char := (buf[address + idx])
        $20..$7E: byte[ascii_ptr + idx] := char
        other:
          if char == 0
            byte[ascii_ptr + idx] := "."
          else
            byte[ascii_ptr + idx] := char // 26 + "a"
    debug[CH_DIR](uhex_word_(address),uhex_byte_array_(@buf + address,8),"-",uhex_byte_array_(@buf + address + 8,8)," | ",lstr_(ascii_ptr,HEX_BYTES_PER_ROW))

PUB displayEntry() | address, char, ascii_ptr, idx
'' Display directory entry - prints hex dump of entry_buffer with ASCII representation.
''
' @local address - Current byte offset in entry
' @local char - Current character being processed
' @local ascii_ptr - Pointer to ASCII representation string
' @local idx - Loop counter

  ascii_ptr := string("0123456789ABCDEF")
  repeat address from 0 to DIR_ENTRY_SIZE - 1 step HEX_BYTES_PER_ROW
    repeat idx from 0 to HEX_BYTES_PER_ROW - 1
      case char := (BYTE[@entry_buffer][address + idx])
        $20..$7E: byte[ascii_ptr + idx] := char
        other:
          if char == 0
            byte[ascii_ptr + idx] := "."
          else
            byte[ascii_ptr + idx] := char // 26 + "a"
    debug[CH_DIR](uhex_word_(address),uhex_byte_array_(@entry_buffer + address,8),"-",uhex_byte_array_(@entry_buffer + address + 8,8)," | ",lstr_(ascii_ptr,16))

PUB displayFAT(cluster) | local_buf[128]
'' Display FAT sector containing cluster number via worker cog.
'' Reads through worker cog (which owns SPI pins) then copies to @buf
'' for displaySector().
''
'' @param cluster - Cluster number to display FAT sector for
' @local local_buf - Local 512-byte buffer for sector data (128 longs)

  if cog_id == -1
    debug[CH_DIR]("  [displayFAT] ERROR: Worker not running")
  else
    n_sec := fat_sec + cluster >> 7
    if send_command(CMD_READ_SECTOR_RAW, n_sec, @local_buf, 0, 0) <> SUCCESS
      debug[CH_DIR]("  [displayFAT] FAILED to read FAT sector")
    else
      bytemove(@buf, @local_buf, SECTOR_SIZE)                                            ' Copy to @buf for displaySector()
      displaySector()

PUB setTestMaxClusters(limit)
'' Set artificial cluster limit for testing allocation wrap-around.
'' When non-zero, allocateCluster() and findContiguousRun() treat the FAT
'' as if it has only this many clusters. Set to 0 to disable.
''
'' @param limit - Maximum cluster number (0 = disabled)

  test_max_clusters := limit

#endif

CON ' ---- Worker Infrastructure ----
    ' WORKER INFRASTRUCTURE
    ' =============================================================================
PRI set_error(code) : code_out
' Set error code for this cog - store error code in per-cog slot and return the code.
'
' @param code - Error code to store
' @returns code_out - The same error code (for chained returns)

  LONG[@last_error][COGID()] := code
  code_out := code

PRI fs_worker() | cur_cmd
' Worker cog main loop - runs in the dedicated worker cog.
' Owns the SPI pins and handles all filesystem operations.
'
' @local cur_cmd - Current command being processed

  debug[CH_API]("  [fs_worker] Starting on cog ", udec_(COGID()))

  ' Initialize SPI pins (this cog owns them)
  pinh(PIN_SD_CS)                                                                      ' CS HIGH = deselected
  pinh(PIN_MOSI)                                                                    ' MOSI HIGH idle
  pinl(PIN_SD_SCK)                                                                     ' SCK LOW (SPI mode 0)

  debug[CH_API]("  [fs_worker] Pins initialized: CS=P", udec_(PIN_SD_CS), " MOSI=P", udec_(PIN_MOSI), " MISO=P", udec_(PIN_MISO), " SCK=P", udec_(PIN_SD_SCK))

  ' Initialize FIELD pointers into date_stamp (accessible from any cog via hub RAM)
  fld_yr  := ^@date_stamp.[31..25]
  fld_mon := ^@date_stamp.[24..21]
  fld_day := ^@date_stamp.[20..16]
  fld_hr  := ^@date_stamp.[15..11]
  fld_min := ^@date_stamp.[10..5]
  fld_sec := ^@date_stamp.[4..0]

  ' Main command loop (structured: clock tick, command dispatch, idle flush)
  idle_timer := getct()
  flush_done := true

  repeat
    ' --- Filesystem command (Priority 1) ---
    repeat until (cur_cmd := pb_cmd) <> CMD_NONE
      ' --- Clock tick (F2) ---
      if ct_active
        if (getct() - ct_last_tick) >= ct_tick_clocks
          tick_clock()
          ct_last_tick := getct()

      ' --- Auto-flush (F3) ---
      if not flush_done
        if (getct() - idle_timer) >= idle_flush_clocks
          do_idle_flush()

#ifdef SD_INCLUDE_STACK_CHECK
    if stackUtils.isStackOverflow(@cog_stack, STACK_SIZE)
      ' Stack overflow - report to caller through mailbox before halting
      pb_data0 := stackUtils.getStackDepth(@cog_stack, STACK_SIZE)
      pb_status := E_STACK_OVERFLOW
      pb_cmd := CMD_NONE
      COGATN(1 << pb_caller)
      repeat  ' halt worker cog
#endif

    debug[CH_API]("  [fs_worker] Received command ", udec_(cur_cmd))

    ' =======================================================================
    ' MODE ENFORCEMENT: Reject commands invalid for current mode
    ' =======================================================================
    ' File system commands require MODE_FILESYSTEM
    ' Raw sector commands are allowed in both MODE_RAW and MODE_FILESYSTEM
    ' Mode transitions (MOUNT, UNMOUNT, INIT_CARD_ONLY) have their own logic
    ' V3: Include handle-based commands (CMD_OPEN_READ through CMD_SD_FILE_SIZE_UNUSED)
    ' V4: Include defrag commands (CMD_CREATE_CONTIGUOUS through CMD_FILE_FRAGMENTS)
#ifdef SD_INCLUDE_DEFRAG
    if (cur_cmd >= CMD_NEWDIR and cur_cmd <= CMD_MOVEFILE) or (cur_cmd >= CMD_OPEN_READ and cur_cmd <= CMD_SD_FILE_SIZE_UNUSED) or (cur_cmd >= CMD_CREATE_CONTIGUOUS and cur_cmd <= CMD_FILE_FRAGMENTS)
#else
    if (cur_cmd >= CMD_NEWDIR and cur_cmd <= CMD_MOVEFILE) or (cur_cmd >= CMD_OPEN_READ and cur_cmd <= CMD_SD_FILE_SIZE_UNUSED)
#endif
      if driver_mode <> MODE_FILESYSTEM
        debug[CH_API]("  [fs_worker] REJECTED: File operation requires MODE_FILESYSTEM")
        pb_status := E_NOT_MOUNTED
        pb_data0 := E_NOT_MOUNTED
        pb_cmd := CMD_NONE
        COGATN(1 << pb_caller)
        next                                                                    ' Skip to next command

    ' FLASH MOUNT ENFORCEMENT: Reject Flash file operations when Flash is not mounted.
    ' Allow: CMD_FLASH_MOUNT (need to mount), CMD_FLASH_FORMAT (creates FS), CMD_FL_CAN_MOUNT (HW check)
    if cur_cmd > CMD_FLASH_FORMAT and cur_cmd < CMD_FL_CAN_MOUNT
      ifnot flash_mounted
        debug[CH_API]("  [fs_worker] REJECTED: Flash not mounted for cmd ", udec_(cur_cmd))
        pb_status := E_NOT_MOUNTED
        pb_data0 := E_NOT_MOUNTED
        pb_cmd := CMD_NONE
        COGATN(1 << pb_caller)
        next

    ' Lazy SPI bus switching: only switch when target device changes.
    ' The guards inside switch_to_flash()/switch_to_sd() make these no-ops
    ' when already on the correct device, so consecutive Flash operations
    ' only switch once (not per-command with expensive reinitCard).
    if cur_cmd >= CMD_FLASH_MOUNT and cur_cmd <= CMD_FL_CAN_MOUNT
      switch_to_flash()
    else
      switch_to_sd()

    ' Dispatch command
    case cur_cmd
      CMD_MOUNT:
        pb_status := do_mount()

      CMD_UNMOUNT:
        pb_status := do_unmount()

      CMD_NEWDIR:
        pb_status := do_newdir(pb_param0)

      CMD_DELETE:
        pb_status := do_delete(pb_param0)

      CMD_CHDIR:
        pb_status := do_chdir(pb_param0)

      CMD_FILESIZE:
        pb_data0 := fileSize()
        pb_status := SUCCESS

      CMD_FREESPACE:
        pb_data0 := do_freespace()
        pb_status := SUCCESS

      CMD_SYNC:
        do_sync()
        pb_status := SUCCESS

      CMD_RENAME:
        pb_status := do_rename(pb_param0, pb_param1)

      CMD_MOVEFILE:
        pb_status := do_movefile(pb_param0, pb_param1)

      CMD_READDIR:
        pb_status := do_readdir(pb_param0)

#ifdef SD_INCLUDE_DEBUG
      CMD_DEBUG_SLOW_READ:
        ' DEBUG: Read sector byte-by-byte without streamer for comparison
        pb_status := readSectorSlow(pb_param0, pb_param1)

      CMD_DEBUG_CLEAR_ROOT:
        ' DEBUG: Clear root directory by writing zeros
        bytefill(@buf, 0, SECTOR_SIZE)                                                  ' Zero the buffer
        if writeSector(root_sec, BUF_DATA)                                      ' Write to root directory
          dir_sec_in_buf := -1                                                  ' Invalidate cache
          pb_status := SUCCESS
        else
          pb_status := E_IO_ERROR
#endif

      CMD_READ_SECTOR_RAW:
        sec_in_buf := -1                                                        ' Force re-read
        if readSector(pb_param0, BUF_DATA) == 0                                 ' readSector returns 0 on success, -1 on error
          bytemove(pb_param1, @buf, SECTOR_SIZE)
          pb_status := SUCCESS
        else
          pb_status := E_IO_ERROR

#ifdef SD_INCLUDE_RAW
      CMD_READ_SECTORS:
        pb_data0 := readSectors(pb_param0, pb_param1, pb_param2)
        pb_status := SUCCESS

      CMD_WRITE_SECTORS:
        pb_data0 := writeSectors(pb_param0, pb_param1, pb_param2)
        pb_status := SUCCESS

      CMD_WRITE_SECTOR_RAW:
        bytemove(@buf, pb_param1, SECTOR_SIZE)
        debug[CH_SECTOR]("  [WRITE_RAW] after bytemove: buf[0..3]=$", uhex_byte_(buf[0]), " $", uhex_byte_(buf[1]), " $", uhex_byte_(buf[2]), " $", uhex_byte_(buf[3]), " sig=$", uhex_word_(WORD[@buf + $1FE]))
        if writeSector(pb_param0, BUF_DATA)                                     ' writeSector returns true on success
          pb_status := SUCCESS
        else
          pb_status := E_IO_ERROR

      CMD_INIT_CARD_ONLY:
        pb_status := do_init_card_only()

      CMD_GET_CARD_SIZE:
        pb_data0 := do_get_card_size()
        pb_status := SUCCESS

      CMD_TEST_CMD13:
        pb_data0 := do_test_cmd13()
        pb_status := SUCCESS
#endif

#ifdef SD_INCLUDE_REGISTERS
      CMD_READ_SCR:
        pb_status := do_read_scr(pb_param0)

      CMD_READ_CID:
        pb_status := do_read_cid(pb_param0)

      CMD_READ_CSD:
        pb_status := do_read_csd(pb_param0)

      CMD_READ_SD_STATUS:
        pb_status := do_read_sd_status(pb_param0)
#endif

#ifdef SD_INCLUDE_SPEED
      CMD_ATTEMPT_HIGH_SPEED:
        pb_data0 := do_attempt_high_speed()
        pb_status := SUCCESS

      CMD_CHECK_HS_CAPABILITY:
        pb_data0 := do_check_hs_capability()
        pb_status := SUCCESS

      CMD_SET_SPI_SPEED:
        do_set_spi_speed(pb_param0)
        pb_status := SUCCESS
#endif

      ' =======================================================================
      ' V3 Handle-Based File Commands
      ' =======================================================================
      CMD_OPEN_READ:
        pb_data0 := do_open_read(pb_param0)                                       ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_OPEN_WRITE:
        pb_data0 := do_open_write(pb_param0)                                      ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_CREATE:
        pb_data0 := do_create(pb_param0)                                          ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_CLOSE_H:
        pb_status := do_close_h(pb_param0)                                        ' param0 = handle

      CMD_READ_H:
        pb_data0 := do_read_h(pb_param0, pb_param1, pb_param2)                    ' handle, buffer, count -> bytes_read
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_WRITE_H:
        pb_data0 := do_write_h(pb_param0, pb_param1, pb_param2)                   ' handle, buffer, count -> bytes_written
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_SEEK_H:
        pb_status := do_seek_h(pb_param0, pb_param1)                              ' handle, position

      CMD_TELL_H:
        if validateHandle(pb_param0)
          if h_flags[pb_param0] & HF_DIR
            pb_status := E_NOT_A_DIR_HANDLE
          else
            pb_data0 := h_position[pb_param0]
            pb_status := SUCCESS
        else
          pb_status := E_INVALID_HANDLE

      CMD_FILESIZE_H:
        if validateHandle(pb_param0)
          if h_flags[pb_param0] & HF_DIR
            pb_status := E_NOT_A_DIR_HANDLE
          else
            pb_data0 := h_size[pb_param0]
            pb_status := SUCCESS
        else
          pb_status := E_INVALID_HANDLE

      CMD_SYNC_H:
        pb_status := do_sync_h(pb_param0)                                         ' handle

      CMD_SYNC_ALL:
        pb_status := do_sync_all()

      CMD_EOF_H:
        if validateHandle(pb_param0)
          if h_flags[pb_param0] & HF_DIR
            pb_status := E_NOT_A_DIR_HANDLE
          else
            pb_data0 := h_position[pb_param0] >= h_size[pb_param0] ? 1 : 0
            pb_status := SUCCESS
        else
          pb_status := E_INVALID_HANDLE

      ' =======================================================================
      ' V3 Directory Handle Commands
      ' =======================================================================
      CMD_OPEN_DIR:
        pb_data0 := do_open_dir(pb_param0)                                           ' Returns handle or error
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_READ_DIR_H:
        pb_status := do_read_dir_h(pb_param0)
        if pb_status == SUCCESS
          pb_data0 := @entry_buffer

      CMD_CLOSE_DIR_H:
        pb_status := do_close_dir_h(pb_param0)

      CMD_SD_EXISTS:
        pb_data0 := searchDirectory(pb_param0) ? 1 : 0
        pb_status := SUCCESS

      CMD_SD_FILE_SIZE:
        if searchDirectory(pb_param0)
          pb_data0 := BYTE[@entry_buffer][28] | BYTE[@entry_buffer][29] << 8 | BYTE[@entry_buffer][30] << 16 | BYTE[@entry_buffer][31] << 24
          pb_status := SUCCESS
        else
          pb_data0 := 0
          pb_status := E_FILE_NOT_FOUND

      CMD_SD_FILE_SIZE_UNUSED:
        pb_data0, pb_status := do_sd_file_size_unused(pb_param0)

      CMD_SET_VOL_LABEL:
        pb_status := do_set_vol_label(pb_param0)

#ifdef SD_INCLUDE_DEFRAG
      CMD_FILE_FRAGMENTS:
        pb_data0 := do_file_fragments(pb_param0)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_COMPACT_FILE:
        pb_status := do_compact_file(pb_param0)

      CMD_CREATE_CONTIGUOUS:
        pb_data0 := do_create_contiguous(pb_param0, pb_param1)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS
#endif

      CMD_FLASH_FORMAT:
        pb_status := fl_format()

      CMD_FLASH_MOUNT:
        pb_status := do_flash_mount()
        if pb_status == SUCCESS
          flash_mounted := TRUE

      CMD_SERIAL_NUMBER:
        pb_data0, pb_data1 := do_flash_serial_number()
        pb_status := SUCCESS

      CMD_FLASH_OPEN:
        pb_data0 := fl_open(pb_param0, pb_param1)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FLASH_OPEN_CIRC:
        pb_data0 := fl_open_circular(pb_param0, pb_param1, pb_param2)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FLASH_CLOSE:
        pb_status := fl_close(pb_param0)

      CMD_FLASH_READ:
        pb_data0 := fl_read(pb_param0, pb_param1, pb_param2)
        if pb_data0 < 0
          pb_status := pb_data0
        elseif fl_errorCode < 0
          pb_status := fl_errorCode           ' propagate EOF from fl_rd_byte_no_locks
        else
          pb_status := SUCCESS

      CMD_FLASH_WRITE:
        pb_data0 := fl_write(pb_param0, pb_param1, pb_param2)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FLASH_SEEK:
        pb_data0 := fl_seek(pb_param0, pb_param1, pb_param2)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FLASH_FLUSH:
        pb_status := fl_flush(pb_param0)

      CMD_FLASH_DELETE:
        pb_status := fl_delete(pb_param0)

      CMD_FLASH_RENAME:
        pb_status := fl_rename(pb_param0, pb_param1)

      CMD_FLASH_EXISTS:
        pb_data0 := fl_exists(pb_param0) ? 1 : 0
        pb_status := SUCCESS

      CMD_FLASH_CREATE_FILE:
        pb_status := fl_create_file(pb_param0, pb_param1, pb_param2)

      CMD_FLASH_FILE_SIZE:
        pb_data0 := fl_file_size(pb_param0)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FLASH_STATS:
        pb_data0, pb_data1, pb_data2 := fl_stats()
        pb_status := SUCCESS

      CMD_FLASH_DIRECTORY:
        pb_data0 := fl_directory(pb_param0, pb_param1, pb_param2)
        pb_status := SUCCESS

      CMD_FL_WR_BYTE:
        pb_status := fl_wr_byte_no_locks(pb_param0, pb_param1)

      CMD_FL_RD_BYTE:
        pb_data0 := fl_rd_byte_no_locks(pb_param0)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FL_RD_STR:
        pb_data0 := fl_rd_str(pb_param0, pb_param1, pb_param2)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FL_FILE_SIZE_UNUSED:
        pb_data0 := fl_file_size_unused(pb_param0)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FL_COUNT_BYTES:
        pb_data0, pb_data1, pb_data2 := fl_TEST_count_file_bytes(pb_param0)
        pb_status := pb_data0 < 0 ? pb_data0 : SUCCESS

      CMD_FL_CAN_MOUNT:
        pb_data0 := fl_can_mount()
        pb_status := SUCCESS

#ifdef SD_INCLUDE_STACK_CHECK
      CMD_STACK_DEPTH:
        pb_data0 := stackUtils.getStackDepth(@cog_stack, STACK_SIZE)
        pb_status := SUCCESS
#endif

      other:
        debug[CH_API]("  [fs_worker] Unknown command: ", udec_(cur_cmd))
        pb_status := E_BAD_RESPONSE

    ' Signal completion and reset idle timer
    pb_cmd := CMD_NONE
    COGATN(1 << pb_caller)                                                      ' Wake the caller
    idle_timer := getct()
    flush_done := false

PRI tick_clock()
' Increment live clock by 2 seconds using FIELD operators on date_stamp.
' Called from worker loop every 2 seconds when ct_active is true.

  FIELD[fld_sec][0]++
  if FIELD[fld_sec][0] >= 30
    FIELD[fld_sec][0]~
    FIELD[fld_min][0]++
    if FIELD[fld_min][0] >= 60
      FIELD[fld_min][0]~
      FIELD[fld_hr][0]++
      if FIELD[fld_hr][0] >= 24
        FIELD[fld_hr][0]~
        FIELD[fld_day][0]++
        if FIELD[fld_day][0] > daysInMonth(FIELD[fld_yr][0] + FAT_YEAR_BASE, FIELD[fld_mon][0])
          FIELD[fld_day][0] := 1
          FIELD[fld_mon][0]++
          if FIELD[fld_mon][0] > 12
            FIELD[fld_mon][0] := 1
            FIELD[fld_yr][0]++

PRI daysInMonth(year, month) : days
' Return number of days in given month, accounting for leap years.
'
' @param year - Full year (e.g., 2026)
' @param month - Month (1-12)
' @returns days - Number of days in the month

  days := BYTE[@days_table][month - 1]
  if month == 2 and isLeapYear(year)
    days := 29

PRI isLeapYear(year) : bLeap
' Check if year is a leap year.
'
' @param year - Full year (e.g., 2024)
' @returns bLeap - TRUE if leap year

  bLeap := (year & 3) == 0
  if year == 2100
    bLeap := false

PRI do_idle_flush() | idx
' Auto-flush dirty handles after idle period. Scans all handles for HF_DIRTY,
' syncs each, then updates FSInfo if needed. Checks pb_cmd between each handle
' sync to abort immediately if a command arrives.

  repeat idx from 0 to MAX_OPEN_FILES - 1
    if pb_cmd <> CMD_NONE
      return                            ' Command arrived, abort flush
    if h_flags[idx] & HF_DIRTY
      do_sync_h(idx)
  updateFSInfo()
  flush_done := true

PRI send_command(op_cmd, p0, p1, p2, p3) : status
' Send command to worker and wait - acquire lock, send command, wait for completion.
'
' @param op_cmd - Command opcode to send
' @param p0 - Parameter 0
' @param p1 - Parameter 1
' @param p2 - Parameter 2
' @param p3 - Parameter 3
' @returns status - SUCCESS or error code

  ' Clear stale errors before each operation (matches reference driver behavior)
  set_error(SUCCESS)

  ' Verify worker cog is running
  if cog_id == -1
    debug[CH_API]("  [send_command] ERROR: Worker not running")
    LONG[@saved_data0][COGID()] := E_NOT_MOUNTED
    LONG[@saved_data1][COGID()] := 0
    LONG[@saved_data2][COGID()] := 0
    status := E_NOT_MOUNTED

  ' Acquire API lock (serialize multi-cog access)
  else
    repeat until locktry(api_lock)

    ' Store caller ID and parameters
    pb_caller := COGID()
    pb_param0 := p0
    pb_param1 := p1
    pb_param2 := p2
    pb_param3 := p3

    ' Issue command (triggers worker)
    pb_cmd := op_cmd

    ' Wait for completion using WAITATN (efficient sleep)
    WAITATN()

    ' Check worker cog stack guard after every command
    ' (Skip when stack checker is active -- prepStackForCheck sentinel overlaps guard[0])
#ifndef SD_INCLUDE_STACK_CHECK
    if not checkStackGuard()
      debug[CH_API]("  [send_command] STACK OVERFLOW after cmd ", udec_(op_cmd))
#endif

    ' Snapshot results while still holding lock (multi-cog safety, per-cog storage)
    status := pb_status
    LONG[@saved_data0][pb_caller] := pb_data0
    LONG[@saved_data1][pb_caller] := pb_data1
    LONG[@saved_data2][pb_caller] := pb_data2

    ' Propagate worker error to caller-side error() mechanism
    if status < 0
      set_error(status)

    ' Release lock
    lockrel(api_lock)


CON ' ---- V3 File Handle Management Helpers ----
    ' V3 FILE HANDLE MANAGEMENT HELPERS
    ' ===========================================================================


CON ' ---- Handle Management ----
    ' HANDLE MANAGEMENT
    ' =============================================================================
PRI allocateHandle() : handle | idx
' Find and allocate a free handle slot by searching the handle table.
' NOTE: Does not set h_flags - caller must do that after populating handle state.
'
' @returns handle - Handle index (0 to MAX_OPEN_FILES-1) on success, E_TOO_MANY_FILES if all in use

  handle := E_TOO_MANY_FILES  ' Default: no free slots available
  repeat idx from 0 to MAX_OPEN_FILES - 1
    if h_flags[idx] == HF_FREE
      handle := idx
      quit  ' Found a free slot

PRI freeHandle(handle)
' Release a handle back to the free pool - clears all state and marks slot as available.
' Does NOT validate handle - caller must ensure handle is valid.
' Does NOT flush dirty buffers - caller must do that before calling.
' Defensively releases any Flash buffer still attached (prevents leaks from any teardown path).
'
' @param handle - Handle index to release

  ' Defensive: release Flash buffer if still attached
  if fl_hBufIndex[handle] <> $FF
    fl_free_buffer(handle)

  h_device[handle] := DEV_SD
  h_flags[handle] := HF_FREE
  h_attr[handle] := 0
  h_dir_offset[handle] := 0
  h_position[handle] := 0
  h_sector[handle] := 0
  h_start_clus[handle] := 0
  h_size[handle] := 0
  h_dir_sector[handle] := 0
  h_cluster[handle] := 0
  h_buf_sector[handle] := -1                  ' Mark buffer as invalid

PRI validateHandle(handle) : is_valid
' Check if handle is valid and in use - fast guard function for handle operations.
'
' @param handle - Handle index to validate
' @returns is_valid - TRUE if valid and in use, FALSE if invalid or free

  if handle < 0 or handle >= MAX_OPEN_FILES
    is_valid := FALSE
  elseif h_flags[handle] == HF_FREE
    is_valid := FALSE
  else
    is_valid := TRUE  ' Handle is valid and in use

PRI isFileOpenForWrite(dir_sector, dir_offset) : is_open | handle
' Check if file is already open for write - enforces single-writer policy.
' Multiple read handles allowed, only one write handle per file.
'
' @param dir_sector - Directory sector containing the file entry
' @param dir_offset - Offset within sector of the file entry
' @returns is_open - TRUE if file is open for write, FALSE otherwise
' @local handle - Loop variable for handle search

  is_open := FALSE
  repeat handle from 0 to MAX_OPEN_FILES - 1
    if h_flags[handle] & HF_WRITE             ' Check if handle has write access
      if h_dir_sector[handle] == dir_sector and h_dir_offset[handle] == dir_offset
        is_open := TRUE  ' File is already open for write

PRI getHandleBuffer(handle) : p_buffer
' Get pointer to handle's data buffer - each handle has a dedicated 512-byte buffer.
' Does NOT validate handle - caller must do that first.
'
' @param handle - Handle index
' @returns p_buffer - Address of the 512-byte buffer for this handle

  p_buffer := @h_buf + (handle << SECTOR_BITS)  ' handle * 512

PRI initHandleTable() | idx
' Initialize all handles to free state - called during mount() for clean state.
' Releases all handles and invalidates all buffer cache tracking.
'
' @local idx - Loop variable

  repeat idx from 0 to MAX_OPEN_FILES - 1
    freeHandle(idx)

CON ' ---- Struct Accessor Helpers ----
    ' STRUCT ACCESSOR HELPERS (workaround: pnut-ts v51a ^structName not in locals)
    ' ===========================================================================


CON ' ---- Struct Accessors ----
    ' STRUCT ACCESSORS
    ' =============================================================================
PRI partType(^mbr_partition_t pPart) : value
' Get partition type code from MBR partition entry.
'
' @param pPart - Pointer to MBR partition entry
' @returns value - Partition type code ($0B/$0C = FAT32)
  value := pPart.partType

PRI partLbaStart(^mbr_partition_t pPart) : value
' Get LBA start sector of partition from MBR partition entry.
'
' @param pPart - Pointer to MBR partition entry
' @returns value - LBA start sector number
  value := pPart.lbaStart

PRI vbrBytesPerSec(^vbr_t pVBR) : value
' Get bytes per sector from Volume Boot Record.
'
' @param pVBR - Pointer to VBR structure
' @returns value - Bytes per sector (must be 512)
  value := pVBR.bytesPerSec

PRI vbrSecPerClus(^vbr_t pVBR) : value
' Get sectors per cluster from Volume Boot Record.
'
' @param pVBR - Pointer to VBR structure
' @returns value - Sectors per cluster (power of 2)
  value := pVBR.secPerClus

PRI vbrReservedSec(^vbr_t pVBR) : value
' Get reserved sector count from Volume Boot Record.
'
' @param pVBR - Pointer to VBR structure
' @returns value - Number of reserved sectors before first FAT
  value := pVBR.reservedSec

PRI vbrNumFats(^vbr_t pVBR) : value
' Get number of FATs from Volume Boot Record.
'
' @param pVBR - Pointer to VBR structure
' @returns value - Number of FAT copies (must be 2)
  value := pVBR.numFats

PRI vbrSecPerFat32(^vbr_t pVBR) : value
' Get sectors per FAT (FAT32) from Volume Boot Record.
'
' @param pVBR - Pointer to VBR structure
' @returns value - Sectors per FAT
  value := pVBR.secPerFat32

PRI vbrFsInfoSec(^vbr_t pVBR) : value
' Get FSInfo sector number from Volume Boot Record.
'
' @param pVBR - Pointer to VBR structure
' @returns value - Sector number of FSInfo structure (relative to VBR)
  value := pVBR.fsInfoSec

PRI vbrVolLabelAddr(^vbr_t pVBR) : addr
' Get address of volume label field in Volume Boot Record.
'
' @param pVBR - Pointer to VBR structure
' @returns addr - Hub address of 11-byte volume label field
  addr := @pVBR.volLabel

PRI fsiLeadSig(^fsinfo_t pFSI) : value
' Get lead signature from FSInfo sector (expected $41615252).
'
' @param pFSI - Pointer to FSInfo structure
' @returns value - Lead signature value
  value := pFSI.leadSig

PRI fsiStructSig(^fsinfo_t pFSI) : value
' Get struct signature from FSInfo sector (expected $61417272).
'
' @param pFSI - Pointer to FSInfo structure
' @returns value - Struct signature value
  value := pFSI.structSig

PRI fsiFreeClusters(^fsinfo_t pFSI) : value
' Get free cluster count from FSInfo sector.
'
' @param pFSI - Pointer to FSInfo structure
' @returns value - Free cluster count ($FFFFFFFF if unknown)
  value := pFSI.freeClusters

PRI fsiNextFreeHint(^fsinfo_t pFSI) : value
' Get next free cluster hint from FSInfo sector.
'
' @param pFSI - Pointer to FSInfo structure
' @returns value - Next free cluster hint ($FFFFFFFF if unknown)
  value := pFSI.nextFreeHint

PRI fsiSetFreeClusters(^fsinfo_t pFSI, value)
' Set free cluster count in FSInfo sector.
'
' @param pFSI - Pointer to FSInfo structure
' @param value - Free cluster count to store
  pFSI.freeClusters := value

PRI fsiSetNextFreeHint(^fsinfo_t pFSI, value)
' Set next free cluster hint in FSInfo sector.
'
' @param pFSI - Pointer to FSInfo structure
' @param value - Next free cluster hint to store
  pFSI.nextFreeHint := value

PRI dirEntAttr(^dir_entry_t pEntry) : value
' Get attribute byte from directory entry.
'
' @param pEntry - Pointer to directory entry
' @returns value - Attribute byte ($10=dir, $20=archive, $08=volume label)
  value := pEntry.attr

PRI dirEntStartClus(^dir_entry_t pEntry) : value
' Get start cluster from directory entry (combines high and low words).
'
' @param pEntry - Pointer to directory entry
' @returns value - 32-bit start cluster number
  value := pEntry.clusHI << 16 | pEntry.clusLO

PRI dirEntFileSize(^dir_entry_t pEntry) : value
' Get file size from directory entry.
'
' @param pEntry - Pointer to directory entry
' @returns value - File size in bytes
  value := pEntry.fileSize

PRI dirEntSetAttr(^dir_entry_t pEntry, value)
' Set attribute byte in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param value - Attribute byte to store
  pEntry.attr := value

PRI dirEntSetStartClus(^dir_entry_t pEntry, value)
' Set start cluster in directory entry (splits into high and low words).
'
' @param pEntry - Pointer to directory entry
' @param value - 32-bit start cluster number
  pEntry.clusHI := value >> 16
  pEntry.clusLO := value & $FFFF

PRI dirEntSetFileSize(^dir_entry_t pEntry, value)
' Set file size in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param value - File size in bytes
  pEntry.fileSize := value

PRI dirEntAddFileSize(^dir_entry_t pEntry, delta)
' Add delta to file size in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param delta - Byte count to add to current file size
  pEntry.fileSize += delta

PRI dirEntSetCreateStamp(^dir_entry_t pEntry, stamp)
' Set creation timestamp in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param stamp - Packed FAT timestamp (low word=time, high word=date)
  pEntry.crtTime := stamp & $FFFF
  pEntry.crtDate := stamp >> 16

PRI dirEntSetModifyStamp(^dir_entry_t pEntry, stamp)
' Set modification timestamp in directory entry.
'
' @param pEntry - Pointer to directory entry
' @param stamp - Packed FAT timestamp (low word=time, high word=date)
  pEntry.wrtTime := stamp & $FFFF
  pEntry.wrtDate := stamp >> 16

CON ' ---- Internal Worker Operations ----
    ' INTERNAL WORKER OPERATIONS (called by fs_worker, not directly by API)
    ' ===========================================================================


CON ' ---- SD Worker Operations ----
    ' SD WORKER OPERATIONS
    ' =============================================================================
PRI do_mount() : status | reserved, pPart, pVBR, pFSI, idx, p_entry, cluster, sector, sec_idx, next_cluster, found
' Internal mount operation - initializes card and reads filesystem structures.
'
' @returns status - SUCCESS, E_NO_CARD, E_BAD_RESPONSE, E_TIMEOUT, E_INIT_FAILED, E_IO_ERROR, E_NOT_FAT32, or E_BAD_SECTOR_SIZE
' @local reserved - Reserved sector count from VBR

  dir_sec_in_buf := -1
  fat_sec_in_buf := -1
  sec_in_buf := -1

  ' V3: Initialize handle table to clean state
  initHandleTable()

  ' Skip card init if already in RAW mode (card already initialized)
  ' This avoids reinitializing smart pins which would corrupt pin states
  if driver_mode == MODE_RAW
    debug[CH_MOUNT]("  [do_mount] Upgrading from RAW mode - skipping initCard()")
  else
    debug[CH_MOUNT]("  [do_mount] Calling initCard()...")
    if not initCard()
      debug[CH_MOUNT]("  [do_mount] FAIL: initCard() returned false")
      status := last_init_error

  ' Card is initialized (either fresh or from RAW mode)
  if status == SUCCESS
    debug[CH_MOUNT]("  [do_mount] Reading MBR sector 0...")
    if readSector(0, BUF_DATA) < 0                                                '  read master boot record
      debug[CH_MOUNT]("  [do_mount] FAIL: MBR read error")
      status := E_IO_ERROR
    else
      pPart := @buf + $1BE                                                          '  overlay partition entry 1
      debug[CH_MOUNT]("  [do_mount] MBR type code: ", uhex_(partType(pPart)))
      if partType(pPart) == $0B or partType(pPart) == $0C                           '  $0B and $0C specify FAT32
        vbr_sec := partLbaStart(pPart)                                              '  volume boot record sector number
        debug[CH_MOUNT]("  [do_mount] FAT32 detected, VBR at sector ", udec(vbr_sec))
        if readSector(vbr_sec, BUF_DATA) < 0                                        '  read volume boot record
          debug[CH_MOUNT]("  [do_mount] FAIL: VBR read error")
          status := E_IO_ERROR
      else
        debug[CH_MOUNT]("  [do_mount] FAIL: Not FAT32 (type=", uhex_(partType(pPart)), ")")
        status := E_NOT_FAT32

  if status == SUCCESS
    pVBR := @buf                                                                  '  overlay VBR
    debug[CH_MOUNT]("  [do_mount] Bytes/sector: ", udec(vbrBytesPerSec(pVBR)))
    if vbrBytesPerSec(pVBR) <> SECTOR_SIZE
      debug[CH_MOUNT]("  [do_mount] FAIL: Bytes/sector not 512")
      status := E_BAD_SECTOR_SIZE

  if status == SUCCESS
    sec_per_clus := vbrSecPerClus(pVBR)
    debug[CH_MOUNT]("  [do_mount] Sectors/cluster: ", udec(sec_per_clus))
    if (sec_per_clus & (sec_per_clus - 1))
      debug[CH_MOUNT]("  [do_mount] FAIL: sec_per_clus not power of 2")
      status := E_NOT_FAT32

  if status == SUCCESS
    reserved := vbrReservedSec(pVBR)
    debug[CH_MOUNT]("  [do_mount] Reserved sectors: ", udec(reserved))
    debug[CH_MOUNT]("  [do_mount] Number of FATs: ", udec(vbrNumFats(pVBR)))
    if vbrNumFats(pVBR) <> 2
      debug[CH_MOUNT]("  [do_mount] FAIL: FAT count not 2")
      status := E_NOT_FAT32

  if status == SUCCESS
    sec_per_fat := vbrSecPerFat32(pVBR)
    fsinfo_sec := vbrFsInfoSec(pVBR)
    fat_sec := vbr_sec + reserved
    fat2_sec := fat_sec + sec_per_fat
    root_sec := (fat_sec + 2 * sec_per_fat)
    longfill(@cog_dir_sec, root_sec, 8)                                             ' All cogs start at root
    idle_flush_clocks := clkfreq / 1000 * IDLE_FLUSH_MS
    ct_tick_clocks := clkfreq * 2
    cluster_offset := root_sec // sec_per_clus
    bytemove(@vol_label, vbrVolLabelAddr(pVBR), 11)
    vol_label[11] := 0
    debug[CH_MOUNT]("  [do_mount] VBR volume label: ", zstr(@vol_label))

    ' Check root directory for authoritative volume label entry (ATTR_VOLUME_ID)
    ' The root directory entry is the primary source per the FAT32 spec;
    ' the VBR copy is a fallback (Windows format may write "NO NAME" to VBR).
    ' Follow the root cluster chain so we find the label even if it's not in the first sector.
    cluster := 2
    found := false
    repeat while cluster >= 2 and cluster +< $0FFF_FFF8 and not found
      sector := clus2sec(cluster)
      repeat sec_idx from 0 to sec_per_clus - 1
        if readSector(sector + sec_idx, BUF_DIR) < 0
          debug[CH_MOUNT]("  [do_mount] Root dir read failed, using VBR label")
          found := true
          quit
        repeat idx from 0 to ENTRIES_PER_SECTOR - 1
          p_entry := @dir_buf + (idx * DIR_ENTRY_SIZE)
          if byte[p_entry] == $00                                                        '  end of directory
            found := true
            quit
          if byte[p_entry] <> $E5 and dirEntAttr(p_entry) == $08                         '  volume label entry
            bytemove(@vol_label, p_entry, 11)
            vol_label[11] := 0
            debug[CH_MOUNT]("  [do_mount] Root dir volume label: ", zstr(@vol_label))
            found := true
            quit
        if found
          quit
      ' Follow FAT chain to next cluster
      if not found
        if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
          quit
        next_cluster := LONG[@fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)]
        cluster := next_cluster

    ' Read FSInfo sector for free cluster count and next-free hint
    if fsinfo_sec > 0 and fsinfo_sec < reserved
      if readSector(vbr_sec + fsinfo_sec, BUF_DATA) < 0
        debug[CH_MOUNT]("  [do_mount] FSInfo read failed, continuing without free count")
        fsi_free_count := $FFFF_FFFF
        fsi_nxt_free := $FFFF_FFFF
      else
        pFSI := @buf                                                               '  overlay FSInfo
        if fsiLeadSig(pFSI) == $4161_5252 and fsiStructSig(pFSI) == $6141_7272
          fsi_free_count := fsiFreeClusters(pFSI)
          fsi_nxt_free := fsiNextFreeHint(pFSI)
          debug[CH_MOUNT]("  [do_mount] FSInfo: free_count=", udec(fsi_free_count), " nxt_free=", udec(fsi_nxt_free))
        else
          fsi_free_count := $FFFF_FFFF
          fsi_nxt_free := $FFFF_FFFF
          debug[CH_MOUNT]("  [do_mount] FSInfo: invalid signatures, ignoring")
    else
      fsi_free_count := $FFFF_FFFF
      fsi_nxt_free := $FFFF_FFFF
      debug[CH_MOUNT]("  [do_mount] FSInfo: sector not present")

    debug[CH_MOUNT]("  [do_mount] SUCCESS")
    if date_stamp == 0
      setdate(2009,01,27,07,00,00)
    flags |= F_MOUNTED
    sd_mounted := TRUE

    driver_mode := MODE_FILESYSTEM
    debug[CH_MOUNT]("  [do_mount] SUCCESS, mode=FILESYSTEM")
    if card_warning_flags & CW_CMD13_UNRELIABLE
      debug[CH_MOUNT]("  [do_mount] WARNING: CMD13 unreliable on this card - status checks disabled")
    status := SUCCESS

PRI do_unmount() : status
' Internal unmount operation - syncs all handles and updates FSInfo.
'
' @returns status - SUCCESS or error code

  ' V3: Sync all open handles before unmount
  do_sync_all()
  do_close()
  status := updateFSInfo()
  flags := flags & !F_MOUNTED
  sd_mounted := FALSE
  driver_mode := MODE_NONE
  debug[CH_MOUNT]("  [do_unmount] Card unmounted cleanly, mode=NONE")
  status := SUCCESS

PRI do_open(name_ptr) : status | search_result, p_leaf, saved_sec
' Internal open file operation - opens an existing file for reading/writing.
' Accepts full paths (e.g., "/MYDIR/FILE.TXT") -- navigates to parent, operates on leaf.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns status - SUCCESS or error code
' @local search_result - Result from searchDirectory
' @local p_leaf - Pointer to leaf filename after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(name_ptr)
  if p_leaf == 0
    status := E_FILE_NOT_FOUND
  else
    do_close()
    search_result := searchDirectory(p_leaf)
    if search_result and (attributes() & %0001_1110 == 0)
      status := SUCCESS
    else
      status := E_FILE_NOT_FOUND
  sd_restore_path(saved_sec)

PRI do_close() : status
' Internal close file operation - close the file and update directory entry on disk.
'
' @returns status - SUCCESS or error code

  status := SUCCESS

  ' Update directory entry on disk
  if flags & F_NEWDIR
    if readSector(entry_address >> SECTOR_BITS, BUF_DIR) < 0
      debug[CH_FILE]("  [do_close] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_BITS))
      status := E_IO_ERROR
    else
      bytemove(@dir_buf + (entry_address & SECTOR_MASK), @entry_buffer, DIR_ENTRY_SIZE)
      if not writeSector(entry_address >> SECTOR_BITS, BUF_DIR)
        debug[CH_FILE]("  [do_close] Directory write FAILED for sector ", udec_(entry_address >> SECTOR_BITS))
        status := E_IO_ERROR

  bytefill(@entry_buffer, 0, 32)
  flags := flags & !F_NEWDIR

' ===========================================================================
' V3 HANDLE-BASED FILE OPERATIONS
' These functions use the multi-file handle system for independent file access
' ===========================================================================

PRI do_open_read(p_path) : handle | start_cluster, p_leaf, saved_sec
' Open file for reading (V3 handle) - opens existing file and returns handle.
' Multiple files can be open simultaneously for reading.
' Each handle has its own position, enabling interleaved reads.
' Accepts full paths (e.g., "/MYDIR/FILE.TXT") -- navigates to parent, operates on leaf.
'
' @param p_path - Pointer to null-terminated path string
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local start_cluster - Starting cluster of the file
' @local p_leaf - Pointer to leaf filename after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(p_path)
  if p_leaf == 0
    handle := E_FILE_NOT_FOUND

  ' Allocate a handle slot
  else
    handle := allocateHandle()
    if handle < 0
      debug[CH_FILE]("  [do_open_read] No free handles")

    ' Search for the file
    elseif not searchDirectory(p_leaf)
      debug[CH_FILE]("  [do_open_read] File not found: ", zstr_(p_leaf))
      freeHandle(handle)
      handle := E_FILE_NOT_FOUND

    ' Verify it's a file, not a directory
    elseif attributes() & DIR_ATTR_DIRECTORY                                                ' Directory bit
      debug[CH_FILE]("  [do_open_read] Path is a directory, not a file")
      freeHandle(handle)
      handle := E_NOT_A_FILE

    ' Populate handle state from directory entry
    else
      start_cluster := firstCluster()
      h_start_clus[handle] := start_cluster
      h_size[handle] := fileSize()
      h_attr[handle] := attributes()
      h_dir_sector[handle] := entry_address >> SECTOR_BITS
      h_dir_offset[handle] := entry_address & SECTOR_MASK
      h_cluster[handle] := start_cluster
      h_sector[handle] := clus2sec(start_cluster)
      h_position[handle] := 0
      h_buf_sector[handle] := -1                                                  ' No sector cached yet
      h_flags[handle] := HF_READ

      debug[CH_FILE]("  [do_open_read] Success: handle=", udec_(handle), " size=", udec_(h_size[handle]), " cluster=", udec_(start_cluster))

  sd_restore_path(saved_sec)

PRI do_open_write(p_path) : handle | start_cluster, current_cluster, fat_addr, f_size, cluster_count, p_leaf, saved_sec
' Open file for writing/append (V3 handle) - opens existing file for appending.
' Enforces single-writer policy: only one write handle per file allowed.
' Position is set to end of file for appending.
' Accepts full paths (e.g., "/MYDIR/FILE.TXT") -- navigates to parent, operates on leaf.
'
' @param p_path - Pointer to null-terminated path string
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local start_cluster - Starting cluster of the file
' @local current_cluster - Current cluster during FAT chain walk
' @local fat_addr - Address of FAT entry
' @local f_size - Size of file in bytes
' @local cluster_count - Number of clusters to walk
' @local p_leaf - Pointer to leaf filename after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(p_path)
  if p_leaf == 0
    handle := E_FILE_NOT_FOUND

  else
    ' Allocate a handle slot
    handle := allocateHandle()
    if handle < 0
      debug[CH_FILE]("  [do_open_write] No free handles")

    ' Search for the file
    elseif not searchDirectory(p_leaf)
      debug[CH_FILE]("  [do_open_write] File not found: ", zstr_(p_leaf))
      freeHandle(handle)
      handle := E_FILE_NOT_FOUND

    ' Verify it's a file, not a directory
    elseif attributes() & DIR_ATTR_DIRECTORY                                                ' Directory bit
      debug[CH_FILE]("  [do_open_write] Path is a directory, not a file")
      freeHandle(handle)
      handle := E_NOT_A_FILE

    ' Check single-writer policy
    elseif isFileOpenForWrite(entry_address >> SECTOR_BITS, entry_address & SECTOR_MASK)
      debug[CH_FILE]("  [do_open_write] File already open for write")
      freeHandle(handle)
      handle := E_FILE_ALREADY_OPEN

    ' Populate handle state from directory entry
    else
      start_cluster := firstCluster()
      f_size := fileSize()
      h_start_clus[handle] := start_cluster
      h_size[handle] := f_size
      h_attr[handle] := attributes()
      h_dir_sector[handle] := entry_address >> SECTOR_BITS
      h_dir_offset[handle] := entry_address & SECTOR_MASK

      ' Position at end of file for append mode
      ' Walk FAT chain to find the last cluster
      h_position[handle] := f_size
      if f_size > 0
        ' Calculate which cluster contains the last byte
        cluster_count := (f_size - 1) / (sec_per_clus << SECTOR_BITS)
        current_cluster := start_cluster
        repeat cluster_count
          fat_addr := readFat(current_cluster)
          current_cluster := long[fat_addr]
          if current_cluster +>= $0FFF_FFF8                                       ' End of chain - shouldn't happen
            quit
        h_cluster[handle] := current_cluster
        h_sector[handle] := clus2sec(current_cluster) + ((f_size - 1) >> SECTOR_BITS) & (sec_per_clus - 1)
      else
        ' Empty file - position at start
        h_cluster[handle] := start_cluster
        h_sector[handle] := clus2sec(start_cluster)

      h_buf_sector[handle] := -1                                                  ' No sector cached yet
      h_flags[handle] := HF_WRITE

      debug[CH_FILE]("  [do_open_write] Success: handle=", udec_(handle), " size=", udec_(f_size), " pos=", udec_(h_position[handle]))

  sd_restore_path(saved_sec)

PRI do_create(p_path) : handle | temp, first_cluster, p_leaf, saved_sec
' Create new file (V3 handle) - creates empty file and opens for writing.
' If file already exists, returns error.
' Accepts full paths (e.g., "/MYDIR/FILE.TXT") -- navigates to parent, operates on leaf.
'
' @param p_path - Pointer to null-terminated path string
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local temp - Temporary calculation variable
' @local first_cluster - First cluster allocated for the new file
' @local p_leaf - Pointer to leaf filename after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(p_path)
  if p_leaf == 0
    handle := E_FILE_NOT_FOUND

  ' Allocate a handle slot
  else
    handle := allocateHandle()
    if handle < 0
      debug[CH_FILE]("  [do_create] No free handles")

    ' Check if file already exists
    elseif searchDirectory(p_leaf)
      debug[CH_FILE]("  [do_create] File already exists: ", zstr_(p_leaf))
      freeHandle(handle)
      handle := E_FILE_EXISTS

    ' Guard: entry_address 0 means searchDirectory never found a valid directory
    elseif entry_address == 0
      debug[CH_FILE]("  [do_create] entry_address=0 -- path not valid, aborting")
      freeHandle(handle)
      handle := E_FILE_NOT_FOUND

    ' searchDirectory() sets entry_address to first free directory entry
    ' Check if we need to allocate a new cluster for the directory
    else
      temp := (entry_address + cluster_offset << SECTOR_BITS) & (sec_per_clus << SECTOR_BITS - 1)
      if temp == (sec_per_clus << SECTOR_BITS - DIR_ENTRY_SIZE)
        if dir_buf[480] == $00                                                    ' End of directory
          temp := allocateCluster(byte2clus(entry_address))
          if temp < 0
            debug[CH_FILE]("  [do_create] Failed to allocate dir cluster")
            freeHandle(handle)
            handle := E_DISK_FULL
          else
            clearCluster(temp)

      ' Allocate first cluster for the new file
      first_cluster := allocateCluster(0)
      if first_cluster < 0
        debug[CH_FILE]("  [do_create] Failed to allocate file cluster")
        freeHandle(handle)
        handle := E_DISK_FULL

      ' Set up directory entry in entry_buffer
      else
        dirEntSetAttr(@entry_buffer, DIR_ATTR_ARCHIVE)                                            ' Archive attribute
        dirEntSetCreateStamp(@entry_buffer, date_stamp)
        dirEntSetStartClus(@entry_buffer, first_cluster)
        dirEntSetModifyStamp(@entry_buffer, date_stamp)
        dirEntSetFileSize(@entry_buffer, 0)

        ' Write directory entry to disk
        if readSector(entry_address >> SECTOR_BITS, BUF_DIR) < 0
          debug[CH_FILE]("  [do_create] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_BITS))
          freeHandle(handle)
          handle := E_IO_ERROR
        else
          bytemove(@dir_buf + (entry_address & SECTOR_MASK), @entry_buffer, DIR_ENTRY_SIZE)
          if not writeSector(entry_address >> SECTOR_BITS, BUF_DIR)
            debug[CH_FILE]("  [do_create] Directory write FAILED for sector ", udec_(entry_address >> SECTOR_BITS))
            freeHandle(handle)
            handle := E_IO_ERROR

          ' Populate handle state
          else
            h_start_clus[handle] := first_cluster
            h_size[handle] := 0
            h_attr[handle] := DIR_ATTR_ARCHIVE
            h_dir_sector[handle] := entry_address >> SECTOR_BITS
            h_dir_offset[handle] := entry_address & SECTOR_MASK
            h_cluster[handle] := first_cluster
            h_sector[handle] := clus2sec(first_cluster)
            h_position[handle] := 0
            h_buf_sector[handle] := -1                                                  ' No sector cached yet
            h_flags[handle] := HF_WRITE

            debug[CH_FILE]("  [do_create] Success: handle=", udec_(handle), " cluster=", udec_(first_cluster))

  sd_restore_path(saved_sec)

PRI do_close_h(handle) : status | p_buf
' Close file handle (V3) - closes handle, flushing writes and updating directory.
' For write handles, the directory entry is updated with the final file size.
'
' @param handle - Handle to close
' @returns status - SUCCESS or error code
' @local p_buf - Pointer to handle's buffer

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_close_h] Invalid handle: ", sdec_(handle))
    status := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    status := E_NOT_A_DIR_HANDLE

  else
    status := SUCCESS

    ' If buffer is dirty, flush it to disk
    if h_flags[handle] & HF_DIRTY
      p_buf := getHandleBuffer(handle)
      bytemove(@buf, p_buf, SECTOR_SIZE)                                                    ' Copy to shared buffer
      if not writeSector(h_buf_sector[handle], BUF_DATA)
        debug[CH_FILE]("  [do_close_h] Data write FAILED for sector ", udec_(h_buf_sector[handle]))
        status := E_IO_ERROR

    ' If opened for write, update directory entry with final size
    if h_flags[handle] & HF_WRITE
      if readSector(h_dir_sector[handle], BUF_DIR) < 0
        debug[CH_FILE]("  [do_close_h] Directory read FAILED for sector ", udec_(h_dir_sector[handle]))
        status := E_IO_ERROR
      else
        long[@dir_buf + h_dir_offset[handle] + 28] := h_size[handle]                ' Update size field
        long[@dir_buf + h_dir_offset[handle] + DIR_WRT_TIME_OFFSET] := date_stamp  ' Update modification timestamp
        if not writeSector(h_dir_sector[handle], BUF_DIR)
          debug[CH_FILE]("  [do_close_h] Directory write FAILED for sector ", udec_(h_dir_sector[handle]))
          status := E_IO_ERROR

    ' Clear pre-allocation tracking
#ifdef SD_INCLUDE_DEFRAG
    h_prealloc_end[handle] := 0
#endif

    ' Free the handle
    freeHandle(handle)

PRI do_read_h(handle, p_buffer, count) : bytes_read | p_hbuf, available, offset, to_read, cluster, fat_addr, next_cluster
' Handle-based read (V3) - reads data from file handle into user buffer.
' Uses per-handle buffer to avoid cache thrashing. Independent position per handle.
'
' @param handle - Valid read handle
' @param p_buffer - Pointer to destination buffer
' @param count - Number of bytes to read
' @returns bytes_read - Number of bytes actually read (0 at EOF), negative on error
' @local p_hbuf - Pointer to handle's buffer
' @local available - Bytes available to read
' @local offset - Offset within current sector
' @local to_read - Bytes to read from current sector
' @local cluster - Current cluster number
' @local fat_addr - Address of FAT entry
' @local next_cluster - Next cluster in chain

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_read_h] Invalid handle: ", sdec_(handle))
    bytes_read := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    bytes_read := E_NOT_A_DIR_HANDLE

  ' Calculate how many bytes we can actually read
  else
    available := h_size[handle] - h_position[handle]
    if available <= 0
      debug[CH_FILE]("  [do_read_h] EOF reached")
      bytes_read := 0  ' EOF

    else
      count := count <# available                                                     ' Cap at available bytes
      debug[CH_FILE]("  [do_read_h] handle=", udec_(handle), " pos=", udec_(h_position[handle]), " count=", udec_(count))

      ' Get pointer to handle's buffer
      p_hbuf := getHandleBuffer(handle)

      ' Advance past sector boundary left by previous read that ended exactly at 512-byte boundary.
      ' Without this, the next read returns stale data from the previous sector's buffer.
      if (h_position[handle] & SECTOR_MASK) == 0 and h_position[handle] > 0 and h_buf_sector[handle] == h_sector[handle]
        h_buf_sector[handle] := -1
        h_sector[handle]++
        if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
          ' Follow FAT chain to next cluster
          cluster := h_cluster[handle]
          if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
            debug[CH_FILE]("  [do_read_h] FAT chain follow FAILED at boundary advance")
            bytes_read := 0
          else
            fat_addr := @fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)
            next_cluster := long[fat_addr]
            if next_cluster +>= $0FFF_FFF8
              debug[CH_FILE]("  [do_read_h] End of chain at boundary advance")
              bytes_read := 0
            else
              h_cluster[handle] := next_cluster
              h_sector[handle] := clus2sec(next_cluster)

      bytes_read := 0
      repeat while count > 0
        ' Ensure current sector is loaded into handle's buffer
        if h_buf_sector[handle] <> h_sector[handle]
          ' Load sector into shared buffer, then copy to handle's buffer
          if readSector(h_sector[handle], BUF_DATA) < 0
            debug[CH_FILE]("  [do_read_h] Sector read FAILED for sector ", udec_(h_sector[handle]))
            quit  ' Return partial read count
          bytemove(p_hbuf, @buf, SECTOR_SIZE)
          h_buf_sector[handle] := h_sector[handle]

        ' Calculate offset within sector and bytes to read from this sector
        offset := h_position[handle] & SECTOR_MASK
        to_read := (SECTOR_SIZE - offset) <# count

        ' Copy data from handle buffer to user buffer
        bytemove(p_buffer, p_hbuf + offset, to_read)

        ' Advance positions
        p_buffer += to_read
        h_position[handle] += to_read
        bytes_read += to_read
        count -= to_read

        ' If we've finished this sector, advance to next
        if (h_position[handle] & SECTOR_MASK) == 0 and count > 0
          h_sector[handle]++
          ' Check if we crossed a cluster boundary
          if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
            ' Follow FAT chain to next cluster
            cluster := h_cluster[handle]
            if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
              debug[CH_FILE]("  [do_read_h] FAT read FAILED for cluster ", udec_(cluster))
              quit  ' Return partial read count
            fat_addr := @fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)
            next_cluster := long[fat_addr]
            if next_cluster +>= $0FFF_FFF8
              ' End of chain - shouldn't happen if h_size is correct
              debug[CH_FILE]("  [do_read_h] Unexpected end of FAT chain")
              quit
            h_cluster[handle] := next_cluster
            h_sector[handle] := clus2sec(next_cluster)

      debug[CH_FILE]("  [do_read_h] Read ", udec_(bytes_read), " bytes, pos now ", udec_(h_position[handle]))

PRI do_write_h(handle, p_buffer, count) : bytes_written | p_hbuf, offset, to_write, new_cluster, fat_addr
' Handle-based write (V3) - writes data from user buffer to file handle.
' Uses per-handle buffer with dirty tracking. File grows as needed.
' Clusters allocated when extending past current allocation.
'
' @param handle - Valid write handle (must have HF_WRITE set)
' @param p_buffer - Pointer to source data buffer
' @param count - Number of bytes to write
' @returns bytes_written - Number of bytes written, negative on error
' @local p_hbuf - Pointer to handle's buffer
' @local offset - Offset within current sector
' @local to_write - Bytes to write to current sector
' @local new_cluster - Newly allocated cluster
' @local fat_addr - Address of FAT entry

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_write_h] Invalid handle: ", sdec_(handle))
    bytes_written := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    bytes_written := E_NOT_A_DIR_HANDLE

  ' Verify handle is open for writing
  elseif not (h_flags[handle] & HF_WRITE)
    debug[CH_FILE]("  [do_write_h] Handle not open for write")
    bytes_written := E_INVALID_HANDLE

  elseif count <= 0
    bytes_written := 0

  else
    debug[CH_FILE]("  [do_write_h] handle=", udec_(handle), " pos=", udec_(h_position[handle]), " count=", udec_(count))

    ' Get pointer to handle's buffer
    p_hbuf := getHandleBuffer(handle)

    ' Advance past sector boundary left by previous write that ended exactly at 512-byte boundary.
    ' Without this, the next write overwrites the unflushed handle buffer before it reaches disk.
    if (h_position[handle] & SECTOR_MASK) == 0 and h_position[handle] > 0 and h_buf_sector[handle] == h_sector[handle]
      if h_flags[handle] & HF_DIRTY
        debug[CH_FILE]("  [do_write_h] Flushing stale sector ", udec_(h_buf_sector[handle]))
        bytemove(@buf, p_hbuf, SECTOR_SIZE)
        writeSector(h_buf_sector[handle], BUF_DATA)
        h_flags[handle] &= !HF_DIRTY
      h_buf_sector[handle] := -1
      h_sector[handle]++
      if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
#ifdef SD_INCLUDE_DEFRAG
        if h_prealloc_end[handle] > 0
          new_cluster := h_cluster[handle] + 1
          if new_cluster > h_prealloc_end[handle]
            debug[CH_FILE]("  [do_write_h] Pre-allocated space exhausted")
            bytes_written := 0
          else
            h_cluster[handle] := new_cluster
            h_sector[handle] := clus2sec(new_cluster)
        else
#endif
          new_cluster := allocateCluster(h_cluster[handle])
          if new_cluster < 0
            debug[CH_FILE]("  [do_write_h] Failed to allocate cluster at boundary advance")
            bytes_written := 0
          else
            h_cluster[handle] := new_cluster
            h_sector[handle] := clus2sec(new_cluster)

    bytes_written := 0
    repeat while count > 0
      ' Ensure current sector is in handle's buffer
      if h_buf_sector[handle] <> h_sector[handle]
        ' Flush dirty buffer first if needed
        if h_flags[handle] & HF_DIRTY
          debug[CH_FILE]("  [do_write_h] Flushing dirty sector ", udec_(h_buf_sector[handle]))
          bytemove(@buf, p_hbuf, SECTOR_SIZE)
          writeSector(h_buf_sector[handle], BUF_DATA)
          h_flags[handle] &= !HF_DIRTY

        ' Load sector (or zero-fill if writing past end)
        if h_position[handle] < h_size[handle]
          ' Within existing file - load sector
          if readSector(h_sector[handle], BUF_DATA) < 0
            debug[CH_FILE]("  [do_write_h] Sector read FAILED for sector ", udec_(h_sector[handle]))
            quit  ' Return partial write count
          bytemove(p_hbuf, @buf, SECTOR_SIZE)
        else
          ' Past end of file - zero-fill buffer
          bytefill(p_hbuf, 0, SECTOR_SIZE)
        h_buf_sector[handle] := h_sector[handle]

      ' Calculate offset within sector and bytes to write to this sector
      offset := h_position[handle] & SECTOR_MASK
      to_write := (SECTOR_SIZE - offset) <# count

      ' Copy data from user buffer to handle buffer
      bytemove(p_hbuf + offset, p_buffer, to_write)
      h_flags[handle] |= HF_DIRTY

      ' Advance positions
      p_buffer += to_write
      h_position[handle] += to_write
      bytes_written += to_write
      count -= to_write

      ' Update file size if we've grown past it
      if h_position[handle] > h_size[handle]
        h_size[handle] := h_position[handle]

      ' If we've filled this sector, flush and advance to next
      if (h_position[handle] & SECTOR_MASK) == 0 and count > 0
        ' Flush current sector
        debug[CH_FILE]("  [do_write_h] Sector full, flushing sector ", udec_(h_sector[handle]))
        bytemove(@buf, p_hbuf, SECTOR_SIZE)
        writeSector(h_sector[handle], BUF_DATA)
        h_flags[handle] &= !HF_DIRTY
        h_buf_sector[handle] := -1

        h_sector[handle]++
        ' Check if we crossed a cluster boundary
        if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
#ifdef SD_INCLUDE_DEFRAG
          if h_prealloc_end[handle] > 0
            new_cluster := h_cluster[handle] + 1
            if new_cluster > h_prealloc_end[handle]
              debug[CH_FILE]("  [do_write_h] Pre-allocated space exhausted")
              quit  ' Return what we've written so far
            else
              h_cluster[handle] := new_cluster
              h_sector[handle] := clus2sec(new_cluster)
          else
#endif
            ' Need to allocate new cluster or follow chain
            new_cluster := allocateCluster(h_cluster[handle])
            if new_cluster < 0
              debug[CH_FILE]("  [do_write_h] Failed to allocate cluster")
              quit  ' Return what we've written so far
            debug[CH_FILE]("  [do_write_h] Allocated new cluster ", udec_(new_cluster))
            h_cluster[handle] := new_cluster
            h_sector[handle] := clus2sec(new_cluster)

    debug[CH_FILE]("  [do_write_h] Wrote ", udec_(bytes_written), " bytes, size now ", udec_(h_size[handle]))

PRI do_seek_h(handle, position) : status | target_cluster_idx, cluster, idx, fat_addr, sector_in_cluster
' Handle-based seek (V3) - seeks to absolute position in file.
' Position must be <= file size (no seeking past EOF).
'
' @param handle - Valid file handle
' @param position - Absolute byte position to seek to
' @returns status - SUCCESS or error code
' @local target_cluster_idx - Target cluster index from start
' @local cluster - Current cluster during walk
' @local idx - Loop counter
' @local fat_addr - Address of FAT entry
' @local sector_in_cluster - Sector offset within cluster

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_seek_h] Invalid handle: ", sdec_(handle))
    status := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    status := E_NOT_A_DIR_HANDLE

  ' Validate position is within file
  elseif position > h_size[handle]
    debug[CH_FILE]("  [do_seek_h] Position ", udec_(position), " > size ", udec_(h_size[handle]))
    status := E_END_OF_FILE

  else
    debug[CH_FILE]("  [do_seek_h] handle=", udec_(handle), " pos ", udec_(h_position[handle]), " -> ", udec_(position))

    ' Fast path: if position is in the same sector, just update position
    if (position >> SECTOR_BITS) == (h_position[handle] >> SECTOR_BITS)
      h_position[handle] := position
      debug[CH_FILE]("  [do_seek_h] Same sector, fast path")
      status := SUCCESS

    ' Calculate which cluster the target position is in
    ' target_cluster_idx = how many clusters from the start
    else
      target_cluster_idx := position / (sec_per_clus << SECTOR_BITS)

      ' Walk the FAT chain from the file's start cluster
      cluster := h_start_clus[handle]

      ' BUG FIX: Guard against Spin2's count-down behavior
      ' When target_cluster_idx is 0, "repeat idx from 0 to -1" would execute twice
      ' (counting down from 0 to -1), incorrectly walking the FAT chain.
      ' Only walk the chain if we need to move to a different cluster.
      if target_cluster_idx > 0
        repeat idx from 0 to target_cluster_idx - 1
          ' Read FAT entry for current cluster
          if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
            debug[CH_FILE]("  [do_seek_h] FAT read FAILED for cluster ", udec_(cluster))
            status := E_IO_ERROR
          else
            fat_addr := @fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)
            cluster := long[fat_addr]
            if cluster +>= $0FFF_FFF8
              ' End of chain reached before target - shouldn't happen
              debug[CH_FILE]("  [do_seek_h] Unexpected end of FAT chain at index ", udec_(idx))
              status := E_END_OF_FILE
              quit

      if status <> E_END_OF_FILE
        ' Calculate sector within cluster
        sector_in_cluster := (position >> SECTOR_BITS) & (sec_per_clus - 1)

        ' Update handle state
        h_cluster[handle] := cluster
        h_sector[handle] := clus2sec(cluster) + sector_in_cluster
        h_position[handle] := position
        h_buf_sector[handle] := -1                                                      ' Invalidate buffer cache

        debug[CH_FILE]("  [do_seek_h] Seek complete: cluster=", udec_(cluster), " sector=", udec_(h_sector[handle]))
        status := SUCCESS

PRI do_sync_h(handle) : status | p_buf
' Sync handle buffer to disk (V3) - flushes pending writes and updates directory.
' Does NOT close handle - file remains open for further operations.
'
' @param handle - Valid file handle
' @returns status - SUCCESS or error code
' @local p_buf - Pointer to handle's buffer

  ' Validate handle
  if not validateHandle(handle)
    debug[CH_FILE]("  [do_sync_h] Invalid handle: ", sdec_(handle))
    status := E_INVALID_HANDLE
  elseif h_flags[handle] & HF_DIR
    status := E_NOT_A_DIR_HANDLE

  else
    debug[CH_FILE]("  [do_sync_h] Syncing handle=", udec_(handle), " flags=$", uhex_byte_(h_flags[handle]))

    ' If buffer is dirty, flush it to disk
    if h_flags[handle] & HF_DIRTY
      debug[CH_FILE]("  [do_sync_h] Flushing dirty buffer for sector ", udec_(h_buf_sector[handle]))
      p_buf := getHandleBuffer(handle)
      bytemove(@buf, p_buf, SECTOR_SIZE)
      writeSector(h_buf_sector[handle], BUF_DATA)
      h_flags[handle] &= !HF_DIRTY

    ' If opened for write, update directory entry with current size
    if h_flags[handle] & HF_WRITE
      debug[CH_FILE]("  [do_sync_h] Updating directory: size=", udec_(h_size[handle]))
      if readSector(h_dir_sector[handle], BUF_DIR) < 0
        debug[CH_FILE]("  [do_sync_h] Directory read FAILED for sector ", udec_(h_dir_sector[handle]))
        status := E_IO_ERROR
      else
        long[@dir_buf + h_dir_offset[handle] + 28] := h_size[handle]
        long[@dir_buf + h_dir_offset[handle] + DIR_WRT_TIME_OFFSET] := date_stamp  ' Update modification timestamp
        writeSector(h_dir_sector[handle], BUF_DIR)

    debug[CH_FILE]("  [do_sync_h] Sync complete")
    status := SUCCESS

PRI do_sync_all() : status | idx
' Sync all open write handles (V3) - flushes all write handles to disk.
' Called by unmount() to ensure all data is written before stopping.
'
' @returns status - SUCCESS or error code
' @local idx - Loop variable

  debug[CH_FILE]("  [do_sync_all] Syncing all handles")
  repeat idx from 0 to MAX_OPEN_FILES - 1
    if h_flags[idx] & HF_WRITE
      debug[CH_FILE]("  [do_sync_all] Syncing write handle ", udec_(idx))
      do_sync_h(idx)

  debug[CH_FILE]("  [do_sync_all] All handles synced")
  status := SUCCESS

' ===========================================================================
' V3 DIRECTORY HANDLE OPERATIONS
' Directory handles share the existing unified handle pool.
' A directory handle reuses per-handle fields with HF_DIR flag.
' ===========================================================================

PRI do_open_dir(p_path) : handle | start_cluster, p_leaf, saved_sec
' Open directory for enumeration (V3 handle) - returns handle for iterating entries.
' Directory handles share the existing handle pool with file handles.
' Accepts full paths (e.g., "/MYDIR/SUBDIR") -- navigates to parent, opens leaf dir.
'
' @param p_path - Pointer to null-terminated path string ("." or "" for CWD)
' @returns handle - Handle (0 to MAX_OPEN_FILES-1) on success, negative error code on failure
' @local start_cluster - Starting cluster of the directory
' @local p_leaf - Pointer to leaf name after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(p_path)

  ' Allocate a handle slot
  handle := allocateHandle()
  if handle < 0
    debug[CH_DIR]("  [do_open_dir] No free handles")
  elseif p_leaf == 0
    freeHandle(handle)
    handle := E_FILE_NOT_FOUND
  else
    ' Determine which directory to enumerate
    if byte[p_leaf] == 0 or (byte[p_leaf] == "." and byte[p_leaf + 1] == 0)
      ' Empty string or "." -- enumerate calling cog's CWD
      n_sec := cog_dir_sec[pb_caller]
      start_cluster := sec2clus(n_sec)
    elseif byte[p_leaf] == "/" and byte[p_leaf + 1] == 0
      ' "/" -- enumerate root directory
      n_sec := root_sec
      start_cluster := sec2clus(root_sec)
    else
      ' Search for the named directory
      if not searchDirectory(p_leaf)
        debug[CH_DIR]("  [do_open_dir] Directory not found: ", zstr_(p_leaf))
        freeHandle(handle)
        handle := E_FILE_NOT_FOUND
      ' Verify it's a directory
      elseif not (attributes() & DIR_ATTR_DIRECTORY)
        debug[CH_DIR]("  [do_open_dir] Not a directory: ", zstr_(p_leaf))
        freeHandle(handle)
        handle := E_NOT_A_DIR
      else
        start_cluster := firstCluster()
        if start_cluster < 2
          start_cluster := 2                                                      ' Root directory

    ' Populate handle state (only if handle is still valid)
    if handle >= 0
      h_flags[handle] := HF_DIR
      h_start_clus[handle] := start_cluster
      h_cluster[handle] := start_cluster
      h_sector[handle] := clus2sec(start_cluster)
      h_position[handle] := 0                                                    ' Entry index
      h_size[handle] := 0                                                        ' Not used for directories
      h_buf_sector[handle] := -1                                                 ' No sector cached yet

      debug[CH_DIR]("  [do_open_dir] Success: handle=", udec_(handle), " cluster=", udec_(start_cluster))

  sd_restore_path(saved_sec)

PRI do_read_dir_h(handle) : status | p_hbuf, offset, char, attrib, cluster, fat_addr, next_cluster
' Read next directory entry from handle (V3) - skips deleted and LFN entries.
' Copies valid entry into entry_buffer for caller to inspect via fileName()/attributes().
'
' @param handle - Valid directory handle (must have HF_DIR flag)
' @returns status - SUCCESS or error code
' @local p_hbuf - Pointer to handle's buffer
' @local offset - Byte offset within current sector
' @local char - First byte of entry
' @local attrib - Entry attribute byte
' @local cluster - Current cluster number
' @local fat_addr - Address of FAT entry
' @local next_cluster - Next cluster in chain

  ' Validate handle
  if not validateHandle(handle)
    status := E_INVALID_HANDLE
  elseif not (h_flags[handle] & HF_DIR)
    status := E_INVALID_HANDLE

  else
    p_hbuf := getHandleBuffer(handle)

    repeat
      ' Check if we need to advance to next sector (16 entries per 512-byte sector)
      if h_position[handle] > 0 and (h_position[handle] & 15) == 0
        h_sector[handle]++
        ' Check if we crossed a cluster boundary
        if ((h_sector[handle] - cluster_offset) & (sec_per_clus - 1)) == 0
          ' Follow FAT chain to next cluster
          cluster := h_cluster[handle]
          if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0
            debug[CH_DIR]("  [do_read_dir_h] FAT read FAILED for cluster ", udec_(cluster))
            status := E_IO_ERROR
            quit
          else
            fat_addr := @fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)
            next_cluster := long[fat_addr]
            if next_cluster +>= $0FFF_FFF8
              status := E_FILE_NOT_FOUND  ' End of directory chain
              quit
            else
              h_cluster[handle] := next_cluster
              h_sector[handle] := clus2sec(next_cluster)
        h_buf_sector[handle] := -1                                                ' Force re-read

      ' Load current sector into handle's buffer if not cached
      if h_buf_sector[handle] <> h_sector[handle]
        if readSector(h_sector[handle], BUF_DATA) < 0
          debug[CH_DIR]("  [do_read_dir_h] Sector read FAILED for sector ", udec_(h_sector[handle]))
          status := E_IO_ERROR
          quit
        else
          bytemove(p_hbuf, @buf, SECTOR_SIZE)
          h_buf_sector[handle] := h_sector[handle]

      ' Calculate byte offset within sector (each entry is 32 bytes)
      offset := (h_position[handle] & 15) << 5                                   ' (position % 16) * 32

      ' Read first byte and attributes
      char := byte[p_hbuf + offset]
      attrib := byte[p_hbuf + offset + DIR_ATTR_OFFSET]

      ' Advance position for next call
      h_position[handle]++

      ' Check for end of directory
      if char == $00
        status := E_FILE_NOT_FOUND
        quit

      ' Skip deleted entries and LFN entries
      else
        if char == $E5
          next
        if attrib == $0F                                                            ' LFN entry
          next
        ' Skip entries with hidden/system attributes that aren't normally shown
        if attrib & %0000_1110 <> 0
          next

        ' Valid entry found - copy to entry_buffer
        bytemove(@entry_buffer, p_hbuf + offset, 32)
        status := SUCCESS
        quit

PRI do_close_dir_h(handle) : status
' Close directory handle (V3) - releases handle back to pool.
'
' @param handle - Valid directory handle
' @returns status - SUCCESS or error code

  if not validateHandle(handle)
    status := E_INVALID_HANDLE
  elseif not (h_flags[handle] & HF_DIR)
    status := E_INVALID_HANDLE

  else
    debug[CH_DIR]("  [do_close_dir_h] Closing handle=", udec_(handle))
    freeHandle(handle)
    status := SUCCESS


PRI do_newfile(name_ptr) : status | temp
' Internal new file operation - creates a new file in current directory.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns status - SUCCESS or error code
' @local temp - Temporary calculation variable

  do_close()
  if searchDirectory(name_ptr)
    status := E_FILE_EXISTS

  ' Guard: entry_address 0 means searchDirectory never found a valid directory
  ' (e.g., path component doesn't exist). Writing at address 0 would corrupt the MBR.
  elseif entry_address == 0
    debug[CH_FILE]("  [do_newfile] entry_address=0 -- path not valid, aborting")
    status := E_FILE_NOT_FOUND

  else
    temp := (entry_address + cluster_offset << SECTOR_BITS) & (sec_per_clus << SECTOR_BITS - 1)
    if temp == (sec_per_clus << SECTOR_BITS - DIR_ENTRY_SIZE)
      if dir_buf[480] == $00                                                      ' Check dir buffer after searchDirectory
        temp := allocateCluster(byte2clus(entry_address))
        clearCluster(temp)

    dirEntSetAttr(@entry_buffer, DIR_ATTR_ARCHIVE)
    dirEntSetCreateStamp(@entry_buffer, date_stamp)
    dirEntSetStartClus(@entry_buffer, 0)
    dirEntSetModifyStamp(@entry_buffer, date_stamp)
    dirEntSetFileSize(@entry_buffer, 0)
    flags |= F_NEWDIR
    status := SUCCESS

PRI do_newdir(name_ptr) : status | temp, p_leaf, saved_sec
' Internal new directory operation - creates a new directory in current directory.
' Accepts full paths (e.g., "/MYDIR/NEWDIR") -- navigates to parent, creates leaf dir.
'
' @param name_ptr - Pointer to null-terminated directory name string
' @returns status - SUCCESS or error code
' @local temp - Temporary calculation variable for cluster allocation
' @local p_leaf - Pointer to leaf name after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(name_ptr)
  if p_leaf == 0
    status := E_FILE_NOT_FOUND
  else
    do_close()
    if searchDirectory(p_leaf)
      status := E_FILE_EXISTS

    ' Guard: entry_address 0 means searchDirectory never found a valid directory
    ' (e.g., path component doesn't exist). Writing at address 0 would corrupt the MBR.
    elseif entry_address == 0
      debug[CH_DIR]("  [do_newdir] entry_address=0 -- path not valid, aborting")
      status := E_FILE_NOT_FOUND

    else
      temp := (entry_address + cluster_offset << SECTOR_BITS) & (sec_per_clus << SECTOR_BITS - 1)
      if temp == sec_per_clus << SECTOR_BITS - DIR_ENTRY_SIZE
        if dir_buf[480] == $00                                                    ' Check dir buffer after searchDirectory
          temp := allocateCluster(byte2clus(entry_address))
          clearCluster(temp)

      temp := allocateCluster(0)
      clearCluster(temp)                                                           ' Zero all sectors in new dir cluster
      dirEntSetAttr(@entry_buffer, $10)                                            ' Directory attribute
      dirEntSetCreateStamp(@entry_buffer, date_stamp)
      dirEntSetStartClus(@entry_buffer, temp)
      dirEntSetModifyStamp(@entry_buffer, date_stamp)
      dirEntSetFileSize(@entry_buffer, 0)

      if readSector(entry_address >> SECTOR_BITS, BUF_DIR) < 0
        debug[CH_DIR]("  [do_newdir] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_BITS))
        status := E_IO_ERROR
      else
        debug[CH_DIR]("  [do_newdir] Before write: dir_buf[", udec_(entry_address & SECTOR_MASK), "]=[", lstr_(@dir_buf + (entry_address & SECTOR_MASK), 11), "]")
        bytemove(@dir_buf + (entry_address & SECTOR_MASK), @entry_buffer, DIR_ENTRY_SIZE)
        debug[CH_DIR]("  [do_newdir] After copy: dir_buf[", udec_(entry_address & SECTOR_MASK), "]=[", lstr_(@dir_buf + (entry_address & SECTOR_MASK), 11), "]")
        debug[CH_DIR]("  [do_newdir] entry_buffer=[", lstr_(@entry_buffer, 11), "]")
        writeSector(entry_address >> SECTOR_BITS, BUF_DIR)
        ' Verify write by reading back
        dir_sec_in_buf := -1                                                        ' Force re-read
        if readSector(entry_address >> SECTOR_BITS, BUF_DIR) < 0
          debug[CH_DIR]("  [do_newdir] Verify read FAILED for sector ", udec_(entry_address >> SECTOR_BITS))
        else
          debug[CH_DIR]("  [do_newdir] After verify read: dir_buf[", udec_(entry_address & SECTOR_MASK), "]=[", lstr_(@dir_buf + (entry_address & SECTOR_MASK), 11), "]")

        bytefill(@dir_buf, 0, SECTOR_SIZE)
        bytemove(@dir_buf[0], string(".          "), FILENAME_83_LEN)
        byte[@dir_buf + DIR_ATTR_OFFSET] := DIR_ATTR_DIRECTORY
        long[@dir_buf + DIR_CRT_TIME_OFFSET] := date_stamp
        word[@dir_buf + DIR_CLUS_HI_OFFSET] := temp >> 16
        long[@dir_buf + DIR_WRT_TIME_OFFSET] := date_stamp
        word[@dir_buf + DIR_CLUS_LO_OFFSET] := temp & $FFFF

        temp := byte2clus(entry_address)
        if temp == 2
          temp := 0
        bytemove(@dir_buf[DIR_ENTRY_SIZE], string("..         "), FILENAME_83_LEN)
        byte[@dir_buf + DIR_ENTRY_SIZE + DIR_ATTR_OFFSET] := DIR_ATTR_DIRECTORY
        long[@dir_buf + DIR_ENTRY_SIZE + DIR_CRT_TIME_OFFSET] := date_stamp
        word[@dir_buf + DIR_ENTRY_SIZE + DIR_CLUS_HI_OFFSET] := temp >> 16
        long[@dir_buf + DIR_ENTRY_SIZE + DIR_WRT_TIME_OFFSET] := date_stamp
        word[@dir_buf + DIR_ENTRY_SIZE + DIR_CLUS_LO_OFFSET] := temp & $FFFF

        n_sec := clus2sec(firstCluster())
        debug[CH_DIR]("  [do_newdir] Writing ./.. to sector ", udec_(n_sec), ": dir_buf[0]=[", lstr_(@dir_buf, FILENAME_83_LEN), "] dir_buf[32]=[", lstr_(@dir_buf + DIR_ENTRY_SIZE, FILENAME_83_LEN), "]")
        writeSector(n_sec, BUF_DIR)
        dir_sec_in_buf := n_sec
        ' Verify the ./.. write
        dir_sec_in_buf := -1
        if readSector(n_sec, BUF_DIR) < 0
          debug[CH_DIR]("  [do_newdir] Verify ./.. read FAILED for sector ", udec_(n_sec))
        else
          debug[CH_DIR]("  [do_newdir] After ./.. verify: dir_buf[0]=[", lstr_(@dir_buf, FILENAME_83_LEN), "] dir_buf[32]=[", lstr_(@dir_buf + DIR_ENTRY_SIZE, FILENAME_83_LEN), "]")
        status := SUCCESS
  sd_restore_path(saved_sec)

PRI do_delete(name_ptr) : status | p_leaf, saved_sec
' Internal delete operation - deletes a file and frees its clusters.
' Accepts full paths (e.g., "/MYDIR/FILE.TXT") -- navigates to parent, operates on leaf.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns status - SUCCESS or error code
' @local p_leaf - Pointer to leaf filename after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(name_ptr)
  if p_leaf == 0
    status := E_FILE_NOT_FOUND
  else
    do_close()
    if searchDirectory(p_leaf) == 0
      status := E_FILE_NOT_FOUND
    elseif attributes() & %0000_1111                                                 ' Check read-only, hidden, system, volume label
      status := E_FILE_NOT_FOUND  ' Protected file (but allow directories)

    else
      dir_buf[entry_address & SECTOR_MASK] := $E5                                         ' Mark entry as deleted in dir buffer
      writeSector(entry_address >> SECTOR_BITS, BUF_DIR)

      ' Only deallocate clusters if file has data (cluster >= 2)
      status := freeClusterChain(firstCluster())
      if status <> E_IO_ERROR
        status := SUCCESS
  sd_restore_path(saved_sec)

PRI do_sd_file_size_unused(name_ptr) : unused_bytes, status | fsize, cluster, cluster_count, loop_count, p_leaf, saved_sec
' Calculate unused (slack) bytes in last cluster of an SD file.
' Walks the FAT chain to count allocated clusters, then subtracts actual file size.
' Accepts full paths (e.g., "/MYDIR/FILE.TXT") -- navigates to parent, operates on leaf.
'
' @param name_ptr - Pointer to null-terminated filename string
' @returns unused_bytes - Allocated space minus file size, or 0 on error
' @returns status - SUCCESS or error code
' @local fsize - File size in bytes from directory entry
' @local cluster - Current cluster number
' @local cluster_count - Number of clusters traversed
' @local loop_count - Safety counter for chain traversal loops
' @local p_leaf - Pointer to leaf filename after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(name_ptr)
  if p_leaf == 0
    unused_bytes := 0
    status := E_FILE_NOT_FOUND
  elseif not searchDirectory(p_leaf)
    unused_bytes := 0
    status := E_FILE_NOT_FOUND

  else
    fsize := dirEntFileSize(@entry_buffer)
    cluster := firstCluster()

    ' Empty file (no clusters allocated)
    if cluster < 2
      unused_bytes := 0
      status := SUCCESS

    ' Walk FAT chain counting clusters
    else
      cluster_count := 0
      loop_count := 0
      repeat
        cluster_count++
        cluster := long[readFAT(cluster)]
        loop_count++
        if loop_count > MAX_CHAIN_WALK
          unused_bytes := 0
          status := E_IO_ERROR
          quit
      until cluster +>= $0FFF_FFF8

      if status <> E_IO_ERROR
        unused_bytes := (cluster_count * sec_per_clus * SECTOR_SIZE) - fsize
        status := SUCCESS
  sd_restore_path(saved_sec)

PRI do_chdir(name_ptr) : status
' Internal change directory operation - changes current directory.
'
' @param name_ptr - Pointer to null-terminated directory name string
' @returns status - SUCCESS or error code

  do_close()
  if searchDirectory(name_ptr)
    if (attributes() & DIR_ATTR_DIRECTORY) or (n_sec == root_sec)
      cog_dir_sec[pb_caller] := n_sec
      status := SUCCESS
    else
      debug[CH_DIR]("  [do_chdir] NOT a directory: attr=", uhex_byte_(attributes()))
      status := E_NOT_A_DIR
  else
    debug[CH_DIR]("  [do_chdir] searchDirectory FAILED for: ", zstr(name_ptr), " dir_sec=", udec_(cog_dir_sec[pb_caller]))
    status := E_FILE_NOT_FOUND

PRI sd_resolve_path(p_path) : p_leaf, saved_sec | i, last_slash, status, seg_start
' Split path at "/" separators, navigate to parent directory, return leaf name.
' Caller MUST call sd_restore_path(saved_sec) after the operation to restore CWD.
'
' Examples:
'   "FILE.TXT"           -> no navigation, returns ^"FILE.TXT", saved_sec = current
'   "/MYDIR/FILE.TXT"    -> cd to /MYDIR, returns ^"FILE.TXT"
'   "SUB/FILE.TXT"       -> cd to SUB (relative), returns ^"FILE.TXT"
'   "/A/B/FILE.TXT"      -> cd to /A/B, returns ^"FILE.TXT"
'
' @param p_path - Pointer to null-terminated path string (may be modified temporarily)
' @returns p_leaf - Pointer to leaf filename within p_path, or 0 on navigation error
' @returns saved_sec - Original cog_dir_sec value to pass to sd_restore_path()

  saved_sec := cog_dir_sec[pb_caller]

  ' Find last "/" in path
  last_slash := -1
  i := 0
  repeat while BYTE[p_path + i] <> 0
    if BYTE[p_path + i] == "/"
      last_slash := i
    i++

  ' No "/" -- leaf is the whole path, no navigation needed
  if last_slash < 0
    p_leaf := p_path
  else
    ' Leaf starts after last "/"
    p_leaf := p_path + last_slash + 1

    ' Navigate through parent path components
    i := 0

    ' Handle leading "/" -- start from root
    if BYTE[p_path] == "/"
      cog_dir_sec[pb_caller] := root_sec
      i := 1

    ' Walk each segment between "/" separators (up to last_slash)
    seg_start := i
    repeat while i < last_slash
      if BYTE[p_path + i] == "/"
        ' Null-terminate this segment temporarily
        BYTE[p_path + i] := 0
        status := do_chdir(p_path + seg_start)
        BYTE[p_path + i] := "/"                                                ' Restore
        if status <> SUCCESS
          cog_dir_sec[pb_caller] := saved_sec
          p_leaf := 0
          return
        seg_start := i + 1
      i++

    ' Navigate last parent segment (from seg_start to last_slash)
    if seg_start < last_slash
      BYTE[p_path + last_slash] := 0
      status := do_chdir(p_path + seg_start)
      BYTE[p_path + last_slash] := "/"                                          ' Restore
      if status <> SUCCESS
        cog_dir_sec[pb_caller] := saved_sec
        p_leaf := 0


PRI sd_restore_path(saved_sec)
' Restore per-cog directory sector after sd_resolve_path() operation.
' No SPI operations -- just restores the saved sector number.
'
' @param saved_sec - Value returned by sd_resolve_path()

  cog_dir_sec[pb_caller] := saved_sec


PRI do_freespace() : free_sectors | cluster
' Internal free space calculation - returns free sectors on card.
'
' @returns free_sectors - Number of free sectors
' @local cluster - Loop variable for FAT scan

  if not (flags & F_MOUNTED)
    free_sectors := 0
  else
    n_sec := fat_sec
    repeat sec_per_fat
      if readSector(n_sec++, BUF_FAT) < 0
        debug[CH_FILE]("  [do_freespace] FAT read FAILED, returning partial count")
      else
        repeat cluster from 0 to CLUSTERS_PER_FAT_SEC - 1
          if long[@fat_buf + cluster << FAT_ENTRY_SHIFT] == 0
            free_sectors++
    free_sectors := free_sectors * sec_per_clus

PRI do_sync()
' Internal sync operation - flushes directory entry without closing file.

  if flags & F_NEWDIR
    if readSector(entry_address >> SECTOR_BITS, BUF_DIR) < 0
      debug[CH_FILE]("  [do_sync] Directory read FAILED for sector ", udec_(entry_address >> SECTOR_BITS))
    else
      bytemove(@dir_buf + (entry_address & SECTOR_MASK), @entry_buffer, DIR_ENTRY_SIZE)
      writeSector(entry_address >> SECTOR_BITS, BUF_DIR)
    flags := flags & !F_NEWDIR

PRI do_rename(old_name, new_name) : status | bookmark, temp_sec, idx, saved_entry[8], p_buf, p_leaf, saved_sec
' Internal rename operation - renames file/directory by updating directory entry.
' Finds old file, saves entry, parses new_name into 8.3 format, writes back.
' Accepts full paths for old_name (e.g., "/MYDIR/FILE.TXT"). New name uses leaf only.
'
' @param old_name - Pointer to current filename string (may include path)
' @param new_name - Pointer to new filename string
' @returns status - SUCCESS or error code
' @local bookmark - Saved entry address
' @local temp_sec - Saved directory sector
' @local idx - Loop counter
' @local saved_entry - Saved directory entry (32 bytes = 8 longs)
' @local p_buf - Pointer to buffer position
' @local p_leaf - Pointer to leaf filename after path resolution
' @local saved_sec - Saved directory sector for path restore

  p_leaf, saved_sec := sd_resolve_path(old_name)
  if p_leaf == 0
    status := E_FILE_NOT_FOUND
  else
    debug[CH_DIR]("  [do_rename] old=", zstr_(p_leaf), " new=", zstr_(new_name), " dir_sec=", udec_(cog_dir_sec[pb_caller]))
    if searchDirectory(p_leaf)
      debug[CH_DIR]("  [do_rename] Found old file, entry_address=", uhex_(entry_address))
      bookmark := entry_address
      temp_sec := cog_dir_sec[pb_caller]
      bytemove(@saved_entry, @entry_buffer, DIR_ENTRY_SIZE)                                ' Save complete entry (32 bytes)
      cog_dir_sec[pb_caller] := entry_address >> SECTOR_BITS                              ' Search in same directory
      idx := 0
      repeat until byte[new_name + idx] == $00
        if byte[new_name + idx] == "/"
          new_name += idx+1
          idx := 0
        idx++
      debug[CH_DIR]("  [do_rename] Checking if new name exists...")
      if searchDirectory(new_name) == 0                                         ' Verify new name doesn't exist
        debug[CH_DIR]("  [do_rename] New name doesn't exist, proceeding")
        bytemove(@entry_buffer, @saved_entry, DIR_ENTRY_SIZE)                              ' Restore complete entry
        if readSector(bookmark >> SECTOR_BITS, BUF_DIR) < 0
          debug[CH_DIR]("  [do_rename] Directory read FAILED for sector ", udec_(bookmark >> SECTOR_BITS))
          status := E_IO_ERROR
        ' Parse new_name directly into buffer in 8.3 format
        else
          p_buf := @dir_buf + (bookmark & SECTOR_MASK)
          idx := 0
          repeat until byte[new_name + idx] == "/" or byte[new_name + idx] == $00
            idx++
          bytefill(p_buf, " ", 11)                                               ' Clear name field
          bytemove(p_buf, new_name, idx <# 12)                                     ' Copy name
          ' Convert to uppercase first (must happen before 8.3 rearrangement)
          repeat idx from 0 to FILENAME_83_LEN - 1
            case byte[p_buf + idx]
              "a".."z" : byte[p_buf + idx] -= $20
          ' Handle 8.3 extension separator
          repeat idx from 0 to FILENAME_83_LEN - 1
            if byte[p_buf + idx] == "."
              bytemove(p_buf + 8, p_buf + idx + 1, 3)
              bytefill(p_buf + idx, " ", 8 - idx)
              quit
          writeSector(bookmark >> SECTOR_BITS, BUF_DIR)
          cog_dir_sec[pb_caller] := temp_sec
          debug[CH_DIR]("  [do_rename] SUCCESS")
          status := SUCCESS
      else
        debug[CH_DIR]("  [do_rename] New name already exists!")
        status := E_FILE_EXISTS
    else
      debug[CH_DIR]("  [do_rename] Old file NOT FOUND")
      status := E_FILE_NOT_FOUND
  sd_restore_path(saved_sec)

PRI do_set_vol_label(p_label) : status | idx, ch, p_entry, label_83[3], pVBR
' Internal set volume label - updates BPB and root directory volume label entry.
'
' @param p_label - Pointer to new volume label string (max 11 chars)
' @returns status - SUCCESS or error code

  ' Format label: uppercase, space-pad to 11 chars
' @local idx - Loop index
' @local ch - Current character being processed
' @local p_entry - Pointer to directory entry
' @local label_83 - 8.3 formatted volume label buffer
' @local pVBR - Pointer to VBR (Volume Boot Record) data
  bytefill(@label_83, " ", 11)
  idx := 0
  repeat while byte[p_label + idx] <> 0 and idx < 11
    ch := byte[p_label + idx]
    if ch >= "a" and ch <= "z"
      ch -= $20
    BYTE[@label_83][idx] := ch
    idx++

  debug[CH_DIR]("  [do_set_vol_label] new label=[", lstr_(@label_83, 11), "]")

  ' Step 1: Update BPB volume label (VBR sector)
  if readSector(vbr_sec, BUF_DATA) < 0
    debug[CH_DIR]("  [do_set_vol_label] FAIL: read VBR")
    status := E_IO_ERROR
  else
    pVBR := @buf
    bytemove(vbrVolLabelAddr(pVBR), @label_83, 11)
    if writeSector(vbr_sec, BUF_DATA) == 0
      debug[CH_DIR]("  [do_set_vol_label] FAIL: write VBR")
      status := E_IO_ERROR

    ' Step 2: Find and update volume label entry in root directory
    else
      n_sec := root_sec
      if readSector(n_sec, BUF_DIR) < 0
        debug[CH_DIR]("  [do_set_vol_label] FAIL: read root dir")
        status := E_IO_ERROR
      else
        idx := 0
        repeat
          p_entry := @dir_buf + (idx & SECTOR_MASK)
          if byte[p_entry] == $00                                                            ' End of directory
            quit
          if byte[p_entry] <> $E5 and dirEntAttr(p_entry) == $08                              ' Volume label entry found
            bytemove(p_entry, @label_83, 11)
            writeSector(n_sec, BUF_DIR)
            debug[CH_DIR]("  [do_set_vol_label] Updated root dir entry")
            quit
          idx += 32
          if idx & SECTOR_MASK == 0
            readNextSector(BUF_DIR)

        ' Step 3: Update in-memory copy
        bytemove(@vol_label, @label_83, 11)
        vol_label[11] := 0

        debug[CH_DIR]("  [do_set_vol_label] SUCCESS")
        status := SUCCESS

PRI do_movefile(name_ptr, dest_folder) : status | bookmark, p_temp, temp_sec
' Internal move file operation - moves file from current directory to destination.
'
' @param name_ptr - Pointer to filename to move
' @param dest_folder - Pointer to destination folder name
' @returns status - SUCCESS or error code
' @local bookmark - Saved entry address
' @local p_temp - Pointer to temporary filename buffer
' @local temp_sec - Saved directory sector

  p_temp := @"FILENAME.TXT"
  if do_open(name_ptr) == SUCCESS
    bookmark := entry_address
    bytemove(p_temp, filename(), 12)
    temp_sec := cog_dir_sec[pb_caller]
    if do_chdir(dest_folder) == SUCCESS
      if bookmark >> SECTOR_BITS == n_sec
        status := E_FILE_EXISTS  ' Same directory
      else
        if do_newfile(p_temp) == SUCCESS
          debug[CH_DIR]("  [do_movefile] newfile OK, new entry_address=", uhex_(entry_address))
          debug[CH_DIR]("  [do_movefile] Reading sector ", udec_(bookmark >> SECTOR_BITS), " (dir_sec_in_buf=", sdec_(dir_sec_in_buf), ")")
          if readSector(bookmark >> SECTOR_BITS, BUF_DIR) < 0
            debug[CH_DIR]("  [do_movefile] Directory read FAILED for sector ", udec_(bookmark >> SECTOR_BITS))
            status := E_IO_ERROR
          else
            debug[CH_DIR]("  [do_movefile] After read: dir_buf[128]=[", lstr_(@dir_buf + 128, 11), "] dir_buf[", udec_(bookmark & SECTOR_MASK), "]=[", lstr_(@dir_buf + (bookmark & SECTOR_MASK), 11), "]")
            bytemove(@entry_buffer, @dir_buf + (bookmark & SECTOR_MASK), 32)
            debug[CH_DIR]("  [do_movefile] Copied entry: [", lstr_(@entry_buffer, 11), "]")
            byte[@dir_buf + (bookmark & SECTOR_MASK)] := $E5
            debug[CH_DIR]("  [do_movefile] After $E5: dir_buf[128]=[", lstr_(@dir_buf + 128, 11), "]")
            writeSector(bookmark >> SECTOR_BITS, BUF_DIR)
            debug[CH_DIR]("  [do_movefile] Calling do_close, flags=", uhex_(flags))
            do_close()
            cog_dir_sec[pb_caller] := temp_sec
            status := SUCCESS
        else
          debug[CH_DIR]("  [do_movefile] do_newfile FAILED")
          status := E_FILE_NOT_FOUND
    else
      debug[CH_DIR]("  [do_movefile] do_chdir FAILED for: ", zstr(dest_folder))
      status := E_FILE_NOT_FOUND
    cog_dir_sec[pb_caller] := temp_sec
  else
    status := E_FILE_NOT_FOUND

PRI do_readdir(entry_num) : p_entry | idx, char, attrib
' Internal read directory operation - reads directory entry at specified index.
'
' @param entry_num - Entry index to read (0-based)
' @returns p_entry - SUCCESS on success, E_FILE_NOT_FOUND if entry doesn't exist
' @local idx - Current byte offset in directory
' @local char - First character of entry
' @local attrib - Entry attributes

  idx := 0
  n_sec := cog_dir_sec[pb_caller]
  if readSector(n_sec, BUF_DIR) < 0
    debug[CH_DIR]("  [do_readdir] Directory read FAILED for sector ", udec_(n_sec))
    p_entry := E_IO_ERROR

  else
    repeat until entry_num == -1
      char := byte[@dir_buf + (idx & SECTOR_MASK)]
      attrib := byte[@dir_buf + (idx & SECTOR_MASK) + DIR_ATTR_OFFSET]

      if char == $00
        p_entry := E_FILE_NOT_FOUND
        quit
      elseif char <> $E5
        if attrib & %0000_1110 == 0
          entry_num--
          if entry_num == -1
            bytemove(@entry_buffer, @dir_buf + (idx & SECTOR_MASK), 32)
            p_entry := SUCCESS
            quit
      idx += 32
      if idx & SECTOR_MASK == 0
        readNextSector(BUF_DIR)
    if p_entry <> SUCCESS
      p_entry := E_FILE_NOT_FOUND

CON ' ---- Flash SPI Engine And Mount Logic ----
    ' FLASH SPI ENGINE AND MOUNT LOGIC (Phase 2)
    ' All methods run in the worker cog context (called from fs_worker dispatch)
    ' ===========================================================================


#ifdef SD_INCLUDE_RAW
PRI do_init_card_only() : status
' Internal card-only init (raw mode) - initialize card for raw sector access.
' Sets driver_mode to MODE_RAW without filesystem parsing.
'
' @returns status - SUCCESS, E_NO_CARD, E_BAD_RESPONSE, E_TIMEOUT, or E_INIT_FAILED

  dir_sec_in_buf := -1
  fat_sec_in_buf := -1
  sec_in_buf := -1
  debug[CH_API]("  [do_init_card_only] Calling initCard()...")
  if initCard()
    debug[CH_API]("  [do_init_card_only] Card initialized successfully")
    driver_mode := MODE_RAW
    debug[CH_API]("  [do_init_card_only] SUCCESS, mode=RAW")
    if card_warning_flags & CW_CMD13_UNRELIABLE
      debug[CH_API]("  [do_init_card_only] WARNING: CMD13 unreliable on this card - status checks disabled")
    status := SUCCESS
  else
    debug[CH_API]("  [do_init_card_only] FAIL: initCard() returned false")
    driver_mode := MODE_NONE
    status := last_init_error

PRI do_get_card_size() : sector_count | csd[4], c_size, read_bl_len, c_size_mult
' Internal get card size operation - returns total number of 512-byte sectors.
' Runs on worker cog where smart pins are configured.
'
' @returns sector_count - Total number of 512-byte sectors on the card
' @local csd - CSD register data (4 longs = 16 bytes)
' @local c_size - Capacity size field from CSD
' @local read_bl_len - Read block length from CSD
' @local c_size_mult - Size multiplier from CSD

  ' Read CSD using CMD9
  if not readCSD(@csd)
    debug[CH_API]("  [do_get_card_size] Failed to read CSD")
    sector_count := 0

  ' CSD structure version is in bits [127:126] (byte 0, bits 7:6)
  else
    if (csd.byte[0] >> 6) == 0
      ' CSD Version 1.0 (SDSC)
      read_bl_len := csd.byte[5] & $0F
      c_size := (csd.byte[6] & $03) << 10
      c_size |= csd.byte[7] << 2
      c_size |= csd.byte[8] >> 6
      c_size_mult := (csd.byte[9] & $03) << 1
      c_size_mult |= csd.byte[10] >> 7
      sector_count := (c_size + 1) << (c_size_mult + 2 + read_bl_len - 9)
      debug[CH_API]("  [do_get_card_size] CSD v1.0: ", udec(sector_count), " sectors")
    else
      ' CSD Version 2.0 (SDHC/SDXC)
      c_size := (csd.byte[7] & $3F) << 16
      c_size |= csd.byte[8] << 8
      c_size |= csd.byte[9]
      sector_count := (c_size + 1) << 10                                                ' * 1024 sectors (512KB units)
      debug[CH_API]("  [do_get_card_size] CSD v2.0: ", udec(sector_count), " sectors")

PRI do_test_cmd13() : r2_response | r1, status
' Internal CMD13 test -- runs on worker cog where SPI pins are configured.
' Sends CMD13 (SEND_STATUS) and returns raw R2 response word.
'
' @returns r2_response - R2 response word ($0000=OK, $FFFF=timeout, other=error)
' @local r1 - R1 response byte
' @local r2_status - Status byte from R2

  ' Send dummy clocks with CS HIGH to ensure card is ready
  pinh(PIN_SD_CS)
  sp_transfer_8($FF)
  sp_transfer_8($FF)

  ' CMD13 requires CS to be asserted
  pinl(PIN_SD_CS)

  ' Send CMD13 with no argument (RCA = 0x0000 for SPI mode)
  sp_transfer_8($40 | CMD13)                                                    ' Command byte: 0x40 | 13 = 0x4D
  sp_transfer_8($00)                                                            ' Argument bytes (RCA, unused in SPI)
  sp_transfer_8($00)
  sp_transfer_8($00)
  sp_transfer_8($00)
  sp_transfer_8($FF)                                                            ' CRC disabled after init in SPI mode

  ' Get R1 response (first byte of R2)
  r1 := waitR1Response()
  if r1 < 0
    debug[CH_STATUS]("  [do_test_cmd13] TIMEOUT waiting for R1")
    pinh(PIN_SD_CS)
    r2_response := $FFFF

  ' Get status byte (second byte of R2)
  else
    status := sp_transfer_8($FF)

    pinh(PIN_SD_CS)                                                                      ' Deselect card

    ' Combine into R2 response word
    r2_response := (r1 << 8) | status

    debug[CH_STATUS]("  [do_test_cmd13] R2=$", uhex_word_(r2_response))

#endif

#ifdef SD_INCLUDE_REGISTERS
PRI do_read_scr(p_buf) : status
' Internal read SCR operation - reads the 8-byte SCR register into buffer.
' Runs on worker cog where smart pins are configured.
'
' @param p_buf - Pointer to 8-byte buffer to receive SCR data
' @returns status - SUCCESS or error code

  if readSCR(p_buf)
    debug[CH_IDENT]("  [do_read_scr] SCR read successfully")
    status := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_scr] SCR read failed")
    status := E_IO_ERROR

PRI do_read_cid(p_buf) : status
' Internal read CID operation - reads the 16-byte CID register into buffer.
' Runs on worker cog where smart pins are configured.
'
' @param p_buf - Pointer to 16-byte buffer to receive CID data
' @returns status - SUCCESS or error code

  if readCID(p_buf)
    debug[CH_IDENT]("  [do_read_cid] CID read successfully")
    status := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_cid] CID read failed")
    status := E_IO_ERROR

PRI do_read_csd(p_buf) : status
' Internal read CSD operation - reads the 16-byte CSD register into buffer.
' Runs on worker cog where smart pins are configured.
'
' @param p_buf - Pointer to 16-byte buffer to receive CSD data
' @returns status - SUCCESS or error code

  if readCSD(p_buf)
    debug[CH_IDENT]("  [do_read_csd] CSD read successfully")
    status := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_csd] CSD read failed")
    status := E_IO_ERROR

PRI do_read_sd_status(p_buf) : status
' Read SD Status register (ACMD13) - 64 bytes.
'
' @param p_buf - Pointer to 64-byte buffer to receive SD Status data
' @returns status - SUCCESS or error code

  if readSDStatus(p_buf)
    debug[CH_IDENT]("  [do_read_sd_status] SD Status read successfully")
    status := SUCCESS
  else
    debug[CH_IDENT]("  [do_read_sd_status] SD Status read failed")
    status := E_IO_ERROR

#endif

#ifdef SD_INCLUDE_SPEED
PRI do_attempt_high_speed() : hs_ok | idx, mismatch
' Internal high-speed attempt -- runs on worker cog where SPI pins are configured.
' Queries capability, switches mode, verifies with sector read/write.
' Uses existing DAT buffers (@buf + @dir_buf) instead of stack locals to stay
' within the worker cog's 1024-byte stack limit.
'
' @returns hs_ok - TRUE if 50 MHz active, FALSE if fell back to 25 MHz
' @local idx - Loop counter
' @local mismatch - Count of mismatched longs

  debug[CH_HSPEED]("  [do_attempt_high_speed] Attempting high-speed mode...")

  ' Check if card supports high-speed
  if not queryHighSpeedSupport()
    debug[CH_HSPEED]("  [do_attempt_high_speed] Card does not support high-speed")
    hs_ok := false

  ' Switch to high-speed mode
  elseif not switchToHighSpeed()
    debug[CH_HSPEED]("  [do_attempt_high_speed] Failed to switch to high-speed")
    hs_ok := false

  ' Set 50 MHz SPI clock
  else
    do_set_spi_speed(50_000_000)
    debug[CH_HSPEED]("  [do_attempt_high_speed] SPI set to 50 MHz, verifying...")

    ' Verify by reading a sector, writing it back, reading again
    ' Use root directory sector as test (always valid after mount)
    ' CRITICAL: Use existing DAT buffers to avoid stack overflow:
    '   @buf (BUF_DATA) -- primary read/write buffer
    '   @dir_buf -- save original data for comparison
    if readSector(root_sec, BUF_DATA) < 0
      debug[CH_HSPEED]("  [do_attempt_high_speed] Read FAILED at 50 MHz")
      hs_ok := false
    else
      bytemove(@dir_buf, @buf, SECTOR_SIZE)                                                ' Save original to dir_buf

      writeSector(root_sec, BUF_DATA)                                              ' Write same data back
      bytefill(@buf, $AA, SECTOR_SIZE)                                                     ' Poison buf

      if readSector(root_sec, BUF_DATA) < 0                                        ' Re-read into buf
        debug[CH_HSPEED]("  [do_attempt_high_speed] Verify read FAILED at 50 MHz")
        hs_ok := false

      ' Compare dir_buf (original) vs buf (re-read) long-by-long
      else
        mismatch := 0
        repeat idx from 0 to SECTOR_LONGS - 1
          if LONG[@dir_buf][idx] <> LONG[@buf][idx]
            mismatch++

        if mismatch > 0
          debug[CH_HSPEED]("  [do_attempt_high_speed] VERIFICATION FAILED - ", udec_(mismatch), " long mismatches")
          debug[CH_HSPEED]("  [do_attempt_high_speed] Falling back to 25 MHz")
          do_set_spi_speed(SD_FALLBACK_SPEED_HZ)
          dir_sec_in_buf := -1                                                       ' Invalidate dir cache (we borrowed dir_buf)
          hs_ok := false

        else
          debug[CH_HSPEED]("  [do_attempt_high_speed] VERIFIED - 50 MHz high-speed mode ACTIVE")
          dir_sec_in_buf := -1                                                         ' Invalidate dir cache (we borrowed dir_buf)
          hs_ok := true

PRI do_check_hs_capability() : capable | status[16]
' Internal high-speed capability check -- runs on worker cog.
' Uses CMD6 mode 0 (check without switch) to query function group 1.
'
' @returns capable - TRUE if high-speed function is supported
' @local status - CMD6 status structure (16 longs = 64 bytes)

  if not sendCMD6($00FFFFF1, @status)
    capable := false
  else
    capable := (status.byte[13] & $02) <> 0

#endif

CON ' ---- SPI Bus Switching ----
    ' SPI BUS SWITCHING
    ' =============================================================================
PRI switch_to_flash()
' Reconfigure SPI bus for Flash device (Mode 3, MOSI/MISO as GPIO bit-bang).
' Fully clears SD smart pin modes so Flash bit-bang GPIO works cleanly.
' Flash SPI methods (fl_command etc.) handle their own SCK/CS setup per command.

  if current_spi_device <> DEV_FLASH
    ' Deselect SD CS (HIGH = deselected) before clearing smart pins
    pinh(PIN_SD_CS)

    ' Fully clear all SD smart pin modes (PINCLEAR = DIR=0 + WRPIN=0).
    ' Flash SPI uses raw GPIO (drvc/testp) for MOSI/MISO. If P_SYNC_TX or
    ' P_SYNC_RX modes remain active, they interfere with GPIO operations.
    pinclear(PIN_SD_CS)
    pinclear(PIN_SD_SCK)
    pinclear(PIN_MOSI)
    pinclear(PIN_MISO)

    current_spi_device := DEV_FLASH
    debug[CH_RECOVER]("  [switch_to_flash] SPI bus switched to Flash mode")

PRI switch_to_sd() : ok
' Reconfigure SPI bus for SD device after Flash operations.
' P60 (SD CS) is reused as Flash SCK, so during Flash operations the SD card
' sees its CS rapidly toggling, which corrupts the card's SPI state machine.
' A full re-initialization (CMD0/CMD8/ACMD41/CMD58) is required to recover.
'
' @returns ok - TRUE if SD card successfully re-initialized, FALSE on failure

  if current_spi_device == DEV_SD
    ok := TRUE

  else
    debug[CH_RECOVER]("  [switch_to_sd] Starting SD recovery sequence...")

    ' Float Flash pins to release any smart pin state
    pinfloat(PIN_FL_CS)
    pinfloat(PIN_FL_SCK)

    ' Re-initialize the SD card (recovery from corrupted SPI state)
    ok := reinitCard()
    if ok
      current_spi_device := DEV_SD
      debug[CH_RECOVER]("  [switch_to_sd] SD card recovered successfully")
    else
      debug[CH_RECOVER]("  [switch_to_sd] ERROR: SD card recovery failed!")

PRI reinitCard() : ok | resp, timeout, saved_freq
' Minimal SD card re-initialization after Flash operations.
' Performs the essential steps from initCard() without redundant ones:
' - Skips power-on delay (card already powered)
' - Skips identifyCard() (card type already cached)
' - Skips setOptimalSpeed() (speed already cached in spi_freq)
' - Reuses saved_acmd41_arg from initial mount
'
' Sequence: GPIO recovery flush -> initSPIPins -> slow clock -> CMD0 -> CMD8
'           -> ACMD41 -> CMD58 -> restore fast clock
'
' @returns ok - TRUE on success, FALSE on failure
' @local resp - Command response
' @local timeout - Timeout counter
' @local saved_freq - Saved SPI frequency to restore after init

  debug[CH_RECOVER]("    [reinitCard] Starting minimal SD re-init...")
  saved_freq := spi_freq
  sec_in_buf := -1                                                                 ' Invalidate sector cache
  dir_sec_in_buf := -1                                                             ' Invalidate dir sector cache
  fat_sec_in_buf := -1                                                             ' Invalidate FAT sector cache

  ' ----------------------------------------------------------
  ' STEP 1: GPIO recovery flush (4096 clocks with CS HIGH)
  ' Must happen BEFORE smart pin setup -- uses raw GPIO.
  ' The SD card may be stuck mid-transfer; flush clears it.
  '
  ' CRITICAL: Must fully reset smart pins first! pinfloat()
  ' only clears DIR, not the wrpin mode register. If smart
  ' pin modes remain active, pinh/pinl produce smart pin
  ' behavior (high-speed transitions) instead of clean GPIO.
  ' PINCLEAR does both: DIR=0 and WRPIN(pin,0) -- the standard
  ' way to stop smart pin operation before reprogramming.
  ' ----------------------------------------------------------
  pinclear(PIN_SD_CS)
  pinclear(PIN_SD_SCK)
  pinclear(PIN_MOSI)
  pinclear(PIN_MISO)

  pinh(PIN_SD_CS)                                                                         ' CS HIGH = deselected
  pinh(PIN_MOSI)                                                                       ' MOSI HIGH (card expects high during idle)
  pinl(PIN_SD_SCK)                                                                        ' SCK LOW (SPI mode 0 idle)
  pinf(PIN_MISO)                                                                       ' MISO as floating input

  repeat GPIO_FLUSH_CYCLES                                                                      ' Flush a full 512-byte sector worth
    pinh(PIN_SD_SCK)
    waitus(10)
    pinl(PIN_SD_SCK)
    waitus(10)
  debug[CH_RECOVER]("    [reinitCard] GPIO recovery flush complete (4096 clocks)")

  ' ----------------------------------------------------------
  ' STEP 2: Initialize smart pins at slow clock (400 kHz)
  ' ----------------------------------------------------------
  initSPIPins()
  do_set_spi_speed(SD_INIT_SPEED_HZ)
  waitus(100)

  ' Send dummy clocks via smart pins
  repeat 10
    sp_transfer_8($FF)
  debug[CH_RECOVER]("    [reinitCard] Smart pins ready at 400 kHz")

  ' ----------------------------------------------------------
  ' STEP 3: CMD0 - GO_IDLE_STATE
  ' ----------------------------------------------------------
  resp := 0
  repeat 5
    resp := cmd(0, 0)
    if resp == $01
      quit
    waitms(10)

  if resp <> $01
    debug[CH_RECOVER]("    [reinitCard] FAIL: CMD0 expected $01, got $", uhex_(resp))
    ok := false

  else
    debug[CH_RECOVER]("    [reinitCard] CMD0 OK")

    ' ----------------------------------------------------------
    ' STEP 4: CMD8 - SEND_IF_COND
    ' ----------------------------------------------------------
    resp := cmd(8, $000001AA)

    if resp == 0
      ' v1.x card -- shouldn'timeout happen for 128GB but handle it
      saved_acmd41_arg := $00000000
    elseif (resp & $FFF) == $1AA
      saved_acmd41_arg := $40000000
    debug[CH_RECOVER]("    [reinitCard] CMD8 done, acmd41_arg=$", uhex_long_(saved_acmd41_arg))

    ' ----------------------------------------------------------
    ' STEP 5: ACMD41 - SD_SEND_OP_COND (loop until ready)
    ' ----------------------------------------------------------
    timeout := getct() + clkfreq * INIT_TIMEOUT_SEC                                                       ' 2 second timeout

    repeat
      resp := cmd(55, 0)
      if resp > $01
        waitms(10)
      else
        resp := cmd(41, saved_acmd41_arg)
        if resp == $00
          quit

      if getct() - timeout > 0
        debug[CH_RECOVER]("    [reinitCard] FAIL: ACMD41 timeout")
        ok := false
        quit
      else
        waitms(10)

    debug[CH_RECOVER]("    [reinitCard] ACMD41 complete - card ready")

    ' ----------------------------------------------------------
    ' STEP 6: CMD58 - READ_OCR (restore HCS addressing)
    ' ----------------------------------------------------------
    resp := cmd(58, 0)
    ocr_value := resp

    if (resp >> 30) & 1
      hcs := 0                                                                       ' SDHC/SDXC: block addressing
    else
      hcs := 9                                                                       ' SDSC: byte addressing

    debug[CH_RECOVER]("    [reinitCard] CMD58 done, hcs=", udec_(hcs))

    ' ----------------------------------------------------------
    ' STEP 7: Restore original SPI speed
    ' ----------------------------------------------------------
    if saved_freq > 0
      do_set_spi_speed(saved_freq)
    else
      do_set_spi_speed(SD_FALLBACK_SPEED_HZ)                                                        ' Fallback to 25 MHz

    ' Stabilize at new clock rate
    pinh(PIN_SD_CS)
    repeat 8
      sp_transfer_8($FF)

    debug[CH_RECOVER]("    [reinitCard] Re-init complete, speed restored to ", udec_(spi_freq / 1000), " kHz")
    ok := true


CON ' ---- Flash SPI Engine ----
    ' FLASH SPI ENGINE
    ' =============================================================================
{$flexspin
DAT
  m_command      LONG    0               ' FlexSpin workaround: hub copy of command for @m_command
}

PRI fl_command(command, count)
' Send Flash SPI command - sets up SCK/CS pins and sends command bytes.
' SCK is configured for Mode 3 (P_TRANSITION inverted, clock idles HIGH).
'
' @param command - Command byte(s) packed into LONG (reversed before send)
' @param count - Number of bytes to send (1-4)

  org
        fltl      #PIN_MISO                       ' MISO to input
        fltl      #PIN_FL_SCK                     ' Reset SCK smart pin
        wrpin     ##%001000000_01_00101_0, #PIN_FL_SCK  ' P_TRANSITION inverted (Mode 3)
        wrpin     ##%001000000_00_00000_0, #PIN_FL_CS   ' CS pin mode (transition, no invert)
        wxpin     #4, #PIN_FL_SCK                 ' 4 clocks per transition
        drvl      #PIN_FL_CS                      ' CS deselect (matches original driver)
        waitx     #14                              ' Guard time (~50ns at 350 MHz)
        drvh      #PIN_FL_CS                      ' CS select (matches original driver)
        movbyts   command, #%%1230                 ' Reverse address byte order for SPI
  end
{$flexspin
#ifdef __FLEXSPIN__
  m_command := command
  fl_send(@m_command, count)
#else
}
  fl_send(@command, count)
{$flexspin #endif}

PRI fl_send(p_buffer, count) | tx_byte
' Write bytes to Flash chip via SPI bit-bang.
'
' @param p_buffer - Hub address of bytes to send
' @param count - Number of bytes to send
' @local tx_byte - Byte being transmitted via SPI

  org
        rdfast    #0, p_buffer                    ' Start fast read from hub

.byte   rfbyte    tx_byte                         ' Read byte to send
        shl       tx_byte, #24 + 1       wc       ' MSB-justify and get D7 into C

        rep       @.r, #1                          ' Protect from interrupts
        fltl      #PIN_FL_SCK                     ' Reset smart pin CK
        drvl      #PIN_FL_SCK                     ' Start smart pin CK
        drvc      #PIN_MOSI                       ' Output D7
        wypin     #16, #PIN_FL_SCK                ' Begin 16 clock transitions (8 bits)
        rep       @.r, #7                          ' Repeat for D6..D0
        shl       tx_byte, #1             wc       ' Get next data bit
        drvc      #PIN_MOSI                       ' Output data bit
        waitx     #2                               ' Delay for 8 clocks/bit
.r
        djnz      count, #.byte                    ' Loop if another byte

        drvl      #PIN_MOSI                       ' MOSI low when done

  end

PRI fl_receive(p_buffer, count) | rx_byte
' Read bytes from Flash chip via SPI bit-bang.
' Terminates command by deselecting CS at end.
'
' @param p_buffer - Hub address to store received bytes
' @param count - Number of bytes to receive
' @local rx_byte - Received SPI byte

  org
        wrfast    #0, p_buffer                    ' Start fast write to hub

.byte   rep       @.r, #1                          ' Protect from interrupts
        fltl      #PIN_FL_SCK                     ' Reset smart pin CK
        drvl      #PIN_FL_SCK                     ' Start smart pin CK
        wypin     #16, #PIN_FL_SCK                ' Begin 16 clock transitions (8 bits)
        waitx     #7                               ' Align TESTP to before 2nd clock fall
        rep       @.r, #8                          ' Repeat for 8 bits
        waitx     #2                               ' Delay for 8 clocks/bit
        testp     #PIN_MISO              wc        ' Input data bit
        rcl       rx_byte, #1                      ' Save data bit
.r
        wfbyte    rx_byte                          ' Write received byte to hub
        djnz      count, #.byte                    ' Loop if another byte

        drvl      #PIN_FL_CS                      ' CS deselect (terminates command)
        fltl      #PIN_FL_SCK                     ' Reset smart pin

  end

PRI fl_wait() | statusBits
' Wait for Flash chip to become ready (BUSY bit clear).
' Polls status register via command $05.
' @local statusBits - Flash status register bits

  repeat
    fl_command($05, 1)
    fl_receive(@statusBits, 1)
  while statusBits.[0]

PRI fl_read_block_id(block_id, p_buffer, firstByte, lastByte)
' Read bytes from Flash block by ID (translates via translation table).
'
' @param block_id - Block ID to look up
' @param p_buffer - Hub address to store data
' @param firstByte - First byte offset within block
' @param lastByte - Last byte offset within block

  fl_read_block_addr(field[fl_IDToBlock][block_id], p_buffer, firstByte, lastByte)

PRI fl_read_block_addr(block_address, p_buffer, firstByte, lastByte)
' Read bytes from Flash block by physical address.
'
' @param block_address - Block offset within filesystem (0 to FL_BLOCKS-1)
' @param p_buffer - Hub address to store data
' @param firstByte - First byte offset within block (0 to $FFF)
' @param lastByte - Last byte offset within block

  fl_command($03 | (FIRST_BLOCK + block_address) << 20 | firstByte << 8, 4)
  fl_receive(p_buffer, lastByte - firstByte + 1)

PRI fl_program_block(block_address, p_buffer, cycle_bits) | pageIndex
' Program a full 4KB block: erase + 16 page writes.
' Installs lifecycle bits and CRC before programming.
'
' @param block_address - Block offset within filesystem
' @param p_buffer - Hub address of 4KB data to write
' @param cycle_bits - Lifecycle bit pattern (3-bit)
' @local pageIndex - Flash page index within block (0-15)

  fl_command($06, 1)                                                              ' Enable write
  fl_command($20 | (FIRST_BLOCK + block_address) << 20, 4)                        ' Erase 4KB block

  BYTE[p_buffer].[7..5] := cycle_bits                                             ' Install lifecycle for CRC
  LONG[p_buffer + $FFC] := fl_block_crc(p_buffer)                                 ' Compute and install CRC
  BYTE[p_buffer].[7..5]~~                                                         ' Remove lifecycle (:= %111, inactive)

  fl_wait()                                                                       ' Wait for erase (~45ms)

  repeat PAGES_PER_FLASH_BLOCK with pageIndex                                      ' Program 16 pages (256 bytes each)
    fl_command($06, 1)                                                            ' Enable write
    fl_command($02 | (FIRST_BLOCK + block_address) << 20 | pageIndex << 16, 4)    ' Program page
    fl_send(p_buffer + pageIndex << 8, FLASH_PAGE_SIZE)                           ' Send 256 bytes
    fl_wait()                                                                     ' Wait for program (~400us)

PRI fl_activate_block(block_address, cycle_bits)
' Activate a programmed block by writing lifecycle pattern.
'
' @param block_address - Block offset within filesystem
' @param cycle_bits - Lifecycle bit pattern

  fl_program_bit(block_address, cycle_bits << 5 | %00011111)

PRI fl_format() : status | block_address, cycleBits
' Format Flash filesystem: cancel all active blocks, then remount.
' Port of flash_fs.spin2 format() lines 250-291.
'
' @returns status - SUCCESS or error code
' @local block_address - Physical Flash block address
' @local cycleBits - Block cycle bits for wear-leveling generation

  debug[CH_MOUNT]("  [fl_format] Formatting ", udec_(FL_BLOCKS), " blocks...")

  repeat FL_BLOCKS with block_address
    fl_read_block_addr(block_address, @cycleBits, $000, $000)
    if lookdown(cycleBits.[7..5] : %011, %101, %110)
      fl_cancel_block(block_address)

  debug[CH_MOUNT]("  [fl_format] Format complete, remounting...")
  flash_mounted := FALSE
  status := do_flash_mount()

PRI fl_cancel_block(block_address)
' Cancel a block by clearing all lifecycle bits.
'
' @param block_address - Block offset within filesystem

  fl_program_bit(block_address, %00011111)

PRI fl_program_bit(block_address, bit_pattern)
' Write bit pattern to first byte of block (lifecycle bits).
' Most atomic Flash filesystem operation.
'
' @param block_address - Block offset within filesystem
' @param bit_pattern - Value to write to first byte

  fl_command($06, 1)                                                              ' Enable write
  fl_command($02 | (FIRST_BLOCK + block_address) << 20, 4)                        ' Program address
  fl_send(@bit_pattern, 1)                                                        ' Send byte
  fl_wait()                                                                       ' Wait for completion

PRI fl_next_active_cycle(cycle_in) : cycle_out
' Calculate next lifecycle pattern (3 -> 5 -> 6 -> 3 -> 5 -> 6 -> ...).
'
' @param cycle_in - Current lifecycle pattern
' @returns cycle_out - Next lifecycle pattern

  cycle_out := (cycle_in * %001_001) >> 1 & %111

PRI fl_block_crc(p_block_buffer) : crc
' Calculate CRC for a 4KB Flash block using P2 hardware GETCRC.
'
' @param p_block_buffer - Address of 4KB block buffer
' @returns crc - 32-bit CRC value

  crc := getcrc(p_block_buffer, $AD0424F3 rev 31, BLOCK_SIZE - 4)

PRI fl_activate_updated_block(block_address, pBuff) | nextCycleBits
' Activate an updated block with the next lifecycle pattern.
' Used by rename, rewrite_block, froncate_file, close_no_lock.
' Port of flash_fs.spin2 activate_updated_block().
'
' @param block_address - Block address to activate
' @param pBuff - Pointer to block buffer to program
' @local nextCycleBits - Next-generation cycle bits for block replacement

  nextCycleBits := fl_next_active_cycle(LONG[pBuff].[7..5])
  fl_program_block(block_address, pBuff, nextCycleBits)
  fl_activate_block(block_address, nextCycleBits)

PRI fl_check_block_fix_dupe_id(thisBlockAddress) | otherBlockAddress, thisCycleBits, otherCycleBits, thisBlockID
' Check block for valid lifecycle and CRC, resolve duplicate IDs.
' During mount M1 pass: recovers from incomplete block switchover due to power loss.
' Port of flash_fs.spin2 check_block_fix_dupe_id().
'
' @param thisBlockAddress - Block offset within filesystem
' @local otherBlockAddress - Address of duplicate block being compared
' @local thisCycleBits - Cycle bits of current block
' @local otherCycleBits - Cycle bits of other block being compared
' @local thisBlockID - Block ID of current block

  fl_read_block_addr(thisBlockAddress, @thisCycleBits, $000, $000)                ' Read first byte

  if lookdown(thisCycleBits.[7..5]: %011, %101, %110)                             ' Valid lifecycle?
    fl_read_block_addr(thisBlockAddress, @fl_tmpBlockBuff, $000, $FFF)            ' Read entire block

    if LONG[@fl_tmpBlockBuff + $FFC] <> fl_block_crc(@fl_tmpBlockBuff)            ' CRC valid?
      fl_cancel_block(thisBlockAddress)                                           ' No - cancel block

    else
      thisBlockID := LONG[@fl_tmpBlockBuff].[19..8]                               ' Good block, get its ID

      ifnot field[fl_IDValid][thisBlockID]~~                                      ' Set ID flag; was it already set?
        field[fl_IDToBlock][thisBlockID] := thisBlockAddress                       ' First block with this ID
        field[fl_BlockState][thisBlockAddress] := B_TEMP

      else
        ' Duplicate ID found - resolve by keeping the newer block
        otherBlockAddress := field[fl_IDToBlock][thisBlockID]
        fl_read_block_addr(otherBlockAddress, @otherCycleBits, $000, $000)

        if lookdown(thisCycleBits.[7..5] << 3 | otherCycleBits.[7..5]: %011_110, %101_011, %110_101)
          ' This block is newer - keep this, cancel other
          field[fl_IDToBlock][thisBlockID] := thisBlockAddress
          field[fl_BlockState][thisBlockAddress] := B_TEMP
          field[fl_BlockState][otherBlockAddress] := B_FREE
          fl_cancel_block(otherBlockAddress)
        else
          ' Other block is newer - cancel this one
          fl_cancel_block(thisBlockAddress)

PRI fl_trace_file_set_flags(block_address, set) : valid | signature, block_id
' Trace file chain setting block states to B_HEAD/B_BODY (or back to B_TEMP on error).
' Port of flash_fs.spin2 trace_file_set_flags().
'
' @param block_address - Starting block address (head block)
' @param set - TRUE to set B_HEAD/B_BODY, FALSE to restore B_TEMP
' @returns valid - TRUE if file chain is complete and valid
' @local signature - Block header signature (type + CRC + filename CRC)
' @local block_id - Logical Flash block ID

  valid := false
  fl_read_block_addr(block_address, @signature, $000, $003)                       ' Read first LONG
  field[fl_BlockState][block_address] := set ? B_HEAD : B_TEMP                    ' Set head block state

  repeat FL_BLOCKS                                                                ' Limit to prevent infinite loop
    ifnot signature.[0]                                                           ' Last block? File is complete
      valid := true
      quit
    else
      block_id := signature.[31..20]                                                ' Get next block ID
      ifnot field[fl_IDValid][block_id]                                             ' ID invalid?
        quit                                                                        ' Error - valid stays false
      block_address := field[fl_IDToBlock][block_id]                                ' Get address of next block
      fl_read_block_addr(block_address, @signature, $000, $003)                     ' Read first LONG
      ifnot signature.[1]                                                           ' Head block in chain? Error!
        quit                                                                        ' Valid stays false
      field[fl_BlockState][block_address] := set ? B_BODY : B_TEMP                  ' Set body block state


CON ' ---- Flash Mount ----
    ' FLASH MOUNT
    ' =============================================================================
PRI do_flash_mount() : status | block_address, blockTypeBits, signature
' Mount Flash filesystem - scans all blocks and initializes translation tables.
' Port of flash_fs.spin2 mount() adapted for worker cog context.
' Three-pass scan: M1=fix duplicates, M2=trace files, M3=clean dead blocks.
'
' @returns status - SUCCESS or error code
' @local block_address - Physical Flash block address
' @local blockTypeBits - Block type field from header
' @local signature - Block header signature (type + CRC + filename CRC)

  debug[CH_MOUNT]("  [do_flash_mount] Starting Flash mount scan...")

  ' Clear Flash handle state
  bytefill(@fl_hStatus, 0, MAX_OPEN_FILES)

  ' Reset Flash buffer pool
  bytefill(@fl_buf_owner, $FF, MAX_FLASH_BUFFERS)
  bytefill(@fl_hBufIndex, $FF, MAX_OPEN_FILES)

  ' Clear translation tables
  bytefill(@fl_IDToBlocks, 0, ID_TO_BLOCKS_SZ * 2)                               ' WORD array
  bytefill(@fl_IDValids, 0, FL_FLAGS_SIZE)
  bytefill(@fl_BlockStates, 0, FL_STATES_SIZE)

  ' Set field pointers for bit-field access
  fl_IDToBlock  := ^@fl_IDToBlocks.[11..0]                                        ' 12-bit field pointer
  fl_IDValid    := ^@fl_IDValids.[0]                                              ' 1-bit field pointer
  fl_BlockState := ^@fl_BlockStates.[1..0]                                        ' 2-bit field pointer

  status := SUCCESS

  ' M1 pass: Check each block and fix duplicate IDs
  debug[CH_MOUNT]("  [do_flash_mount] M1: Scanning ", udec_(FL_BLOCKS), " blocks for duplicates...")
  repeat FL_BLOCKS with block_address
    fl_check_block_fix_dupe_id(block_address)

  ' M2 pass: Trace head blocks, set B_HEAD/B_BODY flags
  debug[CH_MOUNT]("  [do_flash_mount] M2: Locating files...")
  repeat FL_BLOCKS with block_address
    if field[fl_BlockState][block_address] == B_TEMP                              ' Valid block?
      fl_read_block_addr(block_address, @blockTypeBits, $000, $000)               ' Read first byte
      ifnot blockTypeBits.[1]                                                     ' Head block?
        ifnot fl_trace_file_set_flags(block_address, true)                        ' Trace file chain
          fl_trace_file_set_flags(block_address, false)                           ' Error: retrace to B_TEMP

  ' M3 pass: Cancel remaining B_TEMP blocks (dead/orphaned)
  debug[CH_MOUNT]("  [do_flash_mount] M3: Cleaning dead blocks...")
  repeat FL_BLOCKS with block_address
    if field[fl_BlockState][block_address] == B_TEMP
      fl_read_block_addr(block_address, @signature, $000, $003)                   ' Read first LONG
      field[fl_IDValid][signature.[19..8]]~                                       ' Cancel ID flag
      field[fl_BlockState][block_address] := B_FREE                               ' Return to free
      fl_cancel_block(block_address)                                              ' Cancel on chip
      status := E_FLASH_BAD_BLOCKS

  ' Bad blocks found but cleaned is informational, not fatal
  if status == E_FLASH_BAD_BLOCKS
    debug[CH_MOUNT]("  [do_flash_mount] WARNING: Dead blocks were cleaned during mount")
    status := SUCCESS

  debug[CH_MOUNT]("  [do_flash_mount] Flash mount complete")

PRI fl_can_mount() : ok | block_address, blockTypeBits, signature, bad_count, dupe_count, badBlockCount
' Non-destructive check if Flash would mount cleanly.
' Like do_flash_mount() but read-only: never calls fl_cancel_block().
' Uses fl_check_block_read_only() instead of fl_check_block_fix_dupe_id().
'
' @returns ok - TRUE if no blocks would need repair, FALSE otherwise
' @local block_address - Physical Flash block address
' @local blockTypeBits - Block type field from header
' @local signature - Block header signature (type + CRC + filename CRC)
' @local bad_count - Count of bad/corrupt blocks found
' @local dupe_count - Count of duplicate block IDs found
' @local badBlockCount - Total bad block count

  debug[CH_MOUNT]("  [fl_can_mount] Checking Flash mount readiness...")

  if flash_mounted
    ok := true  ' Already mounted is OK

  ' Clear translation tables (temporary, for scan only)
  else
    bytefill(@fl_IDToBlocks, 0, ID_TO_BLOCKS_SZ * 2)
    bytefill(@fl_IDValids, 0, FL_FLAGS_SIZE)
    bytefill(@fl_BlockStates, 0, FL_STATES_SIZE)

    fl_IDToBlock  := ^@fl_IDToBlocks.[11..0]
    fl_IDValid    := ^@fl_IDValids.[0]
    fl_BlockState := ^@fl_BlockStates.[1..0]

    badBlockCount := 0

    ' Pass 1: Read-only block check (no cancel operations)
    repeat FL_BLOCKS with block_address
      bad_count, dupe_count := fl_check_block_read_only(block_address)
      badBlockCount += bad_count

    ' Pass 2: Trace head blocks
    repeat FL_BLOCKS with block_address
      if field[fl_BlockState][block_address] == B_TEMP
        fl_read_block_addr(block_address, @blockTypeBits, $000, $000)
        ifnot blockTypeBits.[1]                                                    ' Head block?
          ifnot fl_trace_file_set_flags(block_address, true)
            fl_trace_file_set_flags(block_address, false)

    ' Pass 3: Count dead blocks (read-only -- do NOT cancel)
    repeat FL_BLOCKS with block_address
      if field[fl_BlockState][block_address] == B_TEMP
        fl_read_block_addr(block_address, @signature, $000, $003)
        field[fl_IDValid][signature.[19..8]]~
        field[fl_BlockState][block_address] := B_FREE
        badBlockCount++

    ok := badBlockCount == 0
    debug[CH_MOUNT]("  [fl_can_mount] Result: ", udec_(badBlockCount), " bad blocks, ok=", udec_(ok))

PRI fl_check_block_read_only(thisBlockAddress) : bad_count, dupe_count | otherBlockAddress, thisCycleBits, otherCycleBits, thisBlockID
' Read-only block check: like fl_check_block_fix_dupe_id but never cancels blocks.
' Port of flash_fs.spin2 check_block_read_only().
'
' @param thisBlockAddress - Block offset within filesystem
' @returns bad_count - 1 if block has bad CRC, 0 otherwise
' @returns dupe_count - 1 if duplicate ID found, 0 otherwise
' @local otherBlockAddress - Address of duplicate block being compared
' @local thisCycleBits - Cycle bits of current block
' @local otherCycleBits - Cycle bits of other block being compared
' @local thisBlockID - Block ID of current block

  fl_read_block_addr(thisBlockAddress, @thisCycleBits, $000, $000)               ' Read first byte

  if lookdown(thisCycleBits.[7..5]: %011, %101, %110)                            ' Valid lifecycle?
    fl_read_block_addr(thisBlockAddress, @fl_tmpBlockBuff, $000, $FFF)           ' Read entire block

    if LONG[@fl_tmpBlockBuff + $FFC] <> fl_block_crc(@fl_tmpBlockBuff)           ' CRC valid?
      bad_count++                                                                 ' No - count as bad

    else
      thisBlockID := LONG[@fl_tmpBlockBuff].[19..8]                              ' Good block, get ID

      ifnot field[fl_IDValid][thisBlockID]~~                                     ' Set flag, was it set?
        field[fl_IDToBlock][thisBlockID] := thisBlockAddress                      ' First with this ID
        field[fl_BlockState][thisBlockAddress] := B_TEMP

      ' Duplicate ID found -- resolve in tables only (no cancel)
      else
    otherBlockAddress := field[fl_IDToBlock][thisBlockID]
    dupe_count++

    fl_read_block_addr(otherBlockAddress, @otherCycleBits, $000, $000)

    if lookdown(thisCycleBits.[7..5] << 3 | otherCycleBits.[7..5]: %011_110, %101_011, %110_101)
      field[fl_IDToBlock][thisBlockID] := thisBlockAddress                          ' This is newer
      field[fl_BlockState][thisBlockAddress] := B_TEMP
      field[fl_BlockState][otherBlockAddress] := B_FREE

PRI do_flash_serial_number() : sn_hi, sn_lo
' Read Flash chip 64-bit JEDEC unique ID (command $4B).
' Matches original flash_fs.spin2 serial_number() pattern.
' Sequence: $4B cmd + 4 dummy bytes + 8 ID bytes.
' Uses DAT buffer (fl_sn_buf) for wrfast target to avoid
' potential stack address issues with inline PASM2 FIFO writes.
'
' @returns sn_hi - High 32 bits of unique ID
' @returns sn_lo - Low 32 bits of unique ID

  fl_command($4B, 1)                                                              ' Read Unique ID command
  fl_send($00, 4)                                                                 ' 4 dummy bytes
  fl_receive(@fl_sn_buf, 8)                                                       ' 8 ID bytes into DAT buffer

  ' Copy from DAT buffer and reverse byte order (Big Endian to Little Endian)
  sn_hi := fl_sn_buf[0]
  sn_lo := fl_sn_buf[1]
  org
    movbyts   sn_hi, #%%0123
    movbyts   sn_lo, #%%0123
  end

  debug[CH_IDENT]("  [do_flash_serial_number] ID: $", uhex_long_(sn_hi), "_", uhex_long_(sn_lo))

CON ' ---- Flash Directory Emulation ----
    ' FLASH DIRECTORY EMULATION (caller-cog helpers)
    ' These PRI methods run in the calling cog, using COGID() to index per-cog CWD.
    ' Flash filenames support "/" characters (up to 127 chars). CWD is stored as a
    ' prefix string that gets prepended to filenames transparently.
    ' ===========================================================================


CON ' ---- Flash CWD Emulation ----
    ' FLASH CWD EMULATION
    ' =============================================================================
PRI fl_get_cwd() : p_cwd
' Return pointer to the calling cog's Flash CWD prefix string.
'
' @returns p_cwd - Pointer to null-terminated CWD string in fl_cog_cwd

  p_cwd := @fl_cog_cwd + COGID() << FL_FILENAME_SIZE_EXP

PRI fl_prepend_cwd(p_dest, p_name) | p_cwd, cwd_len, name_len
' Build full Flash path by prepending the calling cog's CWD prefix to a filename.
' Result is stored in p_dest (must be FL_FILENAME_SIZE bytes).
' If CWD is empty (root), p_name is copied directly.
' If CWD is "dir1", result is "dir1/name".
'
' @param p_dest - Destination buffer (FL_FILENAME_SIZE bytes)
' @param p_name - Filename to prepend CWD to
' @local p_cwd - Pointer to current working directory path
' @local cwd_len - Length of CWD path string
' @local name_len - Length of filename string

  bytefill(p_dest, 0, FL_FILENAME_SIZE)

  ' Absolute path (starts with "/") -- strip leading "/" and use directly, skip CWD
  if BYTE[p_name] == "/"
    strcopy(p_dest, p_name + 1, FL_FILENAME_SIZE - 1)
  else
    ' Relative path -- prepend CWD as before
    p_cwd := fl_get_cwd()
    cwd_len := strsize(p_cwd)
    name_len := strsize(p_name)

    if cwd_len == 0
      ' At root -- just copy the filename
      strcopy(p_dest, p_name, FL_FILENAME_SIZE - 1)
    else
      ' Build: CWD + "/" + name
      strcopy(p_dest, p_cwd, FL_FILENAME_SIZE - 1)
      if cwd_len + 1 + name_len < FL_FILENAME_SIZE
        BYTE[p_dest][cwd_len] := "/"
        strcopy(p_dest + cwd_len + 1, p_name, FL_FILENAME_SIZE - cwd_len - 2)

PRI fl_change_cwd(p_path) | p_cwd, cwd_len, path_len, idx
' Change the calling cog's Flash CWD prefix.
' "/" navigates to root (empty prefix).
' ".." strips the last path segment.
' Any other path appends to the current CWD with "/" separator.
'
' @param p_path - Pointer to path string
' @local p_cwd - Pointer to current working directory path
' @local cwd_len - Length of CWD path string
' @local path_len - Length of path string
' @local idx - Array or table index

  p_cwd := fl_get_cwd()
  cwd_len := strsize(p_cwd)

  ' "/" = navigate to root
  if BYTE[p_path] == "/" and BYTE[p_path][1] == 0
    BYTE[p_cwd] := 0

  ' ".." = strip last path segment
  elseif BYTE[p_path] == "." and BYTE[p_path][1] == "." and BYTE[p_path][2] == 0
    if cwd_len > 0
      ' Find last "/" in CWD
      idx := cwd_len - 1
      repeat while idx > 0
        if BYTE[p_cwd][idx] == "/"
          BYTE[p_cwd][idx] := 0
          quit
        idx--
      ' No "/" found -- CWD is a single segment, clear to root
      if idx == 0
        BYTE[p_cwd] := 0

  ' Relative path -- append to CWD
  else
    path_len := strsize(p_path)
    if cwd_len == 0
      ' At root -- set CWD to this path directly
      strcopy(p_cwd, p_path, FL_FILENAME_SIZE - 1)
    else
      ' Append: CWD + "/" + path
      if cwd_len + 1 + path_len < FL_FILENAME_SIZE
        BYTE[p_cwd][cwd_len] := "/"
        strcopy(p_cwd + cwd_len + 1, p_path, FL_FILENAME_SIZE - cwd_len - 2)

PRI fl_cwd_matches(p_stored_name, p_bare_name) : matches | p_cwd, cwd_len, name_len, idx
' Check if a stored Flash filename is a direct child of the current CWD.
' If it matches, copies the bare (stripped) filename into p_bare_name.
' A "direct child" means the name after the CWD prefix has no further "/" separators.
'
' @param p_stored_name - Full stored filename from Flash
' @param p_bare_name - Buffer to receive the stripped bare filename (FL_FILENAME_SIZE bytes)
' @returns matches - TRUE if the file is a direct child of CWD
' @local p_cwd - Pointer to current working directory path
' @local cwd_len - Length of CWD path string
' @local name_len - Length of filename string
' @local idx - Array or table index

  p_cwd := fl_get_cwd()
  cwd_len := strsize(p_cwd)
  name_len := strsize(p_stored_name)

  if cwd_len == 0
    ' At root -- match files that have no "/" in their name
    matches := true
    repeat idx from 0 to name_len - 1
      if BYTE[p_stored_name][idx] == "/"
        matches := false
        quit
    if matches
      strcopy(p_bare_name, p_stored_name, FL_FILENAME_SIZE - 1)

  ' Check if stored name starts with CWD prefix + "/"
  elseif name_len <= cwd_len + 1
    matches := false
  else
    matches := true
    repeat idx from 0 to cwd_len - 1
      if BYTE[p_stored_name][idx] <> BYTE[p_cwd][idx]
        matches := false
        quit
    if matches
      if BYTE[p_stored_name][cwd_len] <> "/"
        matches := false

      ' Check the remainder has no further "/" (direct child, not deeper subdirectory)
      else
        repeat idx from cwd_len + 1 to name_len - 1
          if BYTE[p_stored_name][idx] == "/"
            matches := false
            quit

        ' It's a direct child -- extract the bare name
        if matches
          strcopy(p_bare_name, p_stored_name + cwd_len + 1, FL_FILENAME_SIZE - 1)


CON ' ---- Flash Directory Handle Support ----
    ' FLASH DIRECTORY HANDLE SUPPORT (caller-cog methods)
    ' Implements openDirectory/readDirectoryHandle/closeDirectoryHandle for Flash.
    ' Uses per-handle 512-byte buffer for prefix storage (bytes 0-127) and
    ' subdirectory dedup tracking (bytes 128-383).
    ' ===========================================================================

  ' Flash directory handle buffer layout constants
  FL_DH_PREFIX_OFFSET   = 0         ' Offset in handle buffer for stored prefix
  FL_DH_PREFIX_SIZE     = 128       ' Max prefix length including null
  FL_DH_DEDUP_OFFSET    = 128       ' Offset in handle buffer for dedup area
  FL_DH_DEDUP_SIZE      = 256       ' Size of dedup area (fits ~28 names at 9 bytes each)

PRI fl_open_directory(p_path) : handle | p_buf, p_prefix, p_cwd, cwd_len, path_len
' Open a Flash directory for handle-based enumeration.
' Allocates a handle, resolves the path to an absolute prefix, and stores it
' in the handle's buffer for use by fl_read_dir_handle().
'
' Path resolution:
'   "" or "." -- copy caller's CWD as prefix
'   "/"       -- empty prefix (root)
'   "/dirA"   -- strip leading "/", use "dirA"
'   "subdir"  -- prepend CWD via fl_prepend_cwd()
'
' @param p_path - Pointer to null-terminated path string
' @returns handle - Handle index on success, negative error code on failure
' @local p_buf - Pointer to handle's 512-byte buffer
' @local p_prefix - Pointer to prefix area within handle buffer
' @local p_cwd - Pointer to caller's CWD string
' @local cwd_len - Length of CWD string
' @local path_len - Length of path argument

  ' Check Flash is mounted
  if cog_id == -1
    handle := set_error(E_NOT_MOUNTED)
  elseifnot flash_mounted
    handle := set_error(E_NOT_MOUNTED)
  else
    ' Allocate handle under lock
    repeat until locktry(api_lock)
    handle := allocateHandle()
    if handle >= 0
      h_device[handle] := DEV_FLASH
      h_flags[handle] := HF_DIR
    lockrel(api_lock)

    if handle >= 0
      ' Initialize handle state
      h_position[handle] := 0         ' block_id counter starts at 0

      ' Get buffer pointer and initialize
      p_buf := getHandleBuffer(handle)
      p_prefix := p_buf + FL_DH_PREFIX_OFFSET

      ' Zero the prefix and dedup areas
      bytefill(p_prefix, 0, FL_DH_PREFIX_SIZE)
      bytefill(p_buf + FL_DH_DEDUP_OFFSET, 0, FL_DH_DEDUP_SIZE)

      ' Resolve path to absolute prefix
      path_len := strsize(p_path)
      if path_len == 0 or (BYTE[p_path] == "." and path_len == 1)
        ' "" or "." -- use caller's CWD
        p_cwd := fl_get_cwd()
        strcopy(p_prefix, p_cwd, FL_DH_PREFIX_SIZE - 1)
      elseif BYTE[p_path] == "/" and path_len == 1
        ' "/" -- root (empty prefix, already zeroed)
      elseif BYTE[p_path] == "/"
        ' "/dirA" -- absolute path, strip leading "/"
        strcopy(p_prefix, p_path + 1, FL_DH_PREFIX_SIZE - 1)
      else
        ' "subdir" -- relative path, prepend CWD
        fl_prepend_cwd(p_prefix, p_path)

PRI fl_read_dir_handle(handle) : status | p_buf, p_prefix, prefix_len, tmpName[32], fsize, remainder_len, seg_len, idx, attr
' Read next entry from a Flash directory handle.
' Iterates Flash files via CMD_FLASH_DIRECTORY using the handle's stored prefix
' (NOT the caller's CWD). Returns files as ATTR_ARCHIVE entries and subdirectories
' as DIR_ATTR_DIRECTORY pseudo-entries with dedup tracking.
'
' @param handle - Valid Flash directory handle
' @returns status - SUCCESS if entry found (entry_buffer populated), E_FILE_NOT_FOUND at end
' @local p_buf - Pointer to handle's 512-byte buffer
' @local p_prefix - Pointer to stored prefix in handle buffer
' @local prefix_len - Length of the stored prefix
' @local tmpName - Temporary buffer for Flash filename
' @local fsize - File size from Flash directory iteration
' @local remainder_len - Length of filename portion after prefix
' @local seg_len - Length of first path segment (subdirectory name)
' @local idx - Loop index
' @local attr - Entry attribute byte

  p_buf := getHandleBuffer(handle)
  p_prefix := p_buf + FL_DH_PREFIX_OFFSET
  prefix_len := strsize(p_prefix)

  ' Iterate Flash files starting from current block_id position
  repeat
    send_command(CMD_FLASH_DIRECTORY, @h_position[handle], @tmpName, @fsize, 0)

    ' No more files -- end of enumeration
    if BYTE[@tmpName][0] == 0
      status := E_FILE_NOT_FOUND
      quit

    ' Check if this file matches the handle's prefix
    if prefix_len == 0
      ' Root prefix -- check if filename has no "/" (direct child at root)
      idx := 0
      seg_len := strsize(@tmpName)
      repeat idx from 0 to seg_len - 1
        if BYTE[@tmpName][idx] == "/"
          quit
      if idx < seg_len
        ' Has "/" -- this is a subdirectory entry at root
        ' Extract first segment as directory name
        if fl_dh_dedup_check(handle, @tmpName, idx)
          fl_populate_entry_buffer(@tmpName, idx, DIR_ATTR_DIRECTORY, 0)
          status := SUCCESS
          quit
        ' Already seen this subdir, continue to next file
      else
        ' No "/" -- direct file at root
        fl_populate_entry_buffer(@tmpName, seg_len, $20, fsize)
        status := SUCCESS
        quit

    else
      ' Non-root prefix -- check if filename starts with prefix + "/"
      remainder_len := strsize(@tmpName)
      if remainder_len > prefix_len + 1
        ' Check prefix match
        idx := 0
        repeat idx from 0 to prefix_len - 1
          if BYTE[@tmpName][idx] <> BYTE[p_prefix][idx]
            idx := -1
            quit
        if idx >= 0 and BYTE[@tmpName][prefix_len] == "/"
          ' Prefix matches. Check remainder after prefix + "/"
          ' Find next "/" in remainder to distinguish file vs subdir
          seg_len := 0
          repeat idx from prefix_len + 1 to remainder_len - 1
            if BYTE[@tmpName][idx] == "/"
              quit
            seg_len++
          if idx < remainder_len
            ' Has another "/" -- subdirectory entry
            if fl_dh_dedup_check(handle, @tmpName + prefix_len + 1, seg_len)
              fl_populate_entry_buffer(@tmpName + prefix_len + 1, seg_len, DIR_ATTR_DIRECTORY, 0)
              status := SUCCESS
              quit
            ' Already seen, continue
          else
            ' No more "/" -- direct child file
            fl_populate_entry_buffer(@tmpName + prefix_len + 1, seg_len, $20, fsize)
            status := SUCCESS
            quit

PRI fl_populate_entry_buffer(p_name, name_len, attr, fsize) | idx, dot_pos, copy_len
' Build a FAT32-compatible entry_buffer from a Flash filename.
' Makes fileName(), attributes(), and fileSize() work transparently.
'
' @param p_name - Pointer to filename (not necessarily null-terminated, length given)
' @param name_len - Number of characters in the name
' @param attr - Attribute byte ($10=directory, $20=archive)
' @param fsize - File size in bytes (0 for directories)
' @local idx - Loop index
' @local dot_pos - Position of "." separator (-1 if none)
' @local copy_len - Number of characters to copy

  ' Zero-fill entry_buffer (32 bytes)
  bytefill(@entry_buffer, 0, 32)

  ' Find "." separator position
  dot_pos := -1
  repeat idx from 0 to name_len - 1
    if BYTE[p_name][idx] == "."
      dot_pos := idx
      quit

  ' Fill name field (bytes 0-7) with space padding
  bytefill(@entry_buffer, " ", 8)
  if dot_pos < 0
    ' No extension -- copy entire name (up to 8 chars)
    copy_len := name_len
    if copy_len > 8
      copy_len := 8
    bytemove(@entry_buffer, p_name, copy_len)
  else
    ' Has extension -- copy name part (up to 8 chars)
    copy_len := dot_pos
    if copy_len > 8
      copy_len := 8
    bytemove(@entry_buffer, p_name, copy_len)

  ' Fill extension field (bytes 8-10) with space padding
  bytefill(@entry_buffer + 8, " ", 3)
  if dot_pos >= 0
    ' Copy extension (up to 3 chars after ".")
    copy_len := name_len - dot_pos - 1
    if copy_len > 3
      copy_len := 3
    bytemove(@entry_buffer + 8, p_name + dot_pos + 1, copy_len)

  ' Set attribute byte (byte 11)
  BYTE[@entry_buffer][11] := attr

  ' Set file size (bytes 28-31, little-endian LONG)
  LONG[@entry_buffer][7] := fsize

PRI fl_dh_dedup_check(handle, p_name, name_len) : is_new | p_buf, p_dedup, p_scan, scan_len, total_used, idx, matches
' Check if a subdirectory name has been seen before for this handle.
' If new, adds it to the dedup list. Returns TRUE if the name is new (first time seen).
'
' @param handle - Directory handle
' @param p_name - Pointer to subdirectory name (not null-terminated, length given)
' @param name_len - Length of the name to check
' @returns is_new - TRUE if this name was not previously seen
' @local p_buf - Pointer to handle's 512-byte buffer
' @local p_dedup - Pointer to start of dedup area
' @local p_scan - Current scan position in dedup area
' @local scan_len - Length of current entry being scanned
' @local total_used - Total bytes used in dedup area
' @local idx - Loop index
' @local matches - Whether current entry matches

  p_buf := getHandleBuffer(handle)
  p_dedup := p_buf + FL_DH_DEDUP_OFFSET

  ' Scan existing entries for a match
  total_used := 0
  p_scan := p_dedup
  repeat while total_used < FL_DH_DEDUP_SIZE
    scan_len := strsize(p_scan)
    if scan_len == 0
      quit  ' End of entries (empty slot)

    ' Compare this entry with the name
    if scan_len == name_len
      matches := true
      repeat idx from 0 to name_len - 1
        if BYTE[p_scan][idx] <> BYTE[p_name][idx]
          matches := false
          quit
      if matches
        is_new := false
        return

    ' Advance past this entry + null terminator
    total_used += scan_len + 1
    p_scan += scan_len + 1

  ' Name not found -- add it if there's room
  if total_used + name_len + 1 <= FL_DH_DEDUP_SIZE
    bytemove(p_scan, p_name, name_len)
    BYTE[p_scan][name_len] := 0  ' Null terminate
  is_new := true

CON ' ---- Flash File Operations (Worker Cog) ----
    ' PHASE 3: FLASH FILE OPERATIONS (worker cog internal methods)
    ' Ported from flash_fs.spin2 with fl_ prefix, adapted for unified driver.
    ' All methods run in worker cog -- no locks, no mount checks (dispatch handles).
    ' ===========================================================================

' --- Step 3: Non-SPI Helpers ------------------------------------------------


CON ' ---- Flash Handle and Buffer Management ----
    ' FLASH HANDLE AND BUFFER MANAGEMENT
    ' =============================================================================
PRI fl_set_error(code) : error_code
' Set Flash error code and return the same code (for chained returns).
'
' @param code - Error code to store
' @returns error_code - The same error code passed in

  fl_errorCode := code
  error_code := code

PRI fl_filename_crc(p_filename) : filenameCRC
' Return the CRC19 value calculated for the filename zstring.
' Port of flash_fs.spin2 filename_crc().
'
' @param p_filename - address of a zstring containing the filename
' @returns filenameCRC - the calculated CRC value

  filenameCRC := getcrc(p_filename, $B5827 rev 19, strsize(p_filename))

PRI fl_filename_pointer(handle) : p_filename
' Return pointer to Flash filename for this handle.
' Port of flash_fs.spin2 filename_pointer().
'
' @param handle - a handle to an open file
' @returns p_filename - address of filename zstring

  p_filename := @fl_hFilename + handle << FL_FILENAME_SIZE_EXP

PRI fl_buffer_pointer(handle) : p_buffer
' Return pointer to the 4KB block buffer for this handle.
' Uses fl_hBufIndex indirection to map handle to buffer pool slot.
'
' @param handle - a handle to an open file (must have buffer assigned)
' @returns p_buffer - address of the 4KB buffer

  p_buffer := @fl_hBlockBuff + fl_hBufIndex[handle] << BLOCK_SIZE_EXP

PRI fl_alloc_buffer(handle) : status | bufIdx
' Assign a free buffer from the pool to a handle.
' Called by fl_new_handle() after allocateHandle() succeeds.
'
' @param handle - handle to assign a buffer to
' @returns status - SUCCESS or E_FLASH_NO_BUFFER
' @local bufIdx - Buffer pool index

  status := E_FLASH_NO_BUFFER
  repeat bufIdx from 0 to MAX_FLASH_BUFFERS - 1
    if fl_buf_owner[bufIdx] == $FF
      fl_buf_owner[bufIdx] := handle
      fl_hBufIndex[handle] := bufIdx
      status := SUCCESS
      quit

PRI fl_free_buffer(handle) | bufIdx
' Release buffer from handle back to the pool.
' Safe to call when handle has no buffer ($FF).
'
' @param handle - handle whose buffer to release
' @local bufIdx - Buffer pool index

  bufIdx := fl_hBufIndex[handle]
  if bufIdx <> $FF
    fl_buf_owner[bufIdx] := $FF
    fl_hBufIndex[handle] := $FF

PRI fl_has_free_buffer() : bAvail | bufIdx
' Check if any buffer pool slot is available without allocating.
' Used for early-exit error checking before expensive operations.
'
' @returns bAvail - TRUE if at least one buffer is free
' @local bufIdx - Buffer pool index

  bAvail := FALSE
  repeat bufIdx from 0 to MAX_FLASH_BUFFERS - 1
    if fl_buf_owner[bufIdx] == $FF
      bAvail := TRUE
      quit

PRI fl_ensure_handle_mode(handle, open_mode_bits) : status
' Determine if handle is open with desired Flash mode.
' Port of flash_fs.spin2 ensure_handle_mode().
'
' @param handle - handle to check
' @param open_mode_bits - combination of FL_H_READ, FL_H_WRITE, etc.
' @returns status - SUCCESS or error code

  if handle < 0 or handle > MAX_OPEN_FILES - 1
    status := E_FLASH_BAD_HANDLE
  elseif fl_hStatus[handle] & open_mode_bits
    status := SUCCESS
  else
    status := E_FLASH_FILE_MODE

PRI fl_has_free_handle() : bAvail | idx
' Check if any handle slot is available without allocating.
' Used for early-exit error checking before expensive operations.
'
' @returns bAvail - TRUE if at least one handle is free
' @local idx - Array or table index

  bAvail := FALSE
  repeat idx from 0 to MAX_OPEN_FILES - 1
    if h_flags[idx] == HF_FREE
      bAvail := TRUE
      quit

PRI fl_new_handle(p_filename) : handle | status
' Allocate a unified handle and buffer, configure for Flash use.
' Adapted from flash_fs.spin2 new_handle() for unified handle pool.
' Buffer is assigned from the pool; if exhausted, handle is freed.
'
' @param p_filename - address of filename zstring
' @returns handle - handle index, E_FLASH_NO_HANDLE, or E_FLASH_NO_BUFFER
' @local status - Operation status code

  handle := allocateHandle()
  if handle < 0
    handle := fl_set_error(E_FLASH_NO_HANDLE)

  ' Attach a buffer from the pool
  else
    status := fl_alloc_buffer(handle)
    if status <> SUCCESS
      freeHandle(handle)
      handle := fl_set_error(E_FLASH_NO_BUFFER)

    ' Mark as Flash device handle with read flag (caller overrides fl_hStatus)
    else
      h_device[handle] := DEV_FLASH
      h_flags[handle] := HF_READ

      ' Copy filename into Flash filename buffer
      bytefill(@fl_hFilename + handle * FL_FILENAME_SIZE, 0, FL_FILENAME_SIZE)
      strcopy(@fl_hFilename + handle * FL_FILENAME_SIZE, p_filename, FL_FILENAME_SIZE - 1)

PRI fl_free_handle(handle)
' Release a Flash handle back to the unified pool.
' Releases buffer back to pool, clears Flash-specific state, calls freeHandle().
'
' @param handle - handle to release

  fl_free_buffer(handle)
  fl_hStatus[handle] := 0
  fl_hHeadBlockID[handle] := FL_NOT_VALID
  fl_hChainBlockID[handle] := 0
  fl_hChainBlockAddr[handle] := 0
  fl_hChainLifeCycle[handle] := 0
  fl_hModified[handle] := 0
  fl_hEndPtr[handle] := 0
  fl_hSeekPtr[handle] := FL_NOT_ENABLED
  fl_hSeekFileOffset[handle] := 0
  fl_hCircularLength[handle] := 0
  freeHandle(handle)


CON ' ---- Flash File Operations ----
    ' FLASH FILE OPERATIONS
    ' =============================================================================
PRI fl_build_head_block(pBuff, p_filename, head_block_id)
' Initialize empty block with control information for a new file.
' Port of flash_fs.spin2 build_head_block().
'
' @param pBuff - address of block buffer in RAM
' @param p_filename - address of filename zstring
' @param head_block_id - the head block ID for this new file

  bytefill(pBuff, $FF, BLOCK_SIZE)
  long[pBuff].[1..0] := %00                                                    ' set head/last
  long[pBuff].[19..8] := head_block_id                                         ' set head block ID
  long[pBuff][1].[11..0] := $000                                               ' clear data offset
  long[pBuff][1].[31..12] := fl_filename_crc(p_filename)                       ' set filename CRC
  bytefill(pBuff + $008, $E5, FL_FILENAME_SIZE)                                ' erase filename portion
  strcopy(pBuff + $008, p_filename, FL_FILENAME_SIZE - 1)                      ' set filename

PRI fl_is_file_open(p_filename, open_mode_bits) : is_open | handle
' Return true if named file is open in the specified mode.
' Port of flash_fs.spin2 is_file_open().
'
' @param p_filename - address of filename zstring
' @param open_mode_bits - combination of FL_H_READ, FL_H_WRITE, etc.
' @returns is_open - TRUE if file is open, FALSE otherwise
' @local handle - File/directory handle

  repeat MAX_OPEN_FILES with handle
    if fl_hStatus[handle] & open_mode_bits
      if strcomp(@fl_hFilename + handle * FL_FILENAME_SIZE, p_filename)
        is_open := true

PRI fl_exists_no_lock(p_filename) : bExists
' Determine if named file exists (internal, no lock needed in worker cog).
' Port of flash_fs.spin2 exists_no_lock().
'
' @param p_filename - address of filename zstring
' @returns bExists - TRUE if file exists

  bExists := fl_get_file_head_signature(p_filename) ? true : false

PRI fl_blocks_free() : count | block_address
' Return count of free blocks in Flash filesystem.
' Port of flash_fs.spin2 blocks_free().
'
' @returns count - number of B_FREE blocks
' @local block_address - Physical Flash block address

  repeat FL_BLOCKS with block_address
    ifnot field[fl_BlockState][block_address]
      count++

PRI fl_available_blocks() : bAvail | blk8Idx
' Return true if there are any available block IDs.
' Port of flash_fs.spin2 available_blocks().
'
' @returns bAvail - TRUE if blocks are available for write
' @local blk8Idx - Block index within 8-block group

  bAvail := false
  repeat FL_FLAGS_SIZE with blk8Idx
    if BYTE[@fl_IDValids][blk8Idx] <> $FF
      bAvail := true
      quit

PRI fl_next_available_block_id() : block_id | possible_block_id
' Get next available block ID.
' Port of flash_fs.spin2 next_available_block_id().
'
' @returns block_id - next free ID, or E_FLASH_DRIVE_FULL
' @local possible_block_id - Candidate block ID during allocation scan

  block_id := E_FLASH_DRIVE_FULL
  repeat FL_BLOCKS with possible_block_id
    ifnot field[fl_IDValid][possible_block_id]~~
      block_id := possible_block_id
      quit

  if block_id < 0
    fl_set_error(block_id)

PRI fl_start_write(handle, open_mode, head_block_id, head_cycle) | block_address
' Configure file handle for FL_H_WRITE or FL_H_APPEND.
' Port of flash_fs.spin2 start_write().
'
' @param handle - handle to configure
' @param open_mode - desired open mode
' @param head_block_id - head block ID for the file
' @param head_cycle - lifecycle bits for head block
' @local block_address - Physical Flash block address

  fl_build_head_block(fl_buffer_pointer(handle), fl_filename_pointer(handle), head_block_id)

  fl_hStatus[handle] := open_mode
  fl_hHeadBlockID[handle] := head_block_id
  fl_hChainBlockID[handle] := head_block_id
  fl_hChainLifeCycle[handle] := head_cycle
  fl_hEndPtr[handle] := $088

PRI fl_is_old_format_file_head(block_address, pBlockBuffer) : oldFormatStatus | fnmCrc32, possOldCRC
' Check if block is an old-format (CRC32) file head.
' Port of flash_fs.spin2 is_old_format_file_head().
'
' @param block_address - address of block to check
' @param pBlockBuffer - buffer to receive filename data
' @returns oldFormatStatus - TRUE if old format
' @local fnmCrc32 - Filename CRC32 for Flash file identification
' @local possOldCRC - Possible old-format filename CRC for comparison

  fl_read_block_addr(block_address, @possOldCRC, $004, $007)
  fl_read_block_addr(block_address, pBlockBuffer, $008, $087)
  fnmCrc32 := getcrc(pBlockBuffer, $AD0424F3 rev 31, strsize(pBlockBuffer) + 1)
  oldFormatStatus := possOldCRC == fnmCrc32

' --- Step 4: Block-Chain Read Helpers ---------------------------------------

PRI fl_get_file_head_signature(p_filename) : foundSignature | tmpFilenameCRC, block_address, signature[2], bIsOldFmt
' Look up file by name and return block state bits of file's head block.
' Port of flash_fs.spin2 get_file_head_signature().
'
' @param p_filename - address of filename zstring
' @returns foundSignature - first long of head block (non-zero=found), 0 if not found
' @local tmpFilenameCRC - Temporary filename CRC for comparison
' @local block_address - Physical Flash block address
' @local signature - Block header signature (type + CRC + filename CRC)
' @local bIsOldFmt - TRUE if old-format file head block

  tmpFilenameCRC := fl_filename_crc(p_filename)

  repeat FL_BLOCKS with block_address
    if field[fl_BlockState][block_address] == B_HEAD
      fl_read_block_addr(block_address, @signature, $000, $007)
      if signature[1].[31..12] == tmpFilenameCRC
        fl_read_block_addr(block_address, @fl_tmpBlockBuff, $008, $087)
        if strcomp(p_filename, @fl_tmpBlockBuff)
          foundSignature := signature
          quit
      else
        bIsOldFmt := fl_is_old_format_file_head(block_address, @fl_tmpBlockBuff)
        if bIsOldFmt
          if strcomp(p_filename, @fl_tmpBlockBuff)
            foundSignature := signature
            quit

  if foundSignature <> 0
    foundSignature.[2] := bIsOldFmt ? 0 : 1

PRI fl_TEST_count_file_bytes(p_filename) : bytes_used, bytes_free, block_count | signature
' Return file statistics by filename (used by test utilities).
' Port of flash_fs.spin2 TEST_count_file_bytes().
'
' @param p_filename - pointer to filename string
' @returns bytes_used - bytes written (or E_FILE_NOT_FOUND)
' @returns bytes_free - unused bytes in last block
' @returns block_count - total blocks allocated
' @local signature - Block header signature (type + CRC + filename CRC)

  ifnot flash_mounted
    bytes_used := E_NOT_MOUNTED
    bytes_free := 0
    block_count := 0

  else
    if signature := fl_get_file_head_signature(p_filename)
      bytes_used, bytes_free, block_count := fl_count_file_bytes(field[fl_IDToBlock][signature.[19..8]])
    else
      bytes_used := E_FILE_NOT_FOUND

PRI fl_count_file_bytes(block_address) : bytes_used, bytes_free, block_count | signature
' Return information about a file: bytes used, bytes free, block count.
' Port of flash_fs.spin2 count_file_bytes().
'
' @param block_address - address of first block of file
' @returns bytes_used - bytes written to file
' @returns bytes_free - bytes allocated but not written (in last block)
' @returns block_count - number of blocks allocated
' @local signature - Block header signature (type + CRC + filename CRC)

  if block_address <> FL_NOT_VALID
    repeat
      fl_read_block_addr(block_address, @signature, $000, $003)
      block_count++
      case signature.[1..0]
        %00:                                                                    ' head/last
          bytes_used := signature.[31..20] - $088
          bytes_free := $FFC - signature.[31..20]
          quit
        %01:                                                                    ' head/more
          bytes_used := $FFC - $088
        %10:                                                                    ' body/last
          bytes_used += signature.[31..20] - $004
          bytes_free := $FFC - signature.[31..20]
          quit
        %11:                                                                    ' body/more
          bytes_used += $FFC - $004
      block_address := field[fl_IDToBlock][signature.[31..20]]

PRI fl_count_file_bytes_id(block_id) : byteCount
' Return file size in bytes given head block ID.
' Port of flash_fs.spin2 count_file_bytes_id().
'
' @param block_id - head block ID
' @returns byteCount - file size in bytes

  _, _, byteCount := fl_locate_file_byte(block_id, $FFFFFF)

PRI fl_locate_file_byte(block_id, file_position) : rID, rBlockOfs, rLocation | dataOffset, signature, currOfs, srtOfs, endOfs, fnmCrc32, bIsOldFmt
' Locate position within file's block chain.
' Port of flash_fs.spin2 locate_file_byte().
'
' @param block_id - head block ID of file
' @param file_position - byte offset from beginning of file
' @returns rID - block ID containing desired location
' @returns rBlockOfs - offset into block
' @returns rLocation - location within entire file
' @local dataOffset - Byte offset within Flash block data area
' @local signature - Block header signature (type + CRC + filename CRC)
' @local currOfs - Current offset in Flash block data area
' @local srtOfs - Start offset in Flash block data area
' @local endOfs - End offset in Flash block data area
' @local fnmCrc32 - Filename CRC32 for Flash file identification
' @local bIsOldFmt - TRUE if old-format file head block

  file_position := file_position #> 0 <# $FFFFFF

  bIsOldFmt := fl_is_old_format_file_head(field[fl_IDToBlock][block_id], @fl_tmpBlockBuff)
  if not bIsOldFmt
    fl_read_block_id(block_id, @dataOffset, $004, $005)
    currOfs -= dataOffset.[11..0]

  repeat
    fl_read_block_id(block_id, @signature, $000, $003)
    srtOfs := signature.[1] ? $004 : $088
    endOfs := signature.[0] ? $FFC : signature.[31..20]
    if file_position >= currOfs and file_position < currOfs + endOfs - srtOfs
      rID := block_id
      rBlockOfs := file_position - currOfs + srtOfs
      rLocation := file_position
      quit
    else
      currOfs += endOfs - srtOfs
      ifnot signature.[0]
        rID := block_id
        rBlockOfs := endOfs
        rLocation := currOfs
        quit
      else
        block_id := signature.[31..20]

PRI fl_start_modify(handle, open_mode, head_block_id, file_position, bFileExists) | block_id, pBuff
' Configure file handle for FL_H_APPEND or FL_H_READWRITE.
' Port of flash_fs.spin2 start_modify().
'
' @param handle - handle to configure
' @param open_mode - desired open mode
' @param head_block_id - head block ID
' @param file_position - position to start at
' @param bFileExists - TRUE if file already exists
' @local block_id - Logical Flash block ID
' @local pBuff - Flash block buffer pointer

  pBuff := fl_buffer_pointer(handle)
  if bFileExists
    block_id, fl_hEndPtr[handle], fl_hSeekFileOffset[handle] := fl_locate_file_byte(head_block_id, file_position)
    fl_read_block_id(block_id, pBuff, $000, $FFF)
    if open_mode == FL_H_READWRITE
      fl_hSeekPtr[handle] := fl_hEndPtr[handle]
  else
    fl_hSeekPtr[handle] := fl_hEndPtr[handle] := $088
    fl_hSeekFileOffset[handle] := 0

  fl_hStatus[handle] := open_mode
  fl_hHeadBlockID[handle] := head_block_id
  fl_hChainBlockID[handle] := block_id
  fl_hChainLifeCycle[handle] := fl_next_active_cycle(long[pBuff].[7..5])

PRI fl_seek_no_locks(handle, file_position) | pBuff, block_id, endPtr, fileOffset
' Seek file to new position (internal, no lock).
' Port of flash_fs.spin2 seek_no_locks().
'
' @param handle - handle to open file
' @param file_position - desired file position
' @local pBuff - Flash block buffer pointer
' @local block_id - Logical Flash block ID
' @local endPtr - End-of-data pointer within Flash block buffer
' @local fileOffset - Byte offset within Flash file

  pBuff := fl_buffer_pointer(handle)
  block_id, endPtr, fileOffset := fl_locate_file_byte(fl_hHeadBlockID[handle], file_position)
  if fl_hStatus[handle] & FL_H_MODIFY
    if block_id <> long[pBuff].[19..8]
      if fl_hModified[handle]~
        fl_rewrite_block(handle)

  fl_hSeekFileOffset[handle] := fileOffset
  fl_hSeekPtr[handle] := fl_hEndPtr[handle] := endPtr
  fl_read_block_id(block_id, pBuff, $000, $FFF)

' --- Step 5: Write Helpers --------------------------------------------------

PRI fl_next_block_address() : block_address | blockFreeCount, freeBlockAddress, freeIndex, next_cycle_bits
' Return address of next block to write to (with wear-leveling).
' Port of flash_fs.spin2 next_block_address().
'
' @returns block_address - block address, or E_FLASH_DRIVE_FULL
' @local blockFreeCount - Count of free blocks scanned
' @local freeBlockAddress - Address of available free block
' @local freeIndex - Index into free block scan
' @local next_cycle_bits - Cycle bits for next Flash block generation

  ifnot blockFreeCount := fl_blocks_free()
    block_address := fl_set_error(E_FLASH_DRIVE_FULL)

  else
    repeat
      block_address := abs getrnd() // FL_BLOCKS
    until field[fl_BlockState][block_address] <> B_TEMP

    if field[fl_BlockState][block_address] == B_FREE
      field[fl_BlockState][block_address] := B_TEMP

    ' Block is HEAD or BODY -- must evict it
    else
      freeIndex := abs getrnd() // blockFreeCount
      repeat FL_BLOCKS with freeBlockAddress
        ifnot field[fl_BlockState][freeBlockAddress]
          ifnot freeIndex--
            quit

      fl_read_block_addr(block_address, @fl_tmpBlockBuff, $000, $FFF)
      next_cycle_bits := fl_next_active_cycle(LONG[@fl_tmpBlockBuff].[7..5])
      fl_program_block(freeBlockAddress, @fl_tmpBlockBuff, next_cycle_bits)
      fl_activate_block(freeBlockAddress, next_cycle_bits)
      fl_cancel_block(block_address)

      field[fl_IDToBlock][LONG[@fl_tmpBlockBuff].[19..8]] := freeBlockAddress
      field[fl_BlockState][freeBlockAddress] := field[fl_BlockState][block_address]\B_TEMP

PRI fl_write_block(handle, NextID_EndPtr) | pBuff, block_id, block_address
' Write current block in buffer to next available block address.
' Port of flash_fs.spin2 write_block().
'
' @param handle - handle to file open for write
' @param NextID_EndPtr - next block ID or end-of-data pointer
' @local pBuff - Flash block buffer pointer
' @local block_id - Logical Flash block ID
' @local block_address - Physical Flash block address

  pBuff := fl_buffer_pointer(handle)
  long[pBuff].[31..20] := NextID_EndPtr
  block_id := long[pBuff].[19..8]

  block_address := fl_next_block_address()

  if fl_showRTdebug
    debug[CH_FL_BLOCK]("* fl_wr_block() ", uhex_word_(block_address), " id=", udec_(block_id), " nxt=", uhex_word_(NextID_EndPtr))

  if block_id == fl_hChainBlockID[handle]
    fl_program_block(block_address, pBuff, fl_hChainLifeCycle[handle])
    fl_hChainBlockAddr[handle] := block_address
  else
    fl_program_block(block_address, pBuff, %011)
    fl_activate_block(block_address, %011)
    field[fl_BlockState][block_address] := B_BODY
    field[fl_IDToBlock][block_id] := block_address

PRI fl_rewrite_block(handle) | pBuff, block_id, block_address, oldBlockAddress
' Write block over existing with new lifecycle (make-before-break).
' Port of flash_fs.spin2 rewrite_block().
'
' @param handle - handle to file open for read/modify/write
' @local pBuff - Flash block buffer pointer
' @local block_id - Logical Flash block ID
' @local block_address - Physical Flash block address
' @local oldBlockAddress - Previous block address before replacement

  pBuff := fl_buffer_pointer(handle)
  block_id := long[pBuff].[19..8]

  block_address := fl_next_block_address()
  fl_activate_updated_block(block_address, pBuff)

  oldBlockAddress := field[fl_IDToBlock][block_id]\block_address
  fl_cancel_block(oldBlockAddress)

  field[fl_BlockState][block_address] := field[fl_BlockState][oldBlockAddress]\B_FREE

PRI fl_delete_chain_from_id(block_id, EndID, delete_mode, KeepFirstIDValid) | block_address, signature
' Remove selected part of a file chain.
' Port of flash_fs.spin2 delete_chain_from_id().
'
' @param block_id - starting block ID
' @param EndID - ending block ID
' @param delete_mode - 0=to last, 1=through EndID, 2=before EndID
' @param KeepFirstIDValid - TRUE to keep first block ID valid
' @local block_address - Physical Flash block address
' @local signature - Block header signature (type + CRC + filename CRC)

  block_address := field[fl_IDToBlock][block_id]
  if fl_showRTdebug
    debug[CH_FL_BLOCK]("* fl_delChnFmID() [", uhex_word_(block_address), "] ", udec_(block_id), " end=", udec_(EndID), " mode=", udec_(delete_mode))

  repeat
    ifnot KeepFirstIDValid~
      field[fl_IDValid][block_id]~
    block_address := field[fl_IDToBlock][block_id]
    field[fl_BlockState][block_address] := B_FREE
    fl_cancel_block(block_address)
    fl_read_block_addr(block_address, @signature, $000, $003)
    block_id := signature.[31..20]
  while lookupz(delete_mode: signature.[0], ...
    signature.[19..8] <> EndID, ...
    block_id <> EndID)

PRI fl_froncate_file(head_block_id, limit_in_bytes) | size_in_bytes, block_address, new_head_block_id, block_offset, body_signature, delete_mode, prior_block_id, data_offset
' Remove leading block(s) from file exceeding circular size limit.
' Port of flash_fs.spin2 froncate_file().
'
' @param head_block_id - block ID of file
' @param limit_in_bytes - file size limit in bytes
' @local size_in_bytes - File size in bytes
' @local block_address - Physical Flash block address
' @local new_head_block_id - ID of new head block after froncate
' @local block_offset - Byte offset within a block
' @local body_signature - Signature for body blocks in chain
' @local delete_mode - TRUE if deleting blocks (froncate operation)
' @local prior_block_id - ID of previous block in chain
' @local data_offset - Byte offset into block data area

  size_in_bytes := fl_count_file_bytes_id(head_block_id)

  if size_in_bytes > limit_in_bytes

    block_address := fl_next_block_address()

    new_head_block_id, block_offset, _ := fl_locate_file_byte(head_block_id, size_in_bytes - limit_in_bytes)
    if fl_showRTdebug
      debug[CH_FL_CIRC]("* fl_froncate(id=", udec_(head_block_id), ", ", udec_(limit_in_bytes), ") ", udec_(size_in_bytes), " new=", udec_(new_head_block_id), " ofs=", uhex_word_(block_offset))

    if block_offset > $88
      fl_read_block_id(new_head_block_id, @body_signature, $000, $003)
      fl_read_block_id(new_head_block_id, @fl_tmpBlockBuff + $88, $088, $FFF)
      data_offset := block_offset - $088
    else
      prior_block_id := head_block_id
      repeat
        fl_read_block_id(prior_block_id, @body_signature, $000, $003)
        if body_signature.[0] == 1
          if body_signature.[31..20] <> new_head_block_id
            prior_block_id := body_signature.[31..20]
          else
            quit
        else
          quit
      if fl_showRTdebug
        debug[CH_FL_CIRC]("* fl_froncate AWAKEN PRIOR HEAD ", udec_(prior_block_id))
      fl_read_block_id(prior_block_id, @body_signature, $000, $003)
      fl_read_block_id(prior_block_id, @fl_tmpBlockBuff + $88, $088, $FFF)
      data_offset := block_offset + 3956 - 4

    fl_read_block_id(head_block_id, @fl_tmpBlockBuff, $000, $087)
    LONG[@fl_tmpBlockBuff].[0] := body_signature.[0]
    LONG[@fl_tmpBlockBuff].[31..20] := body_signature.[31..20]
    LONG[@fl_tmpBlockBuff][1].[11..0] := data_offset
    delete_mode := 1

    fl_activate_updated_block(block_address, @fl_tmpBlockBuff)

    fl_delete_chain_from_id(head_block_id, body_signature.[19..8], delete_mode, True)

    field[fl_IDToBlock][head_block_id] := block_address
    field[fl_BlockState][block_address] := B_HEAD

' --- Step 6: Core I/O Engine -----------------------------------------------

PRI fl_rd_byte_no_locks(handle) : byte_value | pBuff, signature, isSeeking, endPtr
' Read next byte from Flash file.
' Port of flash_fs.spin2 rd_byte_no_locks().
'
' @param handle - handle to file open for read
' @returns byte_value - byte [0-255] or negative error code
' @local pBuff - Flash block buffer pointer
' @local signature - Block header signature (type + CRC + filename CRC)
' @local isSeeking - TRUE if in seek mode (not sequential read/write)
' @local endPtr - End-of-data pointer within Flash block buffer

  isSeeking := (fl_hSeekPtr[handle] <> FL_NOT_ENABLED) ? true : false
  endPtr := isSeeking ? fl_hSeekPtr[handle] : fl_hEndPtr[handle]

  pBuff := fl_buffer_pointer(handle)
  signature := LONG[pBuff]

  case fl_hStatus[handle]
    FL_H_READ, FL_H_READWRITE:
      ifnot signature.[0]
        if endPtr == LONG[pBuff].[31..20]
          byte_value := fl_set_error(E_END_OF_FILE)
      else
        if endPtr == $FFC
          if fl_hStatus[handle] & FL_H_MODIFY
            if fl_hModified[handle]~
              fl_rewrite_block(handle)
          fl_read_block_addr(field[fl_IDToBlock][signature.[31..20]], pBuff, $000, $FFF)
          endPtr := $004

    other:
      byte_value := fl_set_error(E_FLASH_FILE_MODE)

  if byte_value >= 0
    byte_value := BYTE[pBuff][endPtr++]
    if isSeeking
      fl_hSeekPtr[handle] := endPtr
      fl_hSeekFileOffset[handle]++
    else
      fl_hEndPtr[handle] := endPtr

PRI fl_wr_byte_no_locks(handle, byte_value) : status | pBuff, nextBlockID, isSeeking, endPtr
' Write a byte to a Flash file open for write.
' Port of flash_fs.spin2 wr_byte_no_locks().
'
' @param handle - handle to file open for write
' @param byte_value - value to write
' @returns status - SUCCESS or error code
' @local pBuff - Flash block buffer pointer
' @local nextBlockID - ID of next block in Flash file chain
' @local isSeeking - TRUE if in seek mode (not sequential read/write)
' @local endPtr - End-of-data pointer within Flash block buffer

  isSeeking := (fl_hSeekPtr[handle] <> FL_NOT_ENABLED) ? true : false
  endPtr := isSeeking ? fl_hSeekPtr[handle] : fl_hEndPtr[handle]

  pBuff := fl_buffer_pointer(handle)
  status := SUCCESS

  case fl_hStatus[handle]
    FL_H_WRITE, FL_H_APPEND:
      if endPtr == $FFC
        long[pBuff].[0]~~
        nextBlockID := fl_next_available_block_id()
        fl_write_block(handle, nextBlockID)
        bytefill(pBuff, $FF, BLOCK_SIZE)
        long[pBuff].[0]~
        long[pBuff].[19..8] := nextBlockID
        endPtr := $004

    FL_H_READWRITE:
      if endPtr == $FFC
        if fl_hModified[handle]~
          fl_rewrite_block(handle)
        fl_read_block_id(long[pBuff].[31..20], pBuff, $000, $FFF)
        endPtr := $004

    other:
      status := E_FLASH_FILE_MODE

  if status == SUCCESS
    fl_hModified[handle]~~
    byte[pBuff][endPtr++] := byte_value
    if isSeeking
      fl_hSeekPtr[handle] := endPtr
      fl_hSeekFileOffset[handle]++
    else
      fl_hEndPtr[handle] := endPtr

PRI fl_rd_str(handle, p_str, count) : bytes_read | byteIndex, readValue
' Read zero-terminated string from Flash file.
' Port of flash_fs.spin2 rd_str().
'
' @param handle - handle to file open for read
' @param p_str - destination buffer in hub RAM
' @param count - max bytes including terminator
' @returns bytes_read - string length (not including terminator), or negative error
' @local byteIndex - Current byte index in read/write loop
' @local readValue - Byte value read from Flash file

  bytefill(p_str, 0, count)
  bytes_read := 0

  repeat count with byteIndex
    readValue := fl_rd_byte_no_locks(handle)
    if readValue < 0
      if readValue == E_END_OF_FILE
        if byteIndex == 0
          bytes_read := readValue
        else
          BYTE[p_str][byteIndex] := 0
          fl_errorCode := E_FLASH_INCOMPLETE_STR
      else
        bytes_read := readValue
      quit
    else
      if byteIndex == count - 1 and readValue <> 0
        BYTE[p_str][byteIndex] := 0
        fl_errorCode := E_FLASH_TRUNCATED_STR
        quit
      else
        BYTE[p_str][byteIndex] := readValue
        if readValue == 0
          quit
        else
          bytes_read++

PRI fl_file_size_unused(p_filename) : size_unused | signature
' Get count of unused bytes in last allocated block of a Flash file.
' Port of flash_fs.spin2 file_size_unused().
'
' @param p_filename - pointer to filename string
' @returns size_unused - unused bytes, or negative error
' @local signature - Block header signature (type + CRC + filename CRC)

  ifnot flash_mounted
    size_unused := E_NOT_MOUNTED

  else
    if signature := fl_get_file_head_signature(p_filename)
      _, size_unused, _ := fl_count_file_bytes(field[fl_IDToBlock][signature.[19..8]])
    else
      size_unused := E_FILE_NOT_FOUND

PRI fl_close_no_lock(handle) : status | open_mode, chain_block_address, head_block_id, chain_block_id, chainState
' Close an open Flash file (internal, no lock).
' Port of flash_fs.spin2 close_no_lock().
'
' @param handle - handle to close
' @returns status - SUCCESS or error code
' @local open_mode - File open mode (read/write/append/readwrite)
' @local chain_block_address - Physical address of current chain block
' @local head_block_id - ID of file's head block
' @local chain_block_id - Logical ID of current chain block
' @local chainState - State machine for chain traversal

  fl_errorCode := SUCCESS

  if fl_hModified[handle]
    open_mode := fl_hStatus[handle]
    case open_mode
      FL_H_WRITE, FL_H_APPEND:
        fl_write_block(handle, fl_hEndPtr[handle])

        head_block_id := fl_hHeadBlockID[handle]
        chain_block_id := fl_hChainBlockID[handle]
        chain_block_address := fl_hChainBlockAddr[handle]
        chainState := chain_block_id == head_block_id ? B_HEAD : B_BODY

        fl_activate_block(chain_block_address, fl_hChainLifeCycle[handle])

        if open_mode & FL_H_FORK
          fl_delete_chain_from_id(chain_block_id, 0, 0, True)

        field[fl_BlockState][chain_block_address] := chainState
        field[fl_IDToBlock][chain_block_id] := chain_block_address

        if fl_hCircularLength[handle]
          fl_froncate_file(head_block_id, fl_hCircularLength[handle])

      FL_H_READWRITE:
        if fl_hModified[handle]~
          fl_rewrite_block(handle)

  fl_hEndPtr[handle] := 0
  fl_hSeekPtr[handle] := FL_NOT_ENABLED
  fl_hSeekFileOffset[handle] := 0
  fl_hChainBlockID[handle] := 0
  fl_hChainBlockAddr[handle] := 0
  fl_hChainLifeCycle[handle] := 0
  fl_hModified[handle]~

PRI fl_finish_open_read(p_filename, max_file_length) : handle | signature, block_id, lenInBytes, offsetInBytes, bNeedSeek
' Open a Flash file for reading.
' Port of flash_fs.spin2 finish_open_read().
'
' @param p_filename - address of filename zstring
' @param max_file_length - max circular length (0 for normal)
' @returns handle - handle or negative error code
' @local signature - Block header signature (type + CRC + filename CRC)
' @local block_id - Logical Flash block ID
' @local lenInBytes - File length in bytes
' @local offsetInBytes - Current read offset in bytes
' @local bNeedSeek - TRUE if seek is needed before read

  ifnot signature := fl_get_file_head_signature(p_filename)
    handle := fl_set_error(E_FILE_NOT_FOUND)

  else
    bNeedSeek := true
    handle := fl_new_handle(p_filename)
    if handle < 0
    else
      fl_hCircularLength[handle] := max_file_length
      fl_hStatus[handle] := FL_H_READ
      block_id := signature.[19..8]
      fl_hHeadBlockID[handle] := block_id

      if max_file_length > 0 and signature.[2] == 0
        lenInBytes := fl_count_file_bytes_id(block_id)
        if fl_showRTdebug
          debug[CH_FL_CIRC]("*** OLD format circular read! ", udec_(lenInBytes), " max=", udec_(max_file_length))
        if lenInBytes > max_file_length
          bNeedSeek := false
          offsetInBytes := lenInBytes - max_file_length
          block_id, fl_hEndPtr[handle], _ := fl_locate_file_byte(block_id, offsetInBytes)
          fl_read_block_id(block_id, fl_buffer_pointer(handle), $000, $FFF)
      if bNeedSeek
        fl_seek_no_locks(handle, 0)

PRI fl_finish_open_write(p_filename, max_file_length) : handle | signature, ptr
' Open a Flash file for writing (overwrites existing).
' Port of flash_fs.spin2 finish_open_write().
'
' @param p_filename - address of filename zstring
' @param max_file_length - max circular length (0 for normal)
' @returns handle - handle or negative error code
' @local signature - Block header signature (type + CRC + filename CRC)
' @local ptr - Working pointer

  handle := fl_new_handle(p_filename)
  if handle < 0
  else
    fl_hCircularLength[handle] := max_file_length

    if signature := fl_get_file_head_signature(p_filename)
      fl_start_write(handle, FL_H_APPEND, signature.[19..8], fl_next_active_cycle(signature.[7..5]))
    else
      fl_start_write(handle, FL_H_WRITE, fl_next_available_block_id(), %011)

PRI fl_finish_open_append(p_filename, max_file_length) : handle | signature, end_block_address, endPtr, bytes_used, ptr
' Open a Flash file for append (file must exist).
' Port of flash_fs.spin2 finish_open_append().
'
' @param p_filename - address of filename zstring
' @param max_file_length - max circular length (0 for normal)
' @returns handle - handle or negative error code
' @local signature - Block header signature (type + CRC + filename CRC)
' @local end_block_address - Address of last block in file
' @local endPtr - End-of-data pointer within Flash block buffer
' @local bytes_used - Number of data bytes used in block
' @local ptr - Working pointer

  handle := fl_new_handle(p_filename)
  if handle < 0
  else
    fl_hCircularLength[handle] := max_file_length

    if signature := fl_get_file_head_signature(p_filename)
      fl_start_modify(handle, FL_H_APPEND, signature.[19..8], $FFFFFF, true)
    else
      fl_start_write(handle, FL_H_WRITE, fl_next_available_block_id(), %011)

PRI fl_finish_open_readwrite(p_filename) : handle | signature, head_block_id
' Open an existing Flash file for read/modify/write.
' Port of flash_fs.spin2 finish_open_readwrite().
'
' @param p_filename - address of filename zstring
' @returns handle - handle or negative error code
' @local signature - Block header signature (type + CRC + filename CRC)
' @local head_block_id - ID of file's head block

  handle := fl_new_handle(p_filename)
  if handle < 0

  else
    if signature := fl_get_file_head_signature(p_filename)
      fl_start_modify(handle, FL_H_READWRITE, signature.[19..8], 0, true)
    else
      head_block_id := fl_next_available_block_id()
      fl_build_head_block(fl_buffer_pointer(handle), fl_filename_pointer(handle), head_block_id)
      fl_start_modify(handle, FL_H_READWRITE, head_block_id, 0, false)

' --- Step 7: Top-Level Flash Operations ------------------------------------

PRI fl_open(p_filename, mode) : handle | findings, bFileExists
' Open Flash file in mode.
' Port of flash_fs.spin2 open() -- no mount check, no lock.
'
' @param p_filename - address of filename zstring
' @param mode - FILEMODE_READ, FILEMODE_WRITE, FILEMODE_APPEND, etc.
' @returns handle - handle or negative error code
' @local findings - Search result flags from fl_exists_no_lock()
' @local bFileExists - TRUE if file already exists

  fl_errorCode := SUCCESS
  handle := FL_NOT_VALID

  ' Check for available handle BEFORE other checks (matches reference driver order)
  ifnot fl_has_free_handle()
    handle := fl_set_error(E_FLASH_NO_HANDLE)

  else
    case mode
      "r", "R":
      "a", "A", "w", "W", FILEMODE_READ_EXTENDED, FILEMODE_WRITE_EXTENDED:
        ifnot fl_blocks_free()
          handle := fl_set_error(E_FLASH_DRIVE_FULL)
      other:
        handle := fl_set_error(E_FLASH_FILE_MODE)

    if handle == FL_NOT_VALID
      bFileExists := fl_exists_no_lock(p_filename)

      case mode
        "r", "R", FILEMODE_READ_EXTENDED:
          ifnot bFileExists
            handle := fl_set_error(E_FILE_NOT_FOUND)

    if handle == FL_NOT_VALID and fl_is_file_open(p_filename, FL_H_READ_WRITE)
      handle := fl_set_error(E_FLASH_FILE_OPEN)

    elseif fl_errorCode <> SUCCESS
      handle := fl_errorCode

    else
      case mode
        "r", "R"  : handle := fl_finish_open_read(p_filename, 0)
        "w", "W"  : handle := fl_finish_open_write(p_filename, 0)
        "a", "A"  :
          if bFileExists
            handle := fl_finish_open_append(p_filename, 0)
          else
            handle := fl_finish_open_write(p_filename, 0)
        FILEMODE_READ_EXTENDED : handle := fl_finish_open_readwrite(p_filename)
        FILEMODE_WRITE_EXTENDED: handle := fl_finish_open_readwrite(p_filename)

      if handle < 0
        fl_set_error(handle)

PRI fl_open_circular(p_filename, mode, max_file_length) : handle | bFileExists
' Open Flash circular file.
' Port of flash_fs.spin2 open_circular() -- no mount check, no lock.
'
' @param p_filename - address of filename zstring
' @param mode - "r"/"R" or "a"/"A"
' @param max_file_length - max file size in bytes
' @returns handle - handle or negative error code
' @local bFileExists - TRUE if file already exists

  fl_errorCode := SUCCESS
  handle := FL_NOT_VALID

  if max_file_length < 1
    handle := fl_set_error(E_FLASH_BAD_FILE_LENGTH)

  else
    case mode
      "r", "R":
      "a", "A":
      other:
        handle := fl_set_error(E_FLASH_FILE_MODE)

    if fl_errorCode == SUCCESS
      ' Check for available handle BEFORE other checks (matches reference driver order)
      ifnot fl_has_free_handle()
        handle := fl_set_error(E_FLASH_NO_HANDLE)

      else
        bFileExists := fl_exists_no_lock(p_filename)

        case mode
          "r", "R":
            ifnot bFileExists
              handle := fl_set_error(E_FILE_NOT_FOUND)
          "a", "A":
            ifnot fl_blocks_free()
              handle := fl_set_error(E_FLASH_DRIVE_FULL)

        if handle == FL_NOT_VALID and fl_is_file_open(p_filename, FL_H_READ_WRITE)
          handle := fl_set_error(E_FLASH_FILE_OPEN)

        elseif fl_errorCode <> SUCCESS
          handle := fl_errorCode

        else
          case mode
            "a", "A":
              if bFileExists
                handle := fl_finish_open_append(p_filename, max_file_length)
              else
                handle := fl_finish_open_write(p_filename, max_file_length)
            "r", "R": handle := fl_finish_open_read(p_filename, max_file_length)

          if handle < 0
            fl_set_error(handle)

PRI fl_close(handle) : status
' Close a Flash file handle.
' Port of flash_fs.spin2 close() -- no mount check, no lock.
'
' @param handle - handle to close
' @returns status - SUCCESS or error code

  if handle < 0 or handle > MAX_OPEN_FILES - 1
    status := fl_set_error(E_FLASH_BAD_HANDLE)

  else
    status := fl_close_no_lock(handle)
    fl_hCircularLength[handle] := 0
    fl_hHeadBlockID[handle] := FL_NOT_VALID
    fl_hStatus[handle] := 0

    ' Release unified handle
    fl_free_handle(handle)

PRI fl_flush(handle) : status
' Flush pending Flash writes (close then reopen in append).
' Port of flash_fs.spin2 flush() -- no mount check, no lock.
'
' @param handle - handle to flush
' @returns status - SUCCESS or error code

  if handle < 0 or handle > MAX_OPEN_FILES - 1
    status := fl_set_error(E_FLASH_BAD_HANDLE)

  else
    fl_errorCode := SUCCESS

    case fl_hStatus[handle]
      FL_H_WRITE, FL_H_APPEND:
        fl_close_no_lock(handle)
        fl_start_modify(handle, FL_H_APPEND, fl_hHeadBlockID[handle], $FFFFFF, true)

      FL_H_READWRITE:
        if fl_hModified[handle]
          fl_rewrite_block(handle)

      other:
        fl_set_error(E_FLASH_FILE_MODE)

    fl_hModified[handle]~

    status := fl_errorCode

PRI fl_read(handle, p_buffer, count) : bytes_read | byteIndex, readValue, checkValue
' Read bytes from a Flash file.
' Port of flash_fs.spin2 read() -- no mount check, no lock.
'
' @param handle - handle to file open for reading
' @param p_buffer - destination buffer
' @param count - max bytes to read
' @returns bytes_read - bytes actually read
' @local byteIndex - Current byte index in read/write loop
' @local readValue - Byte value read from Flash file
' @local checkValue - Byte value read back for verification

  fl_errorCode := SUCCESS

  if (checkValue := fl_ensure_handle_mode(handle, FL_H_READ | FL_H_MODIFY)) < 0
    fl_set_error(checkValue)
    bytes_read := 0
  else
    bytes_read := 0
    repeat count with byteIndex
      if (readValue := fl_rd_byte_no_locks(handle)) < 0
        fl_set_error(readValue)
        quit
      else
        BYTE[p_buffer][byteIndex] := readValue
        bytes_read++

PRI fl_write(handle, p_buffer, count) : bytes_written | checkValue, byteIndex, wr_value, wr_status
' Write bytes to a Flash file.
' Port of flash_fs.spin2 write() -- no mount check, no lock.
'
' @param handle - handle to file open for writing
' @param p_buffer - source buffer
' @param count - bytes to write
' @returns bytes_written - bytes actually written
' @local checkValue - Byte value read back for verification
' @local byteIndex - Current byte index in read/write loop
' @local wr_value - Byte value being written
' @local wr_status - Write operation status code

  fl_errorCode := SUCCESS

  if (checkValue := fl_ensure_handle_mode(handle, FL_H_WRITE)) < 0
    bytes_written := fl_set_error(checkValue)
  else
    bytes_written := 0
    repeat count with byteIndex
      wr_value := BYTE[p_buffer][byteIndex]
      if (wr_status := fl_wr_byte_no_locks(handle, wr_value)) < 0
        fl_set_error(wr_status)
        if bytes_written == 0
          bytes_written := fl_errorCode
        quit
      else
        bytes_written++

PRI fl_seek(handle, position, whence) : end_position | file_length, file_position, block_id, pBuff
' Seek within a Flash file.
' Port of flash_fs.spin2 seek() -- no mount check, no lock.
'
' @param handle - handle to open file
' @param position - byte position or offset
' @param whence - SK_FILE_START or SK_CURRENT_POSN
' @returns end_position - resulting position or negative error code
' @local file_length - Total file length in bytes
' @local file_position - Current position within file
' @local block_id - Logical Flash block ID
' @local pBuff - Flash block buffer pointer

  if handle < 0 or handle > MAX_OPEN_FILES - 1
    end_position := fl_set_error(E_FLASH_BAD_HANDLE)
  elseif whence <> SK_FILE_START and whence <> SK_CURRENT_POSN
    end_position := fl_set_error(E_FLASH_BAD_SEEK_ARG)
  elseif whence == SK_FILE_START and position < 0
    end_position := fl_set_error(E_FLASH_FILE_SEEK)

  else
    case fl_hStatus[handle]
      FL_H_READ:
      FL_H_READWRITE:
      other:
        end_position := fl_set_error(E_FLASH_FILE_MODE)

    if end_position >= 0
      fl_errorCode := SUCCESS

      if whence == SK_FILE_START
        file_position := position
      else
        file_position := fl_hSeekPtr[handle] <> FL_NOT_ENABLED ? fl_hSeekFileOffset[handle] : fl_hEndPtr[handle]
        file_position += position

      file_length, _, _ := fl_count_file_bytes(field[fl_IDToBlock][fl_hHeadBlockID[handle]])

      if file_length > 0 and position == POSX
        file_position := file_length

      if file_length < 0
        end_position := fl_set_error(file_length)
      elseif fl_hCircularLength[handle] > 0 and (file_position < 0 or file_position > fl_hCircularLength[handle])
        end_position := fl_set_error(E_FLASH_FILE_SEEK)
      elseif file_position >= 0 and file_position <= file_length
        fl_seek_no_locks(handle, file_position)
        end_position := file_position
      else
        end_position := fl_set_error(E_FLASH_FILE_SEEK)

PRI fl_delete(p_filename) : status | signature
' Delete a Flash file.
' Port of flash_fs.spin2 delete() -- no mount check, no lock.
'
' @param p_filename - address of filename zstring
' @returns status - SUCCESS or error code
' @local signature - Block header signature (type + CRC + filename CRC)

  status := fl_errorCode := SUCCESS

  if fl_is_file_open(p_filename, FL_H_READ_WRITE)
    status := fl_set_error(E_FLASH_FILE_OPEN)

  elseifnot signature := fl_get_file_head_signature(p_filename)
    status := fl_set_error(E_FILE_NOT_FOUND)

  else
    fl_delete_chain_from_id(signature.[19..8], 0, 0, False)

PRI fl_rename(p_cur_filename, p_new_filename) : status | signature, new_block_address, cur_block_address, next_cycle_bits
' Rename a Flash file.
' Port of flash_fs.spin2 rename() -- no mount check, no lock.
'
' @param p_cur_filename - current filename
' @param p_new_filename - new filename
' @returns status - SUCCESS or error code
' @local signature - Block header signature (type + CRC + filename CRC)
' @local new_block_address - Address of newly allocated Flash block
' @local cur_block_address - Address of current Flash block
' @local next_cycle_bits - Cycle bits for next Flash block generation

  fl_errorCode := SUCCESS

  if fl_is_file_open(p_cur_filename, FL_H_READ_WRITE)
    status := fl_set_error(E_FLASH_FILE_OPEN)

  elseif fl_is_file_open(p_new_filename, FL_H_READ_WRITE)
    status := fl_set_error(E_FLASH_FILE_OPEN)

  elseifnot fl_available_blocks()
    status := fl_set_error(E_FLASH_DRIVE_FULL)

  elseif fl_get_file_head_signature(p_new_filename)
    status := fl_set_error(E_FLASH_FILE_EXISTS)

  elseifnot signature := fl_get_file_head_signature(p_cur_filename)
    status := fl_set_error(E_FILE_NOT_FOUND)

  else
    new_block_address := fl_next_block_address()
    cur_block_address := field[fl_IDToBlock][signature.[19..8]]

    fl_read_block_addr(cur_block_address, @fl_tmpBlockBuff, $000, $FFF)
    LONG[@fl_tmpBlockBuff][1].[31..12] := fl_filename_crc(p_new_filename)
    bytefill(@fl_tmpBlockBuff + $008, $E5, FL_FILENAME_SIZE)
    strcopy(@fl_tmpBlockBuff + $008, p_new_filename, FL_FILENAME_SIZE - 1)
    fl_activate_updated_block(new_block_address, @fl_tmpBlockBuff)
    fl_cancel_block(cur_block_address)

    field[fl_IDToBlock][signature.[19..8]] := new_block_address
    field[fl_BlockState][new_block_address] := B_HEAD
    field[fl_BlockState][cur_block_address] := B_FREE

PRI fl_exists(p_filename) : bExists
' Check if Flash file exists.
' Port of flash_fs.spin2 exists() -- no mount check, no lock.
'
' @param p_filename - address of filename zstring
' @returns bExists - TRUE if file exists

  fl_errorCode := SUCCESS
  bExists := fl_exists_no_lock(p_filename)

PRI fl_file_size(p_filename) : size_in_bytes | signature
' Get Flash file size by name.
' Port of flash_fs.spin2 file_size() -- no mount check, no lock.
'
' @param p_filename - address of filename zstring
' @returns size_in_bytes - file size or negative error code
' @local signature - Block header signature (type + CRC + filename CRC)

  fl_errorCode := SUCCESS

  if signature := fl_get_file_head_signature(p_filename)
    size_in_bytes, _, _ := fl_count_file_bytes(field[fl_IDToBlock][signature.[19..8]])
  else
    size_in_bytes := fl_set_error(E_FILE_NOT_FOUND)

PRI fl_stats() : used_blocks, free_blocks, file_count | block_address
' Get Flash filesystem statistics.
' Port of flash_fs.spin2 stats() -- no mount check, no lock.
'
' @returns used_blocks - blocks in use
' @returns free_blocks - free blocks
' @returns file_count - number of files
' @local block_address - Physical Flash block address

  fl_errorCode := SUCCESS

  used_blocks := 0
  free_blocks := 0
  file_count := 0

  repeat FL_BLOCKS with block_address
    case field[fl_BlockState][block_address]
      B_FREE: free_blocks++
      B_TEMP: used_blocks++
      B_HEAD: used_blocks++
              file_count++
      B_BODY: used_blocks++

PRI fl_directory(p_block_id, p_filename, p_file_size) : status | blockID, block_address, signature
' Get next Flash file entry for directory iteration.
' Port of flash_fs.spin2 directory() -- no mount check, no lock.
'
' @param p_block_id - pointer to current block ID (auto-advanced)
' @param p_filename - pointer to 128-byte filename buffer
' @param p_file_size - pointer to LONG receiving file size
' @returns status - SUCCESS or error code
' @local blockID - Logical block ID for Flash file chain
' @local block_address - Physical Flash block address
' @local signature - Block header signature (type + CRC + filename CRC)

  fl_errorCode := SUCCESS

  BYTE[p_filename][0] := 0

  repeat while LONG[p_block_id] < FL_BLOCKS
    blockID := LONG[p_block_id]++
    if field[fl_IDValid][blockID]
      block_address := field[fl_IDToBlock][blockID]
      if field[fl_BlockState][block_address] == B_HEAD
        fl_read_block_addr(block_address, p_filename, $008, $088)
        LONG[p_file_size], _, _ := fl_count_file_bytes(block_address)
        quit

PRI fl_create_file(p_filename, fill_value, byte_count) : status | signature, head_block_id, block_id, block_address, notHead, dataOffset, isLast, currOffset, NextID_EndPtr
' Create pre-allocated Flash file filled with specified value.
' Port of flash_fs.spin2 create_file() -- no mount check, no lock.
'
' @param p_filename - address of filename zstring
' @param fill_value - initial byte value
' @param byte_count - desired file length in bytes
' @returns status - SUCCESS or error code
' @local signature - Block header signature (type + CRC + filename CRC)
' @local head_block_id - ID of file's head block
' @local block_id - Logical Flash block ID
' @local block_address - Physical Flash block address
' @local notHead - TRUE if block is a body block (not head)
' @local dataOffset - Byte offset within Flash block data area
' @local isLast - TRUE if this is the last block in chain
' @local currOffset - Current byte offset in write operation
' @local NextID_EndPtr - Packed next-block-ID and end-pointer value

  fl_errorCode := SUCCESS

  if fl_is_file_open(p_filename, FL_H_READ_WRITE)
    status := fl_set_error(E_FLASH_FILE_OPEN)

  elseifnot fl_available_blocks()
    status := fl_set_error(E_FLASH_DRIVE_FULL)

  elseif signature := fl_get_file_head_signature(p_filename)
    status := fl_set_error(E_FLASH_FILE_EXISTS)

  else
    block_id := head_block_id := fl_next_available_block_id()

    repeat
      block_address := fl_next_block_address()
      ifnot notHead
        fl_build_head_block(@fl_tmpBlockBuff, p_filename, 0)
        dataOffset := $088
      else
        dataOffset := $004
      bytefill(@fl_tmpBlockBuff + dataOffset, fill_value, BLOCK_SIZE - dataOffset)
      if isLast := byte_count <= (currOffset += $FFC - dataOffset)
        NextID_EndPtr := byte_count - currOffset + $FFC
      else
        NextID_EndPtr := fl_next_available_block_id()
      LONG[@fl_tmpBlockBuff].[0] := !isLast
      LONG[@fl_tmpBlockBuff].[1] := notHead
      LONG[@fl_tmpBlockBuff].[19..8] := block_id
      LONG[@fl_tmpBlockBuff].[31..20] := NextID_EndPtr
      fl_program_block(block_address, @fl_tmpBlockBuff, %011)
      if notHead
        fl_activate_block(block_address, %011)
      field[fl_IDToBlock][block_id] := block_address
      field[fl_BlockState][block_address] := notHead ? B_BODY : B_HEAD
      block_id := NextID_EndPtr
      notHead := true
    until isLast

    fl_activate_block(field[fl_IDToBlock][head_block_id], %011)
CON ' ---- Public API - Multi-Cog Safe ----
    ' PUBLIC API - Multi-cog safe via worker cog
    ' All operations are serialized through send_command()
    ' ===========================================================================


CON ' ---- SD Directory and FAT Operations ----
    ' SD DIRECTORY AND FAT OPERATIONS
    ' =============================================================================
PRI searchDirectory(name_ptr) : found | p_temp, p_entry, idx, search_sec, jdx
' Search directory for a file/directory by name.
'
' @param name_ptr - Pointer to null-terminated path string
' @returns found - TRUE if found, FALSE otherwise
' @local p_temp - Pointer to temporary filename buffer
' @local p_entry - Pointer to current directory entry
' @local idx - Loop counter
' @local search_sec - Local directory sector for path resolution

  p_temp := @"FILENAMETXT"
  search_sec := cog_dir_sec[pb_caller]
  if byte[name_ptr] == "/"
    search_sec := root_sec
    name_ptr++
    found := true                                                                '  "/" alone resolves to root (loop won't run)
  n_sec := search_sec

  repeat until byte[name_ptr] == $00
    bytefill(@entry_buffer,0,32)
    idx := 0

    repeat until byte[name_ptr + idx] == "/" or byte[name_ptr + idx] == $00         '  advance idx up to "/" or null
      idx++
    bytemove(@entry_buffer,name_ptr,idx <# 12)                                    '  copy name into entry_buffer, max 12 characters
    name_ptr += idx                                                               '  advance ptr to "/" or null
    if byte[name_ptr] == "/"                                                    '  if "/"
      name_ptr++                                                                '   advance ptr to byte following "/"

    repeat idx from 0 to 11                                                       '  convert name to uppercase
      case BYTE[@entry_buffer][idx]
        "a".."z" : BYTE[@entry_buffer][idx] -= $20

    idx := 0                                                                      '  convert 8.3 filename into short filename
    if strcomp(@entry_buffer,string("..")) == 0                                 '  exception if changing directory to ".."
      repeat strsize(@entry_buffer) <# 9                                        '  search name for extension
        if BYTE[@entry_buffer][idx++] == "."                                       '  if extension found
          bytemove(@entry_buffer + 8,@entry_buffer + idx,3)                       '   move extension to byte 8
          bytefill(@entry_buffer + idx-1," ",9-idx)                                 '   fill space between name and extension
    bytefill(@entry_buffer + strsize(@entry_buffer)," ",12-strsize(@entry_buffer)) ' fill remaining space (in case extension < 3 characters)
    BYTE[@entry_buffer][DIR_ATTR_OFFSET] := $00                                  '  append null

    found := true                                                                '  assume found until proven otherwise
    idx := 0
    debug[CH_DIR]("  [searchDir] Starting search at n_sec=", udec_(n_sec), " for [", lstr_(@entry_buffer, 11), "]")
    if readSector(n_sec, BUF_DIR) < 0                                           '  read 1st sector of directory
      debug[CH_DIR]("  [searchDir] Directory read FAILED for sector ", udec_(n_sec))
      found := false
      quit                                                                        '  exit outer loop on read failure
    else
      debug[CH_DIR]("  [searchDir] After read: dir_buf[0]=[", lstr_(@dir_buf, FILENAME_83_LEN), "] dir_buf[32]=[", lstr_(@dir_buf + DIR_ENTRY_SIZE, FILENAME_83_LEN), "]")
      entry_address := 0
      repeat
        p_entry := @dir_buf + (idx & SECTOR_MASK)                                           '  locate entry in directory (FIXED precedence)
        bytemove(p_temp,p_entry,11)                                               '  copy short filename into p_temp
        byte[p_temp + DIR_ATTR_OFFSET] := 0                                        '  null terminate for comparison
        repeat jdx from 0 to FILENAME_83_LEN - 1                                                     '  uppercase on-disk entry for case-insensitive match
          case byte[p_temp + jdx]
            "a".."z" : byte[p_temp + jdx] -= $20
        if strcomp(@entry_buffer,p_temp)                                          '  if matching entry located
          entry_address := (n_sec << SECTOR_BITS) | (idx & SECTOR_MASK)                               '   store the byte-level address of the entry
          bytemove(@entry_buffer,p_entry,32)                                      '   copy entire entry into entry_buffer
          debug[CH_DIR]("  [searchDir] FOUND at idx=", udec_(idx), " firstCluster=", udec_(firstCluster()), " n_sec will be ", udec_(clus2sec(firstCluster())))
          if firstCluster() == 0                                                  '  exception if ".." points to root directory
            n_sec := clus2sec(2)                                                  '   root directory located in cluster 2
          else
            n_sec := clus2sec(firstCluster())                                     '   set n_sec to 1st sector of 1st cluster of file
          quit
        elseif byte[name_ptr] == $00                                              '  if end of path reached
          if (entry_address == 0) and (byte[p_temp] == $E5 or byte[p_temp] == $00) '  if entry_address not set, and 1st byte is $E5 or $00
            entry_address := (n_sec << SECTOR_BITS) | (idx & SECTOR_MASK)                             '    set entry_address to 1st unused entry (for newFile / newDirectory)
            debug[CH_DIR]("  [searchDir] Free slot at n_sec=", udec_(n_sec), " idx=", udec_(idx), " entry_address=$", uhex_(entry_address))

        if byte[p_temp] == $00                                                    '  entry not found in directory
          found := false
          quit
        else
          idx += 32                                                                   '  increment to next entry
          if idx & SECTOR_MASK == 0                                                           '  read new directory sector/cluster if needed
            readNextSector(BUF_DIR)
      if not found                                                                '  if inner loop ended without match
        quit                                                                      '   exit outer loop too

PRI firstCluster() : cluster_num
' Return the 1st cluster location of the currently opened file.
'
' @returns cluster_num - First cluster number (combined from entry bytes $14-$15 and $1A-$1B)

  cluster_num := dirEntStartClus(@entry_buffer)

PRI readFat(cluster) : p_fat_entry | contents, p_contents
' Read a FAT location and return a pointer to the location of that entry.
'
' @param cluster - Cluster number to look up
' @returns p_fat_entry - Pointer to FAT entry in fat_buf
' @local contents - (unused)
' @local p_contents - (unused)

  if readSector((cluster >> 7 + fat_sec), BUF_FAT) < 0                          '  128 entries in each FAT sector
    debug[CH_SECTOR]("  [readFat] FAT read FAILED for cluster ", udec_(cluster))
    p_fat_entry := @fat_buf  '  Return valid pointer but caller gets stale data
  else
    p_fat_entry := @fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)

PRI allocateCluster(cluster) : cluster_num | fat_idx, buf_idx, high_bits, startFatIdx, fatLimit, wrapped
' Search FAT for an empty cluster using next-fit allocation, allocate it, and return cluster number.
' If cluster parameter is non-zero, links the new cluster to that chain.
' Next-fit: scans from previous cluster+1 (or fsi_nxt_free for new chains), wraps to cluster 2 at end-of-FAT.
'
' @param cluster - Previous cluster to link (0 for new chain)
' @returns cluster_num - Newly allocated cluster number, or negative error code
' @local fat_idx - Current FAT byte index
' @local buf_idx - Index within FAT buffer
' @local high_bits - Preserved high 4 bits of FAT entry
' @local startFatIdx - Byte index where scan began (for wrap-around termination)
' @local fatLimit - End of FAT in bytes (sec_per_fat << SECTOR_BITS)
' @local wrapped - Boolean, TRUE after scan wraps from end-of-FAT back to cluster 2

  ' Next-fit: choose starting scan position
  if cluster > 0
    fat_idx := (cluster + 1) << FAT_ENTRY_SHIFT                                 ' Start after previous cluster
  elseif fsi_nxt_free <> $FFFF_FFFF and fsi_nxt_free >= ROOT_CLUSTER
    fat_idx := fsi_nxt_free << FAT_ENTRY_SHIFT                                  ' Use FSInfo hint for new chains
  else
    fat_idx := 8                                                                 ' Default: cluster 2

  fatLimit := sec_per_fat << SECTOR_BITS                                        ' End of FAT in bytes
  if fat_idx >= fatLimit                                                        ' Guard: if start is past end, wrap to cluster 2
    fat_idx := 8
  if test_max_clusters > 0 and (fat_idx >> FAT_ENTRY_SHIFT) >= test_max_clusters
    fat_idx := 8                                                                 ' Guard: if start is past test limit, wrap
  startFatIdx := fat_idx                                                       ' Remember where we started
  wrapped := FALSE

  if readSector(fat_sec + fat_idx >> SECTOR_BITS, BUF_FAT) < 0                  ' Pre-load FAT sector at starting position
    debug[CH_SECTOR]("  [allocateCluster] FAT pre-load FAILED")
    cluster_num := E_IO_ERROR
  else
    repeat
      if fat_idx & SECTOR_MASK == 0 and fat_idx > 0                             '  if at sector boundary (but not first iteration)
        if fat_idx >= fatLimit                                                  '    past end of FAT?
          if wrapped                                                             '      already wrapped — entire FAT scanned
            cluster_num := E_DISK_FULL
            quit
          fat_idx := 8                                                           '      wrap to cluster 2
          wrapped := TRUE
        if wrapped and fat_idx >= startFatIdx                                  '    wrapped and reached starting point?
          cluster_num := E_DISK_FULL
          quit
        if readSector(fat_sec + fat_idx >> SECTOR_BITS, BUF_FAT) < 0            '    load next sector of FAT
          debug[CH_SECTOR]("  [allocateCluster] FAT scan read FAILED")
          cluster_num := E_IO_ERROR
          quit
      ' Test hook: artificial cluster limit for testing
      if test_max_clusters > 0 and (fat_idx >> FAT_ENTRY_SHIFT) >= test_max_clusters
        if wrapped                                                               '    already wrapped — all visible clusters scanned
          cluster_num := E_DISK_FULL
          quit
        fat_idx := 8                                                             '    wrap to cluster 2
        buf_idx := 8
        wrapped := TRUE
        if fat_idx >= startFatIdx                                              '    started at cluster 2? nowhere left to scan
          cluster_num := E_DISK_FULL
          quit
        if readSector(fat_sec, BUF_FAT) < 0                                     '    pre-load first FAT sector after wrap
          debug[CH_SECTOR]("  [allocateCluster] FAT wrap pre-load FAILED")
          cluster_num := E_IO_ERROR
          quit
      buf_idx := fat_idx & SECTOR_MASK
      cluster_num := long[@fat_buf + buf_idx]                                    '  read a cluster cell
      if (cluster_num & FAT_EOC_MASK) == $0000_0000                              '  if cluster cell is empty (check only low 28 bits)
        high_bits := cluster_num & FAT_HIGH_BITS_MASK                            '  preserve high 4 bits
        long[@fat_buf + buf_idx] := high_bits | FAT_EOC_MASK                     '  mark as end-of-chain, preserve high bits
        cluster_num := fat_idx >> FAT_ENTRY_SHIFT                                '  store cluster number in cluster_num
        writeSector(fat_sec + cluster_num >> 7, BUF_FAT)                         '  write FAT1 sector
        writeSector(fat2_sec + cluster_num >> 7, BUF_FAT)                        '  write FAT2 sector (MIRROR)
        if cluster <> 0                                                          '  if called with a non-zero cluster parameter
          if readSector(fat_sec + cluster >> 7, BUF_FAT) < 0                     '   read FAT sector containing cluster cell
            debug[CH_SECTOR]("  [allocateCluster] FAT chain-link read FAILED - cluster orphaned")
            cluster_num := -1
            quit
          else
            buf_idx := (cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK
            high_bits := long[@fat_buf + buf_idx] & FAT_HIGH_BITS_MASK           '  preserve high 4 bits
            long[@fat_buf + buf_idx] := high_bits | (cluster_num & FAT_EOC_MASK) '  link to new cluster, preserve high bits
            writeSector(fat_sec + cluster >> 7, BUF_FAT)                         '  write FAT1 sector
            writeSector(fat2_sec + cluster >> 7, BUF_FAT)                        '  write FAT2 sector (MIRROR)
        if fsi_free_count <> $FFFF_FFFF                                          '  track free count incrementally
          fsi_free_count--                                                        '   (avoids slow FAT scan on unmount)
        fsi_nxt_free := cluster_num + 1                                          '  update next-free hint
        quit
      else
        fat_idx += 4                                                             '  advance index to next cluster cell
        if fat_idx >= fatLimit and not wrapped                                  '  past end of FAT? wrap around
          fat_idx := 8
          wrapped := TRUE
          if readSector(fat_sec, BUF_FAT) < 0                                   '    pre-load first FAT sector after wrap
            debug[CH_SECTOR]("  [allocateCluster] FAT wrap pre-load FAILED")
            cluster_num := E_IO_ERROR
            quit
        elseif wrapped and fat_idx >= startFatIdx                              '  wrapped and back to start?
          cluster_num := E_DISK_FULL
          quit

PRI freeClusterChain(first_cluster) : status | clstr, nextClstr, lastClstr, fat_sector, loop_count
' Walk a FAT chain and mark every cluster as free (zero entry).
' Writes both FAT1 and FAT2 (mirror) at sector boundaries and at end.
' Used by do_delete() and compactFile().
'
' @param first_cluster - First cluster of the chain to free
' @returns status - SUCCESS or E_IO_ERROR on safety limit

  status := SUCCESS
  clstr := first_cluster
  lastClstr := first_cluster
  loop_count := 0
  if clstr >= ROOT_CLUSTER
    repeat
      nextClstr := long[readFat(clstr)]
      long[@fat_buf + ((clstr << FAT_ENTRY_SHIFT) & SECTOR_MASK)] := 0             ' Zero the FAT entry
      if fsi_free_count <> $FFFF_FFFF                                              ' Track free count
        fsi_free_count++
      lastClstr := clstr
      if (nextClstr >> 7) - (clstr >> 7) <> 0                                     ' Different FAT sector?
        fat_sector := clstr >> 7
        writeSector(fat_sector + fat_sec, BUF_FAT)
        writeSector(fat_sector + fat2_sec, BUF_FAT)
      clstr := nextClstr
      loop_count++
      if loop_count > MAX_CHAIN_WALK                                                       ' Safety limit
        status := E_IO_ERROR
        quit
    until nextClstr +>= FAT_EOC_MIN
    ' Always write the FAT sector containing the last freed cluster
    if status == SUCCESS
      fat_sector := lastClstr >> 7
      writeSector(fat_sector + fat_sec, BUF_FAT)
      writeSector(fat_sector + fat2_sec, BUF_FAT)

#ifdef SD_INCLUDE_DEFRAG
' =============================================================================
' DEFRAGMENTATION INTERNAL HELPERS
' =============================================================================

PRI countFileFragments(first_cluster) : count | clstr, nextClstr, loop_count
' Count non-contiguous fragments in a FAT chain.
' A contiguous file = 1 fragment. Each gap (next != current+1) adds one.
'
' @param first_cluster - First cluster of the file's chain
' @returns count - Fragment count (1 = contiguous), 0 if empty chain

  count := 0
  if first_cluster >= ROOT_CLUSTER
    count := 1
    clstr := first_cluster
    loop_count := 0
    repeat
      nextClstr := long[readFat(clstr)] & FAT_EOC_MASK
      if nextClstr >= FAT_EOC_MIN
        quit                                                                     ' end of chain
      if nextClstr < ROOT_CLUSTER                                                ' bad reference
        quit
      if nextClstr <> clstr + 1                                                  ' non-contiguous?
        count++
      clstr := nextClstr
      loop_count++
      if loop_count > MAX_CHAIN_WALK                                                     ' safety limit
        quit

PRI do_file_fragments(p_path) : count | startClstr, p_leaf, saved_sec
' Worker-side handler for CMD_FILE_FRAGMENTS.
'
' @param p_path - Pointer to null-terminated filename string
' @returns count - Fragment count (1 = contiguous), 0 if empty, or negative error code

  p_leaf, saved_sec := sd_resolve_path(p_path)
  if p_leaf == 0
    count := E_FILE_NOT_FOUND
  elseif searchDirectory(p_leaf) == 0
    count := E_FILE_NOT_FOUND
  else
    startClstr := firstCluster()
    if startClstr < ROOT_CLUSTER
      count := 0                                                                 ' empty file (no clusters)
    else
      count := countFileFragments(startClstr)
  sd_restore_path(saved_sec)

PRI findContiguousRun(cluster_count) : first_cluster | fat_idx, fatEntry, runStart, runLen
' Scan FAT for a contiguous run of N free clusters.
' Linear scan from cluster 2 through end of FAT.
'
' @param cluster_count - Number of consecutive free clusters needed
' @returns first_cluster - First cluster of the run, or E_NO_CONTIGUOUS_SPACE / E_IO_ERROR

  first_cluster := E_NO_CONTIGUOUS_SPACE
  runStart := ROOT_CLUSTER
  runLen := 0
  fat_idx := ROOT_CLUSTER * 4                                                   ' start at cluster 2
  repeat
    if fat_idx & SECTOR_MASK == 0                                                ' at sector boundary?
      if fat_idx >> SECTOR_BITS >= sec_per_fat                                   '   past end of FAT?
        quit
      if readSector(fat_sec + fat_idx >> SECTOR_BITS, BUF_FAT) < 0
        debug[CH_SECTOR]("  [findContiguousRun] FAT read FAILED")
        first_cluster := E_IO_ERROR
        quit
    if test_max_clusters > 0 and (fat_idx >> FAT_ENTRY_SHIFT) >= test_max_clusters
      quit                                                                       ' test hook: artificial limit
    fatEntry := long[@fat_buf + (fat_idx & SECTOR_MASK)]
    if (fatEntry & FAT_EOC_MASK) == 0                                            ' free cluster?
      if runLen == 0
        runStart := fat_idx >> FAT_ENTRY_SHIFT                                   '   start new run
      runLen++
      if runLen >= cluster_count                                                 ' found enough?
        first_cluster := runStart
        quit
    else
      runLen := 0                                                                ' reset run
    fat_idx += 4
  fat_sec_in_buf := -1                                                           ' invalidate cache at single exit

PRI allocateContiguousChain(first_cluster, count) : status | clstr, fat_idx, buf_idx, high_bits, prev_fat_sector
' Mark N consecutive clusters as a linked sequential chain in FAT.
' Writes both FAT1 and FAT2 (mirror). Preserves high 4 reserved bits.
'
' @param first_cluster - First cluster of the contiguous run
' @param count - Number of clusters to link
' @returns status - SUCCESS or E_IO_ERROR

  status := SUCCESS
  prev_fat_sector := -1
  repeat clstr from first_cluster to first_cluster + count - 1
    fat_idx := clstr << FAT_ENTRY_SHIFT
    buf_idx := fat_idx & SECTOR_MASK
    ' Load FAT sector if needed
    if (fat_idx >> SECTOR_BITS) <> prev_fat_sector
      if prev_fat_sector >= 0                                                    ' write previous sector before loading new one
        writeSector(fat_sec + prev_fat_sector, BUF_FAT)
        writeSector(fat2_sec + prev_fat_sector, BUF_FAT)
      prev_fat_sector := fat_idx >> SECTOR_BITS
      if readSector(fat_sec + prev_fat_sector, BUF_FAT) < 0
        debug[CH_SECTOR]("  [allocateContiguousChain] FAT read FAILED at cluster ", udec_(clstr))
        status := E_IO_ERROR
        quit
    ' Write chain link or EOC
    high_bits := long[@fat_buf + buf_idx] & FAT_HIGH_BITS_MASK                   ' preserve high 4 bits
    if clstr < first_cluster + count - 1
      long[@fat_buf + buf_idx] := high_bits | ((clstr + 1) & FAT_EOC_MASK)       ' link to next
    else
      long[@fat_buf + buf_idx] := high_bits | FAT_EOC_MASK                       ' end of chain
  ' Write final FAT sector
  if prev_fat_sector >= 0 and status == SUCCESS
    writeSector(fat_sec + prev_fat_sector, BUF_FAT)
    writeSector(fat2_sec + prev_fat_sector, BUF_FAT)
  ' Update free cluster tracking
  if status == SUCCESS
    if fsi_free_count <> $FFFF_FFFF
      fsi_free_count -= count
    fsi_nxt_free := first_cluster + count                                        ' update next-free hint

PRI do_create_contiguous(p_path, expected_size) : handle | clstrCnt, newFirstClstr, allocStatus, firstClstr, p_leaf, saved_sec
' Worker-side handler for CMD_CREATE_CONTIGUOUS.
' Creates a new file with a pre-allocated contiguous cluster chain.
'
' @param p_path - Pointer to null-terminated filename string
' @param expected_size - Expected file size in bytes
' @returns handle - Handle on success, negative error code on failure

  p_leaf, saved_sec := sd_resolve_path(p_path)
  if p_leaf == 0
    handle := E_FILE_NOT_FOUND
  else
    ' Calculate clusters needed
    clstrCnt := (expected_size + (sec_per_clus << SECTOR_BITS) - 1) / (sec_per_clus << SECTOR_BITS)
    if clstrCnt < 1
      clstrCnt := 1                                                              ' minimum 1 cluster

    ' Find contiguous run
    newFirstClstr := findContiguousRun(clstrCnt)
    if newFirstClstr < 0
      handle := newFirstClstr                                                    ' E_NO_CONTIGUOUS_SPACE or E_IO_ERROR
    else
      ' Allocate the contiguous chain in FAT
      allocStatus := allocateContiguousChain(newFirstClstr, clstrCnt)
      if allocStatus < 0
        handle := allocStatus
      else
        ' Allocate a handle slot
        handle := allocateHandle()
        if handle < 0
          debug[CH_FILE]("  [do_create_contiguous] No free handles")
        else
          ' Check file doesn't already exist
          if searchDirectory(p_leaf)
            debug[CH_FILE]("  [do_create_contiguous] File already exists: ", zstr_(p_leaf))
            freeHandle(handle)
            handle := E_FILE_EXISTS
          elseif entry_address == 0
            debug[CH_FILE]("  [do_create_contiguous] entry_address=0 -- path not valid")
            freeHandle(handle)
            handle := E_FILE_NOT_FOUND
          else
            ' Check if directory needs a new cluster for the entry
            allocStatus := (entry_address + cluster_offset << SECTOR_BITS) & (sec_per_clus << SECTOR_BITS - 1)
            if allocStatus == (sec_per_clus << SECTOR_BITS - DIR_ENTRY_SIZE)
              if dir_buf[480] == $00
                allocStatus := allocateCluster(byte2clus(entry_address))
                if allocStatus < 0
                  debug[CH_FILE]("  [do_create_contiguous] Failed to allocate dir cluster")
                  freeHandle(handle)
                  handle := E_DISK_FULL

            if handle >= 0
              ' Set up directory entry
              firstClstr := newFirstClstr
              dirEntSetAttr(@entry_buffer, DIR_ATTR_ARCHIVE)                                    ' Archive attribute
              dirEntSetCreateStamp(@entry_buffer, date_stamp)
              dirEntSetStartClus(@entry_buffer, firstClstr)
              dirEntSetModifyStamp(@entry_buffer, date_stamp)
              dirEntSetFileSize(@entry_buffer, 0)

              ' Write directory entry to disk
              if readSector(entry_address >> SECTOR_BITS, BUF_DIR) < 0
                debug[CH_FILE]("  [do_create_contiguous] Directory read FAILED")
                freeHandle(handle)
                handle := E_IO_ERROR
              else
                bytemove(@dir_buf + (entry_address & SECTOR_MASK), @entry_buffer, DIR_ENTRY_SIZE)
                if not writeSector(entry_address >> SECTOR_BITS, BUF_DIR)
                  debug[CH_FILE]("  [do_create_contiguous] Directory write FAILED")
                  freeHandle(handle)
                  handle := E_IO_ERROR
                else
                  ' Populate handle state
                  h_start_clus[handle] := firstClstr
                  h_size[handle] := 0
                  h_attr[handle] := DIR_ATTR_ARCHIVE
                  h_dir_sector[handle] := entry_address >> SECTOR_BITS
                  h_dir_offset[handle] := entry_address & SECTOR_MASK
                  h_cluster[handle] := firstClstr
                  h_sector[handle] := clus2sec(firstClstr)
                  h_position[handle] := 0
                  h_buf_sector[handle] := -1
                  h_flags[handle] := HF_WRITE
                  h_prealloc_end[handle] := newFirstClstr + clstrCnt - 1

  sd_restore_path(saved_sec)

PRI copyClusterData(src_cluster, dst_cluster) : status | idx
' Copy all sectors of one cluster from source to destination.
'
' @param src_cluster - Source cluster
' @param dst_cluster - Destination cluster
' @returns status - SUCCESS or E_IO_ERROR

  status := SUCCESS
  repeat idx from 0 to sec_per_clus - 1
    if readSector(clus2sec(src_cluster) + idx, BUF_DATA) < 0
      status := E_IO_ERROR
      quit
    if not writeSector(clus2sec(dst_cluster) + idx, BUF_DATA)
      status := E_IO_ERROR
      quit

PRI verifyClusterCopy(src_cluster, dst_cluster) : status | idx, byteIdx
' Verify that all sectors in a cluster were copied correctly.
' Repurposes dir_buf for destination reads (safe when file is closed).
'
' @param src_cluster - Source cluster (read into buf via BUF_DATA)
' @param dst_cluster - Destination cluster (read into dir_buf via BUF_DIR)
' @returns status - SUCCESS or E_VERIFY_FAILED or E_IO_ERROR

  status := SUCCESS
  repeat idx from 0 to sec_per_clus - 1
    if readSector(clus2sec(src_cluster) + idx, BUF_DATA) < 0
      status := E_IO_ERROR
      quit
    if readSector(clus2sec(dst_cluster) + idx, BUF_DIR) < 0
      status := E_IO_ERROR
      quit
    if status == SUCCESS
      repeat byteIdx from 0 to SECTOR_SIZE - 1
        if byte[@buf][byteIdx] <> byte[@dir_buf][byteIdx]
          debug[CH_FILE]("  [verifyClusterCopy] Mismatch at sector ", udec_(idx), " byte ", udec_(byteIdx))
          status := E_VERIFY_FAILED
          quit
    if status <> SUCCESS
      quit

PRI invalidateAllCaches()
' Reset all three sector cache tracking variables to force re-reads.
' Called after compactFile() to prevent stale cached sectors.

  dir_sec_in_buf := -1
  fat_sec_in_buf := -1
  sec_in_buf := -1

PRI isFileOpenAny(dir_sector, dir_offset) : bOpen | hndl
' Check if a file is open in any mode (read, write, or directory).
' Used by compactFile() to reject compaction on open files.
'
' @param dir_sector - Directory sector of the file
' @param dir_offset - Directory offset within sector
' @returns bOpen - TRUE if file is open, FALSE otherwise

  bOpen := FALSE
  repeat hndl from 0 to MAX_OPEN_FILES - 1
    if h_flags[hndl] <> HF_FREE
      if h_dir_sector[hndl] == dir_sector and h_dir_offset[hndl] == dir_offset
        bOpen := TRUE
        quit

PRI do_compact_file(p_path) : status | dir_sec, dir_off, startClstr, fileSzBytes, clstrCnt, newFirstClstr, clstr, nextClstr, idx, fragCnt, p_leaf, saved_sec
' Worker-side handler for CMD_COMPACT_FILE.
' Relocates a file's clusters into a contiguous chain using copy-then-free.
' 12-step process with mandatory read-back verification.
'
' @param p_path - Pointer to null-terminated filename string
' @returns status - SUCCESS or negative error code

  p_leaf, saved_sec := sd_resolve_path(p_path)
  if p_leaf == 0
    status := E_FILE_NOT_FOUND
  else
    ' Step 1: Find the file
    if searchDirectory(p_leaf) == 0
      status := E_FILE_NOT_FOUND
    else
      dir_sec := entry_address >> SECTOR_BITS
      dir_off := entry_address & SECTOR_MASK
      startClstr := firstCluster()
      fileSzBytes := dirEntFileSize(@entry_buffer)

      ' Step 2: Check file is not open
      if isFileOpenAny(dir_sec, dir_off) == TRUE
        status := E_FILE_OPEN_FOR_COMPACT
      ' Step 3: Empty file — nothing to compact
      elseif fileSzBytes == 0
        status := SUCCESS
      else
        ' Step 4: Count clusters and check fragmentation
        fragCnt := countFileFragments(startClstr)
        if fragCnt == CONTIGUOUS_FRAGMENTS
          status := SUCCESS                                                      ' already contiguous
        else
          ' Count clusters by walking the chain
          clstrCnt := 0
          clstr := startClstr
          repeat
            clstrCnt++
            nextClstr := long[readFat(clstr)] & FAT_EOC_MASK
            if nextClstr >= FAT_EOC_MIN
              quit
            if nextClstr < ROOT_CLUSTER
              quit
            clstr := nextClstr

          ' Step 5: Find contiguous free space
          newFirstClstr := findContiguousRun(clstrCnt)
          if newFirstClstr < 0
            status := newFirstClstr                                              ' E_NO_CONTIGUOUS_SPACE or E_IO_ERROR
          else
            ' Step 6: Copy phase — walk old chain, copy each cluster to new location
            clstr := startClstr
            idx := 0
            status := SUCCESS
            repeat
              status := copyClusterData(clstr, newFirstClstr + idx)
              if status < 0
                quit                                                             ' E_IO_ERROR
              idx++
              nextClstr := long[readFat(clstr)] & FAT_EOC_MASK
              if nextClstr >= FAT_EOC_MIN
                quit
              if nextClstr < ROOT_CLUSTER
                quit
              clstr := nextClstr

            if status == SUCCESS
              ' Step 7: Verify phase — read-back compare every cluster
              clstr := startClstr
              idx := 0
              repeat
                status := verifyClusterCopy(clstr, newFirstClstr + idx)
                if status < 0
                  quit                                                           ' E_VERIFY_FAILED
                idx++
                nextClstr := long[readFat(clstr)] & FAT_EOC_MASK
                if nextClstr >= FAT_EOC_MIN
                  quit
                if nextClstr < ROOT_CLUSTER
                  quit
                clstr := nextClstr

            if status == SUCCESS
              ' Step 8: Build new FAT chain
              status := allocateContiguousChain(newFirstClstr, clstrCnt)

            if status == SUCCESS
              ' Step 9: Update directory entry to point to new first cluster
              if readSector(dir_sec, BUF_DIR) < 0
                status := E_IO_ERROR
              else
                bytemove(@entry_buffer, @dir_buf + dir_off, DIR_ENTRY_SIZE)
                dirEntSetStartClus(@entry_buffer, newFirstClstr)
                bytemove(@dir_buf + dir_off, @entry_buffer, DIR_ENTRY_SIZE)
                writeSector(dir_sec, BUF_DIR)

                ' Step 10: Free old clusters
                freeClusterChain(startClstr)

                ' Step 11: Invalidate all caches
                invalidateAllCaches()

                ' Step 12: Success
                status := SUCCESS

  sd_restore_path(saved_sec)

#endif

PRI clearCluster(cluster)
' Initialize entire contents of cluster to 0 - used for new directories.
'
' @param cluster - Cluster number to clear

  n_sec := clus2sec(cluster)                                                    '  set n_sec to 1st sector of specified cluster
  bytefill(@dir_buf, 0, SECTOR_SIZE)                                                    '  clear directory buffer
  repeat sec_per_clus                                                           '  repeat for all sectors in the cluster
    writeSector(n_sec++, BUF_DIR)                                               '   overwrite sector
  dir_sec_in_buf := n_sec - 1

PRI readNextSector(buf_type) | cluster, address, contents, p_buf
' Load the next sector into buffer - follows FAT chain at cluster boundaries.
'
' @param buf_type - Buffer type: BUF_DIR, BUF_FAT, or BUF_DATA
' @local cluster - Current cluster number
' @local address - FAT entry address
' @local contents - FAT entry contents
' @local p_buf - Pointer to buffer (unused)

  n_sec++
  if ((n_sec - cluster_offset) & (sec_per_clus - 1)) == 0                       '  if next sector is in a different cluster
    cluster := sec2clus(n_sec-1)                                                '   find current cluster number
    if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0                          '   read sector of FAT containing cluster number (128 cluster entries in each FAT sector)
      debug[CH_SECTOR]("  [readNextSector] FAT read FAILED for cluster ", udec_(cluster))
    else
      address := @fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)                              '   find long within FAT buffer for current cluster
      contents := long[address]                                                 '   read contents to determine next cluster number
      if contents +>= $0FFF_FFF8                                                '   end-of-chain marker detected
        ' Fill appropriate buffer with zeros based on buf_type
        case buf_type
          BUF_DIR:
            bytefill(@dir_buf, 0, SECTOR_SIZE)
          BUF_FAT:
            bytefill(@fat_buf, 0, SECTOR_SIZE)
          other:
            bytefill(@buf, 0, SECTOR_SIZE)
      else
        n_sec := clus2sec(contents)                                             '   convert next cluster number into sector number
        if readSector(n_sec, buf_type) < 0
          debug[CH_SECTOR]("  [readNextSector] Sector read FAILED for sector ", udec_(n_sec))
  else
    if readSector(n_sec, buf_type) < 0
      debug[CH_SECTOR]("  [readNextSector] Sector read FAILED for sector ", udec_(n_sec))

PRI followFatChain() | cluster, address, contents
' Follow FAT chain to next cluster - for multi-sector reads.
' Called after multi-sector read lands exactly on cluster boundary.
' Updates n_sec to first sector of next cluster in the chain.
' n_sec is already pointing at the first sector of the NEW cluster boundary.
'
' @local cluster - Current cluster number
' @local address - FAT entry address
' @local contents - FAT entry contents (next cluster or end marker)

  cluster := sec2clus(n_sec - 1)                                                '  find cluster number of the sector we just finished reading
  if readSector(cluster >> 7 + fat_sec, BUF_FAT) < 0                            '  read sector of FAT containing cluster number
    debug[CH_SECTOR]("  [followFatChain] FAT read FAILED for cluster ", udec_(cluster))
  else
    address := @fat_buf + ((cluster << FAT_ENTRY_SHIFT) & SECTOR_MASK)                                '  find long within FAT buffer for current cluster
    contents := long[address]                                                   '  read contents to determine next cluster number
    if contents +< $0FFF_FFF8                                                   '  if not end-of-chain marker
      n_sec := clus2sec(contents)                                               '   convert next cluster number into sector number
    ' else: end-of-chain - n_sec stays invalid (caller should check position against fileSize)

PRI updateFSInfo() : ok | pFSI
' Update FSInfo sector with current free cluster count.
' Uses cached fsi_free_count (tracked incrementally during alloc/delete).
' Called by unmount() to ensure other OSes see correct free space.
'
' @returns ok - TRUE on success, FALSE if no valid FSInfo
' @local pFSI - Pointer overlaid on buf for fsinfo_t struct access

  if fsinfo_sec == 0 or fsi_free_count == $FFFF_FFFF
    debug[CH_MOUNT]("  [updateFSInfo] No valid FSInfo to update")
    ok := false  '  no FSInfo sector to update

  ' Use cached free count (tracked incrementally, no FAT scan needed)

  ' Read FSInfo sector
  elseif readSector(vbr_sec + fsinfo_sec, BUF_DATA) < 0
    debug[CH_MOUNT]("  [updateFSInfo] FSInfo read FAILED")
    ok := false
  else
    pFSI := @buf                                                                  '  overlay FSInfo

    ' Verify signatures before writing
    if fsiLeadSig(pFSI) <> $4161_5252 or fsiStructSig(pFSI) <> $6141_7272
      debug[CH_MOUNT]("  [updateFSInfo] Invalid FSInfo signatures")
      ok := false

    ' Update free count and next-free hint
    else
      fsiSetFreeClusters(pFSI, fsi_free_count)                                      '  FSI_Free_Count (cached value)
      fsiSetNextFreeHint(pFSI, fsi_nxt_free)                                        '  FSI_Nxt_Free (keep cached value)

      ' Write updated FSInfo sector (primary at sector 1, backup at sector 7)
      writeSector(vbr_sec + fsinfo_sec, BUF_DATA)
      writeSector(vbr_sec + 7, BUF_DATA)                                            '  backup FSInfo at sector 7
      debug[CH_MOUNT]("  [updateFSInfo] Updated primary+backup: free_count=", udec(fsi_free_count))
      ok := true

PRI countFreeClusters() : count | fat_idx, entry
' Count free clusters in FAT - scans entire FAT for zero entries.
' This is slow on large cards but only called on unmount().
'
' @returns count - Number of free clusters
' @local fat_idx - Current FAT byte index
' @local entry - Current FAT entry value

  count := 0
  fat_idx := 8                                                                  '  start at cluster 2 (skip reserved entries 0,1)
  repeat
    if fat_idx & SECTOR_MASK == 0                                                       '  if at sector boundary
      if fat_idx >> SECTOR_BITS >= sec_per_fat                                            '  if past end of FAT
        quit
      if readSector(fat_sec + fat_idx >> SECTOR_BITS, BUF_FAT) < 0                         '  read next FAT sector
        debug[CH_MOUNT]("  [countFreeClusters] FAT read FAILED, returning partial count")
        quit
    entry := long[@fat_buf + (fat_idx & SECTOR_MASK)]
    if (entry & FAT_EOC_MASK) == 0                                               '  check only low 28 bits
      count++
    fat_idx += 4
  fat_sec_in_buf := -1                                                          '  invalidate FAT buffer


CON ' ---- SD Conversion Helpers ----
    ' SD CONVERSION HELPERS
    ' =============================================================================
PRI byte2clus(byte_address) : cluster_num
' Convert byte address to cluster number.
'
' @param byte_address - Byte address to convert
' @returns cluster_num - Cluster number containing that byte

  cluster_num := (sec2clus(byte_address >> SECTOR_BITS))

PRI sec2clus(sector) : cluster_num
' Convert sector number to cluster number.
'
' @param sector - Sector number to convert
' @returns cluster_num - Cluster number containing that sector

  cluster_num := (sector - root_sec) / sec_per_clus + 2

PRI clus2byte(cluster) : byte_addr
' Convert cluster number to byte address.
'
' @param cluster - Cluster number to convert
' @returns byte_addr - Byte address of first byte in that cluster

  byte_addr := clus2sec(cluster) << SECTOR_BITS

PRI clus2sec(cluster) : sector_num
' Convert cluster number to sector number.
'
' @param cluster - Cluster number to convert
' @returns sector_num - Sector number of first sector in that cluster

  sector_num := (cluster - 2) * sec_per_clus + root_sec



CON ' ---- SD SPI Layer ----
    ' SD SPI LAYER
    ' =============================================================================
PRI initSPIPins()
' Configure smart pins for SPI operation - initialize Smart Pins for high-speed SPI communication.
' Pattern from working isp_tile_sensor.spin2:
' - DIRL -> WRPIN -> WXPIN -> DIRH (no WYPIN during config)
' - Smart pins stay enabled, WYPIN triggers transfers
'
' SCK uses P_PULSE for clock generation (X = period | low_time<<16)
' MOSI uses P_SYNC_TX for synchronized transmit (clocked by SCK)
' MISO uses P_SYNC_RX for synchronized receive (clocked by SCK)
' CS remains standard GPIO (manual control)

  ' Smart pin mode configuration using compiler constants
  ' P_TRANSITION: clock generation with X = half-period (transitions toggle output)
  ' P_SYNC_TX: synchronized serial transmit (clocked by B-input)
  ' P_SYNC_RX: synchronized serial receive (clocked by B-input)
  ' P_PLUS2_B, P_PLUS3_B: B-input pin selector for clock source
  ' Reference: ManAtWork SpiFlash.spin2 (OBEX 2872) - working smart pin SPI
  ' CRITICAL: Do NOT use P_INVERT_OUTPUT for SD card SPI mode 0!
  ' ManAtWork's flash uses different polarity. SD cards need clock idle LOW.
  spi_clk_mode := P_TRANSITION | P_OE                                           ' Transition mode, idle LOW for SPI mode 0
  spi_tx_mode := P_SYNC_TX | P_OE | P_PLUS2_B                                   ' Sync TX, clock from pin+2 (SCK)
  spi_rx_mode := P_SYNC_RX | P_PLUS3_B                                          ' Sync RX, clock from pin+3 (SCK)

  debug[CH_INIT]("    [initSPIPins] Setting up smart pins (ManAtWork pattern)...")
  debug[CH_INIT]("    [initSPIPins] Mode values:")
  debug[CH_INIT]("    [initSPIPins]   spi_clk_mode=$", uhex_long(spi_clk_mode), " (P_TRANSITION | P_OE, idle LOW)")
  debug[CH_INIT]("    [initSPIPins]   spi_tx_mode=$", uhex_long(spi_tx_mode), " (P_SYNC_TX | P_OE | P_PLUS2_B)")
  debug[CH_INIT]("    [initSPIPins]   spi_rx_mode=$", uhex_long(spi_rx_mode), " (P_SYNC_RX | P_PLUS3_B)")
  debug[CH_INIT]("    [initSPIPins]   SCK=P", udec_(PIN_SD_SCK), " MOSI=P", udec_(PIN_MOSI), " MISO=P", udec_(PIN_MISO))

  ' ====================================================================
  ' CS PIN: Standard GPIO (unchanged from bit-bang)
  ' CS is manually controlled - LOW = selected, HIGH = deselected
  ' ====================================================================
  pinh(PIN_SD_CS)                                                                      ' Start deselected

  ' ====================================================================
  ' SCK PIN: P_TRANSITION mode for clock generation
  ' X register: half-period in clocks (time between transitions)
  ' Y register: Number of transitions (2 per bit) - loaded via WYPIN per transfer
  ' Configure with FLTL -> WRPIN, then WXPIN/DRVL in do_set_spi_speed()
  ' ====================================================================
  pinfloat(PIN_SD_SCK)                                                                 ' FLTL - reset smart pin
  wrpin(PIN_SD_SCK, spi_clk_mode)                                                      ' P_TRANSITION | P_OE
  ' X register (half-period) will be set by do_set_spi_speed()
  debug[CH_INIT]("    [initSPIPins]   SCK configured: P_TRANSITION | P_OE (awaiting setSPISpeed)")

  ' ====================================================================
  ' MOSI PIN: P_SYNC_TX mode for synchronized transmit
  ' B-input set via P_PLUS2_B (clock from SCK which is 2 pins higher)
  ' X register: %M_NNNNN where M=mode (1=start/stop), N=bits-1
  ' Y register: Data to transmit - loaded via WYPIN per transfer
  ' Configure with DIRL -> WRPIN -> WXPIN -> DIRH (no WYPIN yet)
  ' ====================================================================
  pinfloat(PIN_MOSI)                                                                ' DIRL - reset smart pin
  wrpin(PIN_MOSI, spi_tx_mode)                                                      ' P_SYNC_TX | P_OE | P_PLUS2_B
  wxpin(PIN_MOSI, %1_00111)                                                         ' Start-stop mode, 8 bits default
  pinh(PIN_MOSI)                                                                    ' DIRH - enable smart pin
  debug[CH_INIT]("    [initSPIPins]   MOSI configured: P_SYNC_TX | P_PLUS2_B (enabled)")

  ' ====================================================================
  ' MISO PIN: P_SYNC_RX mode for synchronized receive
  ' B-input set via P_PLUS3_B (clock from SCK which is 3 pins higher)
  ' X register: %M_NNNNN where M=mode (1=post-edge for SPI mode 0), N=bits-1
  ' Z register: Received data - read via RDPIN per transfer
  ' Configure with DIRL -> WRPIN -> WXPIN -> DIRH (no WYPIN needed)
  ' ====================================================================
  pinfloat(PIN_MISO)                                                                ' DIRL - reset smart pin
  wrpin(PIN_MISO, spi_rx_mode)                                                      ' P_SYNC_RX | P_PLUS3_B
  wxpin(PIN_MISO, %1_00111)                                                         ' On-edge sample (SPI mode 0), 8 bits
  pinh(PIN_MISO)                                                                    ' DIRH - enable smart pin
  debug[CH_INIT]("    [initSPIPins]   MISO configured: P_SYNC_RX | P_PLUS3_B (enabled)")

  ' Configure event SE1 for efficient waiting on SCK completion
  ' Event format: D[5:0]=pin, D[7:6]=%01 for positive edge on IN
  ' This allows waitse1 instead of polling testp loop
  spi_event := %01_000000 | PIN_SD_SCK
  configureEvent(spi_event)
  debug[CH_INIT]("    [initSPIPins]   Event SE1 configured for SCK pin ", udec_(PIN_SD_SCK))

  ' Mark smart pin mode as active
  use_smartpin := 1
  debug[CH_INIT]("    [initSPIPins] Smart pins configured and enabled")

PRI configureEvent(event_config) | ev
' Configure SE1 event for waitse1 - helper to configure SE1 event from a computed value.
' Event format: D[5:0]=pin, D[7:6]=%01 for positive edge on IN
'
' @param event_config - Event configuration value
' @local ev - Copy of event config for inline assembly

  ev := event_config
  org
        setse1  ev
  end

PRI do_set_spi_speed(freq) | half_period, actual_freq
' Set SPI clock frequency -- worker-cog only (directly reconfigures SPI clock smart pin).
' Using P_TRANSITION mode: X = half-period (time between transitions).
' Reference: ManAtWork SpiFlash.spin2
'
' Formula: half_period = clkfreq / (freq * 2)
' For 400 kHz: half_period = 320M / 800k = 400 clocks
' For 25 MHz: half_period = 320M / 50M = 6.4 -> minimum 4
'
' @param freq - Target SPI frequency in Hz (e.g., 400_000 or 25_000_000)
' @local half_period - Calculated half-period in system clocks
' @local actual_freq - Actual achieved frequency

  ' Calculate half-period (time between transitions) in system clocks
  ' Use ceiling division to ensure we never exceed target frequency
  ' Formula: ceil(a/b) = (a + b - 1) / b
  half_period := (clkfreq + (freq * 2) - 1) / (freq * 2)

  ' Guard against too-small period (ManAtWork uses minimum of 4)
  if half_period < 4
    half_period := 4
    debug[CH_INIT]("    [setSPISpeed] WARNING: Half-period clamped to minimum (4)")

  ' Calculate actual achieved frequency for debugging
  actual_freq := clkfreq / (half_period * 2)

  ' Store in DAT variables for debugging/monitoring
  spi_period := half_period
  spi_freq := actual_freq

  ' Configure SCK smart pin X register and enable with DRVL
  wxpin(PIN_SD_SCK, half_period)                                                       ' Set transition period
  pinl(PIN_SD_SCK)                                                                     ' DRVL enables smart pin (ManAtWork pattern)

  debug[CH_INIT]("    [setSPISpeed] Target=", udec_(freq/1000), " kHz, Actual=", udec_(actual_freq/1000), " kHz")
  debug[CH_INIT]("    [setSPISpeed] Half-period=", udec_(half_period), " clocks")

PRI calcDataCRC(pData, len) : crc | raw
' Calculate CRC-16-CCITT for SD card data - hardware-accelerated using P2's GETCRC instruction.
' Eliminates 512-byte lookup table with equivalent results.
'
' Algorithm:
'   1. GETCRC with reflected polynomial $8408 on raw data
'   2. XOR with precomputed base value (compensates for GETCRC quirks)
'   3. REV 31 reverses all 32 bits (LSB-first to MSB-first)
'   4. >> 16 extracts 16-bit CRC from upper half
'
' Note: This formula was validated against lookup table with 100% match
'       across 10 test patterns. See TestCard/SD_CRC_solution_test.spin2
'
' @param pData - Pointer to data buffer
' @param len - Number of bytes to process (must be 512 for sector data)
' @returns crc - 16-bit CRC-16-CCITT value matching SD card's calculation
' @local raw - Raw GETCRC result before transformation
  raw := GETCRC(pData, CRC_POLY_REFLECTED, len)
  crc := ((raw ^ CRC_BASE_512) REV 31) >> 16

PRI sp_transfer(data, bits) : rx_data
' Smart pin SPI transfer (variable bits) - dispatches to 8-bit or 32-bit transfer.
' For now, only support 8-bit and 32-bit transfers.
'
' @param data - Data to transmit
' @param bits - Number of bits to transfer (8 or 32)
' @returns rx_data - Received data

  if bits == 8
    rx_data := sp_transfer_8(data)
  elseif bits == 32
    rx_data := sp_transfer_32(data)
  else
    ' Fallback to bit-bang for unsupported sizes
    rx_data := transfer(data, bits)

PRI sp_transfer_8(data) : rx_byte | tx_data, raw_result
' 8-bit smart pin SPI transfer - full-duplex 8-bit SPI transfer using smart pins.
' Reference: ManAtWork SpiFlash.spin2 (OBEX 2872)
' TX: shl #24, rev, wypin data, 16 transitions
' RX: wait on MISO IN flag, rdpin, rev, zerox #7
'
' @param data - Byte to transmit
' @returns rx_byte - Byte received
' @local tx_data - Prepared transmit data
' @local raw_result - Raw rdpin rx_byte before processing

  tx_data := data
  org
        ' Prepare TX data: shift to MSB position and reverse for LSB-first transmission
        shl     tx_data, #24                    ' Move byte to bits [31:24]
        rev     tx_data                         ' Reverse for MSB-first SPI

        ' Configure MOSI for 8-bit start-stop mode and load data
        wxpin   #$27, #PIN_MOSI                 ' 8 bits, start-stop mode (%1_00111)
        wypin   tx_data, #PIN_MOSI
        drvl    #PIN_MOSI                       ' Enable TX smart pin

        ' Configure MISO for 8-bit receive
        ' Note: wrpin already set from initSPIPins - don't use dirl which clears it!
        wxpin   #$27, #PIN_MISO                 ' 8 bits, start-stop mode
        akpin   #PIN_MISO                       ' Clear any pending IN flag
        dirh    #PIN_MISO                       ' Enable smart pin

        ' Start clock: 16 transitions = 8 clock cycles
        wypin   #16, #PIN_SD_SCK
        nop

        ' Wait for MISO receive complete (not clock!)
.waitRx testp   #PIN_MISO               wz      ' IN=1 when receive complete
  if_nz jmp     #.waitRx

        ' Read received data - keep raw value for debug
        rdpin   raw_result, #PIN_MISO
        mov     rx_byte, raw_result
        rev     rx_byte                          ' Reverse for MSB-first
        zerox   rx_byte, #7                      ' Limit to 8 bits
  end
  ' Debug: show raw rdpin value and pin info occasionally
  if sp_debug_ctr < 5
    debug[CH_INIT]("    [sp_transfer_8] pins: miso=", udec_(PIN_MISO), " sck=", udec_(PIN_SD_SCK), " raw=", uhex_long_(raw_result), " final=", uhex_byte_(rx_byte))
    sp_debug_ctr++

PRI sp_transfer_32(data) : rx_data | tx_data
' 32-bit smart pin SPI transfer - full-duplex 32-bit SPI transfer using smart pins.
'
' @param data - 32-bit data to transmit
' @returns rx_data - 32-bit data received
' @local tx_data - Prepared transmit data

  tx_data := data
  org
        ' Prepare TX data: reverse for LSB-first transmission
        rev     tx_data                         ' Reverse for MSB-first SPI

        ' Configure MOSI for 32-bit start-stop mode and load data
        wxpin   #$3F, #PIN_MOSI                 ' 32 bits, start-stop mode (%1_11111)
        wypin   tx_data, #PIN_MOSI
        drvl    #PIN_MOSI                       ' Enable TX smart pin

        ' Configure MISO for 32-bit receive
        wxpin   #$3F, #PIN_MISO                 ' 32 bits, start-stop mode
        drvl    #PIN_MISO                       ' Enable RX smart pin

        ' Start clock: 64 transitions = 32 clock cycles
        wypin   #64, #PIN_SD_SCK
        nop

        ' Wait for MISO receive complete
.waitRx testp   #PIN_MISO               wz      ' IN=1 when receive complete
  if_nz jmp     #.waitRx

        ' Read received data
        rdpin   rx_data, #PIN_MISO
        rev     rx_data                          ' Reverse for MSB-first
  end

PRI initCard() : ok | timeout, resp, card_version, acmd41_arg, got_response
' Initialize SD card - performs complete card initialization sequence per SD spec.
' Steps: power-on delay, SPI setup, CMD0, CMD8, ACMD41 loop, CMD58.
' Sets last_init_error DAT variable with specific failure reason on error.
'
' @returns ok - TRUE on successful init, FALSE on failure
' @side-effect last_init_error - Set to E_NO_CARD, E_BAD_RESPONSE, E_TIMEOUT, or E_INIT_FAILED
' @local timeout - Timeout counter
' @local resp - Command response byte
' @local card_version - Detected SD version (1 or 2)
' @local acmd41_arg - Argument for ACMD41 (HCS flag)
' @local got_response - TRUE if any CMD0 attempt returned non-zero

  debug[CH_INIT]("    [initCard] Starting card init...")
  debug[CH_INIT]("    [initCard] Reference: SPI_SD_Implementation_Reference.md")
  sec_in_buf := -1
  last_init_error := E_INIT_FAILED                                              '  Default: overwritten with specific error

  ' ============================================
  ' STEP 1: Power-on delay
  ' Spec: VDD must be stable, then wait 1ms minimum
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 1: Power-on delay (100ms)...")
  waitms(100)

  ' ============================================
  ' STEP 2: Configure SPI pins and slow clock
  ' Spec: Use 100-400 kHz during initialization
  ' ============================================
  bit_delay := clkfreq / 100_000                                                '  ~50kHz for init (conservative)
  debug[CH_INIT]("    [initCard] Step 2: SPI config, bit_delay=", udec(bit_delay), " (~50kHz)")

  ' SD card SPI mode 0: CPOL=0, CPHA=0
  ' Data sampled on rising edge, changed on falling edge
  pinh(PIN_SD_CS)                                                                      '  CS HIGH = deselected
  pinh(PIN_MOSI)                                                                    '  MOSI HIGH (card expects high during idle)
  pinl(PIN_SD_SCK)                                                                     '  SCK LOW (SPI mode 0 idle state)
  wrpin(PIN_MISO, P_HIGH_15K)
  pinf(PIN_MISO)                                                                    '  MISO as input with pull-up active
  waitus(10)                                                                    '  Let pull-up settle

  debug[CH_INIT]("    [initCard] Pins: CS=", udec_(pinr(PIN_SD_CS)), " MOSI=", udec_(pinr(PIN_MOSI)), " MISO=", udec_(pinr(PIN_MISO)), " SCK=", udec_(pinr(PIN_SD_SCK)))

  ' ============================================
  ' STEP 3: Card recovery + init clocks
  ' If card is stuck mid-transfer, flush with extra clocks
  ' Then send 74+ clocks per spec for power-on init
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 3: Recovery flush (4096 clocks to clear stuck transfer)...")
  repeat GPIO_FLUSH_CYCLES                                                                     '  Enough to flush a full 512-byte sector
    pinh(PIN_SD_SCK)
    waitus(10)
    pinl(PIN_SD_SCK)
    waitus(10)

  debug[CH_INIT]("    [initCard] MISO after recovery flush: ", udec_(pinr(PIN_MISO)), " (should be 1)")

  ' ============================================
  ' STEP 3.5: Initialize smart pins for SPI
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 3.5: Initializing smart pins (ManAtWork pattern)...")
  initSPIPins()
  do_set_spi_speed(SD_INIT_SPEED_HZ)                                                          ' 400 kHz for init
  waitus(100)                                                                   ' Let smart pins settle

  ' Send dummy clocks using smart pins
  repeat 10
    sp_transfer_8($FF)
  debug[CH_INIT]("    [initCard] Dummy clocks sent via smart pins")

  ' ============================================
  ' STEP 4: CMD0 - GO_IDLE_STATE
  ' Sends: 0x40 0x00 0x00 0x00 0x00 0x95
  ' Expected R1: 0x01 (in idle state)
  ' ============================================
  debug[CH_INIT]("    [initCard] Step 4: CMD0 (GO_IDLE_STATE)...")
  got_response := false
  resp := 0
  repeat CMD0_MAX_RETRIES
    resp := cmd(CMD0, 0)
    debug[CH_INIT]("    [initCard] CMD0 response: $", uhex_(resp))
    if resp <> 0
      got_response := true
    if resp == R1_IN_IDLE
      quit
    waitms(CMD_RETRY_DELAY_MS)

  if resp <> R1_IN_IDLE
    if got_response
      debug[CH_INIT]("    [initCard] FAIL: CMD0 got response $", uhex_(resp), " but not $01 (idle)")
      last_init_error := E_BAD_RESPONSE
    else
      debug[CH_INIT]("    [initCard] FAIL: CMD0 no response (no card or wiring fault)")
      last_init_error := E_NO_CARD
    ok := false

  else
    debug[CH_INIT]("    [initCard] CMD0 OK - card in idle state")

    ' ============================================
    ' STEP 5: CMD8 - SEND_IF_COND
    ' Sends: 0x48 0x00 0x00 0x01 0xAA 0x87
    ' Argument: VHS=0x01 (2.7-3.6V), check_pattern=0xAA
    ' Expected R7: R1 + 4 bytes echoing VHS and pattern
    ' ============================================
    debug[CH_INIT]("    [initCard] Step 5: CMD8 (SEND_IF_COND, VHS=1, pattern=$AA)...")
    resp := cmd(8, $000001AA)                                                     '  send CMD8, get 32-bit echo
    debug[CH_INIT]("    [initCard] CMD8 response (32-bit): $", uhex_long(resp))

    card_version := 1                                                             '  assume v1.x until proven otherwise
    acmd41_arg := $00000000                                                       '  HCS=0 for v1.x cards

    if resp == 0                                                                  '  timeout or no response
      debug[CH_INIT]("    [initCard] CMD8 no response -> Ver 1.x SD card (SDSC only)")
      card_version := 1
      acmd41_arg := $00000000                                                     '  no HCS for v1.x
    elseif (resp & $FFF) == $1AA                                                  '  check VHS and pattern echo
      debug[CH_INIT]("    [initCard] CMD8 echo valid ($1AA) -> Ver 2.0+ SD card")
      card_version := 2
      acmd41_arg := $40000000                                                     '  HCS=1 for v2.0+ (support SDHC/SDXC)
    else
      debug[CH_INIT]("    [initCard] CMD8 echo unexpected: $", uhex_long(resp & $FFF), " expected $1AA")
      debug[CH_INIT]("    [initCard] Treating as Ver 1.x card")
      card_version := 1
      acmd41_arg := $00000000

    ' Save acmd41_arg for reinitCard() use
    saved_acmd41_arg := acmd41_arg

    ' ============================================
    ' STEP 6: ACMD41 - SD_SEND_OP_COND (loop until ready)
    ' Requires CMD55 prefix before each ACMD41
    ' CMD55: 0x77 0x00 0x00 0x00 0x00 0x65
    ' ACMD41: 0x69 [arg] CRC
    ' Expected R1: 0x00 when ready, 0x01 while initializing
    ' ============================================
    debug[CH_INIT]("    [initCard] Step 6: ACMD41 init loop (arg=$", uhex_long(acmd41_arg), ")...")
    timeout := getct() + clkfreq * INIT_TIMEOUT_SEC                                                    '  2 second timeout

    repeat
      resp := cmd(55, 0)                                                          '  APP_CMD prefix
      if resp > $01                                                               '  error other than "in idle"
        debug[CH_INIT]("    [initCard] CMD55 error: $", uhex_(resp))
        waitms(10)
      else
        resp := cmd(41, acmd41_arg)                                               '  SD_SEND_OP_COND
        if resp == $00                                                            '  card ready (not in idle anymore)
          debug[CH_INIT]("    [initCard] ACMD41 complete - card ready!")
          quit
        elseif resp == $01                                                        '  still initializing
          ' continue looping
        else
          debug[CH_INIT]("    [initCard] ACMD41 unexpected response: $", uhex_(resp))

      if getct() - timeout > 0
        debug[CH_INIT]("    [initCard] FAIL: ACMD41 timeout after 2 seconds")
        debug[CH_INIT]("    [initCard] Last response: $", uhex_(resp))
        last_init_error := E_TIMEOUT
        ok := false
        quit
      else
        waitms(10)

    ' ACMD41 succeeded if resp is $00 (card ready)
    if resp == $00
      ok := true

    if ok
      ' ============================================
      ' STEP 7: CMD58 - READ_OCR
      ' Sends: 0x7A 0x00 0x00 0x00 0x00 0xFD
      ' Expected R3: R1 + 32-bit OCR register
      ' Check bit 31 (busy), bit 30 (CCS)
      ' ============================================
      debug[CH_INIT]("    [initCard] Step 7: CMD58 (READ_OCR)...")
      resp := cmd(58, 0)
      ocr_value := resp                                                             '  Cache OCR for later retrieval
      debug[CH_INIT]("    [initCard] OCR: $", uhex_long(resp))
      debug[CH_INIT]("    [initCard]   Bit 31 (ready): ", udec((resp >> 31) & 1))
      debug[CH_INIT]("    [initCard]   Bit 30 (CCS):   ", udec((resp >> 30) & 1))

      if (resp >> 30) & 1
        hcs := 0                                                                    '  SDHC/SDXC: block addressing (no shift)
        debug[CH_INIT]("    [initCard] Card type: SDHC/SDXC (block addressing)")
      else
        hcs := 9                                                                    '  SDSC: byte addressing (shift by 9 = multiply by 512)
        debug[CH_INIT]("    [initCard] Card type: SDSC (byte addressing)")

      ' ============================================
      ' STEP 8: Identify card and set optimal SPI speed
      ' Reads CID for manufacturer ID, CSD for TRAN_SPEED
      ' PNY cards ($1D) limited to 20 MHz due to timing sensitivity
      ' ============================================
      pinh(PIN_SD_CS)                                                                      '  ensure CS HIGH before CID/CSD read
      debug[CH_INIT]("    [initCard] Step 8: Card identification and speed selection...")
      identifyCard()                                                                '  read CID/CSD, identify manufacturer
      setOptimalSpeed()                                                             '  set speed based on card type
      ' Send dummy clocks with CS HIGH to stabilize new clock rate
      repeat 8
        sp_transfer(-1, 8)                                                          '  8 dummy bytes = 64 clocks (using smart pins)
      debug[CH_INIT]("    [initCard] Dummy clocks sent, CS HIGH")

      ' ============================================
      ' STEP 9: Probe CMD13 reliability
      ' ============================================
      cmd13_reliable := TRUE
      card_warning_flags := CW_NONE
      probeCmd13()

      ' ============================================
      ' STEP 10: Check CMD23 support from SCR CMD_SUPPORT field
      ' ============================================
      probeCmd23()

      debug[CH_INIT]("    [initCard] === INIT SUCCESS ===")
      ok := true


PRI cmd(op,parm) : response | timeout
' Send a SPI command using smart pins - sends command byte, argument, and CRC.
' Handles R1, R3, and R7 response formats based on command type.
'
' @param op - Command number (0-63)
' @param parm - 32-bit command argument
' @returns response - R1 response, or R3/R7 32-bit value for CMD8/CMD58
' @local timeout - Timeout counter

  if op == 0
    debug[CH_INIT]("      [cmd] CS before assert: ", udec_(pinr(PIN_SD_CS)))
  sp_transfer(-1,8)                                                             '  required for certain cards (my 512MB card fails if not present)
  pinl(PIN_SD_CS)                                                                      '  CS LOW = selected (standard active-LOW)
  if op == 0
    debug[CH_INIT]("      [cmd] CS after pinl: ", udec_(pinr(PIN_SD_CS)), " MISO=", udec_(pinr(PIN_MISO)))
  sp_transfer(-1,8)                                                             '  required for certain cards (my 512MB and 32GB cards fail if not present)
  sp_transfer($40 | op,8)
  sp_transfer(parm,32)
  if op == 0
    sp_transfer($95,8)                                                          '  send CRC for cmd(0,0)
    debug[CH_INIT]("      [cmd] After CMD0 sent, MISO=", udec_(pinr(PIN_MISO)))
  else
    sp_transfer($87,8)                                                          '  send CRC for cmd(8,$1AA)
  timeout := getct() + clkfreq
  repeat
    response := sp_transfer(-1,8)                                                 '  read 1st byte of reply
    if (response & $80) == 0                                                       '  valid R1 has bit 7 = 0 (SD spec 7.3.2.1)
      if op == 8 or op == 58                                                    '  read 32-bit reply for cmd8 and cmd58
        response := sp_transfer(-1,32)                                            '  (memory card interface condition and operation conditions register
      if op <> 17 and op <> 24 and op <> CMD18 and op <> CMD25 and op <> 55     '  keep CS asserted for sector read/write and application commands
        pinh(PIN_SD_CS)                                                                '  CS HIGH = deselected (standard active-LOW)
      quit
    if getct() - timeout > 0                                                     '  check timeout
      pinh(PIN_SD_CS)                                                                  '  CS HIGH = deselected (standard active-LOW)
      response := false
      quit

PRI readSector(sector, buf_type) : status | data, loop_ctr, timeout, stream_mode, clk_count, xfrq, init_phase, p_buf, align_delay, p_cache, attempt
' Read a sector into buffer using P2 streamer - hardware DMA for bulk 512-byte transfer.
' Reference: flash_loader.spin2 pattern for SPI reads
'
' Protocol:
' 1. CMD17 (READ_SINGLE_BLOCK) with sector address
' 2. Wait for $FE start token (polled via sp_transfer_8)
' 3. Receive 512 bytes via streamer (MISO -> hub)
' 4. Receive 2 CRC bytes, validate against calculated CRC
' 5. Deselect card
'
' @param sector - Sector number to read
' @param buf_type - Buffer type: BUF_DIR, BUF_FAT, or BUF_DATA
' @returns status - 0 on success, -1 on timeout/error
' @local data - Received data/token
' @local loop_ctr - Token polling counter
' @local timeout - Timeout deadline
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local init_phase - Streamer initial phase
' @local p_buf - Pointer to destination buffer
' @local align_delay - Alignment delay before streamer
' @local p_cache - Pointer to cache variable

  ' Select buffer and cache based on type
  case buf_type
    BUF_DIR:
      p_buf := @dir_buf
      p_cache := @dir_sec_in_buf
    BUF_FAT:
      p_buf := @fat_buf
      p_cache := @fat_sec_in_buf
    other:  ' BUF_DATA or default
      p_buf := @buf
      p_cache := @sec_in_buf

  if sector == long[p_cache]
    'if buf_type == BUF_DIR
    '  debug("  [readSector] CACHE HIT sector ", udec_(sector), " bytes: $", uhex_byte_(byte[p_buf]), " $", uhex_byte_(byte[p_buf+1]), " $", uhex_byte_(byte[p_buf+2]))
    status := 0
  'debug("  [readSector] Reading sector ", udec_(sector), " type=", udec_(buf_type), " p_buf=", uhex_(p_buf))
  else
    long[p_cache] := sector

    ' Pre-compute streamer constants (invariant across retries)
    stream_mode := STREAM_RX_BASE | (PIN_MISO << 17) | (SECTOR_SIZE * 8)                  ' RX mode + MISO pin + bit count
    clk_count := SECTOR_SIZE * 8 * 2                                                      ' 8192 clock transitions
    xfrq := $4000_0000 / spi_period                                               ' One sample per full clock period
    init_phase := $4000_0000                                                      ' Sample mid-bit for stability
    align_delay := spi_period                                                     ' Wait one half-period before streamer

    ' ============================================================================
    ' CRC RETRY LOOP: Re-read on CRC mismatch (industry standard practice)
    ' Card has no CRC-error state - it just sees another CMD17 on retry
    ' ============================================================================
    repeat attempt from 1 to MAX_READ_CRC_RETRIES

      ' Send CMD17 (READ_SINGLE_BLOCK)
      cmd(17, sector << hcs)

      ' Wait for start token ($FE) - use sp_transfer_8 for token polling
      timeout := getct() + (clkfreq / 100) * card_read_timeout_ms                 ' CSD-based timeout with 10x margin
      loop_ctr := 0
      repeat
        data := sp_transfer_8($FF)
        loop_ctr++
        if data == $FE
          quit                                                                    ' Got start token
        if data <> $FF
          debug[CH_SECTOR]("  [readSector] ERROR: got $", uhex_byte_(data), " instead of $FF or $FE")
          pinh(PIN_SD_CS)
          long[p_cache] := -1
          status := E_BAD_RESPONSE
          quit
        elseif getct() - timeout > 0
          debug[CH_SECTOR]("  [readSector] TIMEOUT waiting for start token")
          pinh(PIN_SD_CS)
          long[p_cache] := -1
          status := E_TIMEOUT
          quit

      if status < 0
        quit                                                                     ' Exit retry loop on token error/timeout

      ' ==========================================================================
      ' STREAMER BULK TRANSFER: Receive 512 bytes from MISO to hub buffer
      ' Pattern: SETXFRQ -> WRFAST -> WYPIN(clk) -> WAITX -> XINIT -> WAITXFI
      ' CRITICAL: Must disable MISO smart pin before streamer capture!
      ' ==========================================================================

      ' CRITICAL FIX: Disable MISO smart pin before streamer capture
      ' The smart pin interferes with streamer's direct pin reading
      ' Reference: flash_loader.spin2 does NOT configure smart pin on MISO during reads
      ' Verified fix: 2026-01-23 in SD_streamer_lut_test.spin2
      pinclear(PIN_MISO)                                                           ' Clear smart pin mode
      pinf(PIN_MISO)                                                               ' Float pin (input mode)

      ' DIAGNOSTIC: Capture buffer state BEFORE streamer
      diag_before_b0 := byte[p_buf]
      diag_before_b1 := byte[p_buf+1]
      diag_before_b2 := byte[p_buf+2]
      diag_before_b3 := byte[p_buf+3]
      diag_spi_period := spi_period

      ' ==========================================================================
      ' STREAMER BULK TRANSFER: 512 bytes from MISO to hub via DMA
      ' ==========================================================================
      org
            dirl    #PIN_SD_SCK                       ' Reset SCK: counter stops, output LOW, Y=0
            drvl    #PIN_SD_SCK                       ' Re-enable: DIR=1 restarts base period counter fresh
            setxfrq xfrq                              ' Set streamer NCO rate
            wrfast  #0, p_buf                         ' Setup WRFAST to hub buffer
            wypin   clk_count, #PIN_SD_SCK            ' Start clock transitions
            waitx   align_delay                       ' Wait one half-period to align with first rising edge
            xinit   stream_mode, init_phase           ' Start streamer with phase offset
            waitxfi                                   ' Wait for streamer to complete
      end

      ' DIAGNOSTIC: Capture data for test cog to read
      diag_last_sector := sector
      diag_last_buftype := buf_type
      diag_last_token := data                                                     ' Start token ($FE if success)
      diag_p_buf := p_buf
      diag_buf_byte0 := byte[p_buf]
      diag_buf_byte1 := byte[p_buf+1]
      diag_buf_byte2 := byte[p_buf+2]
      diag_buf_byte3 := byte[p_buf+3]

      ' Re-enable MISO smart pin for CRC reads (sp_transfer_8 needs it)
      wrpin(PIN_MISO, spi_rx_mode)                                                ' P_SYNC_RX | P_PLUS3_B
      wxpin(PIN_MISO, %1_00111)                                                   ' On-edge sample, 8 bits
      pinh(PIN_MISO)                                                              ' DIRH - enable smart pin

      ' Read and capture 2 CRC bytes (high byte first per SD protocol)
      diag_recv_crc := sp_transfer_8($FF) << 8
      diag_recv_crc |= sp_transfer_8($FF)

      ' CRC-16 validation: always validate received data against card's CRC
      diag_calc_crc := calcDataCRC(p_buf, SECTOR_SIZE)
      ' TEST HOOK: Force CRC mismatch for error injection testing
      if test_force_read_crc_error > 0
        diag_calc_crc ^= $FFFF
        test_force_read_crc_error--
        test_error_count++
      if diag_calc_crc == diag_recv_crc
        diag_crc_matches++
        pinh(PIN_SD_CS)                                                                  ' Deselect card - CRC OK
        quit                                                                      ' Exit retry loop on success
      else
        diag_crc_mismatches++
        pinh(PIN_SD_CS)                                                                  ' Deselect card before retry
        sp_transfer_8($FF)                                                        ' 8 NCS recovery clocks (CS HIGH, SD spec)
        if attempt < MAX_READ_CRC_RETRIES
          diag_crc_retries++
          debug[CH_SECTOR]("  [readSector] CRC MISMATCH attempt ", udec_(attempt), "/", udec_(MAX_READ_CRC_RETRIES), " recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc), " - retrying")
          long[p_cache] := -1                                                     ' Invalidate cache before retry
        else
          debug[CH_SECTOR]("  [readSector] CRC FAILED after ", udec_(MAX_READ_CRC_RETRIES), " attempts recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc))
          long[p_cache] := -1                                                     ' Invalidate cache on failure
          status := E_CRC_ERROR
          quit

    ' CMD13: Verify card internal state after read
    ' CRC validates wire integrity; CMD13 validates card-internal state (ECC, address, etc.)
    if status >= 0
      if checkCardStatus(@"readSector") < 0
        long[p_cache] := -1                                                         ' Invalidate cache on card error
        status := E_BAD_RESPONSE

      else
        status := 0

PRI transfer(data,bits) : rx_data | delay
' Transfer data to/from SD card - bit-bang fallback for unsupported sizes.
'
' @param data - Data to transmit
' @param bits - Number of bits to transfer
' @returns rx_data - Received data
' @local delay - Bit delay value

  delay := bit_delay
  rx_data := data << (32-bits)                                                   '  move data to MSB
  org
                rep       @.end_rep,bits
                 rcl      rx_data,#1                     wc                      '  send from msb of rx_data, receive into lsb of rx_data
                 drvl     #PIN_SD_SCK
                 drvc     #PIN_MOSI
                 waitx    delay
                 drvh     #PIN_SD_SCK
                 waitx    delay
                 testp    #PIN_MISO                     wc
.end_rep
                drvh      #PIN_MOSI
                rcl       rx_data,#1
  end
  if bits < 32                                                                   '  mask to requested bit count
    rx_data &= (1 << bits) - 1                                                   '  (skip for 32 bits - mask would wrap)

PRI readSectors(start_sector, count, p_buffer) : sectors_read | p_buf, stream_mode, clk_count, xfrq, init_phase, align_delay, idx, resp
' Read multiple consecutive sectors using CMD18 (READ_MULTIPLE_BLOCK).
' More efficient than individual readSector() calls because:
' - Only one CMD18 command instead of N CMD17 commands
' - No inter-sector gaps from CS deassert/reassert
' - Card can pre-fetch ahead for sequential access
'
' Protocol: CMD18 -> (wait $FE -> read 512 bytes -> CRC) x N -> CMD12
'
' @param start_sector - First sector to read
' @param count - Number of sectors to read (0 returns immediately)
' @param p_buffer - Pointer to buffer (must be at least count * 512 bytes)
' @returns sectors_read - Number of sectors successfully read (0 on error)
' @local p_buf - Current buffer position
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local init_phase - Streamer initial phase
' @local align_delay - Alignment delay before streamer
' @local idx - Loop counter (unused)
' @local resp - Command response

  if count == 0
    sectors_read := 0

  ' Setup variables for streamer
  else
    stream_mode := STREAM_RX_BASE | (PIN_MISO << 17) | (SECTOR_SIZE * 8)                  ' RX mode + MISO pin + 4096 bits
    clk_count := SECTOR_SIZE * 8 * 2                                                      ' 8192 clock transitions
    xfrq := $4000_0000 / spi_period                                               ' One sample per full clock period
    init_phase := $4000_0000                                                      ' Sample mid-bit for stability
    align_delay := spi_period                                                     ' Wait one half-period before streamer

    ' Clear diagnostic state and send CMD23 preamble if supported
    last_cmd18_fail := 0                                                        ' Clear failure path
    last_cmd23_used := FALSE
    last_cmd23_r1 := $FF                                                        ' Default: not sent
    last_cmd23_verify := $FF                                                    ' Default: idle
    if cmd23_supported
      resp := cmd(CMD23, count)
      last_cmd23_r1 := resp
      last_cmd23_used := TRUE
      debug[CH_SECTOR]("  [readSectors] CMD23 set block count=", udec_(count))

    ' Send CMD18 (READ_MULTIPLE_BLOCK) with starting sector
    ' Note: cmd() handles CS assertion and returns R1 response
    resp := cmd(CMD18, start_sector << hcs)
    last_cmd18_r1 := resp
    if resp <> $00
      last_cmd18_fail := 1                                                      ' Path 1: R1 reject
      debug[CH_SECTOR]("  [readSectors] CMD18 failed, R1=$", uhex_byte_(resp))
      pinh(PIN_SD_CS)
      sectors_read := 0

    ' Read each sector
    else
      sectors_read := 0
      repeat count
        p_buf := p_buffer + (sectors_read * SECTOR_SIZE)                                    ' Calculate buffer position

        ' Wait for data token ($FE) for this sector
        if waitDataToken() < 0
          last_cmd18_fail := 2                                                  ' Path 2: data token fail
          debug[CH_SECTOR]("  [readSectors] No data token for sector ", udec_(start_sector + sectors_read))
          quit                                                                      ' Exit loop on error

        ' Disable MISO smart pin before streamer capture
        pinclear(PIN_MISO)
        pinf(PIN_MISO)

        ' Streamer bulk transfer: 512 bytes from MISO to hub
        org
              dirl    #PIN_SD_SCK                       ' Reset SCK: counter stops, output LOW, Y=0
              drvl    #PIN_SD_SCK                       ' Re-enable: DIR=1 restarts base period counter fresh
              setxfrq xfrq
              wrfast  #0, p_buf
              wypin   clk_count, #PIN_SD_SCK
              waitx   align_delay
              xinit   stream_mode, init_phase
              waitxfi
        end

        ' Re-enable MISO smart pin for CRC reads
        wrpin(PIN_MISO, spi_rx_mode)
        wxpin(PIN_MISO, %1_00111)
        pinh(PIN_MISO)

        ' Read and capture 2 CRC bytes, validate against calculated CRC
        diag_recv_crc := sp_transfer_8($FF) << 8
        diag_recv_crc |= sp_transfer_8($FF)

        if diag_crc_enabled
          diag_calc_crc := calcDataCRC(p_buf, SECTOR_SIZE)
          if diag_calc_crc == diag_recv_crc
            diag_crc_matches++
          else
            diag_crc_mismatches++
            debug[CH_SECTOR]("  [readSectors] CRC MISMATCH sec ", udec_(start_sector + sectors_read), " recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc))

        sectors_read++

      ' Capture sectors actually read before CMD12/CMD13 might zero the count
      last_cmd18_sread := sectors_read

      if last_cmd23_used
        ' CMD23 path: card should have auto-stopped after N sectors
        ' Verify: clock one byte - if card stopped, MISO should be $FF (idle)
        resp := sp_transfer_8($FF)
        last_cmd23_verify := resp
        if resp <> $FF
          debug[CH_SECTOR]("  [readSectors] CMD23 WARNING: card still outputting after count reached ($", uhex_byte_(resp), ")")
          ' Card didn't honor CMD23 auto-stop - fall back to CMD12 for this and future reads
          cmd23_supported := FALSE
          last_cmd23_used := FALSE
          sendStopTransmission()
        pinh(PIN_SD_CS)                                                                ' Deselect card
        debug[CH_SECTOR]("  [readSectors] CMD23 path: ", udec_(sectors_read), " sectors, no CMD12 needed")

        ' CMD13: Verify card internal state after multi-block read
        if checkCardStatus(@"readSectors") < 0
          last_cmd18_fail := 4                                                  ' Path 4: CMD13 fail
          debug[CH_SECTOR]("  [readSectors] CMD13 status check FAILED")
          sectors_read := 0                                                     ' Card reports error - data can't be trusted
      else
        ' CMD12 path: send CMD12 to stop transmission
        if sendStopTransmission() < 0
          ' CMD12 failed - but if all requested sectors arrived with valid CRC,
          ' the data is trustworthy. Some cards return garbled R1 from CMD12
          ' while data transfer is perfect.
          recoverToIdle()                                                       ' Force card back to idle
          if sectors_read == count
            last_cmd18_fail := 5                                                ' Path 5: CMD12 fail, tolerated
            debug[CH_SECTOR]("  [readSectors] CMD12 R1 error (tolerated, all ", udec_(count), " sectors received)")
          else
            last_cmd18_fail := 3                                                ' Path 3: CMD12 fail, data incomplete
            debug[CH_SECTOR]("  [readSectors] CMD12 failed - incomplete read, recovering")
            sectors_read := 0                                                   ' Incomplete data can't be trusted
        else
          pinh(PIN_SD_CS)                                                              ' Deselect card

          ' CMD13: Verify card internal state after multi-block read
          if checkCardStatus(@"readSectors") < 0
            last_cmd18_fail := 4                                                ' Path 4: CMD13 fail
            debug[CH_SECTOR]("  [readSectors] CMD13 status check FAILED")
            sectors_read := 0                                                   ' Card reports error - data can't be trusted

PRI writeSector(sector, buf_type) : ok | p_buf, stream_mode, clk_count, xfrq, timeout, resp, p_cache, align_delay
' Write buffer into a sector using P2 streamer - hardware DMA for bulk 512-byte transfer.
' Reference: flash_loader.spin2 pattern for SPI writes
'
' PNY COMPATIBILITY: This implementation follows strict SPI write protocol:
' 1. CMD24 with sector address
' 2. Data start token ($FE)
' 3. 512 bytes of data via streamer (hub -> MOSI)
' 4. 2 CRC bytes (calculated CRC-16-CCITT, high byte first)
' 5. Wait for data-response token ($x5 = accepted)
' 6. Wait for MISO to go HIGH ($FF = programming complete)
' CRITICAL: CS must stay LOW and clocking must continue during entire busy period!
'
' @param sector - Sector number to write
' @param buf_type - Buffer type: BUF_DIR, BUF_FAT, or BUF_DATA
' @returns ok - TRUE on success, FALSE on failure
' @local p_buf - Pointer to source buffer
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local timeout - Timeout counter
' @local resp - Response byte
' @local p_cache - Pointer to cache variable

  ' Select buffer and cache based on type
  case buf_type
    BUF_DIR:
      p_buf := @dir_buf
      p_cache := @dir_sec_in_buf
    BUF_FAT:
      p_buf := @fat_buf
      p_cache := @fat_sec_in_buf
    other:  ' BUF_DATA or default
      p_buf := @buf
      p_cache := @sec_in_buf

  ' p_buf already set above based on buf_type

  ' Invalidate cache for this buffer type after write
  long[p_cache] := -1

  ' Cross-buffer cache coherence: if another buffer type has this
  ' sector cached, its copy is now stale after our write
  if dir_sec_in_buf == sector
    dir_sec_in_buf := -1
  if fat_sec_in_buf == sector
    fat_sec_in_buf := -1
  if sec_in_buf == sector
    sec_in_buf := -1

  ' Capture sector for diagnostics
  diag_write_sector := sector
  diag_write_result := 0                                                         ' Reset: not yet determined

  resp := cmd(24, sector << hcs)
  diag_write_r1 := resp                                                          ' Capture CMD24 R1 response
  if resp & $64                                                                  ' Fatal R1 bits: illegal cmd ($04), address err ($20), parameter err ($40)
    debug[CH_SECTOR]("  [writeSector] CMD24 FATAL, R1=$", uhex_byte_(resp))
    diag_write_result := 1                                                       ' 1 = CMD24 fatal
    pinh(PIN_SD_CS)
    ok := false
  else
    if resp & $1B                                                                  ' Stale R1 bits: idle ($01), erase reset ($02), CRC ($08), erase seq ($10)
      debug[CH_SECTOR]("  [writeSector] CMD24 warning: R1=$", uhex_byte_(resp), " (stale bits, proceeding)")
    sp_transfer_8($FE)                                                            ' Data start token

    ' ============================================================================
    ' STREAMER BULK TRANSFER: Send 512 bytes from hub buffer to MOSI
    ' Pattern: SETXFRQ -> RDFAST -> XINIT -> WYPIN(clk) -> WAITXFI
    ' ============================================================================
    ' Mode word format: base_mode | (pin << 17) | bit_count
    ' For 512 bytes: 512 * 8 = 4096 bits = $1000
    stream_mode := STREAM_TX_BASE | (PIN_MOSI << 17) | (SECTOR_SIZE * 8)                   ' TX mode + MOSI pin + bit count
    clk_count := SECTOR_SIZE * 8 * 2                                                      ' 8192 clock transitions

    ' Calculate streamer NCO frequency to match SPI clock
    ' Same formula as readSector: one bit per full clock period
    xfrq := $4000_0000 / spi_period                                               ' One output per full clock period
    if ($4000_0000 // spi_period) == 0                                             ' Exact division (power-of-2 hp)?
      xfrq -= 1                                                                   ' Ensure 1-cycle late rollover like truncated values
    align_delay := spi_period - 2                                                  ' NCO ramp delay minus 2 instruction cycles

    pinclear(PIN_MOSI)                                                             ' Clear smart pin mode (WRPIN=0, DIR=0)
    pinl(PIN_MOSI)                                                                 ' Drive pin low (DIR=1, output mode)

    ' Streamer TX with deterministic clock alignment:
    '   1. dirl/pinl on SCK resets the P_TRANSITION base-period counter to a known state
    '      (DIR=0 resets counter, output, Y without clearing WRPIN/WXPIN config)
    '   2. xinit starts streamer NCO from phase=0
    '   3. waitx gives NCO time to output first data bit before first SCK edge
    '   4. wypin starts clock - base period counter phase is now deterministic
    '      (not dependent on free-running counter from init)
    '
    ' Timing (all relative to pinl, each PASM instruction = 2 sysclk cycles):
    '   T=0:  pinl (SCK counter starts fresh)
    '   T=2:  setxfrq
    '   T=4:  rdfast
    '   T=6:  xinit (streamer NCO starts; first data bit at T=6 + 2*spi_period)
    '   T=8:  waitx begins (waits align_delay cycles)
    '   T=8+align_delay: wypin (clock starts; first edge at next base period boundary)
    org
          dirl    #PIN_SD_SCK                       ' Reset SCK: counter stops, output LOW, Y=0
          drvl    #PIN_SD_SCK                       ' Re-enable: DIR=1 restarts base period counter fresh
          setxfrq xfrq                              ' Set streamer bit rate
          rdfast  #0, p_buf                         ' Setup RDFAST from hub buffer
          xinit   stream_mode, #0                    ' Start streamer; NCO ramps from zero
          waitx   align_delay                        ' Wait for NCO to output first data bit
          wypin   clk_count, #PIN_SD_SCK            ' Start clock - deterministic phase from drvl
          waitxfi                                   ' Wait for streamer to complete
    end

    ' Rebuild MOSI smart pin for CRC and response byte transfers
    wrpin(PIN_MOSI, spi_tx_mode)                                                  ' P_SYNC_TX | P_OE | P_PLUS2_B
    wxpin(PIN_MOSI, %1_00111)                                                     ' Start-stop mode, 8 bits
    pinh(PIN_MOSI)                                                                ' DIRH - enable smart pin

    ' Calculate CRC-16 of the data we just sent and transmit it
    ' SD protocol: CRC high byte first, then low byte
    diag_sent_crc := calcDataCRC(p_buf, SECTOR_SIZE)
    ' TEST HOOK: Corrupt write CRC for error injection testing (one-shot)
    if test_force_write_crc_error
      diag_sent_crc ^= $FFFF
      test_force_write_crc_error := 0
      test_error_count++
    sp_transfer_8(diag_sent_crc >> 8)                                             ' CRC high byte
    sp_transfer_8(diag_sent_crc & $FF)                                            ' CRC low byte

    ' Wait for data-response token (should be immediate, within a few bytes)
    timeout := getct() + clkfreq / RESPONSE_TIMEOUT_DIV                                  ' 100ms timeout for response
    repeat
      resp := sp_transfer_8($FF)
      if resp <> $FF
        quit
      if getct() - timeout > 0
        debug[CH_SECTOR]("  [writeSector] TIMEOUT waiting for data-response")
        diag_write_result := 2                                                     ' 2 = data-response timeout
        diag_write_dresp := $FF
        pinh(PIN_SD_CS)
        ok := false
        quit

    if resp <> $FF
      diag_write_dresp := resp                                                     ' Capture data response token
      ' Verify data-response token: bits [3:1] decode as: 010=accepted, 101=CRC error, 110=write error
      if (resp & $1F) <> $05
        if (resp & $1F) == $0B
          debug[CH_SECTOR]("  [writeSector] Data REJECTED: CRC error (response=$", uhex_byte_(resp), ")")
          diag_write_result := 3                                                   ' 3 = CRC reject
        elseif (resp & $1F) == $0D
          debug[CH_SECTOR]("  [writeSector] Data REJECTED: Write error (response=$", uhex_byte_(resp), ")")
          diag_write_result := 4                                                   ' 4 = write error reject
        else
          debug[CH_SECTOR]("  [writeSector] Data REJECTED: Unknown status (response=$", uhex_byte_(resp), ")")
          diag_write_result := 5                                                   ' 5 = unknown reject
        pinh(PIN_SD_CS)
        ok := false

      ' Wait for card to finish programming (busy period)
      ' Card holds MISO LOW during internal flash write, releases to HIGH ($FF) when done
      ' CRITICAL for PNY: Keep CS LOW and keep clocking until we see stable $FF!
      else
        timeout := getct() + (clkfreq / 1000) * card_write_timeout_ms                     ' CSD-based timeout
        repeat
          resp := sp_transfer_8($FF)                                                ' Clock 8 bits while reading MISO
          if resp == $FF                                                            ' Card released MISO = programming complete
            quit
          if getct() - timeout > 0
            debug[CH_SECTOR]("  [writeSector] TIMEOUT waiting for programming complete")
            diag_write_result := 6                                                   ' 6 = busy timeout
            pinh(PIN_SD_CS)
            ok := false
            quit

        if resp == $FF
          pinh(PIN_SD_CS)

          diag_write_result := 7                                                     ' 7 = success

          ' CMD13: Verify card internal state after write
          ' Data response $05 confirms wire-level acceptance; CMD13 validates card-internal state
          if checkCardStatus(@"writeSector") < 0
            ok := false

          else
            ok := true

PRI writeSectors(start_sector, count, p_buffer) : sectors_written | p_buf, stream_mode, clk_count, xfrq, resp, align_delay
' Write multiple consecutive sectors using CMD25 (WRITE_MULTIPLE_BLOCK).
' More efficient than individual writeSector() calls because:
' - Only one CMD25 command instead of N CMD24 commands
' - Card can optimize internal flash writes for sequential access
' - Reduced overhead from CS cycling and command processing
'
' CRITICAL: Multi-block write uses different tokens than single-block!
' - Each data block uses $FC (not $FE) as start token
' - Transmission ends with $FD stop token (not CMD12!)
'
' Protocol: CMD25 -> ($FC + 512 bytes + CRC + wait busy) x N -> $FD -> wait busy
'
' @param start_sector - First sector to write
' @param count - Number of sectors to write (0 returns immediately)
' @param p_buffer - Pointer to source data (must be at least count * 512 bytes)
' @returns sectors_written - Number of sectors successfully written (0 on error)
' @local p_buf - Current buffer position
' @local stream_mode - Streamer mode word
' @local clk_count - Number of clock transitions
' @local xfrq - Streamer NCO frequency
' @local resp - Response byte
  '' - Reduced overhead from CS cycling and command processing
  ''
  '' CRITICAL: Multi-block write uses different tokens than single-block!
  '' - Each data block uses $FC (not $FE) as start token
  '' - Transmission ends with $FD stop token (not CMD12!)
  ''
  '' Protocol: CMD25 -> ($FC + 512 bytes + CRC + wait busy) x N -> $FD -> wait busy

  if count == 0
    sectors_written := 0

  ' Setup variables for streamer
  else
    stream_mode := STREAM_TX_BASE | (PIN_MOSI << 17) | (SECTOR_SIZE * 8)                   ' TX mode + MOSI pin + 4096 bits
    clk_count := SECTOR_SIZE * 8 * 2                                                      ' 8192 clock transitions
    xfrq := $4000_0000 / spi_period                                               ' One output per full clock period
    if ($4000_0000 // spi_period) == 0                                             ' Exact division (power-of-2 hp)?
      xfrq -= 1                                                                   ' Ensure 1-cycle late rollover like truncated values
    align_delay := spi_period - 2                                                  ' NCO ramp delay minus 2 instruction cycles

    ' Send CMD25 (WRITE_MULTIPLE_BLOCK) with starting sector
    ' Note: cmd() handles CS assertion and returns R1 response
    resp := cmd(CMD25, start_sector << hcs)
    if resp <> $00
      debug[CH_SECTOR]("  [writeSectors] CMD25 failed, R1=$", uhex_byte_(resp))
      pinh(PIN_SD_CS)
      sectors_written := 0

    ' Write each sector
    else
      sectors_written := 0
      repeat count
        p_buf := p_buffer + (sectors_written * 512)                                 ' Calculate buffer position

        ' Send multi-block write start token ($FC, NOT $FE!)
        sp_transfer_8(TOKEN_START_MULTI_WRITE)                                      ' $FC

        pinclear(PIN_MOSI)                                                             ' Clear smart pin mode
        pinl(PIN_MOSI)                                                                 ' Drive pin low (output mode)

        ' Streamer TX with deterministic clock alignment (see writeSector for full rationale)
        ' dirl/drvl resets SCK base-period counter; wypin then starts clock in known phase
        org
              dirl    #PIN_SD_SCK                       ' Reset SCK: counter stops, output LOW, Y=0
              drvl    #PIN_SD_SCK                       ' Re-enable: DIR=1 restarts base period counter fresh
              setxfrq xfrq
              rdfast  #0, p_buf
              xinit   stream_mode, #0                  ' Start streamer; NCO ramps from zero
              waitx   align_delay                      ' Wait for NCO to output first bit
              wypin   clk_count, #PIN_SD_SCK           ' Start clock - deterministic phase from drvl
              waitxfi
        end

        ' Rebuild MOSI smart pin for CRC and response
        wrpin(PIN_MOSI, spi_tx_mode)
        wxpin(PIN_MOSI, %1_00111)
        pinh(PIN_MOSI)

        ' Calculate and send CRC-16 for this sector's data
        diag_sent_crc := calcDataCRC(p_buf, SECTOR_SIZE)
        sp_transfer_8(diag_sent_crc >> 8)                                           ' CRC high byte
        sp_transfer_8(diag_sent_crc & $FF)                                          ' CRC low byte

        ' Wait for data response token
        resp := waitDataResponse()
        if resp < 0
          debug[CH_SECTOR]("  [writeSectors] No data response for sector ", udec_(start_sector + sectors_written))
          quit
        if (resp & $0F) <> DATA_ACCEPTED
          debug[CH_SECTOR]("  [writeSectors] Data rejected for sector ", udec_(start_sector + sectors_written), " resp=$", uhex_byte_(resp))
          quit

        ' Wait for card to finish programming this block
        if waitBusyComplete() < 0
          debug[CH_SECTOR]("  [writeSectors] Busy timeout for sector ", udec_(start_sector + sectors_written))
          quit

        sectors_written++

      ' Send stop token ($FD) to terminate multi-block write (NOT CMD12!)
      sp_transfer_8(TOKEN_STOP_TRAN)                                                ' $FD
      sp_transfer_8($FF)                                                            ' Stuff byte (NWR=1, required by spec)

      ' Wait for card to finish any final programming - card is in PROGRAMMING state
      if waitBusyComplete() < 0
        debug[CH_SECTOR]("  [writeSectors] Final busy timeout - card still programming, recovering")
        recoverToIdle()                                                               ' Force card back to idle
        sectors_written := 0                                                          ' Write integrity unknown

      else
        pinh(PIN_SD_CS)                                                                      ' Deselect card

        ' CMD13: Verify card internal state after multi-block write
        if checkCardStatus(@"writeSectors") < 0
          debug[CH_SECTOR]("  [writeSectors] CMD13 status check FAILED after writing ", udec_(sectors_written), " sectors")
          sectors_written := 0                                                          ' Card reports error - writes can't be trusted

' ================================================================================
' MULTI-BLOCK HELPER FUNCTIONS
' These factor out common patterns used by readSectors() and writeSectors()
' ================================================================================

PRI waitR1Response() : response | timeout, resp
' Wait for R1 response (non-$FF byte) - polls for R1 response after sending a command.
' Timeout: 100ms (per SD spec NCR = 0-8 bytes, but we allow more for slow cards)
'
' @returns response - R1 response byte on success, -1 on timeout
' @local timeout - Timeout deadline
' @local resp - Received response byte

  timeout := getct() + clkfreq / RESPONSE_TIMEOUT_DIV                                 ' 100ms timeout
  repeat
    resp := sp_transfer_8($FF)
    if (resp & $80) == 0                                                         ' valid R1 has bit 7 = 0 (SD spec 7.3.2.1)
      response := resp  ' Got response
      quit
    else
      if getct() - timeout > 0
        debug[CH_STATUS]("  [waitR1Response] TIMEOUT")
        response := E_TIMEOUT
        quit

PRI waitDataToken() : status | timeout, resp
' Wait for data start token ($FE) - polls for data token before sector data.
' Error tokens: $01-$0F indicate read errors.
' Timeout: Uses card_read_timeout_ms from CSD (minimum 100ms, with 10x safety factor)
'
' @returns status - 0 on success (got $FE), -1 on timeout or error token
' @local timeout - Timeout deadline
' @local resp - Received byte

  last_cmd18_token := $FF                                                             ' Default: no token received
  last_cmd18_result := 1                                                              ' Default: timeout
  timeout := getct() + (clkfreq / 100) * card_read_timeout_ms                         ' CSD-based timeout with 10x margin
  repeat
    resp := sp_transfer_8($FF)
    if resp == TOKEN_START_BLOCK                                                ' $FE = data coming
      last_cmd18_token := resp
      last_cmd18_result := 0                                                          ' Success
      status := 0  ' Success
      quit
    elseif resp <> $FF                                                              ' Error token (not $FF, not $FE)
      last_cmd18_token := resp
      last_cmd18_result := 2                                                          ' Error token
      debug[CH_STATUS]("  [waitDataToken] ERROR token: $", uhex_byte_(resp))
      status := E_BAD_RESPONSE
      quit
    else
      if getct() - timeout > 0
        debug[CH_STATUS]("  [waitDataToken] TIMEOUT")
        status := E_TIMEOUT
        quit

PRI waitDataResponse() : response | timeout, resp
' Wait for data response token after write - polls for data response after sending a block.
' Response format: xxx0sss1 where sss = 010 (accepted), 101 (CRC err), 110 (write err)
' Timeout: 100ms
'
' @returns response - Response status on success, -1 on timeout
' @local timeout - Timeout deadline
' @local resp - Received byte

  timeout := getct() + clkfreq / RESPONSE_TIMEOUT_DIV                                 ' 100ms timeout
  repeat
    resp := sp_transfer_8($FF)
    if resp <> $FF
      ' Got response - check if it's a valid data response token (bit 0 = 1, bit 4 = 0)
      if (resp & $11) == $01                                                    ' Valid data response format
        response := resp & $1F  ' Return lower 5 bits
        quit
      ' Not a valid response format, keep polling (might be noise)
    if getct() - timeout > 0
      debug[CH_STATUS]("  [waitDataResponse] TIMEOUT")
      response := E_TIMEOUT
      quit

PRI waitBusyComplete() : status | timeout, resp
' Wait for card to finish programming - polls until MISO returns $FF (not busy).
' Timeout: Uses card_write_timeout_ms from CSD (default 250ms for SDHC, calculated for SDSC)
' CRITICAL: Must keep clocking and CS LOW during busy period!
'
' @returns status - 0 on success, -1 on timeout
' @local timeout - Timeout deadline
' @local resp - Received byte

  timeout := getct() + (clkfreq / 1000) * card_write_timeout_ms                       ' CSD-based timeout
  repeat
    resp := sp_transfer_8($FF)
    if resp == $FF                                                              ' Card released MISO = done
      status := 0
      quit
    else
      if getct() - timeout > 0
        debug[CH_STATUS]("  [waitBusyComplete] TIMEOUT - card still busy")
        status := E_CARD_BUSY
        quit

PRI sendStopTransmission() : result | resp, idx, timeout
' Send CMD12 to stop multi-block operation - terminates multi-block read/write.
' Note: CMD12 has a "stuff byte" before the response - we handle this by polling.
' Captures the first 16 bytes after the stuff byte into cmd12_capture[] for framing analysis.
'
' @returns result - 0 on success, negative error code on error
' @local resp - Response byte
' @local idx - Capture buffer index
' @local timeout - Timeout deadline

  ' Capture MISO bytes during CMD12 transmission (full-duplex: card outputs while we send)
  cmd12_pre_capture[0] := sp_transfer_8($40 | CMD12)                            ' Command byte
  cmd12_pre_capture[1] := sp_transfer_8($00)                                    ' Argument bytes
  cmd12_pre_capture[2] := sp_transfer_8($00)
  cmd12_pre_capture[3] := sp_transfer_8($00)
  cmd12_pre_capture[4] := sp_transfer_8($00)
  cmd12_pre_capture[5] := sp_transfer_8(CRC_CMD12)                              ' CRC7 + stop bit
  cmd12_pre_capture[6] := sp_transfer_8($FF)                                    ' Stuff byte

  ' Capture raw byte stream for framing analysis, then find R1
  bytefill(@cmd12_capture, $FF, 16)
  cmd12_capture_len := 0
  last_cmd12_r1 := -1                                                          ' Default: no response
  last_cmd12_busy := 1                                                         ' Default: timeout

  timeout := getct() + clkfreq / 10                                            ' 100ms timeout
  idx := 0
  repeat
    resp := sp_transfer_8($FF)
    if idx < 16
      cmd12_capture[idx] := resp
      idx++
    if resp <> $FF
      cmd12_capture_len := idx                                                 ' Record position of first non-$FF
      last_cmd12_r1 := resp
      quit
    if getct() - timeout > 0
      cmd12_capture_len := idx
      debug[CH_RECOVER]("  [sendStopTransmission] TIMEOUT waiting for R1")
      result := E_TIMEOUT
      return

  ' Capture remaining bytes after R1 (for post-R1 framing analysis)
  repeat while idx < 16
    cmd12_capture[idx] := sp_transfer_8($FF)
    idx++

  ' Evaluate R1 response
  if last_cmd12_r1 <> $00
    last_cmd12_busy := 2                                                       ' R1 error
    debug[CH_RECOVER]("  [sendStopTransmission] R1 error: $", uhex_byte_(last_cmd12_r1))
    result := E_IO_ERROR
  else
    ' Wait for busy to complete (card may still be finishing last block)
    result := waitBusyComplete()
    if result < 0
      last_cmd12_busy := 3                                                     ' Busy timeout
    else
      last_cmd12_busy := 0                                                     ' Success

PRI recoverToIdle() : status
' Force the card's SPI state machine back to idle by deasserting CS and clocking.
' In SPI mode, CS deassert aborts any pending operation (multi-block read/write, busy).
' Dummy clocks with CS high allow the card to release MISO and transition to standby.
' VERIFIES that the card actually released the bus (MISO goes high).
'
' @returns status - 0 if card released bus, -1 if card still holding MISO low

  status := 0  ' Card released bus - back to idle
  pinh(PIN_SD_CS)                                                                        ' CS HIGH - abort any pending operation
  repeat 10
    sp_transfer_8($FF)                                                            ' 80 clocks with CS deasserted - let card release bus

  ' Verify card released MISO (should be high via pull-up when CS is deasserted)
  if pinr(PIN_MISO) == 0
    ' Card still holding MISO low - try extended clocking
    debug[CH_RECOVER]("  [recoverToIdle] MISO still low after 80 clocks, extending...")
    repeat 20
      sp_transfer_8($FF)                                                          ' 160 more clocks - extended recovery
    if pinr(PIN_MISO) == 0
      debug[CH_RECOVER]("  [recoverToIdle] FAILED: card holding MISO low after 240 clocks")
      status := -1  ' Card stuck - caller must handle

PRI sendCmd13Transaction() : r1, status | idx, resp, timeout
' Send CMD13 and capture full R2 response with full-duplex MISO diagnostics.
' Captures MISO during command transmission (cmd13_pre_capture) and raw post-command
' byte stream (cmd13_capture). Stages diagnostics into last_cmd13_r1/status/error.
'
' @returns r1 - R1 response byte, or -1 on timeout
' @returns status - STATUS byte (second byte of R2), or 0 on timeout
' @local idx - Capture index
' @local resp - Received byte
' @local timeout - Timeout deadline

  ' Initialize capture buffers
  bytefill(@cmd13_pre_capture, $FF, 7)
  bytefill(@cmd13_capture, $FF, 8)
  cmd13_capture_len := 0

  ' Dummy clocks with CS HIGH for card recovery
  pinh(PIN_SD_CS)
  sp_transfer_8($FF)
  sp_transfer_8($FF)

  ' CS LOW, send CMD13 byte-by-byte capturing MISO (full-duplex)
  pinl(PIN_SD_CS)
  cmd13_pre_capture[0] := sp_transfer_8($40 | CMD13)                            ' Command byte
  cmd13_pre_capture[1] := sp_transfer_8($00)                                    ' Argument byte 3
  cmd13_pre_capture[2] := sp_transfer_8($00)                                    ' Argument byte 2
  cmd13_pre_capture[3] := sp_transfer_8($00)                                    ' Argument byte 1
  cmd13_pre_capture[4] := sp_transfer_8($00)                                    ' Argument byte 0
  cmd13_pre_capture[5] := sp_transfer_8($FF)                                    ' CRC (not checked)
  cmd13_pre_capture[6] := sp_transfer_8($FF)                                    ' Padding byte

  ' Scan for R1 with 100ms timeout, capturing raw bytes
  r1 := -1
  timeout := getct() + clkfreq / RESPONSE_TIMEOUT_DIV
  idx := 0
  repeat while idx < 8
    resp := sp_transfer_8($FF)
    cmd13_capture[idx] := resp
    if (resp & $80) == 0                                                         ' valid R1 has bit 7 = 0
      cmd13_capture_len := idx
      r1 := resp
      idx++
      quit
    if getct() - timeout > 0
      last_cmd13_r1 := $FF
      pinh(PIN_SD_CS)
      quit
    idx++

  ' On timeout, return with r1 = -1
  if r1 < 0
    status := 0

  else
    ' Capture remaining bytes up to 8 total
    repeat while idx < 8
      cmd13_capture[idx] := sp_transfer_8($FF)
      idx++

    ' STATUS byte is immediately after R1
    status := cmd13_capture[cmd13_capture_len + 1]
    pinh(PIN_SD_CS)

    ' Stage diagnostics
    last_cmd13_r1 := r1
    last_cmd13_status := status
    if r1 <> 0 or status <> 0
      last_cmd13_error := (r1 << 8) | status

PRI probeCmd13() | r1, status
' Probe CMD13 reliability at end of initCard().
' Sends a single CMD13 on an idle card and checks whether the response is valid.
' If the response violates the SD spec (R1 bit 7 set, or 3+ simultaneous error
' bits in STATUS on an idle card), marks cmd13_reliable := FALSE and sets
' CW_CMD13_UNRELIABLE in card_warning_flags.
'
' @local r1 - R1 response byte from CMD13
' @local status - STATUS byte (second byte of R2 response)

  r1, status := sendCmd13Transaction()

  if r1 < 0
    debug[CH_STATUS]("    [probeCmd13] TIMEOUT - marking CMD13 unreliable")
    cmd13_reliable := FALSE
    card_warning_flags |= CW_CMD13_UNRELIABLE

  ' Check 1: R1 bit 7 must be 0 per SD spec
  elseif r1 & $80
    debug[CH_STATUS]("    [probeCmd13] R1 bit 7 set ($", uhex_byte_(r1), ") - marking CMD13 unreliable")
    cmd13_reliable := FALSE
    card_warning_flags |= CW_CMD13_UNRELIABLE

  ' Check 2: 3+ error bits in STATUS on an idle card = garbage data
  elseif ones status >= 3
    debug[CH_STATUS]("    [probeCmd13] STATUS has ", udec_(ones status), " error bits ($", uhex_byte_(status), ") - marking CMD13 unreliable")
    cmd13_reliable := FALSE
    card_warning_flags |= CW_CMD13_UNRELIABLE

  else
    debug[CH_STATUS]("    [probeCmd13] CMD13 OK (R1=$", uhex_byte_(r1), " STATUS=$", uhex_byte_(status), ")")

PRI probeCmd23() | scr[2], cmd_support, resp
' Probe CMD23 support at init time.
' First checks SCR CMD_SUPPORT field (bit 1 = CMD23 advertised).
' If advertised, sends a real CMD23 to verify the card accepts it in SPI mode.
' Some cards advertise CMD23 in SCR but reject it in SPI mode (R1=$04 Illegal Command).
' Sets cmd23_supported := TRUE only if the card actually accepts CMD23.
'
' @local scr - SCR register data (2 longs = 8 bytes)
' @local cmd_support - CMD_SUPPORT field from SCR
' @local resp - R1 response from CMD23 probe

  cmd23_supported := FALSE

  ' Step 1: Check SCR CMD_SUPPORT field (pre-filter)
  if readSCR(@scr)
    cmd_support := scr.byte[3] & $03
    if cmd_support & $02
      debug[CH_STATUS]("    [probeCmd23] SCR advertises CMD23 (CMD_SUPPORT=$", uhex_byte_(cmd_support), ") - verifying...")

      ' Step 2: Send real CMD23 with count=1 to verify SPI mode support
      resp := cmd(CMD23, 1)
      if resp == $00
        cmd23_supported := TRUE
        card_warning_flags |= CW_CMD23_SUPPORTED
        debug[CH_STATUS]("    [probeCmd23] CMD23 CONFIRMED - card accepts SET_BLOCK_COUNT in SPI mode")
      else
        debug[CH_STATUS]("    [probeCmd23] CMD23 REJECTED R1=$", uhex_byte_(resp), " - not supported in SPI mode")
    else
      debug[CH_STATUS]("    [probeCmd23] CMD23 not advertised (CMD_SUPPORT=$", uhex_byte_(cmd_support), ")")
  else
    debug[CH_STATUS]("    [probeCmd23] SCR read failed - assuming CMD23 not supported")

PRI checkCardStatus(caller) : status | r1, r2_status
' Send CMD13 to verify card status after operation - checks R2 response for errors.
' R2 response format: R1 byte + status byte.
' Call this after every write operation and after CMD12.
'
' @param caller - String identifying the calling function (for debug)
' @returns status - 0 on success (card OK), -1 on error
' @local r1 - R1 response byte
' @local r2_status - STATUS byte (second byte of R2)

  ' Skip CMD13 on cards with broken implementation (detected by probeCmd13 at init)
  if not cmd13_reliable
    return

  r1, r2_status := sendCmd13Transaction()

  if r1 < 0
    debug[CH_STATUS]("  [checkCardStatus] ", zstr_(caller), ": TIMEOUT waiting for R1")
    status := E_TIMEOUT

  ' Check for errors
  elseif r1 <> $00
    debug[CH_STATUS]("  [checkCardStatus] ", zstr_(caller), ": R1 error=$", uhex_byte_(r1))
    status := -1

  elseif r2_status <> $00
    debug[CH_STATUS]("  [checkCardStatus] ", zstr_(caller), ": STATUS error=$", uhex_byte_(r2_status))
    if r2_status & CSR_OUT_OF_RANGE
      debug[CH_STATUS]("    -> OUT_OF_RANGE")
    if r2_status & CSR_ERASE_PARAM
      debug[CH_STATUS]("    -> ERASE_PARAM")
    if r2_status & CSR_WP_VIOLATION
      debug[CH_STATUS]("    -> WP_VIOLATION")
    if r2_status & CSR_CARD_ECC_FAILED
      debug[CH_STATUS]("    -> CARD_ECC_FAILED")
    if r2_status & CSR_CC_ERROR
      debug[CH_STATUS]("    -> CC_ERROR")
    if r2_status & CSR_ERROR
      debug[CH_STATUS]("    -> ERROR")
    if r2_status & CSR_WP_ERASE_SKIP
      debug[CH_STATUS]("    -> WP_ERASE_SKIP")
    if r2_status & CSR_CARD_IS_LOCKED
      debug[CH_STATUS]("    -> CARD_IS_LOCKED")
    status := -1

  else
    status := 0  ' Card status OK

PRI readDataRegister(cmd_num, arg, crc_byte, p_buf, byte_count) : ok | timeout, idx
' Consolidated register read transaction: send command, wait for R1, wait for $FE data token,
' read byte_count bytes into buffer, consume 2-byte CRC, deselect. Used by readCSD, readCID,
' sendCMD6, readSCR (via sendAppCmdPrefix), and readSDStatus (via sendAppCmdPrefix).
'
' @param cmd_num - SD command number (e.g., CMD9, CMD10, CMD6, ACMD51)
' @param arg - 32-bit command argument (0 for most register reads)
' @param crc_byte - Pre-computed CRC-7 byte (or CRC_NONE)
' @param p_buf - Pointer to receive buffer (must be >= byte_count bytes)
' @param byte_count - Number of data bytes to read (e.g., 16 for CSD/CID, 64 for CMD6)
' @returns ok - TRUE on success, FALSE on failure/timeout

  ' Pre-command dummy clock
  sp_transfer_8($FF)
  pinl(PIN_SD_CS)
  sp_transfer_8($FF)

  ' Send command: $40 | cmd_num, 32-bit arg, CRC
  sp_transfer_8($40 | cmd_num)
  sp_transfer(arg, 32)
  sp_transfer_8(crc_byte)

  ' Wait for R1 response (bit 7 = 0 per SD spec 7.3.2.1)
  timeout := getct() + clkfreq
  repeat
    ok := sp_transfer_8($FF)
    if (ok & $80) == 0
      quit
    if getct() - timeout > 0
      ok := $FF
      quit

  if ok <> $00
    if ok <> $FF
      pinh(PIN_SD_CS)
    ok := false

  ' Wait for data token ($FE)
  else
    timeout := getct() + clkfreq
    repeat
      ok := sp_transfer_8($FF)
      if ok == $FE
        quit
      if getct() - timeout > 0
        ok := $FF
        quit

    if ok == $FE
      ' Read data bytes
      repeat idx from 0 to byte_count - 1
        byte[p_buf + idx] := sp_transfer_8($FF)

      ' Consume 2-byte CRC
      sp_transfer_8($FF)
      sp_transfer_8($FF)

      pinh(PIN_SD_CS)
      ok := true
    else
      pinh(PIN_SD_CS)
      ok := false

PRI readCSD(p_csd) : ok
' Read CSD register using CMD9 - reads 16-byte CSD register into buffer.
'
' @param p_csd - Pointer to 16-byte buffer to receive CSD data
' @returns ok - TRUE on success, FALSE on failure

  ok := readDataRegister(CMD9, 0, CRC_CMD9, p_csd, CSD_CID_BYTES)

PRI readCID(p_cid) : ok
' Read CID register using CMD10 - reads 16-byte Card Identification register.
'
' @param p_cid - Pointer to 16-byte buffer to receive CID data
' @returns ok - TRUE on success, FALSE on failure

  ok := readDataRegister(CMD10, 0, CRC_CMD10, p_cid, CSD_CID_BYTES)

PRI parseTransSpeed(p_csd) : speed_hz | tran_speed, time_val, mult_val
' Parse TRAN_SPEED from CSD register - returns max transfer speed in Hz.
' TRAN_SPEED format: bits [2:0] = rate unit, bits [6:3] = time value.
'
' @param p_csd - Pointer to CSD register data
' @returns speed_hz - Maximum transfer speed in Hz
' @local tran_speed - Raw TRAN_SPEED byte
' @local time_val - Time value multiplier
' @local mult_val - Transfer rate unit multiplier

  tran_speed := byte[p_csd + 3]

  ' Time value multiplier (bits 6:3) - values per spec
  case (tran_speed >> 3) & $0F
    0:  time_val := 0       ' Reserved
    1:  time_val := 10      ' 1.0
    2:  time_val := 12      ' 1.2
    3:  time_val := 13      ' 1.3
    4:  time_val := 15      ' 1.5
    5:  time_val := 20      ' 2.0
    6:  time_val := 25      ' 2.5
    7:  time_val := 30      ' 3.0
    8:  time_val := 35      ' 3.5
    9:  time_val := 40      ' 4.0
    10: time_val := 45      ' 4.5
    11: time_val := 50      ' 5.0
    12: time_val := 55      ' 5.5
    13: time_val := 60      ' 6.0
    14: time_val := 70      ' 7.0
    15: time_val := 80      ' 8.0

  ' Transfer rate unit (bits 2:0) - values per spec
  case tran_speed & $07
    0:  mult_val := 100_000 / 10        ' 100 kbit/s
    1:  mult_val := 1_000_000 / 10      ' 1 Mbit/s
    2:  mult_val := 10_000_000 / 10     ' 10 Mbit/s
    3:  mult_val := 100_000_000 / 10    ' 100 Mbit/s (not used in SPI mode)
    other: mult_val := 0               ' Reserved

  speed_hz := time_val * mult_val
  debug[CH_INIT]("  [parseTransSpeed] TRAN_SPEED=$", uhex_byte_(tran_speed), " -> ", udec(speed_hz / 1_000_000), " MHz")

PRI parseMfrId(p_cid) : mfr_id
' Extract manufacturer ID from CID register byte 0.
' Common IDs: $03=SanDisk, $1D=PNY/AData, $27=Samsung, $28=Lexar, $74=Transcend.
'
' @param p_cid - Pointer to CID register data
' @returns mfr_id - Manufacturer ID byte

  mfr_id := byte[p_cid]
  debug[CH_IDENT]("  [parseMfrId] Manufacturer ID=$", uhex_byte_(mfr_id))

PRI parseTimeouts(p_csd) | csd_ver, taac, nsac, r2w_factor, read_timeout_ns, time_val, time_unit
' Extract timeout values from CSD register - sets card_read_timeout_ms and card_write_timeout_ms.
' SDHC/SDXC: Fixed values (100ms read, 250ms write).
' SDSC: Calculated from TAAC, NSAC, and R2W_FACTOR.
'
' @param p_csd - Pointer to CSD register data
' @local csd_ver - CSD structure version
' @local taac - Data read access time-1
' @local nsac - Data read access time-2 in CLK cycles
' @local r2w_factor - Read to write factor
' @local read_timeout_ns - Read timeout in nanoseconds
' @local time_val - Time value multiplier
' @local time_unit - Time unit in nanoseconds

  csd_ver := byte[p_csd] >> 6                                                   ' CSD_STRUCTURE in bits [7:6] of byte 0

  if csd_ver == 1
    ' CSD Version 2.0 (SDHC/SDXC): Use generous timeouts
    ' SD spec says 250ms max for writes, but real cards (especially large SDXC)
    ' can exceed this on cold writes or sector 0. Use 500ms for reliability.
    card_read_timeout_ms := 100                                                 ' 100ms read timeout
    card_write_timeout_ms := 500                                                ' 500ms write timeout (2x spec for margin)
    debug[CH_IDENT]("  [parseTimeouts] SDHC/SDXC: read=", udec_(card_read_timeout_ms), "ms, write=", udec_(card_write_timeout_ms), "ms")
  else
    ' CSD Version 1.0 (SDSC): Calculate from TAAC, NSAC, R2W_FACTOR
    taac := byte[p_csd + 1]                                                     ' Data read access time-1 (TAAC)
    nsac := byte[p_csd + 2]                                                     ' Data read access time-2 (NSAC) in CLK cycles
    r2w_factor := (byte[p_csd + 12] >> 2) & $07                                 ' R2W_FACTOR bits [4:2] of byte 12

    ' Parse TAAC: time value in bits [6:3], time unit in bits [2:0]
    case (taac >> 3) & $0F                                                      ' Time value multiplier
      0:  time_val := 0                                                         ' Reserved
      1:  time_val := 10
      2:  time_val := 12
      3:  time_val := 13
      4:  time_val := 15
      5:  time_val := 20
      6:  time_val := 25
      7:  time_val := 30
      8:  time_val := 35
      9:  time_val := 40
      10: time_val := 45
      11: time_val := 50
      12: time_val := 55
      13: time_val := 60
      14: time_val := 70
      15: time_val := 80

    case taac & $07                                                             ' Time unit (nanoseconds)
      0:  time_unit := 1                                                        ' 1 ns
      1:  time_unit := 10                                                       ' 10 ns
      2:  time_unit := 100                                                      ' 100 ns
      3:  time_unit := 1_000                                                    ' 1 us
      4:  time_unit := 10_000                                                   ' 10 us
      5:  time_unit := 100_000                                                  ' 100 us
      6:  time_unit := 1_000_000                                                ' 1 ms
      7:  time_unit := 10_000_000                                               ' 10 ms

    ' Read timeout = TAAC + NSAC * 100 (NSAC is in clock cycles / 100)
    ' For safety, multiply by 100 to get worst-case timeout
    read_timeout_ns := (time_val * time_unit) * 100                             ' Apply 100x safety factor
    card_read_timeout_ms := (read_timeout_ns / 1_000_000) #> 100                ' Minimum 100ms

    ' Write timeout = read timeout * 2^R2W_FACTOR
    card_write_timeout_ms := (card_read_timeout_ms << r2w_factor) #> 250 <# 1000  ' Min 250ms, max 1000ms

    debug[CH_IDENT]("  [parseTimeouts] SDSC: TAAC=$", uhex_byte_(taac), " NSAC=", udec_(nsac), " R2W=", udec_(r2w_factor))
    debug[CH_IDENT]("  [parseTimeouts] SDSC: read=", udec_(card_read_timeout_ms), "ms, write=", udec_(card_write_timeout_ms), "ms")

PRI identifyCard() | cid[4], csd[4]
' Read card identity and configure adaptive timing.
' Reads CID/CSD, identifies brand, sets optimal SPI speed.
' PNY cards get conservative 20 MHz, others use 25 MHz.
'
' @local cid - CID register data (4 longs = 16 bytes)
' @local csd - CSD register data (4 longs = 16 bytes)

  debug[CH_IDENT]("  [identifyCard] Reading card registers...")

  ' Read CID to identify manufacturer and serial number
  if readCID(@cid)
    card_mfr_id := parseMfrId(@cid)
    ' Extract PSN (Product Serial Number) from CID bytes 9-12 (big-endian)
    card_serial_number := BYTE[@cid][9] << 24 | BYTE[@cid][10] << 16 | BYTE[@cid][11] << 8 | BYTE[@cid][12]
    debug[CH_IDENT]("  [identifyCard] PSN=$", uhex_(card_serial_number))
  else
    debug[CH_IDENT]("  [identifyCard] WARNING: Could not read CID")
    card_mfr_id := 0
    card_serial_number := 0

  ' Read CSD to get maximum speed and timeouts
  if readCSD(@csd)
    card_max_speed_hz := parseTransSpeed(@csd)
    parseTimeouts(@csd)
  else
    debug[CH_IDENT]("  [identifyCard] WARNING: Could not read CSD")
    card_max_speed_hz := SD_FALLBACK_SPEED_HZ                                    ' Default to 25 MHz
    card_read_timeout_ms := 100                                                 ' Safe defaults
    card_write_timeout_ms := 500

PRI setOptimalSpeed()
' Set SPI speed based on card identification.
' Called after identifyCard() to configure optimal SPI clock.
' Uses card's reported max speed, capped at 25 MHz for SPI mode.

  ' Use card's reported max speed, capped at 25 MHz for SPI mode
  if card_max_speed_hz > SD_FALLBACK_SPEED_HZ
    do_set_spi_speed(SD_FALLBACK_SPEED_HZ)
  else
    do_set_spi_speed(card_max_speed_hz)
  debug[CH_INIT]("  [setOptimalSpeed] Set to card's max speed (up to 25 MHz)")


PRI sendAppCmdPrefix() : resp
' Send CMD55 (APP_CMD) prefix for application-specific commands (ACMD*).
' CMD55 is sent via cmd() which keeps CS asserted; we deassert so the
' following ACMD gets its own CS cycle.
'
' @returns resp - R1 response from CMD55

  resp := cmd(CMD55, 0)
  pinh(PIN_SD_CS)

PRI readSCR(p_scr) : ok
' Read SCR register using ACMD51 - reads 8-byte SD Configuration Register.
' Requires CMD55 prefix before ACMD51.
'
' @param p_scr - Pointer to 8-byte buffer to receive SCR data
' @returns ok - TRUE on success, FALSE on failure

  ok := sendAppCmdPrefix()
  debug[CH_IDENT]("  [readSCR] CMD55 response: $", uhex_byte_(ok))
  if ok > $01                                                                    ' Accept $00 or $01 (idle)
    debug[CH_IDENT]("  [readSCR] CMD55 error response")
    ok := false
  else
    ok := readDataRegister(ACMD51, 0, CRC_ACMD51, p_scr, 8)

PRI readSDStatus(p_buf) : ok
' Read SD Status register using ACMD13 - reads 64-byte SD Status.
' Requires CMD55 prefix before ACMD13.
'
' @param p_buf - Pointer to 64-byte buffer to receive SD Status data
' @returns ok - TRUE on success, FALSE on failure

  ok := sendAppCmdPrefix()
  debug[CH_IDENT]("  [readSDStatus] CMD55 response: $", uhex_byte_(ok))
  if ok > $01                                                                    ' Accept $00 or $01 (idle)
    debug[CH_IDENT]("  [readSDStatus] CMD55 error response")
    ok := false
  else
    ok := readDataRegister(CMD13, 0, CRC_NONE, p_buf, SD_STATUS_BYTES)


#ifdef SD_INCLUDE_SPEED
PRI sendCMD6(arg, p_status) : ok
' Send CMD6 (SWITCH_FUNC) and receive 64-byte status structure.
' arg format: [31]=mode (0=check, 1=switch), [3:0]=function group 1 selection.
'
' @param arg - CMD6 argument word
' @param p_status - Pointer to 64-byte buffer to receive status
' @returns ok - TRUE on success, FALSE on failure/timeout

  ok := readDataRegister(CMD6, arg, CRC_NONE, p_status, SD_STATUS_BYTES)

PRI queryHighSpeedSupport() : supported | scr[2], status[16], sd_spec
' Check if card supports high-speed mode - queries SCR and function group 1.
'
' @returns supported - TRUE if high-speed (50 MHz) is supported
' @local scr - SCR register data (2 longs = 8 bytes)
' @local status - CMD6 status structure (16 longs = 64 bytes)
' @local sd_spec - SD spec version from SCR

  debug[CH_HSPEED]("  [queryHighSpeedSupport] Checking card capabilities...")

  ' First check SCR for CMD6 support (SD 2.0+ cards support CMD6)
  if not readSCR(@scr)
    debug[CH_HSPEED]("  [queryHighSpeedSupport] Failed to read SCR")
    supported := false

  else
    sd_spec := scr.byte[0] & $0F                                                  '  SD_SPEC in bits [3:0]
    debug[CH_HSPEED]("  [queryHighSpeedSupport] SD_SPEC=", udec_(sd_spec))
    if sd_spec < 2
      debug[CH_HSPEED]("  [queryHighSpeedSupport] Card is SD 1.x - CMD6 not supported")
      supported := false
    else
      debug[CH_HSPEED]("  [queryHighSpeedSupport] Card is SD 2.0+ - CMD6 supported")

      ' Query function group 1 using CMD6 mode 0 (check)
      ' Argument: 0x00FFFFF1 = check mode, access function group 1, query high-speed
      if not sendCMD6($00FFFFF1, @status)
        debug[CH_HSPEED]("  [queryHighSpeedSupport] CMD6 query failed")
        supported := false

      ' Status bytes 12-13 contain function group 1 support bits
      ' Bit 1 of byte 13 indicates high-speed support
      elseif (status.byte[13] & $02) == 0
        debug[CH_HSPEED]("  [queryHighSpeedSupport] High-speed function not supported")
        supported := false

      else
        debug[CH_HSPEED]("  [queryHighSpeedSupport] High-speed (50 MHz) IS SUPPORTED")
        supported := true

PRI switchToHighSpeed() : ok | status[16]
' Switch card to high-speed mode - sends CMD6 to switch function group 1.
'
' @returns ok - TRUE if switch succeeded
' @local status - CMD6 status structure (16 longs = 64 bytes)

  debug[CH_HSPEED]("  [switchToHighSpeed] Sending CMD6 switch command...")

  ' Switch to high-speed using CMD6 mode 1 (switch)
  ' Argument: 0x80FFFFF1 = switch mode, access function group 1, select high-speed
  if not sendCMD6($80FFFFF1, @status)
    debug[CH_HSPEED]("  [switchToHighSpeed] CMD6 switch failed")
    ok := false

  ' Verify switch succeeded - check function group 1 selection in status
  ' Byte 16, bits 3:0 should be 1 (high-speed selected)
  elseif (status.byte[16] & $0F) <> 1
    debug[CH_HSPEED]("  [switchToHighSpeed] Switch not accepted, status=$", uhex_byte_(status.byte[16]))
    ok := false

  else
    debug[CH_HSPEED]("  [switchToHighSpeed] Successfully switched to high-speed mode")
    ok := true

#endif

#ifdef SD_INCLUDE_DEBUG
PRI readSectorSlow(sector, p_buffer) : status | data, idx, timeout
' DEBUG: Read sector byte-by-byte (no streamer) - for streamer debugging.
' This is SLOW (~50x slower than streamer) but helps isolate timing issues.
'
' @param sector - Sector number to read
' @param p_buffer - Pointer to 512-byte destination buffer
' @returns status - 0 on success, -1 on timeout/error
' @local data - Received byte/token
' @local idx - Loop counter
' @local timeout - Timeout deadline

  ' Send CMD17 (READ_SINGLE_BLOCK)
  cmd(17, sector << hcs)

  ' Wait for start token ($FE)
  timeout := getct() + (clkfreq / 100) * card_read_timeout_ms
  repeat
    data := sp_transfer_8($FF)
    if data == $FE
      quit                                                                      ' Got start token
    if data <> $FF
      pinh(PIN_SD_CS)
      status := E_BAD_RESPONSE  ' Error token
      quit
    elseif getct() - timeout > 0
      pinh(PIN_SD_CS)
      status := E_TIMEOUT  ' Timeout
      quit

  if status >= 0
    ' Read 512 bytes one at a time using sp_transfer_8
    repeat idx from 0 to 511
      byte[p_buffer + idx] := sp_transfer_8($FF)

    ' Read and capture 2 CRC bytes (high byte first per SD protocol)
    diag_recv_crc := sp_transfer_8($FF) << 8
    diag_recv_crc |= sp_transfer_8($FF)

    ' CRC-16 validation: calculate CRC of received data and compare with card's CRC
    if diag_crc_enabled
      diag_calc_crc := calcDataCRC(p_buffer, 512)
      if diag_calc_crc == diag_recv_crc
        diag_crc_matches++
      else
        diag_crc_mismatches++
        debug[CH_INIT]("  [readSectorSlow] CRC MISMATCH! recv=$", uhex_(diag_recv_crc), " calc=$", uhex_(diag_calc_crc))

    pinh(PIN_SD_CS)                                                                      ' Deselect card
    status := 0  ' Success

#endif

CON {      FAT32 file system
  +-------------------------+     The master boot record contains 446 bytes of boot code
  | Master Boot Record      |      followed by four 16-byte partition entries
  |                         |      terminated with $55 $AA in the final 2 bytes
  | Partitions      $55 $AA |     The 16-byte partition
  +-------------------------+     +------+-------+------+-----+-------+-----------+
  | Reserved                |     | Boot | CHS   | Type | CHS | LBA   | Number of |  Type code located at byte address $1C2
  +-------------------------+     | Flag | Begin | Code | End | Begin | Sectors   |   Type code = $0B or $0C for FAT32
  | Volume Boot Record 1    |     +------+-------+------+-----+-------+-----------+  LBA Begin contains address of volume boot record (VBR)
  +-------------------------+     |      |       |  5   |     | 9-12  |           |   VBR address located at byte address $1C6
  | Reserved                |     +------+-------+------+-----+-------+-----------+
  +-------------------------+     Volume boot record contains
  | Volume Boot Record 2    |     +---------------------------------+--------+------+--------------------+
  +-------------------------+     |          Field                  | Offset | Size | Value              |
  | Reserved                |     +---------------------------------+--------+------+--------------------+
  +-------------------------+     | Bytes per Sector                |  $0B   | 16b  |       512          |
  | File allocation table 1 |     | Sectors per Cluster             |  $0D   |  8b  |1/2/4/8/16/32/64/128|
  +-------------------------+     | Number of Reserved Sectors      |  $0E   | 16b  |                    |
  | File allocation table 2 |     | Number of FATs                  |  $10   |  8b  |        2           |
  +-------------------------+     | Sectors per FAT                 |  $24   | 32b  |                    |
  | Root directory and      |     | Root Directory of First Cluster |  $2C   | 32b  |        2           |
  |  Data region            |     | Signature                       | $1FE   | 16b  |      $AA55         |
  |                         |     +---------------------------------+--------+------+--------------------+
  |                         |      The address of the 1st FAT is VBR address + number of reserved sectors
  |                         |      The address of the root directory is FAT address + number of FATs x sectors per fat
  +-------------------------+
                                  The file system directory contains 32-byte entries for each file in the root directory
                                  +---------------------------------+--------+------+
                                  |          Field                  | Offset | Size |  The first byte of the short filename indicates the type of entry
                                  +---------------------------------+--------+------+   Normal entry     - as expected   "FILENAMETXT"
                                  | Short Filename                  |  $00   | 11B  |   Unused/deleted   - 1st byte $E5  "\xE5ILENAMETXT"
                                  | Attrib Byte                     |  $0B   |  1B  |   End of directory - 1st byte $00
                                  | Date of creation                |  $0E   |  4B  |
                                  | First Cluster High              |  $14   |  2B  |
                                  | Date of modification            |  $16   |  4B  |
                                  | First Cluster Low               |  $1A   |  2B  |
                                  | File Size                       |  $1C   |  4B  |
                                  +---------------------------------+--------+------+
                                  Attrib byte contains bitfields
                                  +---+-----------+-----+------------------------------------+
                                  |bit| Function  | LFN | Comment                            |
                                  +---+-----------+-----+------------------------------------+
                                  | 7 | Unused    |  0  | Should be zero                     |
                                  | 6 | Unused    |  0  | Should be zero                     |
                                  | 5 | Archive   |  x  | Has been changed since last backup |
                                  | 4 | Directory |  x  | Is a subdirectory                  |
                                  | 3 | Volume ID |  1  | Filename is Volume ID              |
                                  | 2 | System    |  1  | File is operating system           |
                                  | 1 | Hidden    |  1  | Should not show in dir listing     |
                                  | 0 | Read Only |  1  | Should not allow writing           |
                                  +---+-----------+-----+------------------------------------+
                                  Each entry in the file allocation table is 32 bits, entry 0 is associated with cluster 0, entry 1/cluster 1, and so on
                                   The 32-bit value contains 0 if the associated cluster is available
                                   contains $0FFF_FFFF if the data in the associated cluster ends in that cluster
                                   contains the address of the next cluster in the file if the file occupies multiple clusters
                                  +-----------+-----------+-----------+-----------+
              clusters $00 - $03  | 0FFF_FFFF | 0FFF_FFFF | 0FFF_FFFF | 0FFF_FFFF |  1st four clusters occupied by self-contained files
                       $04 - $07  | 0000_0005 | 0000_0006 | 0000_0007 | 0FFF_FFFF |  next four clusters occupied by a file in sequential clusters
                       $08 - $0B  | 0000_000A | 0FFF_FFFF | 0000_000C | 0FFF_FFFF |  a fragmented file starts in cluster 8, and occupies clusters 10, 12, and ends in 14
                       $0C - $0F  | 0000_000E | 0000_0000 | 0FFF_FFFF | 0000_0000 |  clusters 13 and 15 are unused
}
